@page
@model LeKatsuMNL.Pages.Login.ForgotPasswordModel
@{
    Layout = null;
    // Retrieve all EmailJS credentials from environment variables
    var emailJsPublicKey  = Environment.GetEnvironmentVariable("EMAILJS_PUBLIC_KEY");
    var emailJsServiceId  = Environment.GetEnvironmentVariable("EMAILJS_SERVICE_ID");
    var emailJsTemplateId = Environment.GetEnvironmentVariable("EMAILJS_TEMPLATE_ID");
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Forgot Password - LeKatsuMNL</title>
    <!-- Include Tailwind CSS -->
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
        body {
            font-family: 'Inter', system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, "Helvetica Neue", Arial, sans-serif;
            background-color: #000;
            background-image: url('/images/lekatsu_bg.jpg');
            background-size: cover;
            background-position: center;
            background-repeat: no-repeat;
        }

        input::placeholder {
            color: #9ca3af;
        }
        
        /* Hide number input spinners */
        input[type="number"]::-webkit-outer-spin-button,
        input[type="number"]::-webkit-inner-spin-button {
            -webkit-appearance: none;
            margin: 0;
        }
        input[type="number"] {
            -moz-appearance: textfield;
        }
    </style>

    <!-- EmailJS Integration -->
    <script type="text/javascript" src="https://cdn.jsdelivr.net/npm/@@emailjs/browser@@4/dist/email.min.js"></script>
    <script type="text/javascript">
        (function() {
            var ejs = window.emailjs;
            ejs.init({
                publicKey: '@emailJsPublicKey',
            });
        })();
    </script>
</head>
<body class="min-h-screen flex flex-col relative text-white antialiased">
    <!-- Red top border -->
    <div class="h-2 w-full bg-[#C41E24] absolute top-0 left-0"></div>

    <!-- Dark Blur Overlay -->
    <div class="absolute inset-0 bg-black bg-opacity-60 backdrop-blur-sm z-0"></div>

    <div class="relative z-10 flex-grow flex items-center justify-center pt-12 pb-12 px-4 sm:px-6 lg:px-8">
        <div class="max-w-md w-full space-y-6 flex flex-col items-center">
            
            <!-- Logo and Text -->
            <div class="text-center w-full flex flex-col items-center">
                <div class="h-20 w-20 rounded-full border-2 border-white overflow-hidden shadow-lg p-1 bg-white mb-4">
                    <img class="h-full w-full object-contain rounded-full bg-white" src="/images/lekatsu_icon.jpg" alt="LeKatsu MNL Logo">
                </div>
                
                <h2 class="mt-2 text-xl font-bold tracking-widest text-white uppercase drop-shadow-md">
                    Password Recovery
                </h2>
                
                <p class="mt-2 text-sm text-gray-200 drop-shadow-md px-4">
                    @if (Model.CurrentPhase == 1) {
                        <text>Enter your registered email address to receive a secure One-Time Password.</text>
                    } else if (Model.CurrentPhase == 2) {
                        <text>We've sent a 6-digit code to <strong class="text-[#C41E24]">@Model.RecoveryEmail</strong>. Please enter it below.</text>
                    } else {
                        <text>Create a new strong password for your account.</text>
                    }
                </p>
                <div class="mt-4 w-12 h-0.5 bg-[#C41E24] mx-auto rounded"></div>
            </div>

            <div class="mt-8 w-full flex justify-center">
                <form class="space-y-6 w-full max-w-[340px]" method="post" id="forgotPasswordForm">
                    
                    @if (!string.IsNullOrEmpty(Model.ErrorMessage))
                    {
                        <div class="w-full text-center text-white text-sm font-bold mb-4 bg-[#C41E24] bg-opacity-90 py-3 rounded border border-red-400 shadow-lg tracking-wide">
                            @Model.ErrorMessage
                        </div>
                    }

                    @if (Model.CurrentPhase == 1)
                    {
                        <!-- PHASE 1: EMAIL INPUT -->
                        <div class="space-y-4">
                            <div class="relative">
                                <label for="RecoveryEmail" class="sr-only">Email Address</label>
                                <input asp-for="RecoveryEmail" type="email" autocomplete="email" required 
                                    class="appearance-none rounded-md relative block w-full px-4 py-3 border border-gray-400 border-opacity-40 bg-white bg-opacity-10 text-white placeholder-gray-400 focus:outline-none focus:ring-1 focus:ring-[#C41E24] focus:border-[#C41E24] focus:z-10 sm:text-sm shadow-sm transition-colors duration-200 backdrop-blur-sm" 
                                    placeholder="name@example.com">
                            </div>
                        </div>
                        <div>
                            <button asp-page-handler="RequestOtp" id="btnRequestOtp" type="submit" class="group relative w-full flex justify-center py-3 px-4 border border-transparent text-sm font-semibold rounded-md text-white bg-[#C41E24] hover:bg-[#a52123] focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-[#C41E24] focus:ring-offset-black transition-colors duration-200 shadow-lg tracking-wider">
                                Send Recovery Code
                            </button>
                        </div>
                    }
                    else if (Model.CurrentPhase == 2)
                    {
                        <!-- PHASE 2: OTP VERIFICATION -->
                        <input type="hidden" asp-for="RecoveryEmail" />
                        
                        <div class="space-y-4">
                            <div class="relative">
                                <label for="UserOtp" class="sr-only">6-Digit Code</label>
                                <input asp-for="UserOtp" type="number" required maxlength="6"
                                    class="text-center appearance-none rounded-md relative block w-full px-4 py-3 border border-gray-400 border-opacity-40 bg-white bg-opacity-10 text-white placeholder-gray-400 focus:outline-none focus:ring-1 focus:ring-[#C41E24] focus:border-[#C41E24] focus:z-10 text-lg tracking-[0.5em] shadow-sm transition-colors duration-200 backdrop-blur-sm" 
                                    placeholder="------">
                            </div>
                        </div>
                        <div>
                            <button asp-page-handler="VerifyOtp" type="submit" class="group relative w-full flex justify-center py-3 px-4 border border-transparent text-sm font-semibold rounded-md text-white bg-[#C41E24] hover:bg-[#a52123] focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-[#C41E24] focus:ring-offset-black transition-colors duration-200 shadow-lg tracking-wider">
                                Verify Code
                            </button>
                        </div>
                    }
                    else if (Model.CurrentPhase == 3)
                    {
                        <!-- PHASE 3: RESET PASSWORD -->
                        <input type="hidden" asp-for="RecoveryEmail" />
                        <input type="hidden" asp-for="VerifiedOtpCode" />

                        <div class="space-y-4">
                            <div class="relative">
                                <label for="NewPassword" class="sr-only">New Password</label>
                                <input asp-for="NewPassword" type="password" required 
                                    class="appearance-none rounded-md relative block w-full px-4 py-3 border border-gray-400 border-opacity-40 bg-white bg-opacity-10 text-white placeholder-gray-400 focus:outline-none focus:ring-1 focus:ring-[#C41E24] focus:border-[#C41E24] focus:z-10 sm:text-sm shadow-sm transition-colors duration-200 backdrop-blur-sm" 
                                    placeholder="New Password">
                            </div>
                            <div class="relative">
                                <label for="ConfirmPassword" class="sr-only">Confirm Password</label>
                                <input asp-for="ConfirmPassword" type="password" required 
                                    class="appearance-none rounded-md relative block w-full px-4 py-3 border border-gray-400 border-opacity-40 bg-white bg-opacity-10 text-white placeholder-gray-400 focus:outline-none focus:ring-1 focus:ring-[#C41E24] focus:border-[#C41E24] focus:z-10 sm:text-sm shadow-sm transition-colors duration-200 backdrop-blur-sm" 
                                    placeholder="Confirm Password">
                            </div>
                        </div>
                        <div>
                            <button asp-page-handler="ResetPassword" type="submit" class="group relative w-full flex justify-center py-3 px-4 border border-transparent text-sm font-semibold rounded-md text-white bg-[#C41E24] hover:bg-[#a52123] focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-[#C41E24] focus:ring-offset-black transition-colors duration-200 shadow-lg tracking-wider">
                                Update Password
                            </button>
                        </div>
                    }

                    <div class="flex items-center justify-center mt-6">
                        <div class="text-sm">
                            <a href="/Login/login" class="font-medium text-gray-300 hover:text-white transition-colors duration-200 text-xs tracking-widest flex items-center gap-2">
                                <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
                                </svg>
                                Back to Log In
                            </a>
                        </div>
                    </div>
                </form>
            </div>
            
        </div>
    </div>

    @if (Model.TriggerEmailJsDispatch)
    {
        <!-- Invisible form needed by EmailJS to match field names -->
        <form id="emailJsVirtualForm" style="display:none;">
            <input type="text" name="to_email"  value="@Model.RecoveryEmail" />
            <input type="text" name="passcode"  value="@Model.GeneratedOtp" />
            <input type="text" name="time"      value="10 minutes" />
        </form>

        <script>
            // Automatically trigger EmailJS on page load when the backend flags it ready
            window.onload = function() {
                var btn = document.getElementById('btnRequestOtp');
                if(btn) btn.innerHTML = "Sending..."; // Visual feedback (though page will have reloaded to phase 2)

                // The Service ID AND Template ID parameters. 
                // NOTE: We may need to configure these if SafePoint's differ, 
                // but usually they are default service_id and template_id in EmailJS.
                // You can update 'service_xxxx' and 'template_xxxx' appropriately.
                var ejs = window.emailjs;
                ejs.sendForm('@emailJsServiceId', '@emailJsTemplateId', '#emailJsVirtualForm')
                    .then(() => {
                        console.log('SUCCESS: OTP dispatched via EmailJS');
                    }, (error) => {
                        console.log('FAILED...', error);
                        alert('Warning: Failed to dispatch email. Please check EmailJS configuration.');
                    });
            };
        </script>
    }
</body>
</html>
