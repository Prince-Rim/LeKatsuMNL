@page
@model LeKatsuMNL.Pages.Payment.CancelModel
@{
    ViewData["Title"] = "Payment Cancelled";
}

<div class="flex flex-col items-center justify-center min-h-[60vh] p-4 text-center">
    <div class="w-20 h-20 bg-amber-100 text-amber-600 rounded-full flex items-center justify-center mb-6">
        <i class="bi bi-x-lg text-4xl"></i>
    </div>
    
    <h1 class="text-3xl font-extrabold text-gray-800 mb-2 dark:text-white">Payment Cancelled</h1>
    <p class="text-gray-500 max-w-md mb-8 dark:text-gray-400">
        The payment process was cancelled. No charges were made.
    </p>

    <div class="flex gap-4">
        <a href="/BranchDashboard/OrderDetails?id=@Model.OrderId" 
           class="px-8 py-3 bg-[#C41E24] text-white font-bold rounded-xl hover:bg-red-700 transition-all shadow-lg">
            Try Again
        </a>
        <a href="/BranchDashboard/MyOrder" 
           class="px-8 py-3 border border-gray-200 text-gray-600 font-bold rounded-xl hover:bg-gray-50 transition-all dark:border-gray-700 dark:text-gray-300 dark:hover:bg-slate-700">
            Back to Orders
        </a>
    </div>
</div>
