@page
@model LeKatsuMNL.Pages.Payment.SuccessModel
@{
    ViewData["Title"] = "Payment Successful";
    Layout = "_BranchLayout";
}

<div class="flex flex-col items-center justify-center min-h-[60vh] p-8 text-center bg-white dark:bg-slate-900 rounded-3xl border border-gray-100 dark:border-gray-800 shadow-xl max-w-2xl mx-auto my-8">
    <div class="w-24 h-24 bg-emerald-100 dark:bg-emerald-900/30 text-emerald-600 rounded-full flex items-center justify-center mb-8 animate-bounce shadow-inner">
        <i class="bi bi-check-lg text-5xl"></i>
    </div>
    
    <h1 class="text-4xl font-black text-gray-900 mb-3 dark:text-white tracking-tight">Payment Successful!</h1>
    <p class="text-gray-500 max-w-md mb-10 dark:text-gray-400 text-lg">
        Your payment has been processed successfully. We are now preparing your order for delivery.
    </p>

    <div class="bg-gray-50 dark:bg-slate-800/50 rounded-2xl p-8 border border-gray-100 dark:border-gray-700 w-full mb-10 backdrop-blur-sm">
        <div class="flex justify-between mb-4 items-center">
            <span class="text-gray-400 dark:text-gray-500 font-bold uppercase text-xs tracking-widest">Order Reference</span>
            <span class="font-extrabold text-xl text-gray-900 dark:text-white">#@Model.OrderId</span>
        </div>
        <div class="flex justify-between items-center">
            <span class="text-gray-400 dark:text-gray-500 font-bold uppercase text-xs tracking-widest">Payment Status</span>
            <span class="px-4 py-1.5 bg-emerald-100 dark:bg-emerald-900/40 text-emerald-700 dark:text-emerald-400 rounded-full font-black text-sm uppercase tracking-wider shadow-sm">Paid</span>
        </div>
    </div>

    <a href="/BranchDashboard/OrderDetails?id=@Model.OrderId" 
       class="group relative inline-flex items-center justify-center px-10 py-4 bg-[#C41E24] text-white font-black rounded-2xl hover:bg-red-700 transition-all shadow-2xl overflow-hidden transform hover:scale-105 active:scale-95 duration-200">
        <div class="absolute inset-0 w-3 bg-white/20 transition-all duration-500 ease-out group-hover:w-full group-hover:left-0 -left-full -skew-x-12"></div>
        <i class="bi bi-arrow-left mr-3 group-hover:-translate-x-1 transition-transform"></i>
        <span class="relative">Back to Order Details</span>
    </a>
</div>
