@page
@model LeKatsuMNL.Pages.Dashboard.ReportsModel
@{
    ViewData["Title"] = "Inventory Reports";
}

    <div class="mb-6">
        <h2 class="text-base font-bold text-gray-800 tracking-tight dark:text-white">December 25, 2026</h2>
    </div>
    <div class="bg-white rounded-t-xl border border-gray-200 p-5 flex items-center justify-between shadow-sm dark:bg-slate-800 dark:border-gray-700">
        <div class="relative flex-1 max-w-lg">
            <span class="absolute inset-y-0 left-4 flex items-center text-gray-400 dark:text-gray-500">
                <i class="bi bi-search text-sm"></i>
            </span>
            <input type="text" class="w-full border border-gray-300 rounded-lg pl-11 pr-4 py-2.5 text-sm focus:ring-1 focus:ring-[#C41E24] outline-none placeholder:text-gray-400 dark:placeholder:text-gray-500 dark:border-gray-600" placeholder="Search inventory item...">
        </div>

        <button class="flex items-center space-x-3 border border-gray-300 rounded-lg px-5 py-2.5 text-sm text-gray-600 hover:bg-gray-50 transition-all font-medium dark:hover:bg-slate-700/50 dark:text-gray-300 dark:border-gray-600">
            <i class="bi bi-arrow-clockwise text-base"></i> <span>Refresh Data</span>
        </button>
    </div>

    <div class="bg-white border-x border-b border-gray-200 shadow-sm overflow-hidden dark:bg-slate-800 dark:border-gray-700">
        <table class="w-full text-left text-xs whitespace-nowrap">
            <thead class="bg-gray-50 text-gray-500 uppercase tracking-wider font-bold border-b border-gray-100 dark:bg-slate-700/50 dark:text-gray-400 dark:border-gray-700">
                <tr>
                    <th class="px-8 py-4">Item Name</th>
                    <th class="px-8 py-4 text-center">Computed Beginning</th>
                    <th class="px-8 py-4 text-center">Computed Ending</th>
                    <th class="px-8 py-4 text-center">Received</th>
                    <th class="px-8 py-4 text-center">Consumed</th>
                    <th class="px-8 py-4 text-center">Rejected</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-gray-100 dark:divide-gray-700">
                @if (Model.InventoryReports != null && Model.InventoryReports.Any())
                {
                    foreach (var report in Model.InventoryReports)
                    {
                        <tr class="hover:bg-gray-50 transition-colors border-t border-gray-100 dark:hover:bg-slate-700/50 dark:border-gray-700">
                            <td class="px-8 py-5 font-bold text-gray-800 text-sm dark:text-white">@report.ItemName</td>
                            <td class="px-8 py-5 text-center text-gray-600 font-medium dark:text-gray-300">@report.Beginning</td>
                            <td class="px-8 py-5 text-center text-gray-600 font-medium dark:text-gray-300">@report.Ending</td>
                            <td class="px-8 py-5 text-center text-gray-600 font-medium dark:text-gray-300">@report.Received</td>
                            <td class="px-8 py-5 text-center text-gray-600 font-medium dark:text-gray-300">@report.Consumed</td>
                            <td class="px-8 py-5 text-center text-gray-600 font-medium dark:text-gray-300">@report.Rejected</td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="6" class="px-6 py-8 text-center text-gray-500 font-semibold italic dark:text-gray-400">No inventory reports found.</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <partial name="_Pagination" model="Model.InventoryReports" />