@page
@model LeKatsuMNL.Pages.Dashboard.ReportsModel
@{
    ViewData["Title"] = "Inventory Reports";
}

    <div class="mb-6">
        <h2 class="text-base font-bold text-gray-800 tracking-tight dark:text-white">December 25, 2026</h2>
    </div>
    <div class="bg-white rounded-t-xl border border-gray-200 p-5 flex items-center justify-between shadow-sm dark:bg-slate-800 dark:border-gray-700">
        <div class="relative flex-1 max-w-lg">
            <span class="absolute inset-y-0 left-4 flex items-center text-gray-400 dark:text-gray-500">
                <i class="bi bi-search text-sm"></i>
            </span>
            <input type="text" class="w-full border border-gray-300 rounded-lg pl-11 pr-4 py-2.5 text-sm focus:ring-1 focus:ring-[#C41E24] outline-none placeholder:text-gray-400 dark:placeholder:text-gray-500 dark:border-gray-600" placeholder="Search inventory item...">
        </div>

        <button class="flex items-center space-x-3 border border-gray-300 rounded-lg px-5 py-2.5 text-sm text-gray-600 hover:bg-gray-50 transition-all font-medium dark:hover:bg-slate-700/50 dark:text-gray-300 dark:border-gray-600">
            <i class="bi bi-arrow-clockwise text-base"></i> <span>Refresh Data</span>
        </button>
    </div>

    <div class="bg-white border-x border-b border-gray-200 shadow-sm overflow-hidden dark:bg-slate-800 dark:border-gray-700">
        <table class="w-full text-left text-xs whitespace-nowrap">
            <thead class="bg-gray-50 text-gray-500 uppercase tracking-wider font-bold border-b border-gray-100 dark:bg-slate-700/50 dark:text-gray-400 dark:border-gray-700">
                <tr>
                    <th class="px-8 py-4">Item Name</th>
                    <th class="px-8 py-4 text-center">Computed Beginning</th>
                    <th class="px-8 py-4 text-center">Computed Ending</th>
                    <th class="px-8 py-4 text-center">Received</th>
                    <th class="px-8 py-4 text-center">Consumed</th>
                    <th class="px-8 py-4 text-center">Rejected</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-gray-100 dark:divide-gray-700">
                <tr class="hover:bg-gray-50 transition-colors border-t border-gray-100 dark:hover:bg-slate-700/50 dark:border-gray-700">
                    <td class="px-8 py-5 font-bold text-gray-800 text-sm dark:text-white">Marinated Chicken (kg)</td>
                    <td class="px-8 py-5 text-center text-gray-600 font-medium dark:text-gray-300">150</td>
                    <td class="px-8 py-5 text-center text-gray-600 font-medium dark:text-gray-300">120</td>
                    <td class="px-8 py-5 text-center text-gray-600 font-medium dark:text-gray-300">50</td>
                    <td class="px-8 py-5 text-center text-gray-600 font-medium dark:text-gray-300">80</td>
                    <td class="px-8 py-5 text-center text-gray-600 font-medium dark:text-gray-300">0</td>
                </tr>
                <tr class="hover:bg-gray-50 transition-colors dark:hover:bg-slate-700/50">
                    <td class="px-8 py-5 font-bold text-gray-800 text-sm dark:text-white">Cooking Oil (18L)</td>
                    <td class="px-8 py-5 text-center text-gray-600 font-medium dark:text-gray-300">40</td>
                    <td class="px-8 py-5 text-center text-gray-600 font-medium dark:text-gray-300">32</td>
                    <td class="px-8 py-5 text-center text-gray-600 font-medium dark:text-gray-300">10</td>
                    <td class="px-8 py-5 text-center text-gray-600 font-medium dark:text-gray-300">18</td>
                    <td class="px-8 py-5 text-center text-gray-600 font-medium dark:text-gray-300">0</td>
                </tr>
                <tr class="hover:bg-gray-50 transition-colors dark:hover:bg-slate-700/50">
                    <td class="px-8 py-5 font-bold text-gray-800 text-sm dark:text-white">Breading Mix (kg)</td>
                    <td class="px-8 py-5 text-center text-gray-600 font-medium dark:text-gray-300">25</td>
                    <td class="px-8 py-5 text-center text-gray-600 font-medium dark:text-gray-300">20</td>
                    <td class="px-8 py-5 text-center text-gray-600 font-medium dark:text-gray-300">5</td>
                    <td class="px-8 py-5 text-center text-gray-600 font-medium dark:text-gray-300">10</td>
                    <td class="px-8 py-5 text-center text-gray-600 font-medium dark:text-gray-300">0</td>
                </tr>
            </tbody>
        </table>
    </div>

    <div class="bg-white rounded-b-xl border-x border-b border-gray-200 p-5 flex justify-between items-center text-xs text-gray-500 font-bold uppercase tracking-widest border-t border-gray-100 dark:bg-slate-800 dark:text-gray-400 dark:border-gray-700">
        <div>Showing 1 - 3 of 10</div>
        <div class="flex items-center space-x-8">
            <div class="flex items-center space-x-3">
                <span>Records per page</span>
                <div class="border border-gray-200 rounded-lg px-3 py-1 bg-gray-50 text-gray-700 flex items-center dark:bg-slate-700/50 dark:text-gray-200 dark:border-gray-700">
                    <span>10</span>
                </div>
            </div>
            <div class="flex items-center space-x-2">
                <button class="w-9 h-9 flex items-center justify-center border border-gray-200 rounded-lg text-gray-400 bg-gray-50 hover:bg-gray-100 transition-colors dark:bg-slate-700/50 dark:hover:bg-slate-700 dark:text-gray-500 dark:border-gray-700">&lt;</button>
                <button class="w-9 h-9 flex items-center justify-center border border-gray-200 rounded-lg bg-gray-600 text-white shadow-md dark:border-gray-700">1</button>
                <button class="w-9 h-9 flex items-center justify-center border border-gray-200 rounded-lg text-gray-400 bg-gray-50 hover:bg-gray-100 transition-colors dark:bg-slate-700/50 dark:hover:bg-slate-700 dark:text-gray-500 dark:border-gray-700">&gt;</button>
            </div>
        </div>
    </div>