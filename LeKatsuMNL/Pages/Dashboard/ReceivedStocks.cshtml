@page
@model LeKatsuMNL.Pages.Dashboard.ReceivedStocksModel
@{
    ViewData["Title"] = "Transaction / Received Stocks";
}

@if (!string.IsNullOrEmpty(Model.StatusMessage))
{
    <div class="mb-6 animate-pulse">
        <div class="bg-green-50 border border-green-200 rounded-xl p-4 flex items-center justify-between shadow-sm dark:bg-green-500/10 dark:border-green-500/20">
            <div class="flex items-center space-x-3 text-green-700 dark:text-green-400">
                <i class="bi bi-check-circle-fill text-lg"></i>
                <span class="text-xs font-bold uppercase tracking-wider">@Model.StatusMessage</span>
            </div>
            <button type="button" onclick="this.parentElement.parentElement.remove()" class="text-green-400 hover:text-green-600 dark:text-green-500"><i class="bi bi-x-lg"></i></button>
        </div>
    </div>
}

<!-- KPI Summary Section -->
<div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-8">
    <div class="bg-white rounded-2xl border border-gray-100 p-6 flex items-center space-x-5 shadow-sm dark:bg-slate-800 dark:border-gray-700">
        <div class="w-12 h-12 bg-red-50 rounded-xl flex items-center justify-center text-red-600 dark:bg-red-500/10 dark:text-red-400">
            <i class="bi bi-exclamation-circle text-xl"></i>
        </div>
        <div>
            <p class="text-[10px] font-black text-gray-400 uppercase tracking-widest mb-1 dark:text-gray-500">Unpaid Orders</p>
            <h3 class="text-2xl font-black text-gray-900 dark:text-white">@Model.UnpaidCount</h3>
        </div>
    </div>
    <div class="bg-white rounded-2xl border border-gray-100 p-6 flex items-center space-x-5 shadow-sm dark:bg-slate-800 dark:border-gray-700">
        <div class="w-12 h-12 bg-blue-50 rounded-xl flex items-center justify-center text-blue-600 dark:bg-blue-500/10 dark:text-blue-400">
            <i class="bi bi-cash-stack text-xl"></i>
        </div>
        <div>
            <p class="text-[10px] font-black text-gray-400 uppercase tracking-widest mb-1 dark:text-gray-500">Outstanding Balance</p>
            <h3 class="text-2xl font-black text-gray-900 dark:text-white">₱ @Model.UnpaidTotal.ToString("N2")</h3>
        </div>
    </div>
</div>

<form id="receiveForm" method="post" asp-page-handler="Save" onsubmit="return validateForm()">
        <div class="bg-white rounded-t-xl border border-gray-200 p-5 flex items-center justify-between shadow-sm dark:bg-slate-800 dark:border-gray-700">
            <div class="flex items-center space-x-6">
                <h2 class="text-base font-bold text-gray-800 tracking-tight dark:text-white">Received Stocks</h2>
                <div class="h-8 w-px bg-gray-200 dark:bg-gray-700"></div>
                <div class="flex items-center space-x-3">
                    <label class="text-[10px] font-black text-gray-400 uppercase tracking-widest dark:text-gray-500 whitespace-nowrap">Select Supplier:</label>
                    <select asp-for="SelectedVendorId" id="supplierSelect" onchange="onSupplierChange()" class="min-w-[200px] border border-gray-200 rounded-lg px-4 py-2 text-sm font-bold text-gray-800 focus:ring-1 focus:ring-[#C41E24] outline-none bg-white dark:bg-slate-800 dark:text-white dark:border-gray-700">
                        <option value="0">Select Supplier</option>
                        @foreach (var vendor in Model.Vendors)
                        {
                            <option value="@vendor.VendorId">@vendor.VendorName</option>
                        }
                    </select>
                </div>
                <div class="h-8 w-px bg-gray-200 dark:bg-gray-700"></div>
                <div class="flex items-center space-x-3">
                    <label class="text-[10px] font-black text-gray-400 uppercase tracking-widest dark:text-gray-500 whitespace-nowrap">Payment Status:</label>
                    <select name="PaymentStatus" class="border border-gray-200 rounded-lg px-4 py-2 text-sm font-bold text-gray-800 focus:ring-1 focus:ring-[#C41E24] outline-none bg-white dark:bg-slate-800 dark:text-white dark:border-gray-700">
                        <option value="Unpaid">Unpaid</option>
                        <option value="Paid">Paid</option>
                    </select>
                </div>
            </div>

            <button type="submit" class="bg-[#C41E24] text-white px-6 py-2.5 rounded-lg text-xs font-bold hover:bg-red-700 transition-all flex items-center space-x-2 shadow-sm uppercase tracking-widest">
                <i class="bi bi-floppy-fill"></i>
                <span>Save and Submit</span>
            </button>
        </div>

        <div class="bg-white border-x border-b border-gray-200 shadow-sm overflow-x-auto dark:bg-slate-800 dark:border-gray-700 custom-scrollbar">
            <table class="w-full text-left text-xs whitespace-nowrap min-w-[1200px]">
                <thead class="bg-gray-50 text-gray-500 uppercase tracking-wider font-bold border-b border-gray-100 dark:bg-slate-700/50 dark:text-gray-400 dark:border-gray-700 sticky top-0 z-10 backdrop-blur-sm">
                    <tr>
                        <th class="px-8 py-4 w-10"><input type="checkbox" id="recordSelectAll" class="w-4 h-4 rounded border-gray-300 text-[#C41E24] focus:ring-[#C41E24] dark:bg-slate-800 dark:border-gray-600"></th>
                        <th class="px-8 py-4">Item Name</th>
                        <th class="px-8 py-4">Quantity</th>
                        <th class="px-8 py-4">Unit</th>
                        <th class="px-8 py-4 text-right">Unit Price</th>
                        <th class="px-8 py-4 text-right">Line Total</th>
                        <th class="px-8 py-4 text-center">Actions</th>
                    </tr>
                </thead>
                <tbody id="receiveTableBody" class="divide-y divide-gray-100 dark:divide-gray-700">
                    <!-- Dynamic rows will be added here -->
                    <tr id="emptyRow" class="hidden">
                        <td colspan="7" class="px-8 py-10 text-center text-gray-400 font-medium italic">
                            Select a supplier and add rows to start recording received stocks.
                        </td>
                    </tr>
                </tbody>
            </table>
        </div>

        <div class="bg-white border-x border-b border-gray-200 p-5 flex justify-between items-center dark:bg-slate-800 dark:border-gray-700">
            <button type="button" onclick="addNewRow()" class="text-gray-500 hover:text-gray-800 transition-colors flex items-center space-x-3 text-xs font-bold uppercase tracking-widest dark:text-gray-400 dark:hover:text-white">
                <i class="bi bi-plus-lg text-sm"></i> <span>Add Item</span>
            </button>
            <div class="text-right">
                <span class="text-[10px] font-black text-gray-400 uppercase tracking-widest dark:text-gray-500 block mb-1">Grand Total:</span>
                <span class="text-xl font-black text-gray-900 dark:text-white">₱ <span id="grandTotal">0.00</span></span>
            </div>
        </div>
    </form>

    <!-- History Section -->
    <div class="mt-12 space-y-4">
        <div class="flex items-center justify-between ml-1">
            <div class="flex items-center space-x-6">
                <h3 class="text-sm font-black text-gray-400 uppercase tracking-widest">Stock Ins</h3>
                
                <!-- Bulk Action Toolbar -->
                <div id="bulkToolbar" class="hidden flex items-center space-x-4 animate-in fade-in slide-in-from-top-2 duration-300">
                    <div class="h-4 w-px bg-gray-200 dark:bg-gray-700"></div>
                    <span class="text-[10px] font-black text-[#C41E24] uppercase tracking-widest" id="selectionCount">0 selected</span>
                    <button type="button" onclick="submitBulk('MarkAsPaid')" class="px-3 py-1.5 bg-blue-600 text-white rounded-lg text-[10px] font-black uppercase tracking-widest hover:bg-blue-700 shadow-sm transition-all">Bulk Paid</button>
                    <button type="button" onclick="submitBulk('Archive')" class="px-3 py-1.5 bg-gray-800 text-white rounded-lg text-[10px] font-black uppercase tracking-widest hover:bg-black shadow-sm transition-all">Bulk Archive</button>
                </div>
            </div>
            <div class="flex items-center space-x-4">
                <label class="text-[10px] font-black text-gray-400 uppercase tracking-widest dark:text-gray-500">Filter By:</label>
                <select id="statusFilter" onchange="applyFilter()" class="border border-gray-200 rounded-lg px-4 py-1.5 text-[10px] font-black uppercase tracking-widest text-gray-800 focus:ring-1 focus:ring-[#C41E24] outline-none bg-white dark:bg-slate-800 dark:text-white dark:border-gray-700">
                    <!option value="All" @(Model.FilterStatus == "All" ? "selected" : "")>All Payments</!option>
                    <!option value="Paid" @(Model.FilterStatus == "Paid" ? "selected" : "")>Paid Only</!option>
                    <!option value="Unpaid" @(Model.FilterStatus == "Unpaid" ? "selected" : "")>Unpaid Only</!option>
                </select>
            </div>
        </div>
        <div class="bg-white rounded-xl border border-gray-200 shadow-sm overflow-hidden dark:bg-slate-800 dark:border-gray-700">
            <table class="w-full text-left text-xs">
                <thead class="bg-gray-50 text-gray-500 uppercase font-black text-[10px] tracking-widest border-b border-gray-100 dark:bg-slate-700/50 dark:border-gray-700">
                    <tr>
                        <th class="px-4 py-3 w-10">
                            <input type="checkbox" id="historySelectAll" onchange="toggleAll(this)" class="rounded border-gray-300 text-[#C41E24] focus:ring-[#C41E24] cursor-pointer">
                        </th>
                        <th class="px-8 py-3">Reference</th>
                        <th class="px-8 py-3">Vendor</th>
                        <th class="px-8 py-3">Received Date</th>
                        <th class="px-8 py-3">Items</th>
                        <th class="px-8 py-3 text-right">Total Cost</th>
                        <th class="px-8 py-3 text-center">Payment</th>
                        <th class="px-8 py-4 text-right">Action</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-gray-50 dark:divide-gray-700">
                    @if (Model.SupplyOrders != null && Model.SupplyOrders.Any())
                    {
                        foreach (var order in Model.SupplyOrders)
                        {
                            <tr class="hover:bg-gray-50/50 transition-all dark:hover:bg-slate-700/30">
                                <td class="px-4 py-4 text-center">
                                    <input type="checkbox" value="@order.SoaId" onchange="updateSelection()" class="row-checkbox rounded border-gray-300 text-[#C41E24] focus:ring-[#C41E24] cursor-pointer">
                                </td>
                                <td class="px-8 py-4 font-bold text-gray-800 dark:text-white">SO-@order.SoaId.ToString("D5")</td>
                                <td class="px-8 py-4 text-gray-500 font-bold dark:text-gray-400">@(order.Vendor?.VendorName ?? "-")</td>
                                <td class="px-8 py-4 text-gray-500 font-medium">@order.SupplyDate.ToString("MMM dd, yyyy HH:mm")</td>
                                <td class="px-8 py-4">
                                    <div class="flex flex-wrap gap-2">
                                        @foreach (var item in order.SupplyLists.Take(3))
                                        {
                                            <span class="px-2 py-1 bg-gray-100 rounded text-[10px] font-bold text-gray-600 dark:bg-slate-700 dark:text-gray-300">
                                                @item.CommissaryInventory?.ItemName (@item.Quantity.ToString("G29"))
                                            </span>
                                        }
                                        @if (order.SupplyLists.Count > 3)
                                        {
                                            <span class="text-[10px] text-gray-400 font-bold">+@(order.SupplyLists.Count - 3) more</span>
                                        }
                                    </div>
                                </td>
                                <td class="px-8 py-4 text-right font-bold text-blue-600 dark:text-blue-400">₱ @order.SupplyLists.Sum(sl => sl.TotalPrice).ToString("N2")</td>
                                <td class="px-8 py-4 text-center">
                                    @if (order.PaymentStatus == "Paid")
                                    {
                                        <span class="px-3 py-1 bg-green-50 text-green-600 rounded-full text-[10px] font-bold uppercase tracking-widest dark:bg-green-500/10 dark:text-green-400">Paid</span>
                                    }
                                    else
                                    {
                                        <span class="px-3 py-1 bg-red-50 text-red-600 rounded-full text-[10px] font-bold uppercase tracking-widest dark:bg-red-500/10 dark:text-red-400">Unpaid</span>
                                    }
                                </td>
                                <td class="px-8 py-4 text-right">
                                    <div class="flex items-center justify-end space-x-3">
                                        @if (order.PaymentStatus == "Unpaid")
                                        {
                                            <form method="post" asp-page-handler="MarkAsPaid" asp-route-id="@order.SoaId" class="inline m-0">
                                                <button type="submit" class="px-3 py-1.5 bg-blue-50 text-blue-600 rounded-lg text-xs font-bold hover:bg-blue-100 transition-all dark:bg-blue-500/10 dark:text-blue-400">Mark Paid</button>
                                            </form>
                                        }
                                        <form method="post" asp-page-handler="Archive" asp-route-id="@order.SoaId" class="inline m-0">
                                            <button type="submit" onclick="return confirm('Archive this supply order?')" class="px-3 py-1.5 bg-gray-100 text-gray-500 rounded-lg text-xs font-bold hover:bg-gray-200 transition-all dark:bg-slate-700 dark:text-gray-400">Archive</button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
        <partial name="_Pagination" model="Model.SupplyOrders" />
    </div>

@section Scripts {
    <script>
        const allItems = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.AllItems.Select(i => new { i.ComId, i.ItemName, i.VendorId, i.Uom, i.Yield })));
        let rowCount = 0;

        document.addEventListener('DOMContentLoaded', () => {
            const historySelectAll = document.getElementById('historySelectAll');
            const recordSelectAll = document.getElementById('recordSelectAll');

            if (historySelectAll) {
                historySelectAll.addEventListener('change', function() {
                    const checkboxes = document.querySelectorAll('.row-checkbox');
                    checkboxes.forEach(cb => cb.checked = this.checked);
                    updateSelection();
                });
            }

            if (recordSelectAll) {
                recordSelectAll.addEventListener('change', function() {
                    const checkboxes = document.querySelectorAll('.row-select');
                    checkboxes.forEach(cb => cb.checked = this.checked);
                });
            }

            // Also delegate row-checkbox changes for manual selection
            document.addEventListener('change', (e) => {
                if (e.target.classList.contains('row-checkbox')) {
                    updateSelection();
                }
            });
            
            // Initial supplier state check
            if (document.getElementById('supplierSelect') && document.getElementById('supplierSelect').value === "0") {
                 const tbody = document.getElementById('receiveTableBody');
                 if (tbody) tbody.innerHTML = `<tr><td colspan="7" class="px-8 py-10 text-center text-gray-400 font-medium italic">Select a supplier and add rows to start recording received stocks.</td></tr>`;
            }
        });

        function applyFilter() {
            const status = document.getElementById('statusFilter').value;
            window.location.href = `?FilterStatus=${status}`;
        }

        function updateSelection() {
            const selected = document.querySelectorAll('.row-checkbox:checked');
            const toolbar = document.getElementById('bulkToolbar');
            const countLabel = document.getElementById('selectionCount');
            const historySelectAll = document.getElementById('historySelectAll');
            
            if (selected.length > 0) {
                toolbar.classList.remove('hidden');
                toolbar.classList.add('flex');
                countLabel.innerText = `${selected.length} selected`;
            } else {
                toolbar.classList.add('hidden');
                toolbar.classList.remove('flex');
                if (historySelectAll) historySelectAll.checked = false;
            }
        }

        function submitBulk(action) {
            const selected = document.querySelectorAll('.row-checkbox:checked');
            if (selected.length === 0) return;
            
            if (action === 'Archive' && !confirm(`Archive ${selected.length} supply orders?`)) return;

            const form = document.createElement('form');
            form.method = 'POST';
            form.action = `?handler=Bulk${action}`;
            
            const token = document.querySelector('input[name="__RequestVerificationToken"]');
            if (token) {
                const tokenClone = token.cloneNode();
                form.appendChild(tokenClone);
            }

            selected.forEach(cb => {
                const input = document.createElement('input');
                input.type = 'hidden';
                input.name = 'selectedIds';
                input.value = cb.value;
                form.appendChild(input);
            });

            document.body.appendChild(form);
            form.submit();
        }

        function onSupplierChange() {
            const vendorId = parseInt(document.getElementById('supplierSelect').value);
            const tbody = document.getElementById('receiveTableBody');
            tbody.innerHTML = '';
            rowCount = 0;
            updateGrandTotal();
            
            if (vendorId > 0) {
                addNewRow();
            } else {
                tbody.innerHTML = `<tr><td colspan="7" class="px-8 py-10 text-center text-gray-400 font-medium italic">Select a supplier and add rows to start recording received stocks.</td></tr>`;
            }
        }

        function addNewRow() {
            const vendorId = parseInt(document.getElementById('supplierSelect').value);
            if (vendorId === 0) return;

            const vendorItems = allItems.filter(i => i.VendorId === vendorId);
            const tbody = document.getElementById('receiveTableBody');
            
            if (tbody.rows.length === 1 && tbody.rows[0].cells.length === 1) {
                tbody.innerHTML = '';
            }

            const tr = document.createElement('tr');
            tr.className = "hover:bg-gray-50 transition-colors border-t border-gray-50 dark:hover:bg-slate-700/50 dark:border-gray-700";
            const index = rowCount++;
            
            tr.innerHTML = `
                <td class="px-8 py-5"><input type="checkbox" class="row-select w-4 h-4 rounded border-gray-300 dark:border-gray-600 text-[#C41E24] focus:ring-[#C41E24]"></td>
                <td class="px-8 py-5">
                    <select name="ItemsToReceive[${index}].ComId" onchange="updateRowUom(this, ${index})" class="w-full border border-gray-200 rounded-lg px-4 py-2 text-sm font-bold text-gray-900 focus:ring-1 focus:ring-[#C41E24] outline-none bg-white dark:bg-slate-800 dark:text-white dark:border-gray-700" required>
                        <option value="">Select Product from Supplier</option>
                        ${vendorItems.map(i => `<option value="${i.ComId}" data-yield="${i.Yield || ''}" data-uom="${i.Uom}">${i.ItemName}</option>`).join('')}
                    </select>
                </td>
                <td class="px-8 py-5">
                    <input type="number" step="any" name="ItemsToReceive[${index}].Quantity" id="qty_${index}" oninput="calculateLineTotal(${index})" placeholder="0.00" class="w-full border border-gray-200 rounded-lg px-4 py-2 text-sm font-black text-gray-900 focus:ring-1 focus:ring-[#C41E24] outline-none bg-white dark:bg-slate-800 dark:text-white dark:border-gray-700" required>
                </td>
                <td class="px-8 py-5">
                    <input type="text" name="ItemsToReceive[${index}].Unit" id="uom_${index}" readonly class="w-full bg-gray-50 border border-gray-200 rounded-lg px-4 py-2 text-sm font-bold text-gray-500 outline-none dark:bg-slate-700 dark:text-gray-400 dark:border-gray-700" placeholder="Unit">
                </td>
                <td class="px-8 py-5">
                    <div class="relative">
                        <span class="absolute left-3 top-1/2 -translate-y-1/2 text-gray-400 font-bold">₱</span>
                        <input type="number" step="0.01" name="ItemsToReceive[${index}].UnitPrice" id="price_${index}" oninput="calculateLineTotal(${index})" placeholder="0.00" class="w-full border border-gray-200 rounded-lg pl-7 pr-4 py-2 text-sm font-black text-gray-900 focus:ring-1 focus:ring-[#C41E24] outline-none bg-white dark:bg-slate-800 dark:text-white dark:border-gray-700 text-right" required>
                    </div>
                </td>
                <td class="px-8 py-5 text-right font-black text-gray-900 dark:text-white">
                    ₱ <span id="lineTotal_${index}">0.00</span>
                </td>
                <td class="px-8 py-5 text-center">
                    <button type="button" onclick="this.closest('tr').remove(); updateGrandTotal();" class="text-gray-400 hover:text-red-500 transition-colors dark:text-gray-500"><i class="bi bi-trash3 text-lg"></i></button>
                </td>
            `;
            tbody.appendChild(tr);
        }

        function updateRowUom(select, index) {
            if (!select.options[select.selectedIndex]) return;
            const yieldUnit = select.options[select.selectedIndex].getAttribute('data-yield');
            const uom = select.options[select.selectedIndex].getAttribute('data-uom');
            const uomInput = document.getElementById(`uom_${index}`);
            if (uomInput) uomInput.value = yieldUnit || uom || '';
            const qtyInput = document.getElementById(`qty_${index}`);
            if (qtyInput) qtyInput.focus();
        }

        function calculateLineTotal(index) {
            const qty = parseFloat(document.getElementById(`qty_${index}`).value) || 0;
            const price = parseFloat(document.getElementById(`price_${index}`).value) || 0;
            const total = qty * price;
            const lineTotalSpan = document.getElementById(`lineTotal_${index}`);
            if (lineTotalSpan) lineTotalSpan.innerText = total.toLocaleString('en-US', { minimumFractionDigits: 2, maximumFractionDigits: 2 });
            updateGrandTotal();
        }

        function updateGrandTotal() {
            let grandTotal = 0;
            const lineTotals = document.querySelectorAll('[id^="lineTotal_"]');
            lineTotals.forEach(span => {
                const val = parseFloat(span.innerText.replace(/,/g, '')) || 0;
                grandTotal += val;
            });
            const grandTotalSpan = document.getElementById('grandTotal');
            if (grandTotalSpan) grandTotalSpan.innerText = grandTotal.toLocaleString('en-US', { minimumFractionDigits: 2, maximumFractionDigits: 2 });
        }

        function validateForm() {
            const vendorIdElement = document.getElementById('supplierSelect');
            if (!vendorIdElement) return false;
            const vendorId = parseInt(vendorIdElement.value);
            if (vendorId === 0) {
                alert("Please select a supplier.");
                return false;
            }
            const rows = document.querySelectorAll('#receiveTableBody select[name$=".ComId"]');
            let hasValidItem = false;
            rows.forEach(select => { if (select.value !== "") hasValidItem = true; });
            if (!hasValidItem) {
                alert("Please add at least one item to receive.");
                return false;
            }
            return true;
        }
    </script>
}
