    <option value="Gallon"></option>
    <option value="Sack"></option>
    <option value="Box"></option>
    <option value="Bundle"></option>
    <option value="Can"></option>
    <option value="Tub"></option>
    <option value="Tubs"></option>
    <option value="Jar"></option>
    <option value="Tray"></option>
    <option value="Ctn"></option>
</datalist>

<datalist id="pkgUnitList">
    <option value="Cans"></option>
    <option value="Grams"></option>
    <option value="mL"></option>
    <option value="Kilogram"></option>
    <option value="Pieces"></option>
    <option value="Liter"></option>
    <option value="Pull"></option>
    <option value="Sticks"></option>
    <option value="Bottles"></option>
    <option value="Per pc"></option>
</datalist>

<datalist id="uomList">
    <option value="Grams"></option>
    <option value="Dips"></option>
    <option value="mL"></option>
    <option value="Sticks"></option>
    <option value="Pieces"></option>
    <option value="pack"></option>
    <option value="bottle"></option>
    <option value="Cans"></option>
</datalist>

@section Scripts {
    <script>
        const actionsMenu = document.getElementById('actionsMenu');
        const subCategoriesData = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.SubCategories.Select(s => new { s.SubCategoryId, s.SubCategoryName, s.CategoryId })));

        // UOM categories for client-side validation
        const unitMap = {
            'g': 'weight', 'gram': 'weight', 'grams': 'weight', 'kg': 'weight', 'kilogram': 'weight', 'kilograms': 'weight',
            'oz': 'weight', 'ounce': 'weight', 'ounces': 'weight', 'lb': 'weight', 'lbs': 'weight', 'pound': 'weight', 'pounds': 'weight', 'mg': 'weight',
            'ml': 'volume', 'milliliter': 'volume', 'milliliters': 'volume', 'l': 'volume', 'liter': 'volume', 'liters': 'volume',
            'cup': 'volume', 'cups': 'volume', 'tbsp': 'volume', 'tablespoon': 'volume', 'tsp': 'volume', 'teaspoon': 'volume', 'fl oz': 'volume',
            'gal': 'volume', 'gallon': 'volume', 'gallons': 'volume', 'qt': 'volume', 'quart': 'volume', 'quarts': 'volume', 'pt': 'volume', 'pint': 'volume', 'pints': 'volume',
            'pcs': 'count', 'pc': 'count', 'per pc': 'count', 'pieces': 'count', 'piece': 'count', 'ea': 'count', 'dozen': 'count', 'pack': 'count', 'bundle': 'count',
            'roll': 'count', 'can': 'count', 'cans': 'count', 'stick': 'count', 'sticks': 'count', 'pull': 'count', 'pulls': 'count', 'dip': 'count', 'dips': 'count'
        };

        function validateUomCompatibility(prefix) {
            const pkgUnit = document.getElementById(prefix + 'PackagingUnit').value.trim().toLowerCase();
            const uom = document.getElementById(prefix + 'UOM').value.trim().toLowerCase();
            const errorDiv = document.getElementById(prefix + 'UomError');
            const errorText = document.getElementById(prefix + 'UomErrorText');
            const submitBtn = document.getElementById(prefix + 'SubmitBtn');

            if (!pkgUnit || !uom) {
                if (errorDiv) errorDiv.classList.add('hidden');
                if (submitBtn) {
                    submitBtn.disabled = false;
                    submitBtn.classList.remove('opacity-50', 'cursor-not-allowed');
                }
                return true;
            }

            // Simple cleaning for common parentatical units in datalists (e.g. "Grams (g)" -> "g")
            const cleanUnit = (u) => {
                const match = u.match(/\(([^)]+)\)/);
                return match ? match[1].toLowerCase() : u.toLowerCase();
            };

            const u1 = cleanUnit(pkgUnit);
            const u2 = cleanUnit(uom);

            const cat1 = unitMap[u1] || unitMap[pkgUnit];
            const cat2 = unitMap[u2] || unitMap[uom];

            if (cat1 && cat2 && cat1 !== cat2) {
                if (errorDiv) {
                    errorDiv.classList.remove('hidden');
                    errorText.innerText = `INCOMPATIBLE UNITS: [${pkgUnit}] belongs to ${cat1.toUpperCase()}, while [${uom}] is ${cat2.toUpperCase()}. Please match the unit categories.`;
                }
                if (submitBtn) {
                    submitBtn.disabled = true;
                    submitBtn.classList.add('opacity-50', 'cursor-not-allowed');
                }
                return false;
            }

            if (errorDiv) errorDiv.classList.add('hidden');
            if (submitBtn) {
                submitBtn.disabled = false;
                submitBtn.classList.remove('opacity-50', 'cursor-not-allowed');
            }
            return true;
        }

        function toggleActions(e) {
            e.stopPropagation();
            actionsMenu.classList.toggle('hidden');
        }

        function openModal(modalId) {
            const modal = document.getElementById(modalId);
            const content = modal.querySelector('div');
            
            modal.classList.remove('hidden');
            document.body.style.overflow = 'hidden';
            
            setTimeout(() => {
                content.classList.remove('opacity-0', 'scale-95');
                content.classList.add('opacity-100', 'scale-100');
            }, 10);
        }

        function closeModal(modalId) {
            const modal = document.getElementById(modalId);
            const content = modal.querySelector('div');
            
            content.classList.add('opacity-0', 'scale-95');
            content.classList.remove('opacity-100', 'scale-100');
            
            setTimeout(() => {
                modal.classList.add('hidden');
                document.body.style.overflow = 'auto';
                // Reset form fields
                const form = modal.querySelector('form');
                if (form) {
                    form.reset();
                    // Explicitly reset dynamic UI states
                    if (document.getElementById('newSellingPriceCheck')) togglePriceField('new');
                    if (document.getElementById('editSellingPriceCheck')) togglePriceField('edit');
                    toggleSupplierField('new');
                    toggleSupplierField('edit');
                }
            }, 300);
        }

        function openNewItemModal() {
            // Reset subcategory dropdown
            document.getElementById('newSubCategoryId').innerHTML = '<option value="" disabled selected hidden>Sub-Category</option>';
            openModal('newItemModal');
        }

        function filterSubCategories(prefix, selectedSubId = null) {
            const categoryId = document.getElementById(prefix + 'CategoryId').value;
            const subCategorySelect = document.getElementById(prefix + 'SubCategoryId');
            
            // Clear previous options
            subCategorySelect.innerHTML = '<option value="" disabled selected hidden>Sub-Category</option>';
            
            // Filter subcategories based on selected category id
            const filtered = subCategoriesData.filter(sc => sc.CategoryId == categoryId);
            
            filtered.forEach(sc => {
                const option = document.createElement('option');
                option.value = sc.SubCategoryId;
                option.textContent = sc.SubCategoryName;
                if (selectedSubId && sc.SubCategoryId == selectedSubId) {
                    option.selected = true;
                }
                subCategorySelect.appendChild(option);
            });
        }

        function togglePriceField(prefix = 'new') {
            const checkbox = document.getElementById(prefix + 'SellingPriceCheck');
            const container = document.getElementById(prefix + 'SellingPriceContainer');
            if (checkbox.checked) {
                container.classList.remove('hidden');
            } else {
                container.classList.add('hidden');
            }
        }

        function toggleSupplierField(prefix = 'new') {
            const checkbox = document.getElementById(prefix + 'IsRepack');
            const container = document.getElementById(prefix + 'VendorIdContainer');
            const select = document.getElementById(prefix + 'VendorId');
            if (checkbox.checked) {
                container.classList.add('hidden');
                select.removeAttribute('required');
                select.value = '';
            } else {
                container.classList.remove('hidden');
                select.setAttribute('required', 'required');
            }
        }

        function openEditItemModal(item) {
            document.getElementById('editComId').value = item.comId;
            document.getElementById('editItemName').value = item.itemName;
            document.getElementById('editCategoryId').value = item.categoryId;
            document.getElementById('editVendorId').value = item.vendorId;
            document.getElementById('editUOM').value = item.uom;
            document.getElementById('editCostPrice').value = item.costPrice ? parseFloat(item.costPrice).toFixed(2) : '';
            document.getElementById('editSellingPrice').value = (item.sellingPrice && item.sellingPrice > 0) ? parseFloat(item.sellingPrice).toFixed(2) : '';
            document.getElementById('editStock').value = item.stock ? parseFloat(item.stock).toString() : '0';
            document.getElementById('editIsRepack').checked = item.isRepack || false;
            
            // Handle Selling Price Toggle
            const sellingPriceCheck = document.getElementById('editSellingPriceCheck');
            sellingPriceCheck.checked = item.sellingPrice > 0;
            togglePriceField('edit');
            toggleSupplierField('edit');

            // Filter SubCategories and select the current one
            filterSubCategories('edit', item.subCategoryId);

            // Parse packaging from yield (Format: Type/SizeUnit)
            if (item.yield && item.yield.includes('/')) {
                const parts = item.yield.split('/');
                document.getElementById('editPackagingType').value = parts[0];
                
                const remainder = parts[1];
                const sizeMatch = remainder.match(/^[\d.]+/);
                if (sizeMatch) {
                    const size = sizeMatch[0];
                    const unit = remainder.substring(size.length);
                    document.getElementById('editPackSize').value = size;
                    document.getElementById('editPackagingUnit').value = unit;
                }
            }

            openModal('editItemModal');
        }

        function openRejectModal() {
            const actionsMenu = document.getElementById('actionsMenu');
            if (actionsMenu) actionsMenu.classList.add('hidden');

            const checked = document.querySelectorAll('.row-checkbox:checked');
            if (checked.length === 0) {
                alert('Please select an item to reject.');
                return;
            }
            if (checked.length > 1) {
                alert('Please select only one item at a time for rejection.');
                return;
            }

            const item = checked[0];
            const id = item.dataset.id;
            const name = item.dataset.itemName;
            const stock = parseFloat(item.dataset.stock) || 0;
            const uom = item.dataset.uom;

            document.getElementById('rejectComId').value = id;
            document.getElementById('rejectItemName').value = name;
            document.getElementById('rejectUOM').value = uom;
            document.getElementById('maxStockLabel').innerText = stock;
            
            const qtyInput = document.getElementById('rejectQty');
            qtyInput.max = stock;
            qtyInput.value = '';
            qtyInput.placeholder = `0.00 (Max: ${stock})`;

            openModal('rejectItemModal');
        }

        // Add validation to reject quantity
        document.getElementById('rejectQty')?.addEventListener('input', function() {
            const max = parseFloat(this.max);
            const val = parseFloat(this.value);
            const submitBtn = this.closest('form').querySelector('button[type="submit"]');
            
            if (val > max) {
                this.setCustomValidity(`Quantity cannot exceed available stock (${max})`);
                this.classList.add('border-red-500', 'focus:border-red-500', 'focus:ring-red-500/20');
            } else {
                this.setCustomValidity('');
                this.classList.remove('border-red-500', 'focus:border-red-500', 'focus:ring-red-500/20');
            }
        });

        function toggleSelectAll(source) {
            const checkboxes = document.querySelectorAll('.row-checkbox');
            checkboxes.forEach(cb => cb.checked = source.checked);
        }

        function updateSelectAll() {
            const all = document.querySelectorAll('.row-checkbox');
            const checked = document.querySelectorAll('.row-checkbox:checked');
            const selectAll = document.getElementById('selectAll');
            selectAll.checked = all.length > 0 && all.length === checked.length;
            selectAll.indeterminate = checked.length > 0 && checked.length < all.length;
        }

        window.onclick = function(event) {
            if (!event.target.closest('.relative')) {
                if(actionsMenu) actionsMenu.classList.add('hidden');
            }
        }

        // Datalist Usability Helpers
        function handleDatalistFocus(input) {
            if (input.value) {
                input.dataset.originalValue = input.value;
                input.dataset.tempPlaceholder = input.placeholder;
                input.placeholder = input.value; // Show value as placeholder while focused
                input.value = '';
            }
        }

        function handleDatalistBlur(input) {
            setTimeout(() => {
                if (input.value === '' && input.dataset.originalValue) {
                    input.value = input.dataset.originalValue;
                }
                if (input.dataset.tempPlaceholder !== undefined) {
                    input.placeholder = input.dataset.tempPlaceholder;
                }
            }, 200);
        }
        function handleArchive() {
            const checked = document.querySelectorAll('.row-checkbox:checked');
            if (checked.length === 0) {
                alert('Please select at least one item to archive.');
                return;
            }

            if (confirm(`Are you sure you want to archive ${checked.length} selected item(s)?`)) {
                const ids = Array.from(checked).map(cb => cb.dataset.id).join(',');
                
                const form = document.createElement('form');
                form.method = 'POST';
                form.action = '?handler=BulkArchive';
                
                const input = document.createElement('input');
                input.type = 'hidden';
                input.name = 'ids';
                input.value = ids;
                
                const antiforgery = document.querySelector('input[name="__RequestVerificationToken"]');
                if (antiforgery) {
                    form.appendChild(antiforgery.cloneNode());
                }
                
                form.appendChild(input);
                document.body.appendChild(form);
                form.submit();
            }
        }
    </script>
}
