@page
@model LeKatsuMNL.Pages.Dashboard.ItemsModel
@using LeKatsuMNL.Helpers
@{
    ViewData["Title"] = "Inventory Items";
}

@section TitleActions {
    @if (PermissionHelper.HasPermission(User, "Items", 'C'))
    {
        <button onclick="openNewItemModal()" class="bg-[#C41E24] text-white px-5 py-2 rounded-lg text-sm font-bold hover:bg-red-700 transition-colors shadow-sm whitespace-nowrap">
            + New Item
        </button>
    }
}

<div class="bg-white rounded-xl border border-gray-200 shadow-sm overflow-hidden dark:bg-slate-800 dark:border-gray-700" data-ajax-container>
    <!-- Tabs -->
    <div class="flex border-b border-gray-200 dark:border-gray-700">
        <button class="px-10 py-4 text-sm font-bold text-[#C41E24] border-b-2 border-[#C41E24] transition-all">Ingredient</button>
        <a href="/Dashboard/SKU" data-ajax-link class="px-10 py-4 text-sm font-bold text-gray-400 hover:text-gray-600 transition-all dark:text-gray-500">SKU</a>
    </div>

    <!-- Toolbar -->
    <form method="get" data-ajax-form class="p-5 flex flex-wrap items-center gap-4 bg-white border-b border-gray-100 dark:bg-slate-800 dark:border-gray-700">
        <div class="relative inline-block text-left">
            <button type="button" onclick="toggleActions(event)" class="flex items-center space-x-2 border border-gray-300 rounded-lg px-4 py-2 text-sm text-gray-600 bg-white hover:bg-gray-50 outline-none transition-all dark:bg-slate-800 dark:hover:bg-slate-700/50 dark:text-gray-300 dark:border-gray-600">
                <span>Actions</span>
                <i class="bi bi-chevron-down text-xs"></i>
            </button>
            <div id="actionsMenu" class="hidden absolute left-0 mt-2 w-40 bg-white rounded-xl shadow-xl border border-gray-100 z-[70] overflow-hidden transform origin-top-left transition-all dark:bg-slate-800 dark:border-gray-700">
                @if (PermissionHelper.HasPermission(User, "Items", 'D'))
                {
                    <button type="button" onclick="handleArchive()" class="w-full text-left px-5 py-3 text-xs font-bold text-gray-700 uppercase tracking-widest hover:bg-gray-50 border-b border-gray-50 transition-colors dark:hover:bg-slate-700/50 dark:text-gray-200 dark:border-gray-700">
                        Archive
                    </button>
                }
                @if (PermissionHelper.HasPermission(User, "Rejects", 'C'))
                {
                    <button type="button" onclick="openRejectModal()" class="w-full text-left px-5 py-3 text-xs font-bold text-red-500 uppercase tracking-widest hover:bg-red-50 hover:text-[#C41E24] transition-colors">
                        Reject
                    </button>
                }
            </div>
        </div>

        <div class="relative flex-1 min-w-[200px] max-w-md">
            <span class="absolute inset-y-0 left-4 flex items-center text-gray-400 dark:text-gray-500">
                <i class="bi bi-search text-sm"></i>
            </span>
            <input type="text" name="searchTerm" value="@Model.SearchTerm" class="w-full border border-gray-300 rounded-lg pl-11 pr-4 py-2 text-sm focus:ring-1 focus:ring-[#C41E24] outline-none placeholder:text-gray-400 dark:placeholder:text-gray-500 dark:border-gray-600 dark:bg-slate-800 dark:text-white" placeholder="Search item name...">
        </div>

        <div class="flex flex-wrap items-center gap-3">
            <select name="categoryId" onchange="this.form.requestSubmit()" class="border border-gray-300 rounded-lg px-4 py-2 text-sm text-gray-600 bg-white outline-none cursor-pointer dark:bg-slate-800 dark:text-gray-300 dark:border-gray-600">
                <option value="">All Categories</option>
                @foreach (var cat in Model.Categories)
                {
                    @if (Model.FilterCategoryId == cat.CategoryId)
                    {
                        <option value="@cat.CategoryId" selected>@cat.CategoryName</option>
                    }
                    else
                    {
                        <option value="@cat.CategoryId">@cat.CategoryName</option>
                    }
                }
            </select>

            <select name="vendorId" onchange="this.form.submit()" class="border border-gray-300 rounded-lg px-4 py-2 text-sm text-gray-600 bg-white outline-none cursor-pointer dark:bg-slate-800 dark:text-gray-300 dark:border-gray-600">
                <option value="">All Suppliers</option>
                @foreach (var vendor in Model.Vendors)
                {
                    @if (Model.FilterVendorId == vendor.VendorId)
                    {
                        <option value="@vendor.VendorId" selected>@vendor.VendorName</option>
                    }
                    else
                    {
                        <option value="@vendor.VendorId">@vendor.VendorName</option>
                    }
                }
            </select>

            <select name="stockStatus" onchange="this.form.requestSubmit()" class="border border-gray-300 rounded-lg px-4 py-2 text-sm text-gray-600 bg-white outline-none cursor-pointer dark:bg-slate-800 dark:text-gray-300 dark:border-gray-600">
                <option value="All" selected='@(Model.StockStatus == "All")'>All Stocks</option>
                <option value="In Stock" selected='@(Model.StockStatus == "In Stock")'>In Stock (>=10)</option>
                <option value="Low Stock" selected='@(Model.StockStatus == "Low Stock")'>Low Stock (<10)</option>
                <option value="Out of Stock" selected='@(Model.StockStatus == "Out of Stock")'>Out of Stock</option>
            </select>

            <div class="flex items-center gap-2">
                <button type="submit" class="bg-gray-100 text-gray-700 px-4 py-2 rounded-lg text-sm font-bold hover:bg-gray-200 transition-colors dark:bg-slate-700 dark:text-gray-200">
                    Filter
                </button>
                @if (!string.IsNullOrEmpty(Model.SearchTerm) || Model.FilterCategoryId.HasValue || Model.FilterVendorId.HasValue || Model.StockStatus != "All")
                {
                    <a href="/Dashboard/Items" data-ajax-link class="text-xs font-bold text-red-500 hover:text-red-700 uppercase tracking-widest px-2">Clear</a>
                }
                <button type="button" onclick="location.reload()" class="p-2 text-gray-400 hover:text-gray-600 transition-colors dark:text-gray-500">
                    <i class="bi bi-arrow-clockwise text-base"></i>
                </button>
            </div>
        </div>
    </form>

    <!-- Table & Pagination -->
    <div>
        <div class="overflow-x-auto">
            <table class="w-full text-left text-xs whitespace-nowrap">
                <thead class="bg-gray-50 text-gray-500 uppercase tracking-wider font-bold border-b border-gray-100 dark:bg-slate-700/50 dark:text-gray-400 dark:border-gray-700">
                    <tr>
                        <th class="px-8 py-4 w-12"><input type="checkbox" id="selectAll" onchange="toggleSelectAll(this)" class="w-4 h-4 rounded border-gray-300 text-[#C41E24] focus:ring-[#C41E24] dark:border-gray-600"></th>
                        <th class="px-6 py-4">Image</th>
                        <th class="px-6 py-4">Item Name</th>
                        <th class="px-6 py-4">Category</th>
                        <th class="px-6 py-4">Sub-Category</th>
                        <th class="px-6 py-4">Supplier</th>
                        <th class="px-6 py-4">Yield</th>
                        <th class="px-6 py-4">In Stock</th>
                        <th class="px-6 py-4">Unit Cost</th>
                        <th class="px-6 py-4">Selling Price</th>
                        <th class="px-6 py-4">Action</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-gray-50 dark:divide-gray-700">
                    @if (Model.Items != null && Model.Items.Any())
                    {
                        foreach (var item in Model.Items)
                        {
                            <tr class="hover:bg-gray-50/50 transition-colors group">
                                <td class="px-8 py-5"><input type="checkbox" class="row-checkbox w-4 h-4 rounded border-gray-300 dark:border-gray-600" data-id="@item.ComId" data-item-name="@item.ItemName" data-stock="@item.Stock" data-uom="@item.Uom" onchange="updateSelectAll()"></td>
                                <td class="px-6 py-5">
                                    <div class="w-12 h-12 bg-gray-200 rounded-xl flex items-center justify-center text-gray-400 group-hover:bg-gray-300 transition-colors dark:text-gray-500">
                                        <i class="bi bi-image text-2xl"></i>
                                    </div>
                                </td>
                                <td class="px-6 py-5 font-bold text-gray-900 text-sm dark:text-white">@item.ItemName</td>
                                <td class="px-6 py-5 text-gray-600 dark:text-gray-300">@(item.Category?.CategoryName ?? "-")</td>
                                <td class="px-6 py-5 text-gray-600 dark:text-gray-300">@(item.SubCategory?.SubCategoryName ?? "-")</td>
                                <td class="px-6 py-5 text-gray-600 dark:text-gray-300">@(item.Vendor?.VendorName ?? "-")</td>
                                <td class="px-6 py-5 text-gray-600 font-semibold dark:text-gray-300">@item.Yield</td>
                                <td class="px-6 py-5">
                                    <span class="bg-blue-50 text-blue-600 px-4 py-1.5 rounded-lg font-bold border border-blue-100">@item.Stock.ToString("G29") @item.Uom</span>
                                </td>
                                <td class="px-6 py-5 font-bold text-gray-900 text-sm dark:text-white">₱ @String.Format("{0:0.00}", item.CostPrice)</td>
                                <td class="px-6 py-5 font-bold text-gray-900 text-sm dark:text-white">₱ @String.Format("{0:0.00}", item.SellingPrice)</td>
                                <td class="px-6 py-5">
                                    @if (PermissionHelper.HasPermission(User, "Items", 'U'))
                                    {
                                        <button onclick='openEditItemModal(@Html.Raw(System.Text.Json.JsonSerializer.Serialize(new { 
                                            comId = item.ComId, 
                                            itemName = item.ItemName, 
                                            categoryId = item.CategoryId, 
                                            subCategoryId = item.SubCategoryId,
                                            vendorId = item.VendorId,
                                            uom = item.Uom,
                                            costPrice = item.CostPrice,
                                            sellingPrice = item.SellingPrice,
                                            yield = item.Yield,
                                            stock = item.Stock
                                        })))' class="text-blue-500 hover:text-blue-700 transition-colors">
                                            <i class="bi bi-pencil-square text-lg"></i>
                                        </button>
                                    }
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="11" class="px-6 py-8 text-center text-gray-500 font-semibold italic dark:text-gray-400">No items found. Create a new item to get started.</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <partial name="_Pagination" model="Model.Items" />
    </div>
</div>

<!-- Create New Item Modal -->
<div id="newItemModal" class="fixed inset-0 bg-black/40 hidden flex items-center justify-center z-[100] backdrop-blur-[2px] transition-all duration-300 font-sans">
    <div class="bg-white rounded-2xl shadow-2xl w-full max-w-lg mx-4 overflow-hidden border border-gray-100 transform transition-all opacity-0 scale-95 dark:bg-slate-800 dark:border-gray-700">
        <div class="px-8 py-6 border-b border-gray-50 flex justify-between items-center bg-white dark:bg-slate-800 dark:border-gray-700">
            <h3 class="text-base font-bold text-gray-900 dark:text-white">Create New Item</h3>
            <button onclick="closeModal('newItemModal')" class="text-gray-500 hover:text-gray-700 transition-colors dark:text-gray-400">
                <i class="bi bi-x-lg text-xl"></i>
            </button>
        </div>

        <form method="post" asp-page-handler="Create">
            <div class="px-8 py-6 space-y-6 max-h-[60vh] overflow-y-auto custom-scrollbar">
                <!-- Item Name -->
                <div class="space-y-1.5">
                    <label class="block text-xs font-bold text-gray-700 uppercase tracking-widest ml-1 dark:text-gray-200">Name</label>
                    <input type="text" name="ItemName" id="newItemName" placeholder="Item name" required
                           class="w-full border border-gray-200 rounded-xl px-5 py-3 text-sm outline-none focus:ring-2 focus:ring-[#C41E24]/20 focus:border-[#C41E24] bg-white transition-all placeholder:text-gray-500 text-gray-800 shadow-sm font-medium dark:bg-slate-800 dark:text-white dark:placeholder:text-gray-400 dark:border-gray-700">
                </div>

                <!-- Category & Sub-Category -->
                <div class="grid grid-cols-2 gap-5">
                    <div class="space-y-1.5">
                        <label class="block text-xs font-bold text-gray-700 uppercase tracking-widest ml-1 dark:text-gray-200">Category</label>
                        <div class="relative">
                            <select name="CategoryId" id="newCategoryId" required onchange="filterSubCategories('new')" class="w-full border border-gray-200 rounded-xl px-5 py-3 text-sm outline-none focus:ring-2 focus:ring-[#C41E24]/20 focus:border-[#C41E24] bg-white transition-all cursor-pointer text-gray-700 shadow-sm font-medium appearance-none dark:bg-slate-800 dark:text-gray-200 dark:border-gray-700">
                                <option value="" disabled selected hidden>Category</option>
                                @if(Model.Categories != null) {
                                    foreach(var cat in Model.Categories) {
                                        <option value="@cat.CategoryId">@cat.CategoryName</option>
                                    }
                                }
                            </select>
                            <i class="bi bi-chevron-down absolute right-4 top-1/2 -translate-y-1/2 text-gray-500 pointer-events-none text-xs dark:text-gray-400"></i>
                        </div>
                    </div>
                    <div class="space-y-1.5">
                        <label class="block text-xs font-bold text-gray-700 uppercase tracking-widest ml-1 dark:text-gray-200">Sub-Category</label>
                        <div class="relative">
                            <select name="SubCategoryId" id="newSubCategoryId" class="w-full border border-gray-200 rounded-xl px-5 py-3 text-sm outline-none focus:ring-2 focus:ring-[#C41E24]/20 focus:border-[#C41E24] bg-white transition-all cursor-pointer text-gray-700 shadow-sm font-medium appearance-none dark:bg-slate-800 dark:text-gray-200 dark:border-gray-700">
                                <option value="" disabled selected hidden>Sub-Category</option>
                            </select>
                            <i class="bi bi-chevron-down absolute right-4 top-1/2 -translate-y-1/2 text-gray-500 pointer-events-none text-xs dark:text-gray-400"></i>
                        </div>
                    </div>
                </div>

                <!-- Packaging -->
                <div class="grid grid-cols-3 gap-5">
                    <div class="space-y-1.5">
                        <label class="block text-xs font-bold text-gray-700 uppercase tracking-widest ml-1 whitespace-nowrap dark:text-gray-200">Packaging Type</label>
                        <input type="text" name="PackagingType" id="newPackagingType" list="pkgTypeList" placeholder="Type" required
                               onfocus="handleDatalistFocus(this)" onblur="handleDatalistBlur(this)"
                               class="w-full border border-gray-200 rounded-xl px-5 py-3 text-sm outline-none focus:ring-2 focus:ring-[#C41E24]/20 focus:border-[#C41E24] bg-white transition-all placeholder:text-gray-500 text-gray-800 shadow-sm font-medium dark:bg-slate-800 dark:text-white dark:placeholder:text-gray-400 dark:border-gray-700">
                    </div>
                    <div class="space-y-1.5">
                        <label class="block text-xs font-bold text-gray-700 uppercase tracking-widest ml-1 whitespace-nowrap dark:text-gray-200">Packaging Unit</label>
                        <input type="text" name="PackagingUnit" id="newPackagingUnit" list="pkgUnitList" placeholder="Unit" required
                               onfocus="handleDatalistFocus(this)" onblur="handleDatalistBlur(this)"
                               class="w-full border border-gray-200 rounded-xl px-5 py-3 text-sm outline-none focus:ring-2 focus:ring-[#C41E24]/20 focus:border-[#C41E24] bg-white transition-all placeholder:text-gray-500 text-gray-800 shadow-sm font-medium dark:bg-slate-800 dark:text-white dark:placeholder:text-gray-400 dark:border-gray-700">
                    </div>
                    <div class="space-y-1.5">
                        <label class="block text-xs font-bold text-gray-700 uppercase tracking-widest ml-1 dark:text-gray-200">Pack Size</label>
                        <input type="text" name="PackSize" id="newPackSize" placeholder="00" required
                               class="w-full border border-gray-200 rounded-xl px-5 py-3 text-sm outline-none focus:ring-2 focus:ring-[#C41E24]/20 focus:border-[#C41E24] bg-white transition-all placeholder:text-gray-500 text-gray-800 shadow-sm font-medium dark:bg-slate-800 dark:text-white dark:placeholder:text-gray-400 dark:border-gray-700">
                    </div>
                </div>

                <!-- UOM & Supplier -->
                <div class="grid grid-cols-2 gap-5">
                    <div class="space-y-1.5">
                        <label class="block text-xs font-bold text-gray-700 uppercase tracking-widest ml-1 dark:text-gray-200">Unit of Measurement</label>
                        <input type="text" name="UOM" id="newUOM" list="uomList" placeholder="UOM" required
                               onfocus="handleDatalistFocus(this)" onblur="handleDatalistBlur(this)"
                               class="w-full border border-gray-200 rounded-xl px-5 py-3 text-sm outline-none focus:ring-2 focus:ring-[#C41E24]/20 focus:border-[#C41E24] bg-white transition-all placeholder:text-gray-500 text-gray-800 shadow-sm font-medium dark:bg-slate-800 dark:text-white dark:placeholder:text-gray-400 dark:border-gray-700">
                    </div>
                    <div class="space-y-1.5">
                        <label class="block text-xs font-bold text-gray-700 uppercase tracking-widest ml-1 dark:text-gray-200">Supplier</label>
                        <div class="relative">
                            <select name="VendorId" id="newVendorId" required class="w-full border border-gray-200 rounded-xl px-5 py-3 text-sm outline-none focus:ring-2 focus:ring-[#C41E24]/20 focus:border-[#C41E24] bg-white transition-all cursor-pointer text-gray-700 shadow-sm font-medium appearance-none dark:bg-slate-800 dark:text-gray-200 dark:border-gray-700">
                                <option value="" disabled selected hidden>Supplier</option>
                                @if(Model.Vendors != null) {
                                    foreach(var vendor in Model.Vendors) {
                                        <option value="@vendor.VendorId">@vendor.VendorName</option>
                                    }
                                }
                            </select>
                            <i class="bi bi-chevron-down absolute right-4 top-1/2 -translate-y-1/2 text-gray-500 pointer-events-none text-xs dark:text-gray-400"></i>
                        </div>
                    </div>
                </div>

                <!-- Stock & Pricing -->
                <div class="grid grid-cols-2 gap-5">
                    <div class="space-y-1.5">
                        <label class="block text-xs font-bold text-gray-700 uppercase tracking-widest ml-1 dark:text-gray-200">Add Stock</label>
                        <input type="number" name="Stock" id="newStock" step="any" placeholder="0.00" required onfocus="this.select()"
                               class="w-full border border-gray-200 rounded-xl px-5 py-3 text-sm outline-none focus:ring-2 focus:ring-[#C41E24]/20 focus:border-[#C41E24] bg-white transition-all placeholder:text-gray-500 text-gray-800 shadow-sm font-medium dark:bg-slate-800 dark:text-white dark:placeholder:text-gray-400 dark:border-gray-700">
                    </div>
                    <div class="space-y-1.5">
                        <label class="block text-xs font-bold text-gray-700 uppercase tracking-widest ml-1 dark:text-gray-200">Unit Price</label>
                        <div class="relative">
                            <span class="absolute left-4 top-1/2 -translate-y-1/2 text-gray-500 font-bold dark:text-gray-400 text-sm">₱</span>
                            <input type="number" step="0.01" name="CostPrice" id="newCostPrice" placeholder="0.00" onfocus="this.select()"
                                   class="w-full border border-gray-200 rounded-xl pl-9 pr-5 py-3 text-sm outline-none focus:ring-2 focus:ring-[#C41E24]/20 focus:border-[#C41E24] bg-white transition-all placeholder:text-gray-500 text-gray-800 shadow-sm font-medium dark:bg-slate-800 dark:text-white dark:placeholder:text-gray-400 dark:border-gray-700">
                        </div>
                    </div>
                </div>

                <!-- Selling Price -->
                <div id="newSellingPriceContainer" class="space-y-1.5 hidden">
                    <label class="block text-xs font-bold text-gray-700 uppercase tracking-widest ml-1 dark:text-gray-200">Selling Price</label>
                    <div class="relative">
                        <span class="absolute left-4 top-1/2 -translate-y-1/2 text-gray-500 font-bold dark:text-gray-400 text-sm">₱</span>
                        <input type="number" step="0.01" name="SellingPrice" id="newSellingPrice" placeholder="0.00" onfocus="this.select()"
                               class="w-full border border-gray-200 rounded-xl pl-9 pr-5 py-3 text-sm outline-none focus:ring-2 focus:ring-[#C41E24]/20 focus:border-[#C41E24] bg-white transition-all placeholder:text-gray-500 text-gray-800 shadow-sm font-medium dark:bg-slate-800 dark:text-white dark:placeholder:text-gray-400 dark:border-gray-700">
                    </div>
                </div>

                <!-- Selling Price Toggle -->
                <div class="flex items-center space-x-3 pt-2">
                    <input type="checkbox" id="newSellingPriceCheck" onchange="togglePriceField('new')" 
                           class="w-4 h-4 rounded border-gray-300 text-[#C41E24] focus:ring-0 cursor-pointer dark:border-gray-600">
                    <label for="newSellingPriceCheck" class="text-xs font-bold text-gray-700 uppercase tracking-widest cursor-pointer ml-1 dark:text-gray-200">Selling Price</label>
                </div>
            </div>

            <!-- Buttons -->
            <div class="p-8 bg-gray-50 flex justify-end space-x-4 border-t border-gray-100 dark:bg-slate-700/50 dark:border-gray-700">
                <button type="button" onclick="closeModal('newItemModal')" 
                        class="px-8 py-3 rounded-xl text-xs font-bold text-gray-500 uppercase tracking-widest hover:bg-gray-100 transition-all dark:hover:bg-slate-700 dark:text-gray-400">
                    Cancel
                </button>
                <button type="submit" 
                        class="px-12 py-3 bg-[#C41E24] text-white rounded-xl text-xs font-bold uppercase tracking-widest hover:bg-[#a51a1f] shadow-lg hover:shadow-red-200 transition-all transform active:scale-95">
                    Submit
                </button>
            </div>
        </form>
    </div>
</div>

<!-- Edit Item Modal -->
<div id="editItemModal" class="fixed inset-0 bg-black/40 hidden flex items-center justify-center z-[100] backdrop-blur-[2px] transition-all duration-300 font-sans">
    <div class="bg-white rounded-2xl shadow-2xl w-full max-w-lg mx-4 overflow-hidden border border-gray-100 transform transition-all opacity-0 scale-95 dark:bg-slate-800 dark:border-gray-700">
        <div class="px-8 py-6 border-b border-gray-50 flex justify-between items-center bg-white dark:bg-slate-800 dark:border-gray-700">
            <h3 class="text-base font-bold text-gray-900 dark:text-white">Edit Item</h3>
            <button onclick="closeModal('editItemModal')" class="text-gray-500 hover:text-gray-700 transition-colors dark:text-gray-400">
                <i class="bi bi-x-lg text-xl"></i>
            </button>
        </div>        <form method="post" asp-page-handler="Update">
            <input type="hidden" name="ComId" id="editComId">
            
            <div class="px-8 py-6 space-y-6 max-h-[60vh] overflow-y-auto custom-scrollbar">
                <!-- Name -->
                <div class="space-y-1.5">
                    <label class="block text-xs font-bold text-gray-700 uppercase tracking-widest ml-1 dark:text-gray-200">Name</label>
                    <input type="text" name="ItemName" id="editItemName" placeholder="Item name" required
                           class="w-full border border-gray-200 rounded-xl px-5 py-3 text-sm outline-none focus:ring-2 focus:ring-[#C41E24]/20 focus:border-[#C41E24] bg-white transition-all placeholder:text-gray-500 text-gray-800 shadow-sm font-medium dark:bg-slate-800 dark:text-white dark:placeholder:text-gray-400 dark:border-gray-700">
                </div>

                <!-- Category & Sub-Category -->
                <div class="grid grid-cols-2 gap-5">
                    <div class="space-y-1.5">
                        <label class="block text-xs font-bold text-gray-700 uppercase tracking-widest ml-1 dark:text-gray-200">Category</label>
                        <div class="relative">
                            <select name="CategoryId" id="editCategoryId" required onchange="filterSubCategories('edit')" class="w-full border border-gray-200 rounded-xl px-5 py-3 text-sm outline-none focus:ring-2 focus:ring-[#C41E24]/20 focus:border-[#C41E24] bg-white transition-all cursor-pointer text-gray-700 shadow-sm font-medium appearance-none dark:bg-slate-800 dark:text-gray-200 dark:border-gray-700">
                                <option value="" disabled selected hidden>Category</option>
                                @if(Model.Categories != null) {
                                    foreach(var cat in Model.Categories) {
                                        <option value="@cat.CategoryId">@cat.CategoryName</option>
                                    }
                                }
                            </select>
                            <i class="bi bi-chevron-down absolute right-4 top-1/2 -translate-y-1/2 text-gray-500 pointer-events-none text-xs dark:text-gray-400"></i>
                        </div>
                    </div>
                    <div class="space-y-1.5">
                        <label class="block text-xs font-bold text-gray-700 uppercase tracking-widest ml-1 dark:text-gray-200">Sub-Category</label>
                        <div class="relative">
                            <select name="SubCategoryId" id="editSubCategoryId" class="w-full border border-gray-200 rounded-xl px-5 py-3 text-sm outline-none focus:ring-2 focus:ring-[#C41E24]/20 focus:border-[#C41E24] bg-white transition-all cursor-pointer text-gray-700 shadow-sm font-medium appearance-none dark:bg-slate-800 dark:text-gray-200 dark:border-gray-700">
                                <option value="" disabled selected hidden>Sub-Category</option>
                            </select>
                            <i class="bi bi-chevron-down absolute right-4 top-1/2 -translate-y-1/2 text-gray-500 pointer-events-none text-xs dark:text-gray-400"></i>
                        </div>
                    </div>
                </div>

                <!-- Packaging -->
                <div class="grid grid-cols-3 gap-5">
                    <div class="space-y-1.5">
                        <label class="block text-xs font-bold text-gray-700 uppercase tracking-widest ml-1 whitespace-nowrap dark:text-gray-200">Packaging Type</label>
                        <input type="text" name="PackagingType" id="editPackagingType" list="pkgTypeList" placeholder="Type" required
                               onfocus="handleDatalistFocus(this)" onblur="handleDatalistBlur(this)"
                               class="w-full border border-gray-200 rounded-xl px-5 py-3 text-sm outline-none focus:ring-2 focus:ring-[#C41E24]/20 focus:border-[#C41E24] bg-white transition-all placeholder:text-gray-500 text-gray-800 shadow-sm font-medium dark:bg-slate-800 dark:text-white dark:placeholder:text-gray-400 dark:border-gray-700">
                    </div>
                    <div class="space-y-1.5">
                        <label class="block text-xs font-bold text-gray-700 uppercase tracking-widest ml-1 whitespace-nowrap dark:text-gray-200">Packaging Unit</label>
                        <input type="text" name="PackagingUnit" id="editPackagingUnit" list="pkgUnitList" placeholder="Unit" required
                               onfocus="handleDatalistFocus(this)" onblur="handleDatalistBlur(this)"
                               class="w-full border border-gray-200 rounded-xl px-5 py-3 text-sm outline-none focus:ring-2 focus:ring-[#C41E24]/20 focus:border-[#C41E24] bg-white transition-all placeholder:text-gray-500 text-gray-800 shadow-sm font-medium dark:bg-slate-800 dark:text-white dark:placeholder:text-gray-400 dark:border-gray-700">
                    </div>
                    <div class="space-y-1.5">
                        <label class="block text-xs font-bold text-gray-700 uppercase tracking-widest ml-1 dark:text-gray-200">Pack Size</label>
                        <input type="text" name="PackSize" id="editPackSize" placeholder="00" required
                               class="w-full border border-gray-200 rounded-xl px-5 py-3 text-sm outline-none focus:ring-2 focus:ring-[#C41E24]/20 focus:border-[#C41E24] bg-white transition-all placeholder:text-gray-500 text-gray-800 shadow-sm font-medium dark:bg-slate-800 dark:text-white dark:placeholder:text-gray-400 dark:border-gray-700">
                    </div>
                </div>

                <!-- UOM & Supplier -->
                <div class="grid grid-cols-2 gap-5">
                    <div class="space-y-1.5">
                        <label class="block text-xs font-bold text-gray-700 uppercase tracking-widest ml-1 dark:text-gray-200">Unit of Measurement</label>
                        <input type="text" name="UOM" id="editUOM" list="uomList" placeholder="UOM" required
                               onfocus="handleDatalistFocus(this)" onblur="handleDatalistBlur(this)"
                               class="w-full border border-gray-200 rounded-xl px-5 py-3 text-sm outline-none focus:ring-2 focus:ring-[#C41E24]/20 focus:border-[#C41E24] bg-white transition-all placeholder:text-gray-500 text-gray-800 shadow-sm font-medium dark:bg-slate-800 dark:text-white dark:placeholder:text-gray-400 dark:border-gray-700">
                    </div>
                    <div class="space-y-1.5">
                        <label class="block text-xs font-bold text-gray-700 uppercase tracking-widest ml-1 dark:text-gray-200">Supplier</label>
                        <div class="relative">
                            <select name="VendorId" id="editVendorId" required class="w-full border border-gray-200 rounded-xl px-5 py-3 text-sm outline-none focus:ring-2 focus:ring-[#C41E24]/20 focus:border-[#C41E24] bg-white transition-all cursor-pointer text-gray-700 shadow-sm font-medium appearance-none dark:bg-slate-800 dark:text-gray-200 dark:border-gray-700">
                                <option value="" disabled selected hidden>Supplier</option>
                                @if(Model.Vendors != null) {
                                    foreach(var vendor in Model.Vendors) {
                                        <option value="@vendor.VendorId">@vendor.VendorName</option>
                                    }
                                }
                            </select>
                            <i class="bi bi-chevron-down absolute right-4 top-1/2 -translate-y-1/2 text-gray-500 pointer-events-none text-xs dark:text-gray-400"></i>
                        </div>
                    </div>
                </div>

                <!-- Stock & Pricing -->
                <div class="grid grid-cols-2 gap-5">
                    <div class="space-y-1.5">
                        <label class="block text-xs font-bold text-gray-700 uppercase tracking-widest ml-1 dark:text-gray-200">In Stock</label>
                        <input type="number" name="Stock" id="editStock" step="any" placeholder="0.00" required onfocus="this.select()"
                               class="w-full border border-gray-200 rounded-xl px-5 py-3 text-sm outline-none focus:ring-2 focus:ring-[#C41E24]/20 focus:border-[#C41E24] bg-white transition-all placeholder:text-gray-500 text-gray-800 shadow-sm font-medium dark:bg-slate-800 dark:text-white dark:placeholder:text-gray-400 dark:border-gray-700">
                    </div>
                    <div class="space-y-1.5">
                        <label class="block text-xs font-bold text-gray-700 uppercase tracking-widest ml-1 dark:text-gray-200">Unit Price</label>
                        <div class="relative">
                            <span class="absolute left-4 top-1/2 -translate-y-1/2 text-gray-500 font-bold dark:text-gray-400 text-sm">₱</span>
                            <input type="number" step="0.01" name="CostPrice" id="editCostPrice" placeholder="0.00" onfocus="this.select()"
                                   class="w-full border border-gray-200 rounded-xl pl-9 pr-5 py-3 text-sm outline-none focus:ring-2 focus:ring-[#C41E24]/20 focus:border-[#C41E24] bg-white transition-all placeholder:text-gray-500 text-gray-800 shadow-sm font-medium dark:bg-slate-800 dark:text-white dark:placeholder:text-gray-400 dark:border-gray-700">
                        </div>
                    </div>
                </div>

                <!-- Selling Price -->
                <div id="editSellingPriceContainer" class="space-y-1.5 hidden">
                    <label class="block text-xs font-bold text-gray-700 uppercase tracking-widest ml-1 dark:text-gray-200">Selling Price</label>
                    <div class="relative">
                        <span class="absolute left-4 top-1/2 -translate-y-1/2 text-gray-500 font-bold dark:text-gray-400 text-sm">₱</span>
                        <input type="number" step="0.01" name="SellingPrice" id="editSellingPrice" placeholder="0.00" onfocus="this.select()"
                               class="w-full border border-gray-200 rounded-xl pl-9 pr-5 py-3 text-sm outline-none focus:ring-2 focus:ring-[#C41E24]/20 focus:border-[#C41E24] bg-white transition-all placeholder:text-gray-500 text-gray-800 shadow-sm font-medium dark:bg-slate-800 dark:text-white dark:placeholder:text-gray-400 dark:border-gray-700">
                    </div>
                </div>

                <!-- Selling Price Toggle -->
                <div class="flex items-center space-x-3 pt-2">
                    <input type="checkbox" id="editSellingPriceCheck" onchange="togglePriceField('edit')" 
                           class="w-4 h-4 rounded border-gray-300 text-[#C41E24] focus:ring-0 cursor-pointer dark:border-gray-600">
                    <label for="editSellingPriceCheck" class="text-xs font-bold text-gray-700 uppercase tracking-widest cursor-pointer ml-1 dark:text-gray-200">Selling Price</label>
                </div>
            </div>

            <!-- Buttons -->
            <div class="p-8 bg-gray-50 flex justify-end space-x-4 border-t border-gray-100 dark:bg-slate-700/50 dark:border-gray-700">
                <button type="button" onclick="closeModal('editItemModal')" 
                        class="px-8 py-3 rounded-xl text-xs font-bold text-gray-500 uppercase tracking-widest hover:bg-gray-100 transition-all dark:hover:bg-slate-700 dark:text-gray-400">
                    Cancel
                </button>
                <button type="submit" 
                        class="px-12 py-3 bg-[#C41E24] text-white rounded-xl text-xs font-bold uppercase tracking-widest hover:bg-[#a51a1f] shadow-lg hover:shadow-red-200 transition-all transform active:scale-95">
                    Save Changes
                </button>
            </div>
        </form>
    </div>
</div>

<div id="rejectItemModal" class="fixed inset-0 bg-black/40 hidden flex items-center justify-center z-[100] backdrop-blur-[2px] transition-all duration-300">
    <div class="bg-white rounded-2xl shadow-2xl w-full max-w-md mx-4 overflow-hidden border border-gray-100 transform transition-all opacity-0 scale-95 dark:bg-slate-800 dark:border-gray-700">
        <div class="px-8 py-6 border-b border-gray-50 flex justify-between items-center bg-white dark:bg-slate-800 dark:border-gray-700">
            <h3 class="text-base font-bold text-gray-900 dark:text-white">Reject Item</h3>
            <button onclick="closeModal('rejectItemModal')" class="text-gray-500 hover:text-gray-700 transition-colors dark:text-gray-400">
                <i class="bi bi-x-lg text-xl"></i>
            </button>
        </div>

        <form method="post" asp-page-handler="Reject" class="p-8 space-y-5">
            <div class="space-y-1.5">
                <label class="block text-xs font-bold text-gray-700 uppercase tracking-widest ml-1 dark:text-gray-200">Item Name</label>
                <input type="hidden" name="RejectId" id="rejectComId">
                <input type="text" name="RejectName" id="rejectItemName" readonly 
                       class="w-full border border-gray-200 rounded-xl px-5 py-3 text-sm outline-none bg-gray-50 text-gray-800 shadow-sm font-medium dark:bg-slate-700/50 dark:text-white dark:border-gray-700 cursor-default">
            </div>
            <div class="grid grid-cols-2 gap-5">
                <div class="space-y-1.5">
                    <label class="block text-xs font-bold text-gray-700 uppercase tracking-widest ml-1 dark:text-gray-200">Quantity (Max: <span id="maxStockLabel">0</span>)</label>
                    <input type="number" name="RejectQty" id="rejectQty" step="any" min="0.01" placeholder="0.00" required
                           class="w-full border border-gray-200 rounded-xl px-5 py-3 text-sm outline-none focus:ring-2 focus:ring-[#C41E24]/20 focus:border-[#C41E24] bg-white transition-all placeholder:text-gray-500 text-gray-800 shadow-sm font-medium dark:bg-slate-800 dark:text-white dark:placeholder:text-gray-400 dark:border-gray-700">
                </div>
                <div class="space-y-1.5">
                    <label class="block text-xs font-bold text-gray-700 uppercase tracking-widest ml-1 dark:text-gray-200">Unit (UOM)</label>
                    <input type="text" name="RejectUOM" id="rejectUOM" readonly
                           class="w-full border border-gray-200 rounded-xl px-5 py-3 text-sm outline-none bg-gray-50 text-gray-800 shadow-sm font-medium dark:bg-slate-700/50 dark:text-white dark:border-gray-700 cursor-default">
                </div>
            </div>
            <div class="space-y-1.5">
                <label class="block text-xs font-bold text-gray-700 uppercase tracking-widest ml-1 dark:text-gray-200">Reason</label>
                <textarea name="RejectReason" rows="3" placeholder="Reason for rejection..." 
                          class="w-full border border-gray-200 rounded-xl px-5 py-3 text-sm outline-none focus:ring-2 focus:ring-[#C41E24]/20 focus:border-[#C41E24] bg-white transition-all resize-none placeholder:text-gray-500 text-gray-800 shadow-sm font-medium dark:bg-slate-800 dark:text-white dark:placeholder:text-gray-400 dark:border-gray-700"></textarea>
            </div>
            <div class="flex justify-end space-x-4 pt-8 border-t border-gray-50 dark:border-gray-700">
                <button type="button" onclick="closeModal('rejectItemModal')" 
                        class="px-8 py-3 rounded-xl text-xs font-bold text-gray-500 uppercase tracking-widest hover:bg-gray-100 transition-all dark:hover:bg-slate-700 dark:text-gray-400">
                    Cancel
                </button>
                <button type="submit" 
                        class="px-12 py-3 bg-[#C41E24] text-white rounded-xl text-xs font-bold uppercase tracking-widest hover:bg-[#a51a1f] shadow-lg hover:shadow-red-200 transition-all transform active:scale-95">
                    Submit Reject
                </button>
            </div>
        </form>
    </div>
</div>

</div>

<!-- Data Lists for Client Standards -->
<datalist id="pkgTypeList">
    <option value="Case"></option>
    <option value="Pack"></option>
    <option value="Bottle"></option>
    <option value="Gallon"></option>
    <option value="Sack"></option>
    <option value="Box"></option>
    <option value="Bundle"></option>
    <option value="Can"></option>
    <option value="Tub"></option>
    <option value="Tubs"></option>
    <option value="Jar"></option>
    <option value="Tray"></option>
    <option value="Ctn"></option>
</datalist>

<datalist id="pkgUnitList">
    <option value="Cans"></option>
    <option value="Grams (g)"></option>
    <option value="Milliliter (mL)"></option>
    <option value="Kilogram (kg)"></option>
    <option value="Pieces (pcs)"></option>
    <option value="Liter (L)"></option>
    <option value="Pull"></option>
    <option value="Sticks"></option>
    <option value="Bottles"></option>
    <option value="Per pc"></option>
</datalist>

<datalist id="uomList">
    <option value="Grams"></option>
    <option value="Dips"></option>
    <option value="mL"></option>
    <option value="Sticks"></option>
    <option value="pcs"></option>
    <option value="pack"></option>
    <option value="bottle"></option>
    <option value="cans"></option>
</datalist>

@section Scripts {
    <script>
        const actionsMenu = document.getElementById('actionsMenu');
        const subCategoriesData = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.SubCategories.Select(s => new { s.SubCategoryId, s.SubCategoryName, s.CategoryId })));

        function toggleActions(e) {
            e.stopPropagation();
            actionsMenu.classList.toggle('hidden');
        }

        function openModal(modalId) {
            const modal = document.getElementById(modalId);
            const content = modal.querySelector('div');
            
            modal.classList.remove('hidden');
            document.body.style.overflow = 'hidden';
            
            setTimeout(() => {
                content.classList.remove('opacity-0', 'scale-95');
                content.classList.add('opacity-100', 'scale-100');
            }, 10);
        }

        function closeModal(modalId) {
            const modal = document.getElementById(modalId);
            const content = modal.querySelector('div');
            
            content.classList.add('opacity-0', 'scale-95');
            content.classList.remove('opacity-100', 'scale-100');
            
            setTimeout(() => {
                modal.classList.add('hidden');
                document.body.style.overflow = 'auto';
            }, 300);
        }

        function openNewItemModal() {
            // Reset subcategory dropdown
            document.getElementById('newSubCategoryId').innerHTML = '<option value="" disabled selected hidden>Sub-Category</option>';
            openModal('newItemModal');
        }

        function filterSubCategories(prefix, selectedSubId = null) {
            const categoryId = document.getElementById(prefix + 'CategoryId').value;
            const subCategorySelect = document.getElementById(prefix + 'SubCategoryId');
            
            // Clear previous options
            subCategorySelect.innerHTML = '<option value="" disabled selected hidden>Sub-Category</option>';
            
            // Filter subcategories based on selected category id
            const filtered = subCategoriesData.filter(sc => sc.CategoryId == categoryId);
            
            filtered.forEach(sc => {
                const option = document.createElement('option');
                option.value = sc.SubCategoryId;
                option.textContent = sc.SubCategoryName;
                if (selectedSubId && sc.SubCategoryId == selectedSubId) {
                    option.selected = true;
                }
                subCategorySelect.appendChild(option);
            });
        }

        function togglePriceField(prefix = 'new') {
            const checkbox = document.getElementById(prefix + 'SellingPriceCheck');
            const container = document.getElementById(prefix + 'SellingPriceContainer');
            if (checkbox.checked) {
                container.classList.remove('hidden');
            } else {
                container.classList.add('hidden');
            }
        }

        function openEditItemModal(item) {
            document.getElementById('editComId').value = item.comId;
            document.getElementById('editItemName').value = item.itemName;
            document.getElementById('editCategoryId').value = item.categoryId;
            document.getElementById('editVendorId').value = item.vendorId;
            document.getElementById('editUOM').value = item.uom;
            document.getElementById('editCostPrice').value = item.costPrice ? parseFloat(item.costPrice).toFixed(2) : '';
            document.getElementById('editSellingPrice').value = (item.sellingPrice && item.sellingPrice > 0) ? parseFloat(item.sellingPrice).toFixed(2) : '';
            document.getElementById('editStock').value = item.stock;
            
            // Handle Selling Price Toggle
            const sellingPriceCheck = document.getElementById('editSellingPriceCheck');
            sellingPriceCheck.checked = item.sellingPrice > 0;
            togglePriceField('edit');

            // Filter SubCategories and select the current one
            filterSubCategories('edit', item.subCategoryId);

            // Parse packaging from yield (Format: Type/SizeUnit)
            if (item.yield && item.yield.includes('/')) {
                const parts = item.yield.split('/');
                document.getElementById('editPackagingType').value = parts[0];
                
                const remainder = parts[1];
                const sizeMatch = remainder.match(/^[\d.]+/);
                if (sizeMatch) {
                    const size = sizeMatch[0];
                    const unit = remainder.substring(size.length);
                    document.getElementById('editPackSize').value = size;
                    document.getElementById('editPackagingUnit').value = unit;
                }
            }

            openModal('editItemModal');
        }

        function openRejectModal() {
            const actionsMenu = document.getElementById('actionsMenu');
            if (actionsMenu) actionsMenu.classList.add('hidden');

            const checked = document.querySelectorAll('.row-checkbox:checked');
            if (checked.length === 0) {
                alert('Please select an item to reject.');
                return;
            }
            if (checked.length > 1) {
                alert('Please select only one item at a time for rejection.');
                return;
            }

            const item = checked[0];
            const id = item.dataset.id;
            const name = item.dataset.itemName;
            const stock = parseFloat(item.dataset.stock) || 0;
            const uom = item.dataset.uom;

            document.getElementById('rejectComId').value = id;
            document.getElementById('rejectItemName').value = name;
            document.getElementById('rejectUOM').value = uom;
            document.getElementById('maxStockLabel').innerText = stock;
            
            const qtyInput = document.getElementById('rejectQty');
            qtyInput.max = stock;
            qtyInput.value = '';
            qtyInput.placeholder = `0.00 (Max: ${stock})`;

            openModal('rejectItemModal');
        }

        // Add validation to reject quantity
        document.getElementById('rejectQty')?.addEventListener('input', function() {
            const max = parseFloat(this.max);
            const val = parseFloat(this.value);
            const submitBtn = this.closest('form').querySelector('button[type="submit"]');
            
            if (val > max) {
                this.setCustomValidity(`Quantity cannot exceed available stock (${max})`);
                this.classList.add('border-red-500', 'focus:border-red-500', 'focus:ring-red-500/20');
            } else {
                this.setCustomValidity('');
                this.classList.remove('border-red-500', 'focus:border-red-500', 'focus:ring-red-500/20');
            }
        });

        function toggleSelectAll(source) {
            const checkboxes = document.querySelectorAll('.row-checkbox');
            checkboxes.forEach(cb => cb.checked = source.checked);
        }

        function updateSelectAll() {
            const all = document.querySelectorAll('.row-checkbox');
            const checked = document.querySelectorAll('.row-checkbox:checked');
            const selectAll = document.getElementById('selectAll');
            selectAll.checked = all.length > 0 && all.length === checked.length;
            selectAll.indeterminate = checked.length > 0 && checked.length < all.length;
        }

        window.onclick = function(event) {
            if (!event.target.closest('.relative')) {
                if(actionsMenu) actionsMenu.classList.add('hidden');
            }
            if (event.target.classList.contains('fixed')) {
                closeModal(event.target.id);
            }
        }

        // Datalist Usability Helpers
        function handleDatalistFocus(input) {
            if (input.value) {
                input.dataset.originalValue = input.value;
                input.dataset.tempPlaceholder = input.placeholder;
                input.placeholder = input.value; // Show value as placeholder while focused
                input.value = '';
            }
        }

        function handleDatalistBlur(input) {
            setTimeout(() => {
                if (input.value === '' && input.dataset.originalValue) {
                    input.value = input.dataset.originalValue;
                }
                if (input.dataset.tempPlaceholder !== undefined) {
                    input.placeholder = input.dataset.tempPlaceholder;
                }
            }, 200);
        }
    </script>
}
