@page
@model LeKatsuMNL.Pages.Dashboard.ItemsModel
@{
    ViewData["Title"] = "Inventory Items";
}

@section TitleActions {
    <button onclick="openNewItemModal()" class="bg-[#C41E24] text-white px-5 py-2 rounded-lg text-sm font-bold hover:bg-red-700 transition-colors shadow-sm whitespace-nowrap">
        + New Item
    </button>
}

<div class="bg-white rounded-xl border border-gray-200 shadow-sm overflow-hidden">
    <!-- Tabs -->
    <div class="flex border-b border-gray-200">
        <button class="px-10 py-4 text-sm font-bold text-[#C41E24] border-b-2 border-[#C41E24] transition-all">Recipe</button>
        <a href="/Dashboard/SKU" class="px-10 py-4 text-sm font-bold text-gray-400 hover:text-gray-600 transition-all">SKU</a>
    </div>

    <!-- Toolbar -->
    <div class="p-5 flex items-center space-x-4 bg-white border-b border-gray-100">
        <div class="relative inline-block text-left">
            <button onclick="toggleActions(event)" class="flex items-center space-x-2 border border-gray-300 rounded-lg px-4 py-2 text-sm text-gray-600 bg-white hover:bg-gray-50 outline-none transition-all">
                <span>Actions</span>
                <i class="bi bi-chevron-down text-xs"></i>
            </button>
            <div id="actionsMenu" class="hidden absolute left-0 mt-2 w-40 bg-white rounded-xl shadow-xl border border-gray-100 z-[70] overflow-hidden transform origin-top-left transition-all">
                <button onclick="handleArchive()" class="w-full text-left px-5 py-3 text-xs font-bold text-gray-700 uppercase tracking-widest hover:bg-gray-50 border-b border-gray-50 transition-colors">
                    Archive
                </button>
                <button onclick="openRejectModal()" class="w-full text-left px-5 py-3 text-xs font-bold text-red-500 uppercase tracking-widest hover:bg-red-50 hover:text-[#C41E24] transition-colors">
                    Reject
                </button>
            </div>
        </div>

        <div class="relative flex-1 max-w-md">
            <span class="absolute inset-y-0 left-4 flex items-center text-gray-400">
                <i class="bi bi-search text-sm"></i>
            </span>
            <input type="text" class="w-full border border-gray-300 rounded-lg pl-11 pr-4 py-2 text-sm focus:ring-1 focus:ring-[#C41E24] outline-none placeholder:text-gray-400" placeholder="Search...">
        </div>

        <div class="flex items-center space-x-3">
            <select class="border border-gray-300 rounded-lg px-4 py-2 text-sm text-gray-600 bg-white outline-none cursor-pointer">
                <option>Category</option>
            </select>
            <select class="border border-gray-300 rounded-lg px-4 py-2 text-sm text-gray-600 bg-white outline-none cursor-pointer">
                <option>Status</option>
            </select>
            <button class="flex items-center space-x-3 border border-gray-300 rounded-lg px-4 py-2 text-sm text-gray-600 hover:bg-gray-50 transition-colors">
                <i class="bi bi-arrow-clockwise text-base"></i>
                <span>Refresh</span>
            </button>
        </div>
    </div>

    <!-- Table -->
    <div class="overflow-x-auto">
        <table class="w-full text-left text-xs whitespace-nowrap">
            <thead class="bg-gray-50 text-gray-500 uppercase tracking-wider font-bold border-b border-gray-100">
                <tr>
                    <th class="px-8 py-4 w-12"><input type="checkbox" class="w-4 h-4 rounded border-gray-300 text-[#C41E24] focus:ring-[#C41E24]"></th>
                    <th class="px-6 py-4">Image</th>
                    <th class="px-6 py-4">Item Name</th>
                    <th class="px-6 py-4">Category</th>
                    <th class="px-6 py-4">Supplier</th>
                    <th class="px-6 py-4">Yield</th>
                    <th class="px-6 py-4">In Stock</th>
                    <th class="px-6 py-4">Unit Price</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-gray-50">
                @if (Model.Items != null && Model.Items.Any())
                {
                    foreach (var item in Model.Items)
                    {
                        <tr class="hover:bg-gray-50/50 transition-colors group">
                            <td class="px-8 py-5"><input type="checkbox" class="w-4 h-4 rounded border-gray-300"></td>
                            <td class="px-6 py-5">
                                <div class="w-12 h-12 bg-gray-200 rounded-xl flex items-center justify-center text-gray-400 group-hover:bg-gray-300 transition-colors">
                                    <i class="bi bi-image text-2xl"></i>
                                </div>
                            </td>
                            <td class="px-6 py-5 font-bold text-gray-800 text-sm">@item.ItemName</td>
                            <td class="px-6 py-5 text-gray-600">@(item.Category?.CategoryName ?? "-")</td>
                            <td class="px-6 py-5 text-gray-600">@(item.Vendor?.VendorName ?? "-")</td>
                            <td class="px-6 py-5 text-gray-600 font-semibold">@item.Yield</td>
                            <td class="px-6 py-5">
                                <span class="bg-blue-50 text-blue-600 px-4 py-1.5 rounded-lg font-bold border border-blue-100">@item.Stock @item.Uom</span>
                            </td>
                            <td class="px-6 py-5 font-bold text-gray-900 text-sm">₱ @String.Format("{0:0.00}", item.Price)</td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="8" class="px-6 py-8 text-center text-gray-500 font-semibold italic">No items found. Create a new item to get started.</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <!-- Pagination -->
    <div class="bg-white p-5 flex justify-between items-center text-xs text-gray-500 font-bold border-t border-gray-100 uppercase tracking-widest">
        <div>Showing 1 - 5 of 10</div>
        <div class="flex items-center space-x-6">
            <div class="flex items-center space-x-3">
                <span>Records per page</span>
                <div class="border border-gray-200 rounded-lg px-3 py-1 bg-gray-50 text-gray-700 flex items-center">
                    <span>10</span>
                </div>
            </div>
            <div class="flex items-center space-x-2">
                <button class="w-8 h-8 flex items-center justify-center border border-gray-200 rounded-lg text-gray-400 bg-gray-50 hover:bg-gray-100 transition-colors">&lt;</button>
                <button class="w-8 h-8 flex items-center justify-center border border-gray-200 rounded-lg bg-gray-600 text-white shadow-md">1</button>
                <button class="w-8 h-8 flex items-center justify-center border border-gray-200 rounded-lg text-gray-400 bg-gray-50 hover:bg-gray-100 transition-colors">&gt;</button>
            </div>
        </div>
    </div>
</div>

<!-- Create New Item Modal -->
<div id="newItemModal" class="fixed inset-0 bg-black/40 hidden flex items-center justify-center z-[100] backdrop-blur-[2px] transition-all duration-300 font-sans">
    <div class="bg-white rounded-2xl shadow-2xl w-full max-w-lg mx-4 overflow-hidden border border-gray-100 transform transition-all opacity-0 scale-95">
        <div class="px-8 py-6 border-b border-gray-50 flex justify-between items-center bg-white">
            <h3 class="text-base font-bold text-gray-900">Create New Item</h3>
            <button onclick="closeModal('newItemModal')" class="text-gray-500 hover:text-gray-700 transition-colors">
                <i class="bi bi-x-lg text-xl"></i>
            </button>
        </div>

        <form method="post" asp-page-handler="Create" class="p-8 space-y-5">
            <!-- Item Name -->
            <div class="space-y-1.5">
                <label class="block text-xs font-bold text-gray-700 uppercase tracking-widest ml-1">Item Name</label>
                <input type="text" asp-for="NewItem.ItemName" placeholder="Item name" required
                       class="w-full border border-gray-200 rounded-xl px-5 py-3 text-sm outline-none focus:ring-2 focus:ring-[#C41E24]/20 focus:border-[#C41E24] bg-white transition-all placeholder:text-gray-500 text-gray-800 shadow-sm font-medium">
            </div>

            <!-- Category & Supplier -->
            <div class="grid grid-cols-2 gap-5">
                <div class="space-y-1.5">
                    <label class="block text-xs font-bold text-gray-700 uppercase tracking-widest ml-1">Category</label>
                    <div class="relative">
                        <select asp-for="NewItem.CategoryId" required class="w-full border border-gray-200 rounded-xl px-5 py-3 text-sm outline-none focus:ring-2 focus:ring-[#C41E24]/20 focus:border-[#C41E24] bg-white transition-all cursor-pointer text-gray-700 shadow-sm font-medium appearance-none">
                            <option value="" disabled selected hidden>Select Category</option>
                            @if(Model.Categories != null) {
                                foreach(var cat in Model.Categories) {
                                    <option value="@cat.CategoryId">@cat.CategoryName</option>
                                }
                            }
                        </select>
                        <i class="bi bi-chevron-down absolute right-4 top-1/2 -translate-y-1/2 text-gray-500 pointer-events-none text-xs"></i>
                    </div>
                </div>
                <div class="space-y-1.5">
                    <label class="block text-xs font-bold text-gray-700 uppercase tracking-widest ml-1">Supplier</label>
                    <div class="relative">
                        <select asp-for="NewItem.VendorId" required class="w-full border border-gray-200 rounded-xl px-5 py-3 text-sm outline-none focus:ring-2 focus:ring-[#C41E24]/20 focus:border-[#C41E24] bg-white transition-all cursor-pointer text-gray-700 shadow-sm font-medium appearance-none">
                            <option value="" disabled selected hidden>Select Supplier</option>
                            @if(Model.Vendors != null) {
                                foreach(var vendor in Model.Vendors) {
                                    <option value="@vendor.VendorId">@vendor.VendorName</option>
                                }
                            }
                        </select>
                        <i class="bi bi-chevron-down absolute right-4 top-1/2 -translate-y-1/2 text-gray-500 pointer-events-none text-xs"></i>
                    </div>
                </div>
            </div>

            <!-- Packaging Type, Unit, Pack Size -->
            <div class="grid grid-cols-3 gap-5">
                <div class="space-y-1.5">
                    <label class="block text-xs font-bold text-gray-700 uppercase tracking-widest ml-1 whitespace-nowrap">Packaging Type</label>
                    <div class="relative">
                        <select asp-for="NewItem.PackagingType" required class="w-full border border-gray-200 rounded-xl px-5 py-3 text-sm outline-none focus:ring-2 focus:ring-[#C41E24]/20 focus:border-[#C41E24] bg-white transition-all cursor-pointer text-gray-700 shadow-sm font-medium appearance-none">
                            <option value="" disabled selected hidden>Type</option>
                            <option value="Plastic">Plastic</option>
                            <option value="Box">Box</option>
                            <option value="Pack">Pack</option>
                        </select>
                        <i class="bi bi-chevron-down absolute right-4 top-1/2 -translate-y-1/2 text-gray-500 pointer-events-none text-xs"></i>
                    </div>
                </div>
                <div class="space-y-1.5">
                    <label class="block text-xs font-bold text-gray-700 uppercase tracking-widest ml-1 whitespace-nowrap">Packaging Unit</label>
                    <div class="relative">
                        <select asp-for="NewItem.PackagingUnit" required class="w-full border border-gray-200 rounded-xl px-5 py-3 text-sm outline-none focus:ring-2 focus:ring-[#C41E24]/20 focus:border-[#C41E24] bg-white transition-all cursor-pointer text-gray-700 shadow-sm font-medium appearance-none">
                            <option value="" disabled selected hidden>Unit</option>
                            <option value="bundle">bundle</option>
                            <option value="roll">roll</option>
                            <option value="kg">kg</option>
                            <option value="g">g</option>
                            <option value="pcs">pcs</option>
                        </select>
                        <i class="bi bi-chevron-down absolute right-4 top-1/2 -translate-y-1/2 text-gray-500 pointer-events-none text-xs"></i>
                    </div>
                </div>
                <div class="space-y-1.5">
                    <label class="block text-xs font-bold text-gray-700 uppercase tracking-widest ml-1">Pack Size</label>
                    <input type="text" asp-for="NewItem.PackSize" placeholder="0" required
                           class="w-full border border-gray-200 rounded-xl px-5 py-3 text-sm outline-none focus:ring-2 focus:ring-[#C41E24]/20 focus:border-[#C41E24] bg-white transition-all placeholder:text-gray-500 text-gray-800 shadow-sm font-medium">
                </div>
            </div>

            <!-- UOM & Unit Price Toggle -->
            <div class="grid grid-cols-2 gap-5">
                <div class="space-y-1.5">
                    <label class="block text-xs font-bold text-gray-700 uppercase tracking-widest ml-1">UOM</label>
                    <div class="relative">
                        <select asp-for="NewItem.UOM" required class="w-full border border-gray-200 rounded-xl px-5 py-3 text-sm outline-none focus:ring-2 focus:ring-[#C41E24]/20 focus:border-[#C41E24] bg-white transition-all cursor-pointer text-gray-700 shadow-sm font-medium appearance-none">
                            <option value="" disabled selected hidden>UOM</option>
                            <option value="kg">kg</option>
                            <option value="grams">grams</option>
                            <option value="pack">pack</option>
                            <option value="pcs">pcs</option>
                        </select>
                        <i class="bi bi-chevron-down absolute right-4 top-1/2 -translate-y-1/2 text-gray-500 pointer-events-none text-xs"></i>
                    </div>
                </div>
                <!-- Unit Price (hidden by default) -->
                <div id="unitPriceContainer" class="space-y-1.5 hidden">
                    <label class="block text-xs font-bold text-gray-700 uppercase tracking-widest ml-1">Unit Price</label>
                    <input type="number" step="0.01" asp-for="NewItem.UnitPrice" placeholder="00.00" 
                           class="w-full border border-gray-200 rounded-xl px-5 py-3 text-sm outline-none focus:ring-2 focus:ring-[#C41E24]/20 focus:border-[#C41E24] bg-white transition-all placeholder:text-gray-500 text-gray-800 shadow-sm font-medium">
                </div>
            </div>

            <!-- Selling Price Checkbox -->
            <div class="flex items-center space-x-3 pt-2">
                <input type="checkbox" id="sellingPriceCheck" onchange="togglePriceField()" 
                       class="w-4 h-4 rounded border-gray-300 text-[#C41E24] focus:ring-0 cursor-pointer">
                <label for="sellingPriceCheck" class="text-xs font-bold text-gray-700 uppercase tracking-widest cursor-pointer ml-1">Set Item Price</label>
            </div>

            <!-- Buttons -->
            <div class="flex justify-end space-x-4 pt-8 border-t border-gray-50">
                <button type="button" onclick="closeModal('newItemModal')" 
                        class="px-8 py-3 rounded-xl text-xs font-bold text-gray-500 uppercase tracking-widest hover:bg-gray-100 transition-all">
                    Cancel
                </button>
                <button type="submit" 
                        class="px-12 py-3 bg-[#C41E24] text-white rounded-xl text-xs font-bold uppercase tracking-widest hover:bg-[#a51a1f] shadow-lg hover:shadow-red-200 transition-all transform active:scale-95">
                    Save Item
                </button>
            </div>
        </form>
    </div>
</div>

<div id="rejectItemModal" class="fixed inset-0 bg-black/40 hidden flex items-center justify-center z-[100] backdrop-blur-[2px] transition-all duration-300">
    <div class="bg-white rounded-2xl shadow-2xl w-full max-w-md mx-4 overflow-hidden border border-gray-100 transform transition-all opacity-0 scale-95">
        <div class="px-8 py-6 border-b border-gray-50 flex justify-between items-center bg-white">
            <h3 class="text-base font-bold text-gray-900">Reject Item</h3>
            <button onclick="closeModal('rejectItemModal')" class="text-gray-500 hover:text-gray-700 transition-colors">
                <i class="bi bi-x-lg text-xl"></i>
            </button>
        </div>

        <form method="post" class="p-8 space-y-5">
            <div class="space-y-1.5">
                <label class="block text-xs font-bold text-gray-700 uppercase tracking-widest ml-1">Item Name</label>
                <input type="text" name="RejectName" placeholder="Item Name" 
                       class="w-full border border-gray-200 rounded-xl px-5 py-3 text-sm outline-none focus:ring-2 focus:ring-[#C41E24]/20 focus:border-[#C41E24] bg-white transition-all placeholder:text-gray-500 text-gray-800 shadow-sm font-medium">
            </div>
            <div class="grid grid-cols-2 gap-5">
                <div class="space-y-1.5">
                    <label class="block text-xs font-bold text-gray-700 uppercase tracking-widest ml-1">Quantity</label>
                    <input type="number" name="RejectQty" placeholder="0" 
                           class="w-full border border-gray-200 rounded-xl px-5 py-3 text-sm outline-none focus:ring-2 focus:ring-[#C41E24]/20 focus:border-[#C41E24] bg-white transition-all placeholder:text-gray-500 text-gray-800 shadow-sm font-medium">
                </div>
                <div class="space-y-1.5">
                    <label class="block text-xs font-bold text-gray-700 uppercase tracking-widest ml-1">Unit (UOM)</label>
                    <div class="relative">
                        <select name="RejectUOM" class="w-full border border-gray-200 rounded-xl px-5 py-3 text-sm outline-none focus:ring-2 focus:ring-[#C41E24]/20 focus:border-[#C41E24] bg-white transition-all cursor-pointer text-gray-700 shadow-sm font-medium appearance-none">
                            <option value="" disabled selected hidden>UOM</option>
                            <option value="kg">kg</option>
                            <option value="grams">grams</option>
                            <option value="pack">pack</option>
                            <option value="pcs">pcs</option>
                        </select>
                        <i class="bi bi-chevron-down absolute right-4 top-1/2 -translate-y-1/2 text-gray-500 pointer-events-none text-sm"></i>
                    </div>
                </div>
            </div>
            <div class="space-y-1.5">
                <label class="block text-xs font-bold text-gray-700 uppercase tracking-widest ml-1">Reason</label>
                <textarea name="RejectReason" rows="3" placeholder="Reason for rejection..." 
                          class="w-full border border-gray-200 rounded-xl px-5 py-3 text-sm outline-none focus:ring-2 focus:ring-[#C41E24]/20 focus:border-[#C41E24] bg-white transition-all resize-none placeholder:text-gray-500 text-gray-800 shadow-sm font-medium"></textarea>
            </div>
            <div class="flex justify-end space-x-4 pt-8 border-t border-gray-50">
                <button type="button" onclick="closeModal('rejectItemModal')" 
                        class="px-8 py-3 rounded-xl text-xs font-bold text-gray-500 uppercase tracking-widest hover:bg-gray-100 transition-all">
                    Cancel
                </button>
                <button type="submit" 
                        class="px-12 py-3 bg-[#C41E24] text-white rounded-xl text-xs font-bold uppercase tracking-widest hover:bg-[#a51a1f] shadow-lg hover:shadow-red-200 transition-all transform active:scale-95">
                    Submit Reject
                </button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <script>
        const actionsMenu = document.getElementById('actionsMenu');

        function toggleActions(e) {
            e.stopPropagation();
            actionsMenu.classList.toggle('hidden');
        }

        function openModal(modalId) {
            const modal = document.getElementById(modalId);
            const content = modal.querySelector('div');
            
            modal.classList.remove('hidden');
            document.body.style.overflow = 'hidden';
            
            setTimeout(() => {
                content.classList.remove('opacity-0', 'scale-95');
                content.classList.add('opacity-100', 'scale-100');
            }, 10);
        }

        function closeModal(modalId) {
            const modal = document.getElementById(modalId);
            const content = modal.querySelector('div');
            
            content.classList.add('opacity-0', 'scale-95');
            content.classList.remove('opacity-100', 'scale-100');
            
            setTimeout(() => {
                modal.classList.add('hidden');
                document.body.style.overflow = 'auto';
            }, 300);
        }

        function openNewItemModal() {
            openModal('newItemModal');
        }

        function togglePriceField() {
            const checkbox = document.getElementById('sellingPriceCheck');
            const container = document.getElementById('unitPriceContainer');
            if (checkbox.checked) {
                container.classList.remove('hidden');
            } else {
                container.classList.add('hidden');
            }
        }

        function openRejectModal() {
            actionsMenu.classList.add('hidden');
            openModal('rejectItemModal');
        }

        // Close dropdown when clicking anywhere else
        window.onclick = function(event) {
            if (!event.target.closest('.relative')) {
                actionsMenu.classList.add('hidden');
            }
            if (event.target.classList.contains('fixed')) {
                closeModal(event.target.id);
            }
        }

        // Close on escape
        document.addEventListener('keydown', (e) => {
            if (e.key === 'Escape') {
                const openModals = document.querySelectorAll('.fixed:not(.hidden)');
                openModals.forEach(modal => closeModal(modal.id));
            }
        });
    </script>
}
