@page
@model LeKatsuMNL.Pages.Dashboard.SkuDetailsModel
@{
    Layout = "_DashboardLayout";
    ViewData["Title"] = "Inventory Items / Chicken Karaage";
}

@section Styles {
    <style>
        .box-background {
            background-color: white;
            border-radius: 1rem;
            box-shadow: 0 4px 6px -1px rgb(0 0 0 / 0.1), 0 2px 4px -2px rgb(0 0 0 / 0.1);
            padding: 2rem;
        }
    </style>
}

@section TitleActions {
    <div class="flex items-center space-x-4">
        <a href="/Dashboard/SKU" class="p-3 bg-white border border-gray-100 text-[#C41E24] rounded-xl shadow-sm hover:bg-gray-50 transition-all">
            <i class="bi bi-chevron-left text-xl"></i>
        </a>
        <h1 class="text-2xl font-bold text-gray-800 tracking-tight">Inventory Items / <span class="text-gray-400">Chicken Karaage</span></h1>
    </div>
}

<div class="space-y-8 max-w-7xl mx-auto py-12 px-6">
    <!-- Product Header Section -->
    <div class="flex items-center space-x-10 mb-16">
        <div class="w-32 h-32 bg-gray-50 rounded-[2rem] flex items-center justify-center border border-gray-100 shadow-sm relative overflow-hidden group hover:border-[#C41E24]/30 transition-all">
            <i class="bi bi-image text-4xl text-gray-300"></i>
            <div class="absolute inset-0 bg-black/0 group-hover:bg-black/5 transition-all flex items-center justify-center pointer-events-none">
                <i class="bi bi-camera text-white opacity-0 group-hover:opacity-100 transition-all"></i>
            </div>
        </div>
        <div class="flex-1 space-y-6">
            <h2 class="text-4xl font-bold text-gray-800 tracking-tight">Chicken Karaage: <span class="text-[#C41E24]">100grams</span></h2>
            <div class="flex items-center space-x-4">
                <button class="px-8 py-3 bg-white border border-gray-100 text-[#C41E24] rounded-xl text-xs font-bold uppercase tracking-widest shadow-sm hover:bg-gray-50 transition-all flex items-center">
                    <i class="bi bi-upload mr-3 text-sm"></i> Upload Image
                </button>
                <div class="flex-1 max-w-lg">
                    <input type="text" placeholder="Enter Image URL" class="w-full bg-white border border-gray-200 rounded-xl px-5 py-3 text-sm focus:ring-2 focus:ring-[#C41E24]/10 focus:border-[#C41E24] outline-none transition-all placeholder:text-gray-400 shadow-sm font-medium">
                </div>
                <button class="p-3 bg-[#C41E24] text-white rounded-xl shadow-lg shadow-red-100 hover:bg-red-700 transition-all flex items-center justify-center w-12 h-12">
                    <i class="bi bi-floppy text-xl"></i>
                </button>
            </div>
        </div>
    </div>

    <!-- Main Content Grid -->
    <form class="grid grid-cols-2 gap-x-20">
        <!-- Left: Product Name -->
        <div class="space-y-6">
            <label class="block text-xs font-bold text-gray-700 uppercase tracking-[0.2em] ml-1">Product Name</label>
            <input type="text" value="Chicken Karaage" class="w-full bg-white border border-gray-200 rounded-2xl px-6 py-5 text-base font-bold text-gray-800 focus:ring-4 focus:ring-[#C41E24]/5 focus:border-[#C41E24] outline-none transition-all shadow-sm">
        </div>

        <!-- Right: Stacked Info -->
        <div class="space-y-10">
            <!-- Sub-Category -->
            <div class="space-y-3">
                <label class="block text-xs font-bold text-gray-700 uppercase tracking-[0.2em] ml-1">Sub-Category</label>
                <input type="text" placeholder="Sub-Category" class="w-full bg-white border border-gray-200 rounded-2xl px-6 py-5 text-base font-medium text-gray-800 focus:ring-4 focus:ring-[#C41E24]/5 focus:border-[#C41E24] outline-none transition-all shadow-sm placeholder:text-gray-500">
            </div>

            <!-- Sub-Class -->
            <div class="space-y-3">
                <label class="block text-xs font-bold text-gray-700 uppercase tracking-[0.2em] ml-1">Sub-Class</label>
                <input type="text" placeholder="Sub-Class" class="w-full bg-white border border-gray-200 rounded-2xl px-6 py-5 text-base font-medium text-gray-800 focus:ring-4 focus:ring-[#C41E24]/5 focus:border-[#C41E24] outline-none transition-all shadow-sm placeholder:text-gray-500">
            </div>

            <!-- Yield -->
            <div class="space-y-3">
                <label class="block text-xs font-bold text-gray-700 uppercase tracking-[0.2em] ml-1">Yield</label>
                <input type="text" placeholder="Yield" class="w-full bg-white border border-gray-200 rounded-2xl px-6 py-5 text-base font-medium text-gray-800 focus:ring-4 focus:ring-[#C41E24]/5 focus:border-[#C41E24] outline-none transition-all shadow-sm placeholder:text-gray-500">
            </div>

            <!-- Unit of Measurement -->
            <div class="space-y-3">
                <label class="block text-xs font-bold text-gray-700 uppercase tracking-[0.2em] ml-1">Unit of Measurement</label>
                <input type="text" placeholder="UOM" class="w-full bg-white border border-gray-200 rounded-2xl px-6 py-5 text-base font-medium text-gray-800 focus:ring-4 focus:ring-[#C41E24]/5 focus:border-[#C41E24] outline-none transition-all shadow-sm placeholder:text-gray-500">
            </div>

            <!-- Supplier -->
            <div class="space-y-3">
                <label class="block text-xs font-bold text-gray-700 uppercase tracking-[0.2em] ml-1">Supplier</label>
                <input type="text" placeholder="Supplier" class="w-full bg-white border border-gray-200 rounded-2xl px-6 py-5 text-base font-medium text-gray-800 focus:ring-4 focus:ring-[#C41E24]/5 focus:border-[#C41E24] outline-none transition-all shadow-sm placeholder:text-gray-500">
            </div>
        </div>

        <!-- Bottom: Actions -->
        <div class="col-span-2 pt-12 mt-12 border-t border-gray-50 space-y-6">
            <div class="flex items-center space-x-3">
                <input type="checkbox" id="sellingPrice" class="w-5 h-5 rounded border-gray-300 text-[#C41E24] focus:ring-[#C41E24] transition-all cursor-pointer">
                <label for="sellingPrice" class="text-xs font-bold text-gray-700 uppercase tracking-widest cursor-pointer select-none">Selling Price</label>
            </div>
            <div class="flex justify-start">
                <button type="button" class="px-10 py-4 bg-[#FFF5F5] text-[#C41E24] rounded-xl text-xs font-bold uppercase tracking-widest hover:bg-red-50 transition-all border border-red-100/50 shadow-sm flex items-center">
                    <i class="bi bi-trash3 mr-3 text-sm"></i> Delete this Product
                </button>
            </div>
        </div>
    </form>
</div>

    <!-- Pagination Footer Placeholder -->
    <div class="flex justify-between items-center px-6 py-8 border-t border-gray-50">
        <p class="text-xs text-gray-500 font-bold uppercase tracking-widest">Showing 1 - 5 of 10</p>
        <div class="flex items-center space-x-6">
            <div class="flex items-center space-x-3 text-xs text-gray-500 font-bold uppercase tracking-widest">
                <span>Records per page</span>
                <div class="bg-white border border-gray-200 px-3 py-1 rounded-lg text-gray-700">10</div>
            </div>
            <div class="flex items-center space-x-2">
                <button class="w-9 h-9 flex items-center justify-center rounded-lg bg-gray-50 border border-gray-200 text-gray-400 hover:bg-gray-100 transition-colors"><i class="bi bi-chevron-left"></i></button>
                <button class="w-9 h-9 flex items-center justify-center rounded-lg bg-[#C41E24] text-white shadow-md">1</button>
                <button class="w-9 h-9 flex items-center justify-center rounded-lg bg-gray-50 border border-gray-200 text-gray-400 hover:bg-gray-100 transition-colors"><i class="bi bi-chevron-right"></i></button>
            </div>
        </div>
    </div>
</div>
