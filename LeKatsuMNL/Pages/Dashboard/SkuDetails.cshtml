@page
@model LeKatsuMNL.Pages.Dashboard.SkuDetailsModel
@{
    Layout = "_DashboardLayout";
    ViewData["Title"] = "Inventory Items / Chicken Karaage";
}

@section Styles {
    <style>
        .box-background {
            background-color: white;
            border-radius: 1rem;
            box-shadow: 0 4px 6px -1px rgb(0 0 0 / 0.1), 0 2px 4px -2px rgb(0 0 0 / 0.1);
            padding: 2rem;
        }
    </style>
}

@section TitleActions {
    <div class="flex items-center space-x-3">
        <button type="button" class="px-6 py-2.5 bg-white border border-gray-200 text-gray-500 rounded-lg text-xs font-bold uppercase tracking-widest hover:bg-gray-50 transition-all shadow-sm">
            Cancel
        </button>
        <button type="submit" form="skuForm" class="px-8 py-2.5 bg-[#C41E24] text-white rounded-lg text-xs font-bold uppercase tracking-widest hover:bg-red-700 transition-all shadow-lg shadow-red-100 flex items-center">
            <i class="bi bi-floppy mr-2 text-sm"></i> Save Changes
        </button>
    </div>
}

<div class="space-y-6 max-w-6xl mx-auto py-8 px-6">
    <!-- Product Header Section -->
    <div class="flex items-center space-x-8 mb-8">
        <div class="w-24 h-24 bg-gray-50 rounded-2xl flex items-center justify-center border border-gray-100 shadow-sm relative overflow-hidden group hover:border-[#C41E24]/30 transition-all">
            <i class="bi bi-image text-3xl text-gray-300"></i>
            <div class="absolute inset-0 bg-black/0 group-hover:bg-black/5 transition-all flex items-center justify-center pointer-events-none">
                <i class="bi bi-camera text-white opacity-0 group-hover:opacity-100 transition-all"></i>
            </div>
        </div>
        <div class="flex-1 space-y-4">
            <h2 class="text-3xl font-extrabold text-gray-800 tracking-tight">Chicken Karaage: <span class="text-[#C41E24]">100grams</span></h2>
            <div class="flex items-center space-x-4">
                <button type="button" class="px-6 py-2.5 bg-white border border-gray-200 text-[#C41E24] rounded-lg text-xs font-bold uppercase tracking-widest shadow-sm hover:bg-gray-50 transition-all flex items-center">
                    <i class="bi bi-upload mr-2 text-sm"></i> Upload Image
                </button>
                <div class="flex-1 max-w-md">
                    <input type="text" placeholder="Enter Image URL" class="w-full bg-white border border-gray-200 rounded-lg px-4 py-2.5 text-sm focus:ring-2 focus:ring-[#C41E24]/5 focus:border-[#C41E24] outline-none transition-all placeholder:text-gray-500 shadow-sm font-medium">
                </div>
            </div>
        </div>
    </div>

    <!-- Main Content Grid -->
    <form id="skuForm" method="post" class="grid grid-cols-2 gap-x-12">
        <!-- Left: Product Name -->
        <div class="space-y-5">
            <div>
                <label class="block text-[10px] font-black text-gray-400 uppercase tracking-widest mb-2 ml-1">Product Name</label>
                <input type="text" value="Chicken Karaage" class="w-full bg-white border border-gray-200 rounded-xl px-5 py-3.5 text-base font-bold text-gray-800 focus:ring-2 focus:ring-[#C41E24]/5 focus:border-[#C41E24] outline-none transition-all shadow-sm">
            </div>

            <!-- Selling Price Toggle Section -->
            <div class="pt-4 space-y-5">
                <div class="flex items-center space-x-3 mb-4">
                    <input type="checkbox" id="sellingPrice" onchange="toggleSkuPriceFields()" class="w-5 h-5 rounded border-gray-300 text-[#C41E24] focus:ring-[#C41E24] transition-all cursor-pointer">
                    <label for="sellingPrice" class="text-[10px] font-black text-gray-700 uppercase tracking-widest cursor-pointer select-none">Selling Price</label>
                </div>
                
                <div id="skuPriceContainer" class="hidden grid grid-cols-2 gap-4 transition-all duration-300 bg-gray-50/50 p-6 rounded-2xl border border-dashed border-gray-200">
                    <div>
                        <label class="block text-[10px] font-black text-gray-400 uppercase tracking-widest mb-2 ml-1">Selling Price</label>
                        <input type="text" placeholder="₱ 0.00" class="w-full bg-white border border-gray-200 rounded-xl px-4 py-3 text-sm font-bold text-gray-800 outline-none focus:border-[#C41E24] transition-all">
                    </div>
                    <div>
                        <label class="block text-[10px] font-black text-gray-400 uppercase tracking-widest mb-2 ml-1">Unit Cost</label>
                        <input type="text" placeholder="₱ 0.00" class="w-full bg-white border border-gray-200 rounded-xl px-4 py-3 text-sm font-bold text-gray-800 outline-none focus:border-[#C41E24] transition-all">
                    </div>
                </div>
            </div>
            
            <div class="pt-8 flex justify-start">
                <button type="button" class="px-8 py-3 bg-[#FFF5F5] text-[#C41E24] rounded-lg text-xs font-bold uppercase tracking-widest hover:bg-red-50 transition-all border border-red-100/50 shadow-sm flex items-center">
                    <i class="bi bi-trash3 mr-2 text-sm"></i> Delete this Product
                </button>
            </div>
        </div>

        <!-- Right: Stacked Info -->
        <div class="space-y-5">
            <!-- Sub-Category -->
            <div class="space-y-1.5">
                <label class="block text-[10px] font-black text-gray-400 uppercase tracking-widest ml-1">Sub-Category</label>
                <input type="text" placeholder="Sub-Category" class="w-full bg-white border border-gray-200 rounded-xl px-5 py-3.5 text-sm font-bold text-gray-800 focus:ring-2 focus:ring-[#C41E24]/5 focus:border-[#C41E24] outline-none transition-all shadow-sm placeholder:text-gray-400">
            </div>

            <!-- Sub-Class -->
            <div class="space-y-1.5">
                <label class="block text-[10px] font-black text-gray-400 uppercase tracking-widest ml-1">Sub-Class</label>
                <input type="text" placeholder="Sub-Class" class="w-full bg-white border border-gray-200 rounded-xl px-5 py-3.5 text-sm font-bold text-gray-800 focus:ring-2 focus:ring-[#C41E24]/5 focus:border-[#C41E24] outline-none transition-all shadow-sm placeholder:text-gray-400">
            </div>

            <!-- Yield -->
            <div class="space-y-1.5">
                <label class="block text-[10px] font-black text-gray-400 uppercase tracking-widest ml-1">Yield</label>
                <input type="text" placeholder="Yield" class="w-full bg-white border border-gray-200 rounded-xl px-5 py-3.5 text-sm font-bold text-gray-800 focus:ring-2 focus:ring-[#C41E24]/5 focus:border-[#C41E24] outline-none transition-all shadow-sm placeholder:text-gray-400">
            </div>

            <!-- Unit of Measurement -->
            <div class="space-y-1.5">
                <label class="block text-[10px] font-black text-gray-400 uppercase tracking-widest ml-1">Unit of Measurement</label>
                <input type="text" placeholder="UOM" class="w-full bg-white border border-gray-200 rounded-xl px-5 py-3.5 text-sm font-bold text-gray-800 focus:ring-2 focus:ring-[#C41E24]/5 focus:border-[#C41E24] outline-none transition-all shadow-sm placeholder:text-gray-400">
            </div>

            <!-- Supplier -->
            <div class="space-y-1.5">
                <label class="block text-[10px] font-black text-gray-400 uppercase tracking-widest ml-1">Supplier</label>
                <input type="text" placeholder="Supplier" class="w-full bg-white border border-gray-200 rounded-xl px-5 py-3.5 text-sm font-bold text-gray-800 focus:ring-2 focus:ring-[#C41E24]/5 focus:border-[#C41E24] outline-none transition-all shadow-sm placeholder:text-gray-400">
            </div>
        </div>
    </form>
</div>

@section Scripts {
    <script>
        function toggleSkuPriceFields() {
            const checkbox = document.getElementById('sellingPrice');
            const container = document.getElementById('skuPriceContainer');
            if (checkbox.checked) {
                container.classList.remove('hidden');
            } else {
                container.classList.add('hidden');
            }
        }
    </script>
}
