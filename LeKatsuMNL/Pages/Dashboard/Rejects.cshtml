@page
@model LeKatsuMNL.Pages.Dashboard.RejectsModel
@{
    ViewData["Title"] = "Inventory Item Rejects";
}

@if (!string.IsNullOrEmpty(Model.StatusMessage))
{
    <div class="mb-6 animate-pulse">
        <div class="bg-green-50 border border-green-200 rounded-xl p-4 flex items-center justify-between shadow-sm dark:bg-green-500/10 dark:border-green-500/20">
            <div class="flex items-center space-x-3 text-green-700 dark:text-green-400">
                <i class="bi bi-check-circle-fill text-lg"></i>
                <span class="text-xs font-bold uppercase tracking-wider">@Model.StatusMessage</span>
            </div>
            <button type="button" onclick="this.parentElement.parentElement.remove()" class="text-green-400 hover:text-green-600 dark:text-green-500"><i class="bi bi-x-lg"></i></button>
        </div>
    </div>
}


<!-- Filters Section -->
<div class="bg-white rounded-xl border border-gray-200 p-6 shadow-sm dark:bg-slate-800 dark:border-gray-700 mb-6">
    <form id="filterForm" method="get" class="flex flex-wrap items-end gap-6">
        <div class="relative flex-1 min-w-[200px] max-w-md group h-[41px]">
            <span class="absolute inset-y-0 left-4 flex items-center text-gray-400 dark:text-gray-500">
                <i class="bi bi-search text-sm"></i>
            </span>
            <input id="searchQuery" type="text" asp-for="SearchQuery" placeholder="Search item name..." 
                   class="w-full h-full border border-gray-300 rounded-xl pl-11 pr-32 text-sm font-bold text-gray-700 dark:text-gray-200 focus:ring-1 focus:ring-[#C41E24] outline-none placeholder:text-gray-400 dark:bg-slate-800 dark:border-gray-600 dark:placeholder:text-gray-500 transition-all">
            <div class="absolute inset-y-1 right-1 flex items-center">
                <button type="submit" class="h-full px-4 bg-[#C41E24] text-white rounded-lg text-xs font-bold hover:bg-[#a51a1f] transition-colors flex items-center space-x-2">
                    <i class="bi bi-search"></i>
                    <span>Search</span>
                </button>
            </div>
        </div>

        <div class="flex flex-col">
            <label class="text-[10px] font-black text-gray-400 uppercase tracking-[0.2em] mb-2 leading-none">Reject Period</label>
            <div class="flex items-center bg-gray-50 dark:bg-slate-900/50 border border-gray-100 dark:border-gray-700 rounded-xl px-4 py-2.5 transition-all focus-within:ring-2 focus-within:ring-[#C41E24]/20 focus-within:border-[#C41E24]">
                <input type="date" id="startDate" asp-for="StartDate" class="bg-transparent text-sm font-bold text-gray-700 dark:text-gray-200 outline-none">
                <span class="mx-3 text-gray-400 font-medium text-xs">to</span>
                <input type="date" id="endDate" asp-for="EndDate" class="bg-transparent text-sm font-bold text-gray-700 dark:text-gray-200 outline-none">
            </div>
        </div>

        <div class="flex flex-col">
            <label class="text-[10px] font-black text-gray-400 uppercase tracking-[0.2em] mb-2 leading-none">Quick Ranges</label>
            <div class="flex items-center space-x-2 h-[41px]">
                <button type="button" onclick="setRange('today')" class="px-3 py-2 text-[10px] font-bold uppercase tracking-wider text-gray-500 bg-gray-50 hover:bg-gray-100 rounded-lg border border-gray-100 dark:bg-slate-900/50 dark:border-gray-700 dark:text-gray-400 transition-all">Today</button>
                <button type="button" onclick="setRange('7days')" class="px-3 py-2 text-[10px] font-bold uppercase tracking-wider text-gray-500 bg-gray-50 hover:bg-gray-100 rounded-lg border border-gray-100 dark:bg-slate-900/50 dark:border-gray-700 dark:text-gray-400 transition-all">7D</button>
                <button type="button" onclick="setRange('30days')" class="px-3 py-2 text-[10px] font-bold uppercase tracking-wider text-gray-500 bg-gray-50 hover:bg-gray-100 rounded-lg border border-gray-100 dark:bg-slate-900/50 dark:border-gray-700 dark:text-gray-400 transition-all">30D</button>
                <button type="button" onclick="setRange('month')" class="px-3 py-2 text-[10px] font-bold uppercase tracking-wider text-gray-500 bg-gray-50 hover:bg-gray-100 rounded-lg border border-gray-100 dark:bg-slate-900/50 dark:border-gray-700 dark:text-gray-400 transition-all">Month</button>
            </div>
        </div>

        <div class="flex items-center space-x-2">
            <a asp-page="./Rejects" class="flex items-center justify-center bg-gray-50 dark:bg-slate-900/50 border border-gray-100 dark:border-gray-700 rounded-xl px-4 py-2.5 text-sm text-gray-500 hover:text-gray-800 dark:hover:text-gray-200 transition-all shadow-sm" aria-label="Reset filters" title="Reset filters">
                <i class="bi bi-arrow-clockwise text-lg"></i>
            </a>
        </div>
    </form>
</div>

    <div class="bg-white rounded-t-xl border border-gray-200 p-5 flex items-center justify-between shadow-sm dark:bg-slate-800 dark:border-gray-700">

        <div class="flex items-center space-x-4">
            <div class="relative inline-block text-left">
                <button onclick="toggleActions(event)" class="flex items-center space-x-3 border border-gray-300 rounded-lg px-4 py-2 text-sm text-gray-500 bg-white hover:bg-gray-50 outline-none transition-all dark:bg-slate-800 dark:hover:bg-slate-700/50 dark:text-gray-400 dark:border-gray-600">
                    <span>Actions</span>
                    <i class="bi bi-chevron-down text-xs"></i>
                </button>

                <div id="actionsMenu" class="hidden absolute left-0 mt-2 w-40 bg-white rounded-xl shadow-xl border border-gray-100 z-[70] overflow-hidden transform origin-top-left transition-all dark:bg-slate-800 dark:border-gray-700">
                    <a asp-page-handler="Export" 
                       asp-route-StartDate="@Model.StartDate?.ToString("yyyy-MM-dd")" 
                       asp-route-EndDate="@Model.EndDate?.ToString("yyyy-MM-dd")" 
                       asp-route-SearchQuery="@Model.SearchQuery"
                       class="w-full text-left px-5 py-3 text-xs font-bold text-gray-600 uppercase tracking-widest hover:bg-gray-50 border-b border-gray-50 transition-colors dark:hover:bg-slate-700/50 dark:text-gray-300 dark:border-gray-700">
                        Export List
                    </a>
                    <button type="button" onclick="confirmClearLogs()" class="w-full text-left px-5 py-3 text-xs font-bold text-red-500 uppercase tracking-widest hover:bg-red-50 transition-colors">
                        Clear Logs
                    </button>
                </div>
            </div>
        </div>

        <div></div>
    </div>

    <div class="bg-white border-x border-b border-gray-200 shadow-sm overflow-hidden dark:bg-slate-800 dark:border-gray-700">
        <table class="w-full text-left text-xs whitespace-nowrap">
            <thead class="bg-gray-50 text-gray-500 uppercase tracking-wider font-bold border-b border-gray-100 dark:bg-slate-700/50 dark:text-gray-400 dark:border-gray-700">
                <tr>
                    <th class="px-8 py-4 w-12"><input type="checkbox" class="w-4 h-4 rounded border-gray-300 text-[#C41E24] focus:ring-[#C41E24] dark:border-gray-600"></th>
                    <th class="px-8 py-4">Item Name</th>
                    <th class="px-8 py-4">Quantity</th>
                    <th class="px-8 py-4">UOM</th>
                    <th class="px-8 py-4">Reason</th>
                    <th class="px-8 py-4">Rejected At</th>
                </tr>
            </thead>
                @if (Model.RejectLogs != null && Model.RejectLogs.Any())
                {
                    foreach (var reject in Model.RejectLogs)
                    {
                        <tr class="hover:bg-gray-50 transition-colors dark:hover:bg-slate-700/50">
                            <td class="px-8 py-5"><input type="checkbox" class="w-4 h-4 rounded border-gray-300 dark:border-gray-600 text-[#C41E24] focus:ring-[#C41E24]"></td>
                            <td class="px-8 py-5 font-bold text-gray-800 text-sm dark:text-white">@reject.ItemName</td>
                            <td class="px-8 py-5 text-gray-600 font-medium text-sm dark:text-gray-300">@reject.Quantity</td>
                            <td class="px-8 py-5">
                                <span class="bg-gray-50 border border-gray-200 text-gray-700 px-4 py-1.5 rounded-lg font-bold text-xs uppercase tracking-wide dark:bg-slate-700/50 dark:text-gray-200 dark:border-gray-600">@reject.Uom</span>
                            </td>
                            <td class="px-8 py-5 text-gray-500 font-medium text-sm dark:text-gray-400">@(string.IsNullOrEmpty(reject.Reason) ? "-" : reject.Reason)</td>
                            <td class="px-8 py-5 text-gray-500 text-sm dark:text-gray-400">@reject.RejectedAt.ToString("MMMM dd, yyyy h:mm tt")</td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="6" class="px-6 py-8 text-center text-gray-500 font-semibold italic dark:text-gray-400">No rejected items found.</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <partial name="_Pagination" model="Model.RejectLogs" />

@section Scripts {
    <form id="clearLogsForm" method="post" asp-page-handler="ClearLogs" class="hidden">
        <input type="hidden" name="StartDate" value="@Model.StartDate?.ToString("yyyy-MM-dd")" />
        <input type="hidden" name="EndDate" value="@Model.EndDate?.ToString("yyyy-MM-dd")" />
        <input type="hidden" name="SearchQuery" value="@Model.SearchQuery" />
    </form>

    <script>
        const actionsMenu = document.getElementById('actionsMenu');

        function toggleActions(e) {
            e.stopPropagation();
            actionsMenu.classList.toggle('hidden');
        }

        function confirmClearLogs() {
            if (confirm('Are you sure you want to permanently clear the FILTERED reject logs? This action cannot be undone.')) {
                document.getElementById('clearLogsForm').submit();
            }
        }

        window.onclick = function(event) {
            if (!event.target.closest('.relative')) {
                if (actionsMenu) actionsMenu.classList.add('hidden');
            }
        }

        // Date Filter Logic
        const startDateInput = document.getElementById('startDate');
        const endDateInput = document.getElementById('endDate');

        startDateInput.addEventListener('change', function() {
            if (endDateInput.value && this.value > endDateInput.value) {
                endDateInput.value = this.value;
            }
        });

        endDateInput.addEventListener('change', function() {
            if (startDateInput.value && this.value < startDateInput.value) {
                startDateInput.value = this.value;
            }
        });

        function setRange(range) {
            const now = new Date();
            let start = new Date();
            let end = new Date();

            switch(range) {
                case 'today':
                    start = now;
                    break;
                case '7days':
                    start.setDate(now.getDate() - 7);
                    break;
                case '30days':
                    start.setDate(now.getDate() - 30);
                    break;
                case 'month':
                    start = new Date(now.getFullYear(), now.getMonth(), 1);
                    break;
            }

            startDateInput.value = start.toISOString().split('T')[0];
            endDateInput.value = end.toISOString().split('T')[0];
            document.getElementById('filterForm').submit();
        }
    </script>
}