@page
@model LeKatsuMNL.Pages.Dashboard.RejectsModel
@{
    ViewData["Title"] = "Inventory Item Rejects";
}

@if (!string.IsNullOrEmpty(Model.StatusMessage))
{
    <div class="mb-6 animate-pulse">
        <div class="bg-green-50 border border-green-200 rounded-xl p-4 flex items-center justify-between shadow-sm dark:bg-green-500/10 dark:border-green-500/20">
            <div class="flex items-center space-x-3 text-green-700 dark:text-green-400">
                <i class="bi bi-check-circle-fill text-lg"></i>
                <span class="text-xs font-bold uppercase tracking-wider">@Model.StatusMessage</span>
            </div>
            <button type="button" onclick="this.parentElement.parentElement.remove()" class="text-green-400 hover:text-green-600 dark:text-green-500"><i class="bi bi-x-lg"></i></button>
        </div>
    </div>
}



    <div class="bg-white rounded-t-xl border-t border-gray-200 p-5 flex items-center justify-between shadow-sm dark:bg-slate-800 dark:border-gray-700">

        <div class="flex items-center space-x-4">
            <div class="relative inline-block text-left">
                <button onclick="toggleActions(event)" class="flex items-center space-x-3 border border-gray-300 rounded-lg px-4 py-2 text-sm text-gray-500 bg-white hover:bg-gray-50 outline-none transition-all dark:bg-slate-800 dark:hover:bg-slate-700/50 dark:text-gray-400 dark:border-gray-600">
                    <span>Actions</span>
                    <i class="bi bi-chevron-down text-xs"></i>
                </button>

                <div id="actionsMenu" class="hidden absolute left-0 mt-2 w-40 bg-white rounded-xl shadow-xl border border-gray-100 z-[70] overflow-hidden transform origin-top-left transition-all dark:bg-slate-800 dark:border-gray-700">
                    <a asp-page-handler="Export" class="w-full text-left px-5 py-3 text-xs font-bold text-gray-600 uppercase tracking-widest hover:bg-gray-50 border-b border-gray-50 transition-colors dark:hover:bg-slate-700/50 dark:text-gray-300 dark:border-gray-700">
                        Export List
                    </a>
                    <button type="button" onclick="confirmClearLogs()" class="w-full text-left px-5 py-3 text-xs font-bold text-red-500 uppercase tracking-widest hover:bg-red-50 transition-colors">
                        Clear Logs
                    </button>
                </div>
            </div>
        </div>

        <div class="flex items-center space-x-4">
            <button class="flex items-center space-x-3 border border-gray-300 rounded-lg px-4 py-2 text-sm text-gray-600 hover:bg-gray-50 transition-colors dark:hover:bg-slate-700/50 dark:text-gray-300 dark:border-gray-600">
                <i class="bi bi-arrow-clockwise text-base"></i> <span>Refresh</span>
            </button>
        </div>
    </div>

    <div class="bg-white border-x border-b border-gray-200 shadow-sm overflow-hidden dark:bg-slate-800 dark:border-gray-700">
        <table class="w-full text-left text-xs whitespace-nowrap">
            <thead class="bg-gray-50 text-gray-500 uppercase tracking-wider font-bold border-b border-gray-100 dark:bg-slate-700/50 dark:text-gray-400 dark:border-gray-700">
                <tr>
                    <th class="px-8 py-4 w-12"><input type="checkbox" class="w-4 h-4 rounded border-gray-300 text-[#C41E24] focus:ring-[#C41E24] dark:border-gray-600"></th>
                    <th class="px-8 py-4">Item Name</th>
                    <th class="px-8 py-4">Quantity</th>
                    <th class="px-8 py-4">UOM</th>
                    <th class="px-8 py-4">Reason</th>
                    <th class="px-8 py-4">Rejected At</th>
                </tr>
            </thead>
                @if (Model.RejectLogs != null && Model.RejectLogs.Any())
                {
                    foreach (var reject in Model.RejectLogs)
                    {
                        <tr class="hover:bg-gray-50 transition-colors dark:hover:bg-slate-700/50">
                            <td class="px-8 py-5"><input type="checkbox" class="w-4 h-4 rounded border-gray-300 dark:border-gray-600 text-[#C41E24] focus:ring-[#C41E24]"></td>
                            <td class="px-8 py-5 font-bold text-gray-800 text-sm dark:text-white">@reject.ItemName</td>
                            <td class="px-8 py-5 text-gray-600 font-medium text-sm dark:text-gray-300">@reject.Quantity</td>
                            <td class="px-8 py-5">
                                <span class="bg-gray-50 border border-gray-200 text-gray-700 px-4 py-1.5 rounded-lg font-bold text-xs uppercase tracking-wide dark:bg-slate-700/50 dark:text-gray-200 dark:border-gray-600">@reject.Uom</span>
                            </td>
                            <td class="px-8 py-5 text-gray-500 font-medium text-sm dark:text-gray-400">@(string.IsNullOrEmpty(reject.Reason) ? "-" : reject.Reason)</td>
                            <td class="px-8 py-5 text-gray-500 text-sm dark:text-gray-400">@reject.RejectedAt.ToString("MMMM dd, yyyy h:mm tt")</td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="6" class="px-6 py-8 text-center text-gray-500 font-semibold italic dark:text-gray-400">No rejected items found.</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <partial name="_Pagination" model="Model.RejectLogs" />

@section Scripts {
    <form id="clearLogsForm" method="post" asp-page-handler="ClearLogs" class="hidden"></form>

    <script>
        const actionsMenu = document.getElementById('actionsMenu');

        function toggleActions(e) {
            e.stopPropagation();
            actionsMenu.classList.toggle('hidden');
        }

        function confirmClearLogs() {
            if (confirm('Are you sure you want to permanently clear all reject logs? This action cannot be undone.')) {
                document.getElementById('clearLogsForm').submit();
            }
        }

        window.onclick = function(event) {
            if (!event.target.closest('.relative')) {
                if (actionsMenu) actionsMenu.classList.add('hidden');
            }
        }
    </script>
}