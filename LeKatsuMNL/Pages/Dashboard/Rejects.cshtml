@page
@model LeKatsuMNL.Pages.Dashboard.RejectsModel
@{
    ViewData["Title"] = "Inventory Item Rejects";
}

    <div class="bg-white rounded-t-xl border border-gray-200 p-5 flex items-center justify-between shadow-sm">

        <div class="flex items-center space-x-4">
            <div class="relative inline-block text-left">
                <button onclick="toggleActions(event)" class="flex items-center space-x-3 border border-gray-300 rounded-lg px-4 py-2 text-sm text-gray-500 bg-white hover:bg-gray-50 outline-none transition-all">
                    <span>Actions</span>
                    <i class="bi bi-chevron-down text-xs"></i>
                </button>

                <div id="actionsMenu" class="hidden absolute left-0 mt-2 w-40 bg-white rounded-xl shadow-xl border border-gray-100 z-[70] overflow-hidden transform origin-top-left transition-all">
                    <button class="w-full text-left px-5 py-3 text-xs font-bold text-gray-600 uppercase tracking-widest hover:bg-gray-50 border-b border-gray-50 transition-colors">
                        Export List
                    </button>
                    <button class="w-full text-left px-5 py-3 text-xs font-bold text-red-500 uppercase tracking-widest hover:bg-red-50 transition-colors">
                        Clear Logs
                    </button>
                </div>
            </div>
        </div>

        <div class="flex items-center space-x-4">
            <button class="flex items-center space-x-3 border border-gray-300 rounded-lg px-4 py-2 text-sm text-gray-600 hover:bg-gray-50 transition-colors">
                <i class="bi bi-arrow-clockwise text-base"></i> <span>Refresh</span>
            </button>
        </div>
    </div>

    <div class="bg-white border-x border-b border-gray-200 shadow-sm overflow-hidden">
        <table class="w-full text-left text-xs whitespace-nowrap">
            <thead class="bg-gray-50 text-gray-500 uppercase tracking-wider font-bold border-b border-gray-100">
                <tr>
                    <th class="px-8 py-4"><input type="checkbox" class="w-4 h-4 rounded border-gray-300 text-[#C41E24] focus:ring-[#C41E24]"></th>
                    <th class="px-8 py-4">Item Name</th>
                    <th class="px-8 py-4">Quantity</th>
                    <th class="px-8 py-4">Type</th>
                    <th class="px-8 py-4">Reason</th>
                    <th class="px-8 py-4">Rejected At</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-gray-100">
                <tr class="hover:bg-gray-50 transition-colors">
                    <td class="px-8 py-5"><input type="checkbox" class="w-4 h-4 rounded border-gray-300"></td>
                    <td class="px-8 py-5 font-bold text-gray-800 text-sm">Marinated Chicken</td>
                    <td class="px-8 py-5 text-gray-600 font-medium text-sm">-</td>
                    <td class="px-8 py-5">
                        <span class="bg-orange-50 text-orange-700 px-4 py-1.5 rounded-lg font-bold text-xs uppercase tracking-wide">Spoilage</span>
                    </td>
                    <td class="px-8 py-5 text-gray-500 font-medium text-sm">-</td>
                    <td class="px-8 py-5 text-gray-500 text-sm">December 25, 2026</td>
                </tr>
                <tr class="hover:bg-gray-50 transition-colors">
                    <td class="px-8 py-5"><input type="checkbox" class="w-4 h-4 rounded border-gray-300"></td>
                    <td class="px-8 py-5 font-bold text-gray-800 text-sm">Oil</td>
                    <td class="px-8 py-5 text-gray-600 font-medium text-sm">-</td>
                    <td class="px-8 py-5">
                        <span class="bg-red-50 text-red-700 px-4 py-1.5 rounded-lg font-bold text-xs uppercase tracking-wide">Expired</span>
                    </td>
                    <td class="px-8 py-5 text-gray-500 font-medium text-sm">-</td>
                    <td class="px-8 py-5 text-gray-500 text-sm">December 25, 2026</td>
                </tr>
                <tr class="hover:bg-gray-50 transition-colors">
                    <td class="px-8 py-5"><input type="checkbox" class="w-4 h-4 rounded border-gray-300"></td>
                    <td class="px-8 py-5 font-bold text-gray-800 text-sm">Breading</td>
                    <td class="px-8 py-5 text-gray-600 font-medium text-sm">-</td>
                    <td class="px-8 py-5">
                        <span class="bg-gray-50 text-gray-700 px-4 py-1.5 rounded-lg font-bold text-xs uppercase tracking-wide">Waste</span>
                    </td>
                    <td class="px-8 py-5 text-gray-500 font-medium text-sm">-</td>
                    <td class="px-8 py-5 text-gray-500 text-sm">December 25, 2026</td>
                </tr>
            </tbody>
        </table>
    </div>

    <div class="bg-white rounded-b-xl border-x border-b border-gray-200 p-5 flex justify-between items-center text-xs text-gray-500 font-bold uppercase tracking-widest border-t border-gray-100">
        <div>Showing 1 - 3 of 10</div>
        <div class="flex items-center space-x-8">
            <div class="flex items-center space-x-3">
                <span>Records per page</span>
                <div class="border border-gray-200 rounded-lg px-3 py-1 bg-gray-50 text-gray-700 flex items-center">
                    <span>10</span>
                </div>
            </div>
            <div class="flex items-center space-x-2">
                <button class="w-9 h-9 flex items-center justify-center border border-gray-200 rounded-lg text-gray-400 bg-gray-50 hover:bg-gray-100 transition-colors">&lt;</button>
                <button class="w-9 h-9 flex items-center justify-center border border-gray-200 rounded-lg bg-gray-600 text-white shadow-md">1</button>
                <button class="w-9 h-9 flex items-center justify-center border border-gray-200 rounded-lg text-gray-400 bg-gray-50 hover:bg-gray-100 transition-colors">&gt;</button>
            </div>
        </div>
    </div>

@section Scripts {
    <script>
        const actionsMenu = document.getElementById('actionsMenu');

        function toggleActions(e) {
            e.stopPropagation();
            actionsMenu.classList.toggle('hidden');
        }

        window.onclick = function(event) {
            if (!event.target.closest('.relative')) {
                if (actionsMenu) actionsMenu.classList.add('hidden');
            }
        }
    </script>
}