@page
@model LeKatsuMNL.Pages.Dashboard.RejectsModel
@{
    ViewData["Title"] = "Inventory Item Rejects";
}

<div class="p-6 bg-gray-50 min-h-screen">

    <div class="bg-white rounded-t-xl border border-gray-200 p-4 flex items-center justify-between shadow-sm">

        <div class="flex items-center space-x-3">
            <div class="relative inline-block text-left">
                <button onclick="toggleActions(event)" class="flex items-center space-x-2 border border-gray-300 rounded-md px-3 py-1.5 text-xs text-gray-500 bg-white hover:bg-gray-50 outline-none transition-all">
                    <span>Actions</span>
                    <i class="bi bi-chevron-down text-[10px]"></i>
                </button>

                <div id="actionsMenu" class="hidden absolute left-0 mt-2 w-32 bg-white rounded-xl shadow-xl border border-gray-100 z-[70] overflow-hidden transform origin-top-left transition-all">
                    <button class="w-full text-left px-4 py-2.5 text-[10px] font-bold text-gray-600 uppercase tracking-widest hover:bg-gray-50 border-b border-gray-50 transition-colors">
                        Export List
                    </button>
                    <button class="w-full text-left px-4 py-2.5 text-[10px] font-bold text-red-500 uppercase tracking-widest hover:bg-red-50 transition-colors">
                        Clear Logs
                    </button>
                </div>
            </div>
        </div>

        <div class="flex items-center space-x-3">
            <button class="flex items-center space-x-2 border border-gray-300 rounded px-3 py-1.5 text-xs text-gray-600 hover:bg-gray-50 transition-colors">
                <i class="bi bi-arrow-clockwise text-sm"></i> <span>Refresh</span>
            </button>
        </div>
    </div>

    <div class="bg-white border-x border-b border-gray-200 shadow-sm overflow-hidden">
        <table class="w-full text-left text-[11px] whitespace-nowrap">
            <thead class="bg-gray-200 text-gray-500 uppercase tracking-wider font-bold">
                <tr>
                    <th class="px-6 py-3 border-b"><input type="checkbox" class="rounded border-gray-300 text-[#C41E24] focus:ring-[#C41E24]"></th>
                    <th class="px-4 py-3 border-b">Item Name</th>
                    <th class="px-4 py-3 border-b">Quantity</th>
                    <th class="px-4 py-3 border-b">Type</th>
                    <th class="px-4 py-3 border-b">Reason</th>
                    <th class="px-4 py-3 border-b">Rejected At</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-gray-100">
                @* Sample data mapped from your wireframe *@
                <tr class="hover:bg-gray-50 transition-colors">
                    <td class="px-6 py-4"><input type="checkbox" class="rounded border-gray-300"></td>
                    <td class="px-4 py-4 font-semibold text-gray-700">Marinated Chicken</td>
                    <td class="px-4 py-4 text-gray-500">-</td>
                    <td class="px-4 py-4">
                        <span class="bg-orange-100 text-orange-700 px-3 py-1 rounded-md font-bold text-[10px] uppercase">Spoilage</span>
                    </td>
                    <td class="px-4 py-4 text-gray-400 font-medium">-</td>
                    <td class="px-4 py-4 text-gray-500">December 25, 2026</td>
                </tr>
                <tr class="hover:bg-gray-50 transition-colors">
                    <td class="px-6 py-4"><input type="checkbox" class="rounded border-gray-300"></td>
                    <td class="px-4 py-4 font-semibold text-gray-700">Oil</td>
                    <td class="px-4 py-4 text-gray-500">-</td>
                    <td class="px-4 py-4">
                        <span class="bg-red-100 text-red-700 px-3 py-1 rounded-md font-bold text-[10px] uppercase">Expired</span>
                    </td>
                    <td class="px-4 py-4 text-gray-400 font-medium">-</td>
                    <td class="px-4 py-4 text-gray-500">December 25, 2026</td>
                </tr>
                <tr class="hover:bg-gray-50 transition-colors">
                    <td class="px-6 py-4"><input type="checkbox" class="rounded border-gray-300"></td>
                    <td class="px-4 py-4 font-semibold text-gray-700">Breading</td>
                    <td class="px-4 py-4 text-gray-500">-</td>
                    <td class="px-4 py-4">
                        <span class="bg-gray-100 text-gray-700 px-3 py-1 rounded-md font-bold text-[10px] uppercase">Waste</span>
                    </td>
                    <td class="px-4 py-4 text-gray-400 font-medium">-</td>
                    <td class="px-4 py-4 text-gray-500">December 25, 2026</td>
                </tr>
            </tbody>
        </table>
    </div>

    <div class="bg-white rounded-b-xl border-x border-b border-gray-200 p-4 flex justify-between items-center text-[10px] text-gray-400 font-bold uppercase tracking-widest">
        <div>Showing 1 - 3 of 10</div>
        <div class="flex items-center space-x-6">
            <div class="flex items-center space-x-2">
                <span>Records per page</span>
                <select class="border border-gray-300 rounded px-2 py-0.5 bg-white text-gray-600 outline-none">
                    <option>10</option>
                </select>
            </div>
            <div class="flex items-center space-x-1">
                <button class="px-2 py-1 border border-gray-300 rounded hover:bg-gray-50">&lt;</button>
                <button class="px-3 py-1 bg-gray-600 text-white rounded shadow-md">1</button>
                <button class="px-2 py-1 border border-gray-300 rounded hover:bg-gray-50">&gt;</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        const actionsMenu = document.getElementById('actionsMenu');

        function toggleActions(e) {
            e.stopPropagation();
            actionsMenu.classList.toggle('hidden');
        }

        window.onclick = function(event) {
            if (!event.target.closest('.relative')) {
                if (actionsMenu) actionsMenu.classList.add('hidden');
            }
        }
    </script>
}