@page
@model LeKatsuMNL.Pages.Dashboard.CategoryModel
@using LeKatsuMNL.Helpers
@{
    ViewData["Title"] = "Inventory Categories";
    Layout = "_DashboardLayout";
}

@section TitleActions {
    @if (PermissionHelper.HasPermission(User, "Category", 'C'))
    {
        <button onclick="openModal('createCategoryModal')" class="bg-[#C41E24] text-white px-6 py-2.5 rounded-xl font-bold text-sm shadow-lg hover:bg-[#a51a1f] transition-all flex items-center">
            <i class="bi bi-plus-lg mr-2"></i> New Category
        </button>
    }
}

<div class="h-[calc(100vh-12rem)] flex flex-col">
    <!-- Top toolbar -->
    <div class="bg-white rounded-t-xl border border-gray-200 p-5 flex items-center justify-between shadow-sm dark:bg-slate-800 dark:border-gray-700">
        <div class="relative flex-1 max-w-lg">
            <span class="absolute inset-y-0 left-4 flex items-center text-gray-400 dark:text-gray-500">
                <i class="bi bi-search text-sm"></i>
            </span>
            <input type="text" id="categorySearchInput" class="w-full border border-gray-300 rounded-lg pl-11 pr-4 py-2.5 text-sm focus:ring-1 focus:ring-[#C41E24] outline-none placeholder:text-gray-400 dark:bg-white dark:placeholder:text-gray-400 dark:border-gray-600 dark:text-gray-800" placeholder="Search categories...">
        </div>

        <button onclick="window.location.reload()" class="flex items-center space-x-3 border border-gray-300 rounded-lg px-5 py-2.5 text-sm text-gray-600 hover:bg-gray-50 transition-all font-medium dark:hover:bg-slate-700/50 dark:text-gray-300 dark:border-gray-600">
            <i class="bi bi-arrow-clockwise text-base"></i> <span>Refresh Data</span>
        </button>
    </div>

    <!-- Table content -->
    <div class="flex-1 overflow-auto bg-white border-x border-b border-gray-200 shadow-sm dark:bg-slate-800 dark:border-gray-700 custom-scrollbar">
        <table class="w-full text-left text-xs whitespace-nowrap">
            <thead class="bg-gray-50 text-gray-500 uppercase tracking-wider font-bold border-b border-gray-100 dark:bg-slate-700/50 dark:text-gray-400 dark:border-gray-700 sticky top-0 z-10 backdrop-blur-sm">
                <tr>
                    <th class="px-8 py-4">Category</th>
                    <th class="px-8 py-4">Sub-Categories</th>
                    <th class="px-8 py-4 text-right w-24">Action</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-gray-100 dark:divide-gray-700" id="categoryTableBody">
                @if (Model.Categories != null && Model.Categories.Any())
                {
                    foreach (var category in Model.Categories)
                    {
                        <tr class="hover:bg-gray-50 transition-colors border-t border-gray-100 dark:hover:bg-slate-700/50 dark:border-gray-700">
                            <td class="px-8 py-5 font-bold text-gray-800 text-sm dark:text-white">@category.CategoryName</td>
                            <td class="px-8 py-5">
                                <div class="flex flex-wrap gap-2">
                                    @{
                                        var subCats = string.IsNullOrEmpty(category.SubCategoryNames) 
                                            ? new[] { "-" } 
                                            : category.SubCategoryNames.Split(',', StringSplitOptions.RemoveEmptyEntries);
                                        
                                        foreach(var sub in subCats)
                                        {
                                            var displaySub = sub.Trim();
                                            if (displaySub == "-") {
                                                <span class="text-gray-400 italic">No subcategories</span>
                                            } else {
                                                <span class="inline-flex items-center px-2.5 py-1 rounded-full text-[10px] font-bold bg-[#C41E24]/5 text-[#C41E24] border border-[#C41E24]/10 dark:bg-red-900/20 dark:text-red-400">
                                                    @displaySub
                                                </span>
                                            }
                                        }
                                    }
                                </div>
                            </td>
                            <td class="px-8 py-5 text-right">
                                <div class="flex items-center justify-end space-x-2">
                                    @if (PermissionHelper.HasPermission(User, "Category", 'U'))
                                    {
                                        <button onclick="openEditCategoryModal('@category.CategoryId', '@category.CategoryName', '@category.SubCategoryNames')" 
                                                class="px-3 py-1.5 bg-gray-100 text-gray-600 rounded-lg text-xs font-bold hover:bg-gray-200 transition-all dark:bg-slate-700 dark:text-gray-300">
                                            Update
                                        </button>
                                    }
                                    @if (PermissionHelper.HasPermission(User, "Category", 'D'))
                                    {
                                        <form method="post" asp-page-handler="Delete" asp-route-id="@category.CategoryId" class="inline m-0" onsubmit="return confirm('Note: Deleting a category will also affect items under its subcategories. Continue?')">
                                            <button type="submit" class="px-3 py-1.5 bg-gray-100 text-gray-600 rounded-lg text-xs font-bold hover:bg-red-50 hover:text-red-600 transition-all dark:bg-slate-700 dark:text-gray-300">
                                                Delete
                                            </button>
                                        </form>
                                    }
                                </div>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="3" class="px-8 py-16 text-center text-gray-400 italic text-sm dark:text-gray-500">
                            No categories found. Click "New Category" to add one.
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
    
    <partial name="_Pagination" model="Model.Categories" />
</div>

<!-- Create Category Modal -->
<div id="createCategoryModal" class="fixed inset-0 bg-black/40 hidden flex items-center justify-center z-[100] backdrop-blur-[2px] transition-all duration-300">
    <div class="bg-white rounded-2xl shadow-2xl w-full max-w-md mx-4 overflow-hidden border border-gray-100 transform transition-all opacity-0 scale-95 dark:bg-slate-800 dark:border-gray-700">
        <div class="px-8 py-6 border-b border-gray-50 flex justify-between items-center bg-white dark:bg-slate-800 dark:border-gray-700">
            <h3 class="text-base font-bold text-gray-900 dark:text-white">Create Category</h3>
            <button onclick="closeModal('createCategoryModal')" class="text-gray-500 hover:text-gray-700 transition-colors dark:text-gray-400">
                <i class="bi bi-x-lg text-xl"></i>
            </button>
        </div>

        <form method="post" asp-page-handler="Create" class="p-8 space-y-5" onsubmit="return syncSubCategoriesBeforeSubmit(this)">
            <input type="hidden" asp-for="NewCategory.SubCategoryNames" id="createSubCategoryNames" />
            <div class="space-y-1.5">
                <label class="block text-xs font-bold text-gray-700 uppercase tracking-widest ml-1 dark:text-gray-200">Category name</label>
                <input asp-for="NewCategory.CategoryName" placeholder="Category name" required
                       class="w-full border border-gray-200 rounded-xl px-5 py-3 text-sm outline-none focus:ring-2 focus:ring-[#C41E24]/20 focus:border-[#C41E24] bg-white transition-all placeholder:text-gray-500 text-gray-800 shadow-sm font-medium dark:bg-slate-800 dark:text-white dark:placeholder:text-gray-400 dark:border-gray-700">
            </div>

            <div class="space-y-3">
                <div class="flex justify-between items-center px-1">
                    <label class="block text-xs font-bold text-gray-700 uppercase tracking-widest dark:text-gray-200">Subcategories</label>
                    <button type="button" onclick="addSubCategoryRow('createSubCategoryContainer')" class="text-[#C41E24] hover:text-red-700 transition-colors flex items-center space-x-1">
                        <i class="bi bi-plus-circle-fill"></i>
                        <span class="text-[10px] font-black uppercase tracking-widest">Add</span>
                    </button>
                </div>
                <div id="createSubCategoryContainer" class="space-y-2 max-h-48 overflow-y-auto custom-scrollbar pr-1">
                    <div class="flex items-center space-x-2 group">
                        <input type="text" placeholder="Sub-Category name" required
                               class="sub-input flex-1 border border-gray-200 rounded-xl px-4 py-2.5 text-sm outline-none focus:ring-2 focus:ring-[#C41E24]/20 focus:border-[#C41E24] bg-white transition-all dark:bg-slate-800 dark:text-white dark:border-gray-700">
                    </div>
                </div>
            </div>

            <div class="flex justify-end space-x-4 pt-4">
                <button type="button" onclick="closeModal('createCategoryModal')"
                        class="px-8 py-3 rounded-xl text-xs font-bold text-gray-500 uppercase tracking-widest hover:bg-gray-100 transition-all dark:hover:bg-slate-700 dark:text-gray-400">
                    Cancel
                </button>
                <button type="submit"
                        class="px-12 py-3 bg-[#C41E24] text-white rounded-xl text-xs font-bold uppercase tracking-widest hover:bg-[#a51a1f] shadow-lg hover:shadow-red-200 transition-all transform active:scale-95">
                    Submit
                </button>
            </div>
        </form>
    </div>
</div>

<!-- Edit Category Modal -->
<div id="editCategoryModal" class="fixed inset-0 bg-black/40 hidden flex items-center justify-center z-[100] backdrop-blur-[2px] transition-all duration-300">
    <div class="bg-white rounded-2xl shadow-2xl w-full max-w-md mx-4 overflow-hidden border border-gray-100 transform transition-all opacity-0 scale-95 dark:bg-slate-800 dark:border-gray-700">
        <div class="px-8 py-6 border-b border-gray-50 flex justify-between items-center bg-white dark:bg-slate-800 dark:border-gray-700">
            <h3 class="text-base font-bold text-gray-900 dark:text-white">Edit Category</h3>
            <button onclick="closeModal('editCategoryModal')" class="text-gray-500 hover:text-gray-700 transition-colors dark:text-gray-400">
                <i class="bi bi-x-lg text-xl"></i>
            </button>
        </div>

        <form method="post" asp-page-handler="Update" class="p-8 space-y-5" onsubmit="return syncSubCategoriesBeforeSubmit(this)">
            <input type="hidden" asp-for="EditCategory.CategoryId" id="editCategoryId" />
            <input type="hidden" asp-for="EditCategory.SubCategoryNames" id="editSubCategoryNames" />
            <div class="space-y-1.5">
                <label class="block text-xs font-bold text-gray-700 uppercase tracking-widest ml-1 dark:text-gray-200">Category name</label>
                <input asp-for="EditCategory.CategoryName" id="editCategoryName" placeholder="Category name" required
                       class="w-full border border-gray-200 rounded-xl px-5 py-3 text-sm outline-none focus:ring-2 focus:ring-[#C41E24]/20 focus:border-[#C41E24] bg-white transition-all placeholder:text-gray-500 text-gray-800 shadow-sm font-medium dark:bg-slate-800 dark:text-white dark:placeholder:text-gray-400 dark:border-gray-700">
            </div>

            <div class="space-y-3">
                <div class="flex justify-between items-center px-1">
                    <label class="block text-xs font-bold text-gray-700 uppercase tracking-widest dark:text-gray-200">Subcategories</label>
                    <button type="button" onclick="addSubCategoryRow('editSubCategoryContainer')" class="text-[#C41E24] hover:text-red-700 transition-colors flex items-center space-x-1">
                        <i class="bi bi-plus-circle-fill"></i>
                        <span class="text-[10px] font-black uppercase tracking-widest">Add</span>
                    </button>
                </div>
                <div id="editSubCategoryContainer" class="space-y-2 max-h-48 overflow-y-auto custom-scrollbar pr-1">
                    <!-- Dynamic Rows -->
                </div>
            </div>

            <div class="flex justify-end space-x-4 pt-4">
                <button type="button" onclick="closeModal('editCategoryModal')"
                        class="px-8 py-3 rounded-xl text-xs font-bold text-gray-500 uppercase tracking-widest hover:bg-gray-100 transition-all dark:hover:bg-slate-700 dark:text-gray-400">
                    Cancel
                </button>
                <button type="submit"
                        class="px-12 py-3 bg-[#C41E24] text-white rounded-xl text-xs font-bold uppercase tracking-widest hover:bg-[#a51a1f] shadow-lg hover:shadow-red-200 transition-all transform active:scale-95">
                    Save
                </button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <script>
        function openModal(modalId) {
            const modal = document.getElementById(modalId);
            const content = modal.querySelector('div');
            modal.classList.remove('hidden');
            document.body.style.overflow = 'hidden';

            setTimeout(() => {
                content.classList.remove('opacity-0', 'scale-95');
                content.classList.add('opacity-100', 'scale-100');
            }, 10);
        }

        function closeModal(modalId) {
            const modal = document.getElementById(modalId);
            const content = modal.querySelector('div');
            
            content.classList.add('opacity-0', 'scale-95');
            content.classList.remove('opacity-100', 'scale-100');
            
            setTimeout(() => {
                modal.classList.add('hidden');
                document.body.style.overflow = 'auto';
            }, 300);
        }

        function addSubCategoryRow(containerId, value = '') {
            const container = document.getElementById(containerId);
            const row = document.createElement('div');
            row.className = 'flex items-center space-x-2 group animate-in fade-in slide-in-from-left-2 duration-300';
            row.innerHTML = `
                <input type="text" value="${value}" placeholder="Subcategory name" required
                       class="sub-input flex-1 border border-gray-200 rounded-xl px-4 py-2.5 text-sm outline-none focus:ring-2 focus:ring-[#C41E24]/20 focus:border-[#C41E24] bg-white transition-all dark:bg-slate-800 dark:text-white dark:border-gray-700">
                <button type="button" onclick="removeSubCategoryRow(this)" 
                        class="p-2.5 text-gray-400 hover:text-red-500 hover:bg-red-50 rounded-lg transition-all dark:hover:bg-red-900/10">
                    <i class="bi bi-trash3"></i>
                </button>
            `;
            container.appendChild(row);
        }

        function removeSubCategoryRow(button) {
            const row = button.closest('.flex');
            row.classList.add('animate-out', 'fade-out', 'zoom-out-95', 'duration-200');
            setTimeout(() => row.remove(), 200);
        }

        function syncSubCategoriesBeforeSubmit(form) {
            const container = form.querySelector('[id$="SubCategoryContainer"]');
            const hiddenInput = form.querySelector('[id$="SubCategoryNames"]');
            const inputs = container.querySelectorAll('.sub-input');
            const values = Array.from(inputs).map(i => i.value.trim()).filter(v => v !== '');
            hiddenInput.value = values.join(', ');
            return true;
        }

        function openEditCategoryModal(id, name, subCategoryNames) {
            document.getElementById('editCategoryId').value = id;
            document.getElementById('editCategoryName').value = name;
            document.getElementById('editSubCategoryNames').value = subCategoryNames;
            
            const container = document.getElementById('editSubCategoryContainer');
            container.innerHTML = '';
            
            const subCats = subCategoryNames ? subCategoryNames.split(',').map(s => s.trim()).filter(s => s !== '') : [];
            if (subCats.length === 0) {
                addSubCategoryRow('editSubCategoryContainer');
            } else {
                subCats.forEach(sub => addSubCategoryRow('editSubCategoryContainer', sub));
            }
            
            openModal('editCategoryModal');
        }

        // Search logic
        document.getElementById('categorySearchInput')?.addEventListener('input', function(e) {
            const searchTerm = e.target.value.toLowerCase();
            const rows = document.querySelectorAll('#categoryTableBody tr');
            
            rows.forEach(row => {
               const text = row.innerText.toLowerCase();
               if (row.querySelector('td[colspan]')) return;
               row.style.display = text.includes(searchTerm) ? '' : 'none';
            });
        });

        window.onclick = function(event) {
            if (event.target.classList.contains('fixed')) {
                const modalId = event.target.id;
                closeModal(modalId);
            }
        }

        // Close on escape
        document.addEventListener('keydown', (e) => {
            if (e.key === 'Escape') {
                const openModals = document.querySelectorAll('.fixed:not(.hidden)');
                openModals.forEach(modal => closeModal(modal.id));
            }
        });
    </script>
}