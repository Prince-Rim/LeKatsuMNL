@page
@model LeKatsuMNL.Pages.Dashboard.CategoryModel
@{
    ViewData["Title"] = "Inventory Categories";
    Layout = "_DashboardLayout";
}

@section TitleActions {
    <button onclick="openModal('createCategoryModal')" class="bg-[#C41E24] text-white px-6 py-2.5 rounded-xl font-bold text-sm shadow-lg hover:bg-[#a51a1f] transition-all flex items-center">
        <i class="bi bi-plus-lg mr-2"></i> New Category
    </button>
}

<div class="space-y-6">
    <!-- Search and Refresh -->
    <div class="flex items-center justify-between gap-4">
        <div class="relative flex-1 max-w-sm">
            <i class="bi bi-search absolute left-4 top-1/2 -translate-y-1/2 text-gray-400 dark:text-gray-500"></i>
            <input type="text" id="categorySearch" placeholder="Search categories..." 
                   class="w-full pl-11 pr-4 py-2.5 bg-white border border-gray-200 rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-[#C41E24]/10 focus:border-[#C41E24] transition-all dark:bg-slate-800 dark:border-gray-700">
        </div>
        <button onclick="window.location.reload()" class="px-6 py-2.5 bg-gray-100 text-gray-600 rounded-xl font-bold text-sm hover:bg-gray-200 transition-all dark:bg-slate-700 dark:text-gray-300">
            Refresh
        </button>
    </div>

    <!-- Categories Table -->
    <div class="overflow-x-auto bg-white rounded-2xl border border-gray-200 shadow-sm dark:bg-slate-800 dark:border-gray-700">
        <table class="w-full text-left border-collapse">
            <thead>
                <tr class="bg-gray-50/50 border-b border-gray-100 dark:border-gray-700">
                    <th class="px-6 py-4 text-xs font-bold text-gray-400 uppercase tracking-wider dark:text-gray-500">Category name</th>
                    <th class="px-6 py-4 text-xs font-bold text-gray-400 uppercase tracking-wider dark:text-gray-500">Description</th>
                    <th class="px-6 py-4 text-xs font-bold text-gray-400 uppercase tracking-wider text-right dark:text-gray-500">Actions</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-gray-50 dark:divide-gray-700" id="categoryTableBody">
                @if (Model.Categories != null && Model.Categories.Any())
                {
                    foreach (var category in Model.Categories)
                    {
                        <tr class="hover:bg-gray-50/50 transition-colors">
                            <td class="px-6 py-4 text-sm font-semibold text-gray-700 dark:text-gray-200">@category.CategoryName</td>
                            <td class="px-6 py-4 text-sm text-gray-500 font-medium dark:text-gray-400">@(string.IsNullOrEmpty(category.Description) ? "-" : category.Description)</td>
                            <td class="px-6 py-4 text-right space-x-2">
                                <button onclick="openEditCategoryModal('@category.CategoryId', '@category.CategoryName', '@category.Description')" 
                                        class="px-4 py-1.5 bg-gray-100 text-gray-600 rounded-lg text-xs font-bold hover:bg-gray-200 transition-all dark:bg-slate-700 dark:text-gray-300">
                                    Update
                                </button>
                                <form method="post" asp-page-handler="Delete" asp-route-id="@category.CategoryId" class="inline" onsubmit="return confirm('Are you sure you want to delete this category?')">
                                    <button type="submit" class="px-4 py-1.5 bg-gray-100 text-gray-600 rounded-lg text-xs font-bold hover:bg-red-50 hover:text-red-600 transition-all dark:bg-slate-700 dark:text-gray-300">
                                        Delete
                                    </button>
                                </form>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="3" class="px-6 py-12 text-center text-gray-400 italic text-sm dark:text-gray-500">
                            No categories found. Click "New Category" to add one.
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <!-- Pagination -->
    <div class="flex items-center justify-between px-2 text-xs text-gray-400 font-bold uppercase tracking-widest dark:text-gray-500">
        <p>Showing 1 - @(Model.Categories?.Count ?? 0) of @(Model.Categories?.Count ?? 0)</p>
        <div class="flex items-center space-x-6">
            <div class="flex items-center space-x-3">
                <span>Records per page</span>
                <div class="px-3 py-1 bg-gray-100 rounded-lg text-gray-700 dark:bg-slate-700 dark:text-gray-200">10</div>
            </div>
            <div class="flex items-center space-x-2">
                <button class="w-8 h-8 flex items-center justify-center bg-gray-100 rounded-lg text-gray-400 hover:bg-gray-200 transition-all dark:bg-slate-700 dark:text-gray-500">&lt;</button>
                <button class="w-8 h-8 flex items-center justify-center bg-[#C41E24] text-white rounded-lg shadow-md">1</button>
                <button class="w-8 h-8 flex items-center justify-center bg-gray-100 rounded-lg text-gray-400 hover:bg-gray-200 transition-all dark:bg-slate-700 dark:text-gray-500">&gt;</button>
            </div>
        </div>
    </div>
</div>

<!-- Create Category Modal -->
<div id="createCategoryModal" class="fixed inset-0 bg-black/40 hidden flex items-center justify-center z-[100] backdrop-blur-[2px] transition-all duration-300">
    <div class="bg-white rounded-2xl shadow-2xl w-full max-w-md mx-4 overflow-hidden border border-gray-100 transform transition-all opacity-0 scale-95 dark:bg-slate-800 dark:border-gray-700">
        <div class="px-8 py-6 border-b border-gray-50 flex justify-between items-center bg-white dark:bg-slate-800 dark:border-gray-700">
            <h3 class="text-base font-bold text-gray-900 dark:text-white">Create Category</h3>
            <button onclick="closeModal('createCategoryModal')" class="text-gray-500 hover:text-gray-700 transition-colors dark:text-gray-400">
                <i class="bi bi-x-lg text-xl"></i>
            </button>
        </div>

        <form method="post" asp-page-handler="Create" class="p-8 space-y-5">
            <div class="space-y-1.5">
                <label class="block text-xs font-bold text-gray-700 uppercase tracking-widest ml-1 dark:text-gray-200">Category name</label>
                <input asp-for="NewCategory.CategoryName" placeholder="Category name" required
                       class="w-full border border-gray-200 rounded-xl px-5 py-3 text-sm outline-none focus:ring-2 focus:ring-[#C41E24]/20 focus:border-[#C41E24] bg-white transition-all placeholder:text-gray-500 text-gray-800 shadow-sm font-medium dark:bg-slate-800 dark:text-white dark:placeholder:text-gray-400 dark:border-gray-700">
            </div>

            <div class="space-y-1.5">
                <label class="block text-xs font-bold text-gray-700 uppercase tracking-widest ml-1 dark:text-gray-200">Description</label>
                <textarea asp-for="NewCategory.Description" rows="4" placeholder="Description"
                          class="w-full border border-gray-200 rounded-xl px-5 py-3 text-sm outline-none focus:ring-2 focus:ring-[#C41E24]/20 focus:border-[#C41E24] bg-white transition-all resize-none placeholder:text-gray-500 text-gray-800 shadow-sm font-medium dark:bg-slate-800 dark:text-white dark:placeholder:text-gray-400 dark:border-gray-700"></textarea>
            </div>

            <div class="flex justify-end space-x-4 pt-8">
                <button type="button" onclick="closeModal('createCategoryModal')"
                        class="px-8 py-3 rounded-xl text-xs font-bold text-gray-500 uppercase tracking-widest hover:bg-gray-100 transition-all dark:hover:bg-slate-700 dark:text-gray-400">
                    Cancel
                </button>
                <button type="submit"
                        class="px-12 py-3 bg-[#C41E24] text-white rounded-xl text-xs font-bold uppercase tracking-widest hover:bg-[#a51a1f] shadow-lg hover:shadow-red-200 transition-all transform active:scale-95">
                    Submit
                </button>
            </div>
        </form>
    </div>
</div>

<!-- Edit Category Modal -->
<div id="editCategoryModal" class="fixed inset-0 bg-black/40 hidden flex items-center justify-center z-[100] backdrop-blur-[2px] transition-all duration-300">
    <div class="bg-white rounded-2xl shadow-2xl w-full max-w-md mx-4 overflow-hidden border border-gray-100 transform transition-all opacity-0 scale-95 dark:bg-slate-800 dark:border-gray-700">
        <div class="px-8 py-6 border-b border-gray-50 flex justify-between items-center bg-white dark:bg-slate-800 dark:border-gray-700">
            <h3 class="text-base font-bold text-gray-900 dark:text-white">Edit Category</h3>
            <button onclick="closeModal('editCategoryModal')" class="text-gray-500 hover:text-gray-700 transition-colors dark:text-gray-400">
                <i class="bi bi-x-lg text-xl"></i>
            </button>
        </div>

        <form method="post" asp-page-handler="Update" class="p-8 space-y-5">
            <input type="hidden" asp-for="EditCategory.CategoryId" id="editCategoryId" />
            <div class="space-y-1.5">
                <label class="block text-xs font-bold text-gray-700 uppercase tracking-widest ml-1 dark:text-gray-200">Category name</label>
                <input asp-for="EditCategory.CategoryName" id="editCategoryName" placeholder="Category name" required
                       class="w-full border border-gray-200 rounded-xl px-5 py-3 text-sm outline-none focus:ring-2 focus:ring-[#C41E24]/20 focus:border-[#C41E24] bg-white transition-all placeholder:text-gray-500 text-gray-800 shadow-sm font-medium dark:bg-slate-800 dark:text-white dark:placeholder:text-gray-400 dark:border-gray-700">
            </div>

            <div class="space-y-1.5">
                <label class="block text-xs font-bold text-gray-700 uppercase tracking-widest ml-1 dark:text-gray-200">Description</label>
                <textarea asp-for="EditCategory.Description" id="editCategoryDescription" rows="4" placeholder="Description"
                          class="w-full border border-gray-200 rounded-xl px-5 py-3 text-sm outline-none focus:ring-2 focus:ring-[#C41E24]/20 focus:border-[#C41E24] bg-white transition-all resize-none placeholder:text-gray-500 text-gray-800 shadow-sm font-medium dark:bg-slate-800 dark:text-white dark:placeholder:text-gray-400 dark:border-gray-700"></textarea>
            </div>

            <div class="flex justify-end space-x-4 pt-8">
                <button type="button" onclick="closeModal('editCategoryModal')"
                        class="px-8 py-3 rounded-xl text-xs font-bold text-gray-500 uppercase tracking-widest hover:bg-gray-100 transition-all dark:hover:bg-slate-700 dark:text-gray-400">
                    Cancel
                </button>
                <button type="submit"
                        class="px-12 py-3 bg-[#C41E24] text-white rounded-xl text-xs font-bold uppercase tracking-widest hover:bg-[#a51a1f] shadow-lg hover:shadow-red-200 transition-all transform active:scale-95">
                    Save
                </button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <script>
        function openModal(modalId) {
            const modal = document.getElementById(modalId);
            const content = modal.querySelector('div');
            modal.classList.remove('hidden');
            document.body.style.overflow = 'hidden';

            setTimeout(() => {
                content.classList.remove('opacity-0', 'scale-95');
                content.classList.add('opacity-100', 'scale-100');
            }, 10);
        }

        function closeModal(modalId) {
            const modal = document.getElementById(modalId);
            const content = modal.querySelector('div');
            
            content.classList.add('opacity-0', 'scale-95');
            content.classList.remove('opacity-100', 'scale-100');
            
            setTimeout(() => {
                modal.classList.add('hidden');
                document.body.style.overflow = 'auto';
            }, 300);
        }

        function openEditCategoryModal(id, name, description) {
            document.getElementById('editCategoryId').value = id;
            document.getElementById('editCategoryName').value = name;
            document.getElementById('editCategoryDescription').value = description;
            openModal('editCategoryModal');
        }

        // Search logic
        document.getElementById('categorySearch')?.addEventListener('input', function(e) {
            const searchTerm = e.target.value.toLowerCase();
            const rows = document.querySelectorAll('#categoryTableBody tr');
            
            rows.forEach(row => {
               const text = row.textContent.toLowerCase();
               if (row.querySelector('td[colspan]')) return;
               row.style.display = text.includes(searchTerm) ? '' : 'none';
            });
        });

        window.onclick = function(event) {
            if (event.target.classList.contains('fixed')) {
                const modalId = event.target.id;
                closeModal(modalId);
            }
        }

        // Close on escape
        document.addEventListener('keydown', (e) => {
            if (e.key === 'Escape') {
                const openModals = document.querySelectorAll('.fixed:not(.hidden)');
                openModals.forEach(modal => closeModal(modal.id));
            }
        });
    </script>
}