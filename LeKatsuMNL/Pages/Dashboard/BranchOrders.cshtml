@page
@model LeKatsuMNL.Pages.Dashboard.BranchOrdersModel
@{
    ViewData["Title"] = "Transaction / Branch Orders";
}

<style>
    @@media print {
        /* Hide UI elements */
        #sidebar, 
        form, 
        .relative.inline-block.text-left, /* Actions menu */
        .px-8.py-4:first-child, /* Checkbox header */
        .px-8.py-5:first-child, /* Checkbox cell */
        .px-8.py-4:last-child,  /* Action header */
        .px-8.py-5:last-child,   /* Action cell */
        .pagination-container,
        nav,
        button {
            display: none !important;
        }

        /* Reset layout for print */
        body {
            background: white !important;
            margin: 0 !important;
            padding: 20px !important;
        }

        .bg-white {
            border: none !important;
            box-shadow: none !important;
        }

        table {
            width: 100% !important;
            border-collapse: collapse !important;
            border: 1px solid #eee !important;
        }

        th, td {
            border: 1px solid #eee !important;
            padding: 12px 8px !important;
            white-space: normal !important;
        }

        /* Ensure text is black and crisp */
        * {
            color: black !important;
            -webkit-print-color-adjust: exact !important;
            print-color-adjust: exact !important;
        }

        .text-\[#C41E24\] {
            color: #bc1b21 !important;
        }
    }
</style>



    <form method="get" class="bg-white rounded-t-xl border border-gray-200 p-5 flex items-center justify-between shadow-sm dark:bg-slate-800 dark:border-gray-700">
        <div class="flex items-center space-x-4 flex-1 max-w-4xl">
            <div class="relative inline-block text-left">
                <button type="button" onclick="toggleActions(event)" class="flex items-center space-x-3 border border-gray-300 rounded-lg px-4 py-2 text-sm text-gray-500 bg-white hover:bg-gray-50 outline-none transition-all dark:bg-slate-800 dark:hover:bg-slate-700/50 dark:text-gray-400 dark:border-gray-600">
                    <span>Actions</span>
                    <i class="bi bi-chevron-down text-xs"></i>
                </button>
                <div id="actionsMenu" class="hidden absolute left-0 mt-2 w-48 bg-white rounded-xl shadow-xl border border-gray-100 z-[70] overflow-hidden transform origin-top-left transition-all dark:bg-slate-800 dark:border-gray-700">
                    <a asp-page-handler="Export" class="w-full block text-left px-5 py-3 text-xs font-bold text-gray-600 uppercase tracking-widest hover:bg-gray-50 border-b border-gray-50 dark:hover:bg-slate-700/50 dark:text-gray-300 dark:border-gray-700">Export List</a>
                    <button type="button" onclick="printOrders()" class="w-full text-left px-5 py-3 text-xs font-bold text-gray-600 uppercase tracking-widest hover:bg-gray-50 border-b border-gray-50 dark:hover:bg-slate-700/50 dark:text-gray-300 dark:border-gray-700">Print Table</button>
                    <button type="button" onclick="handleBulkArchive()" class="w-full text-left px-5 py-3 text-xs font-bold text-red-500 uppercase tracking-widest hover:bg-red-50 transition-colors">Bulk Archive</button>
                </div>
            </div>
 
            <div class="relative flex-1 group">
                <span class="absolute inset-y-0 left-4 flex items-center text-gray-400 dark:text-gray-500">
                    <i class="bi bi-search text-sm"></i>
                </span>
                <input type="text" name="searchTerm" value="@Model.SearchTerm" 
                       class="w-full border border-gray-300 rounded-lg pl-11 pr-32 py-2 text-sm focus:ring-1 focus:ring-[#C41E24] outline-none placeholder:text-gray-400 dark:bg-white dark:text-gray-800 dark:placeholder:text-gray-500 dark:border-gray-600" 
                       placeholder="Search Order ID or Branch...">
                <div class="absolute inset-y-1 right-1 flex items-center">
                    <button type="submit" class="h-full px-4 bg-[#C41E24] text-white rounded-md text-xs font-bold hover:bg-[#a51a1f] transition-colors flex items-center space-x-2">
                        <i class="bi bi-search"></i>
                        <span>Search</span>
                    </button>
                </div>
            </div>
        </div>
 
        <div class="flex items-center space-x-4">
            <button type="button" onclick="openCreateOrderModal()" class="px-5 py-2.5 bg-[#C41E24] text-white rounded-lg text-xs font-bold uppercase tracking-widest hover:bg-red-700 transition-all shadow-md flex items-center">
                 <i class="bi bi-plus-lg mr-2"></i> Create New Invoice
            </button>
             <button type="button" onclick="location.reload()" class="flex items-center space-x-3 border border-gray-300 rounded-lg px-4 py-2 text-sm text-gray-600 hover:bg-gray-50 transition-colors dark:hover:bg-slate-700/50 dark:text-gray-300 dark:border-gray-600">
                <i class="bi bi-arrow-clockwise text-base"></i>
                <span>Refresh</span>
            </button>
        </div>
    </form>

    <div class="bg-white border-x border-b border-gray-200 shadow-sm overflow-hidden dark:bg-slate-800 dark:border-gray-700">
        <table class="w-full text-left text-xs whitespace-nowrap">
            <thead class="bg-gray-50 text-gray-500 uppercase tracking-wider font-bold border-b border-gray-100 dark:bg-slate-700/50 dark:text-gray-400 dark:border-gray-700">
                <tr>
                    <th class="px-8 py-4"><input type="checkbox" id="selectAll" onclick="toggleSelectAll(this)" aria-label="Select all orders" class="w-4 h-4 rounded border-gray-300 text-[#C41E24] focus:ring-[#C41E24] dark:border-gray-600"></th>
                    <th class="px-8 py-4">Order ID</th>
                    <th class="px-8 py-4">Branch</th>
                    <th class="px-8 py-4">Branch Manager</th>
                    <th class="px-8 py-4">Invoice Status</th>
                    <th class="px-8 py-4">Status</th>
                    <th class="px-8 py-4">Order Date</th>
                    <th class="px-8 py-4">Expected Date</th>
                    <th class="px-8 py-4 text-right">Action</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-gray-100 dark:divide-gray-700">
                @if (Model.Orders != null && Model.Orders.Any())
                {
                    foreach (var order in Model.Orders)
                    {
                        string formattedOrderId = $"{order.OrderDate.Year}-{order.OrderId:D4}";
                        <tr class="hover:bg-gray-50 transition-colors dark:hover:bg-slate-700/50">
                            <td class="px-8 py-5"><input type="checkbox" name="selectedOrders" value="@order.OrderId" aria-label="Select order @formattedOrderId" class="order-checkbox w-4 h-4 rounded border-gray-300 dark:border-gray-600 text-[#C41E24] focus:ring-[#C41E24]"></td>
                            <td class="px-8 py-5">
                                <a href="/Dashboard/OrderDetails?id=@formattedOrderId"
                                   class="text-[#C41E24] font-bold underline hover:text-red-800 transition-colors text-sm">
                                    @formattedOrderId
                                </a>
                            </td>
                            <td class="px-8 py-5 text-gray-600 font-medium text-sm dark:text-gray-300">@order.BranchManager?.BranchLocation?.BranchName</td>
                            <td class="px-8 py-5 text-gray-600 font-medium text-sm dark:text-gray-300">@(order.BranchManager?.FirstName) @(order.BranchManager?.LastName)</td>
                            <td class="px-8 py-5">
                                @if (order.Invoices != null && order.Invoices.Any())
                                {
                                    var paymentStatus = order.Invoices.First().PaymentStatus;
                                    var payClass = paymentStatus == "Paid" ? "bg-blue-50 text-blue-600 border-blue-100 dark:bg-blue-500/10 dark:text-blue-400" : "bg-amber-50 text-amber-600 border-amber-100 dark:bg-amber-500/10 dark:text-amber-400";
                                    <span class="px-3 py-1 rounded-full text-[10px] font-black uppercase tracking-widest border @payClass">
                                        @paymentStatus
                                    </span>
                                }
                                else
                                {
                                    <span class="text-gray-400 font-bold uppercase tracking-widest text-[10px]">No Invoice</span>
                                }
                            </td>
                            <td class="px-8 py-5">
                                @{
                                    var statusClass = order.Status?.ToLower() switch
                                    {
                                        "approved" => "bg-emerald-50 text-emerald-600 border-emerald-100 dark:bg-emerald-500/10 dark:text-emerald-400 dark:border-emerald-500/20",
                                        "preparing" => "bg-indigo-50 text-indigo-600 border-indigo-100 dark:bg-indigo-500/10 dark:text-indigo-400 dark:border-indigo-500/20",
                                        "delivered" => "bg-gray-50 text-gray-600 border-gray-100 dark:bg-slate-700 dark:text-gray-400 dark:border-gray-600",
                                        "pending" => "bg-amber-50 text-amber-600 border-amber-100 dark:bg-amber-500/10 dark:text-amber-400 dark:border-amber-500/20",
                                        "cancelled" => "bg-rose-50 text-rose-600 border-rose-100 dark:bg-rose-500/10 dark:text-rose-400 dark:border-rose-500/20",
                                        _ => "bg-gray-50 text-gray-600 border-gray-100 dark:bg-slate-700 dark:text-gray-400 dark:border-gray-600"
                                    };
                                }
                                <span class="px-3 py-1 rounded-full text-[10px] font-black uppercase tracking-widest border @statusClass">
                                    @(order.Status ?? "Unknown")
                                </span>
                            </td>
                            <td class="px-8 py-5 text-gray-500 text-sm dark:text-gray-400">@order.OrderDate.ToString("MMMM dd, yyyy")</td>
                            <td class="px-8 py-5 text-gray-500 text-sm dark:text-gray-400">@(order.DeliveryDate?.ToString("MMM dd, yyyy") ?? "-")</td>
                            <td class="px-8 py-5 text-right">
                                <form method="post" asp-page-handler="Archive" asp-route-id="@order.OrderId" class="inline m-0">
                                    <button type="submit" onclick="return confirm('Archive this order?')" class="px-3 py-1.5 bg-yellow-50 text-yellow-600 rounded-lg text-xs font-bold hover:bg-yellow-100 transition-all dark:bg-slate-700 dark:text-gray-500">Archive</button>
                                </form>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="9" class="px-8 py-10 text-center text-gray-400 italic">No orders found.</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <partial name="_Pagination" model="Model.Orders" />

@section Scripts {
    <script>
        const actionsMenu = document.getElementById('actionsMenu');
        function toggleActions(e) {
            e.stopPropagation();
            actionsMenu.classList.toggle('hidden');
        }
        window.onclick = function(event) {
            if (!event.target.closest('.relative')) {
                if(actionsMenu) actionsMenu.classList.add('hidden');
            }
        }

        function openCreateOrderModal() {
            const modal = document.getElementById('createOrderModal');
            const content = modal.querySelector('.inline-block');
            modal.classList.remove('hidden');
            document.body.style.overflow = 'hidden';
            setTimeout(() => {
                content.classList.remove('opacity-0', 'scale-95');
                content.classList.add('opacity-100', 'scale-100');
            }, 10);
        }

        function closeCreateOrderModal() {
            const modal = document.getElementById('createOrderModal');
            const content = modal.querySelector('.inline-block');
            content.classList.add('opacity-0', 'scale-95');
            content.classList.remove('opacity-100', 'scale-100');
            setTimeout(() => {
                modal.classList.add('hidden');
                document.body.style.overflow = 'auto';
                const form = modal.querySelector('form');
                if (form) {
                    form.reset();
                    // Reset Invoice Items to initial single empty row
                    const container = document.getElementById('orderItemsContainer');
                    const rows = container.querySelectorAll('.order-item-row');
                    rows.forEach((row, index) => {
                        if (index > 0) {
                            row.remove();
                        } else {
                            // Reset the first row inputs
                            row.querySelectorAll('input, select').forEach(input => {
                                input.value = '';
                            });
                            const totalSpan = row.querySelector('.row-total');
                            totalSpan.innerText = '₱ 0.00';
                            totalSpan.dataset.value = '0';
                        }
                    });
                    calculateGrandTotal();
                }
            }, 300);
        }

        const itemData = {
            @foreach (var item in Model.AvailableItems)
            {
                var key = item.SkuId.HasValue ? $"SKU-{item.SkuId}" : $"COM-{item.ComId}";
                <text>"@key": { "price": @item.SellingPrice, "name": "@item.ItemName", "type": "@item.Type" },</text>
            }
        };

        function calculateGrandTotal() {
            let grandTotal = 0;
            document.querySelectorAll('.order-item-row').forEach(row => {
                const total = parseFloat(row.querySelector('.row-total').dataset.value) || 0;
                grandTotal += total;
            });
            document.getElementById('grandTotalDisplay').innerText = `₱ ${grandTotal.toLocaleString('en-US', { minimumFractionDigits: 2, maximumFractionDigits: 2 })}`;
        }

        function updateRow(element) {
            const row = element.closest('.order-item-row');
            const itemId = row.querySelector('select[name="ItemIds"]').value;
            const qty = parseFloat(row.querySelector('input[name="Quantities"]').value) || 0;
            const priceInput = row.querySelector('input[name="Prices"]');
            
            // Only update price input if it was an item selection change
            if (element.name === "ItemIds" && itemId) {
                priceInput.value = (itemData[itemId]?.price || 0).toFixed(2);
            }

            const price = parseFloat(priceInput.value) || 0;
            const total = price * qty;
            row.querySelector('input[name="Prices"]').value = price.toFixed(2);
            const totalField = row.querySelector('.row-total');
            totalField.innerText = `₱ ${total.toLocaleString('en-US', { minimumFractionDigits: 2 })}`;
            totalField.dataset.value = total;
            
            calculateGrandTotal();
        }

        function addOrderItemRow() {
            const container = document.getElementById('orderItemsContainer');
            const newRow = `
                <div class="flex items-center gap-4 mb-3 order-item-row group">
                    <div class="flex-[2] min-w-[200px]">
                        <select name="ItemIds" required onchange="updateRow(this)" class="w-full bg-white border border-gray-200 rounded-lg px-4 py-2 text-sm font-bold text-gray-800 outline-none focus:border-[#C41E24] dark:bg-slate-800 dark:text-white dark:border-gray-700">
                            <option value="">Select Item</option>
                            ${Array.from(document.querySelectorAll('#itemTemplate option')).map(opt => `<option value="${opt.value}">${opt.text}</option>`).join('')}
                        </select>
                    </div>
                    <div class="w-24 text-center">
                        <div class="relative">
                            <span class="absolute left-2 top-1/2 -translate-y-1/2 text-gray-500 font-bold dark:text-gray-400 text-xs">₱</span>
                            <input type="number" name="Prices" placeholder="0.00" step="0.01" required oninput="updateRow(this)" class="w-full bg-white border border-gray-200 rounded-lg pl-5 pr-2 py-2 text-sm font-bold text-gray-800 outline-none focus:border-[#C41E24] dark:bg-slate-800 dark:text-white dark:border-gray-700">
                        </div>
                    </div>
                    <div class="w-24">
                        <input type="number" name="Quantities" placeholder="Qty" min="0.01" step="any" required oninput="updateRow(this)" class="w-full bg-white border border-gray-200 rounded-lg px-2 py-2 text-sm font-bold text-gray-800 outline-none focus:border-[#C41E24] dark:bg-slate-800 dark:text-white dark:border-gray-700">
                    </div>
                    <div class="w-28 text-right pr-2">
                        <span class="row-total text-sm font-black text-[#C41E24]" data-value="0">₱ 0.00</span>
                    </div>
                    <button type="button" onclick="this.closest('.order-item-row').remove(); calculateGrandTotal();" class="p-2 text-gray-400 hover:text-red-500 hover:bg-red-50 rounded-lg transition-all dark:hover:bg-red-500/10">
                        <i class="bi bi-trash text-lg"></i>
                    </button>
                </div>
            `;
            container.insertAdjacentHTML('beforeend', newRow);
        }

        function toggleSelectAll(master) {
            const checkboxes = document.getElementsByName('selectedOrders');
            checkboxes.forEach(cb => cb.checked = master.checked);
        }

        function handleBulkArchive() {
            const selected = Array.from(document.getElementsByName('selectedOrders'))
                .filter(cb => cb.checked)
                .map(cb => cb.value);

            if (selected.length === 0) {
                alert('Please select at least one order to archive.');
                return;
            }

            if (confirm(`Are you sure you want to archive ${selected.length} selected orders?`)) {
                document.getElementById('bulkArchiveIds').value = selected.join(',');
                document.getElementById('bulkArchiveForm').submit();
            }
        }

        function printOrders() {
            window.print();
        }
    </script>

    <form id="bulkArchiveForm" method="post" asp-page-handler="BulkArchive" class="hidden">
        <input type="hidden" name="ids" id="bulkArchiveIds">
    </form>
}

<!-- Create Order Modal -->
<div id="createOrderModal" class="fixed inset-0 z-[100] hidden overflow-y-auto">
    <div class="flex items-center justify-center min-h-screen px-4 pt-4 pb-20 text-center sm:block sm:p-0">
        <div class="fixed inset-0 transition-opacity bg-black/40 backdrop-blur-sm"></div>

        <span class="hidden sm:inline-block sm:align-middle sm:h-screen">&#8203;</span>

        <div class="inline-block align-bottom bg-white rounded-2xl text-left overflow-hidden shadow-2xl transform transition-all sm:my-8 sm:align-middle sm:max-w-3xl sm:w-full border border-gray-100 dark:bg-slate-800 dark:border-gray-700 opacity-0 scale-95 duration-300">
            <form method="post" asp-page-handler="CreateOrder">
                <div class="p-8">
                    <div class="flex items-center justify-between mb-8">
                        <h3 class="text-sm font-black text-gray-700 uppercase tracking-widest dark:text-gray-200">Create New Branch Invoice</h3>
                        <button type="button" onclick="closeCreateOrderModal()" class="text-gray-400 hover:text-gray-600 transition-colors dark:text-gray-500">
                            <i class="bi bi-x-lg text-lg"></i>
                        </button>
                    </div>

                    <div class="space-y-6">
                        <div>
                            <label class="block text-[10px] font-black text-gray-400 uppercase tracking-widest mb-2 ml-1 dark:text-gray-500">Branch Manager / Branch</label>
                            <select name="BranchManagerId" required class="w-full bg-white border border-gray-200 rounded-xl px-4 py-3 text-sm font-bold text-gray-800 outline-none focus:border-[#C41E24] transition-all dark:bg-slate-800 dark:text-white dark:border-gray-700">
                                <option value="">Select Branch Manager</option>
                                @foreach (var bm in Model.BranchManagers)
                                {
                                    <option value="@bm.BManagerId">@bm.FirstName @bm.LastName (@bm.BranchLocation?.BranchName)</option>
                                }
                            </select>
                        </div>

                        <div>
                            <div class="flex items-center justify-between mb-2 ml-1">
                                <label class="block text-[10px] font-black text-gray-400 uppercase tracking-widest dark:text-gray-500">Invoice Items</label>
                                <button type="button" onclick="addOrderItemRow()" class="text-[10px] font-black text-[#C41E24] uppercase tracking-widest hover:text-red-700 transition-colors">Add Invoice Item</button>
                            </div>
                            <div id="orderItemsContainer" class="max-h-[300px] overflow-y-auto pr-2 custom-scrollbar">
                                <div class="flex items-center gap-4 mb-2 px-2 border-b border-gray-100 pb-2">
                                    <div class="flex-[2] min-w-[200px] text-[9px] font-black text-gray-400 uppercase tracking-widest">Product / Ingredient</div>
                                    <div class="w-24 text-center text-[9px] font-black text-gray-400 uppercase tracking-widest">Price</div>
                                    <div class="w-24 text-center text-[9px] font-black text-gray-400 uppercase tracking-widest">Qty</div>
                                    <div class="w-28 text-right text-[9px] font-black text-gray-400 uppercase tracking-widest">Line Total</div>
                                    <div class="w-10"></div>
                                </div>
                                <div class="flex items-center gap-4 mb-3 order-item-row group">
                                    <div class="flex-[2] min-w-[200px]">
                                        <select name="ItemIds" required onchange="updateRow(this)" class="w-full bg-white border border-gray-200 rounded-lg px-4 py-2 text-sm font-bold text-gray-800 outline-none focus:border-[#C41E24] dark:bg-slate-800 dark:text-white dark:border-gray-700">
                                            <option value="">Select Item</option>
                                            @foreach (var item in Model.AvailableItems)
                                            {
                                                var key = item.SkuId.HasValue ? $"SKU-{item.SkuId}" : $"COM-{item.ComId}";
                                                <option value="@key">[@item.Type] @item.ItemName</option>
                                            }
                                        </select>
                                    </div>
                                    <div class="w-24 text-center">
                                        <div class="relative">
                                            <span class="absolute left-2 top-1/2 -translate-y-1/2 text-gray-500 font-bold dark:text-gray-400 text-xs">₱</span>
                                            <input type="number" name="Prices" placeholder="0.00" step="0.01" required oninput="updateRow(this)" class="w-full bg-white border border-gray-200 rounded-lg pl-5 pr-2 py-2 text-sm font-bold text-gray-800 outline-none focus:border-[#C41E24] dark:bg-slate-800 dark:text-white dark:border-gray-700">
                                        </div>
                                    </div>
                                    <div class="w-24 text-center">
                                        <input type="number" name="Quantities" placeholder="Qty" min="0.01" step="any" required oninput="updateRow(this)" class="w-full bg-white border border-gray-200 rounded-lg px-2 py-2 text-sm font-bold text-gray-800 outline-none focus:border-[#C41E24] dark:bg-slate-800 dark:text-white dark:border-gray-700">
                                    </div>
                                    <div class="w-28 text-right pr-2">
                                        <span class="row-total text-sm font-black text-[#C41E24]" data-value="0">₱ 0.00</span>
                                    </div>
                                    <div class="w-10"></div>
                                </div>
                            </div>
                            <!-- Grand Total Section -->
                            <div class="mt-4 pt-4 border-t border-gray-100 flex justify-between items-center px-2 dark:border-gray-700">
                                <span class="text-xs font-black text-gray-400 uppercase tracking-widest">Invoice Grand Total</span>
                                <span id="grandTotalDisplay" class="text-xl font-black text-[#C41E24]">₱ 0.00</span>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="p-6 bg-gray-50 border-t border-gray-100 flex justify-end space-x-3 dark:bg-slate-700/50 dark:border-gray-700">
                    <button type="button" onclick="closeCreateOrderModal()" class="px-6 py-2.5 text-xs font-black text-gray-500 uppercase tracking-widest hover:text-gray-700 transition-colors dark:text-gray-400">Cancel</button>
                    <button type="submit" class="px-8 py-2.5 bg-[#C41E24] text-white rounded-lg text-xs font-bold uppercase tracking-widest hover:bg-red-700 transition-all shadow-lg shadow-red-100">Create Invoice</button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Hidden template for Item options -->
<select id="itemTemplate" class="hidden">
    @foreach (var item in Model.AvailableItems)
    {
        var key = item.SkuId.HasValue ? $"SKU-{item.SkuId}" : $"COM-{item.ComId}";
        <option value="@key">[@item.Type] @item.ItemName</option>
    }
</select>