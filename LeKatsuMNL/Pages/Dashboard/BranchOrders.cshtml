@page
@model LeKatsuMNL.Pages.Dashboard.BranchOrdersModel
@{
    ViewData["Title"] = "Transaction / Branch Orders";
}



    <div class="bg-white rounded-t-xl border border-gray-200 p-5 flex items-center justify-between shadow-sm dark:bg-slate-800 dark:border-gray-700">
        <div class="flex items-center space-x-4">
            <div class="relative inline-block text-left">
                <button onclick="toggleActions(event)" class="flex items-center space-x-3 border border-gray-300 rounded-lg px-4 py-2 text-sm text-gray-500 bg-white hover:bg-gray-50 outline-none transition-all dark:bg-slate-800 dark:hover:bg-slate-700/50 dark:text-gray-400 dark:border-gray-600">
                    <span>Actions</span>
                    <i class="bi bi-chevron-down text-xs"></i>
                </button>
                <div id="actionsMenu" class="hidden absolute left-0 mt-2 w-40 bg-white rounded-xl shadow-xl border border-gray-100 z-[70] overflow-hidden transform origin-top-left transition-all dark:bg-slate-800 dark:border-gray-700">
                    <button class="w-full text-left px-5 py-3 text-xs font-bold text-gray-600 uppercase tracking-widest hover:bg-gray-50 border-b border-gray-50 dark:hover:bg-slate-700/50 dark:text-gray-300 dark:border-gray-700">Export</button>
                    <button class="w-full text-left px-5 py-3 text-xs font-bold text-gray-600 uppercase tracking-widest hover:bg-gray-50 dark:hover:bg-slate-700/50 dark:text-gray-300">Print</button>
                </div>
            </div>

            <div class="relative w-80">
                <span class="absolute inset-y-0 left-4 flex items-center text-gray-400 dark:text-gray-500">
                    <i class="bi bi-search text-sm"></i>
                </span>
                <input type="text" class="w-full border border-gray-300 rounded-lg pl-11 pr-4 py-2 text-sm focus:ring-1 focus:ring-[#C41E24] outline-none placeholder:text-gray-400 dark:bg-white dark:text-gray-800 dark:placeholder:text-gray-500 dark:border-gray-600" placeholder="Search orders...">
            </div>
        </div>

        <div class="flex items-center space-x-4">
            <select class="border border-gray-300 rounded-lg px-4 py-2 text-sm text-gray-500 bg-white outline-none cursor-pointer font-medium dark:bg-slate-800 dark:text-gray-400 dark:border-gray-600">
                <option>Status</option>
                <option>Pending</option>
                <option>Completed</option>
            </select>
            <button class="flex items-center space-x-3 border border-gray-300 rounded-lg px-4 py-2 text-sm text-gray-600 hover:bg-gray-50 transition-colors dark:hover:bg-slate-700/50 dark:text-gray-300 dark:border-gray-600">
                <i class="bi bi-arrow-clockwise text-base"></i>
                <span>Refresh</span>
            </button>
        </div>
    </div>

    <div class="bg-white border-x border-b border-gray-200 shadow-sm overflow-hidden dark:bg-slate-800 dark:border-gray-700">
        <table class="w-full text-left text-xs whitespace-nowrap">
            <thead class="bg-gray-50 text-gray-500 uppercase tracking-wider font-bold border-b border-gray-100 dark:bg-slate-700/50 dark:text-gray-400 dark:border-gray-700">
                <tr>
                    <th class="px-8 py-4"><input type="checkbox" class="w-4 h-4 rounded border-gray-300 text-[#C41E24] focus:ring-[#C41E24] dark:border-gray-600"></th>
                    <th class="px-8 py-4">Order ID</th>
                    <th class="px-8 py-4">Branch</th>
                    <th class="px-8 py-4">Branch Manager</th>
                    <th class="px-8 py-4">Invoice Status</th>
                    <th class="px-8 py-4">Status</th>
                    <th class="px-8 py-4">Order Date</th>
                    <th class="px-8 py-4">Expected Date</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-gray-100 dark:divide-gray-700">
                @if (Model.Orders != null && Model.Orders.Any())
                {
                    foreach (var order in Model.Orders)
                    {
                        string formattedOrderId = $"FO-{order.OrderId:D5}";
                        <tr class="hover:bg-gray-50 transition-colors dark:hover:bg-slate-700/50">
                            <td class="px-8 py-5"><input type="checkbox" class="w-4 h-4 rounded border-gray-300 dark:border-gray-600"></td>
                            <td class="px-8 py-5">
                                <a href="/Dashboard/OrderDetails?id=@formattedOrderId"
                                   class="text-[#C41E24] font-bold underline hover:text-red-800 transition-colors text-sm">
                                    @formattedOrderId
                                </a>
                            </td>
                            <td class="px-8 py-5 text-gray-600 font-medium text-sm dark:text-gray-300">@order.BranchManager?.BranchLocation?.BranchName</td>
                            <td class="px-8 py-5 text-gray-600 font-medium text-sm dark:text-gray-300">@(order.BranchManager?.FirstName) @(order.BranchManager?.LastName)</td>
                            <td class="px-8 py-5 text-gray-500 text-sm dark:text-gray-400">-</td>
                            <td class="px-8 py-5 text-gray-500 text-sm dark:text-gray-400">@(order.DeliveryDate?.ToString("MMM dd, yyyy") ?? "-")</td>
                            <td class="px-8 py-5 text-gray-500 text-sm dark:text-gray-400">@order.Status</td>
                            <td class="px-8 py-5 text-gray-500 text-sm dark:text-gray-400">@order.OrderDate.ToString("MMMM dd, yyyy")</td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="8" class="px-8 py-10 text-center text-gray-400 italic">No orders found.</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <partial name="_Pagination" model="Model.Orders" />

@section Scripts {
    <script>
        const actionsMenu = document.getElementById('actionsMenu');
        function toggleActions(e) {
            e.stopPropagation();
            actionsMenu.classList.toggle('hidden');
        }
        window.onclick = function(event) {
            if (!event.target.closest('.relative')) {
                actionsMenu.classList.add('hidden');
            }
        }
    </script>
}