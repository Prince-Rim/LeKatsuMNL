@page
@model LeKatsuMNL.Pages.Dashboard.IndexModel
@{
    ViewData["Title"] = "Dashboard";
}

<div class="grid grid-cols-1 md:grid-cols-4 gap-6 mb-6">
    <div class="bg-[#C41E24] text-white p-7 rounded-2xl shadow-lg relative overflow-hidden transition-all hover:scale-[1.01]">
        <div>
            <p class="text-sm font-bold opacity-80 uppercase tracking-widest mb-2">Total Branch Sales</p>
            <h3 class="text-4xl font-extrabold tracking-tight">₱341,560.00</h3>
            <p class="text-xs font-bold mt-3 flex items-center"><i class="bi bi-caret-down-fill mr-1"></i> 3 Today</p>
        </div>
        <div class="absolute top-7 right-7 opacity-20 text-4xl"><i class="bi bi-wallet2"></i></div>
    </div>

    <div class="bg-white p-7 rounded-2xl border border-gray-100 shadow-sm relative transition-all hover:scale-[1.01] dark:bg-slate-800 dark:border-gray-700">
        <p class="text-gray-500 text-sm font-bold uppercase tracking-widest mb-2 dark:text-gray-400">No. of Low Stocks</p>
        <h3 class="text-4xl font-extrabold text-gray-800 tracking-tight dark:text-white">31</h3>
        <p class="text-red-500 text-xs font-bold mt-3 flex items-center">↗ 5 Today</p>
        <div class="absolute top-7 right-7 text-[#C41E24] text-2xl opacity-80"><i class="bi bi-exclamation-triangle"></i></div>
    </div>

    <div class="bg-white p-7 rounded-2xl border border-gray-100 shadow-sm relative transition-all hover:scale-[1.01] dark:bg-slate-800 dark:border-gray-700">
        <p class="text-gray-500 text-sm font-bold uppercase tracking-widest mb-2 dark:text-gray-400">Pending Orders</p>
        <h3 class="text-4xl font-extrabold text-gray-800 tracking-tight dark:text-white">26</h3>
        <p class="text-red-500 text-xs font-bold mt-3 flex items-center">↗ 3 Today</p>
        <div class="absolute top-7 right-7 text-[#C41E24] text-2xl opacity-80"><i class="bi bi-cart-dash"></i></div>
    </div>

    <div class="bg-white p-7 rounded-2xl border border-gray-100 shadow-sm relative transition-all hover:scale-[1.01] dark:bg-slate-800 dark:border-gray-700">
        <p class="text-gray-500 text-sm font-bold uppercase tracking-widest mb-2 dark:text-gray-400">Open Discrepancies</p>
        <h3 class="text-4xl font-extrabold text-gray-800 tracking-tight dark:text-white">10</h3>
        <p class="text-red-500 text-xs font-bold mt-3 flex items-center">↗ 3 Today</p>
        <div class="absolute top-7 right-7 text-[#C41E24] text-2xl opacity-80"><i class="bi bi-exclamation-octagon"></i></div>
    </div>
</div>

<div class="grid grid-cols-1 lg:grid-cols-2 gap-6 mb-6">
    <div class="bg-white p-7 rounded-2xl border border-gray-100 shadow-sm dark:bg-slate-800 dark:border-gray-700">
        <div class="flex justify-between items-center mb-7">
            <h4 class="font-extrabold text-base text-gray-800 tracking-tight dark:text-white">Low Stock Alert</h4>
            <span class="bg-[#C41E24] text-white text-xs px-3 py-1 rounded-full font-bold shadow-sm">31</span>
        </div>
        <table class="w-full text-xs text-left">
            <thead class="text-gray-400 border-b border-gray-50 dark:text-gray-500 dark:border-gray-700">
                <tr>
                    <th class="pb-4 font-bold uppercase tracking-widest">Item</th>
                    <th class="pb-4 font-bold uppercase tracking-widest">Quantity</th>
                    <th class="pb-4 font-bold uppercase tracking-widest text-center">Safe Stock</th>
                    <th class="pb-4 font-bold uppercase tracking-widest">Status</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-gray-50 dark:divide-gray-700">
                <tr class="transition-colors hover:bg-gray-50/50">
                    <td class="py-4 font-bold text-gray-800 text-sm dark:text-white">Chicken Katsu(500g)</td>
                    <td class="py-4 font-black text-red-600 text-sm">12</td>
                    <td class="py-4 text-gray-600 text-center font-bold dark:text-gray-300">100</td>
                    <td class="py-4 text-xs">
                        <span class="px-4 py-1.5 rounded-lg font-black uppercase tracking-widest bg-red-100 text-red-600">Critical</span>
                    </td>
                </tr>
                <tr class="transition-colors hover:bg-gray-50/50">
                    <td class="py-4 font-bold text-gray-800 text-sm dark:text-white">Raw Rice (25kg)</td>
                    <td class="py-4 font-black text-red-600 text-sm">2</td>
                    <td class="py-4 text-gray-600 text-center font-bold dark:text-gray-300">10</td>
                    <td class="py-4 text-xs">
                        <span class="px-4 py-1.5 rounded-lg font-black uppercase tracking-widest bg-red-100 text-red-600">Critical</span>
                    </td>
                </tr>
                <tr class="transition-colors hover:bg-gray-50/50">
                    <td class="py-4 font-bold text-gray-800 text-sm dark:text-white">Cooking Oil (18L)</td>
                    <td class="py-4 font-black text-orange-600 text-sm">8</td>
                    <td class="py-4 text-gray-600 text-center font-bold dark:text-gray-300">15</td>
                    <td class="py-4 text-xs">
                        <span class="px-4 py-1.5 rounded-lg font-black uppercase tracking-widest bg-orange-100 text-orange-600">Warning</span>
                    </td>
                </tr>
            </tbody>
        </table>
    </div>

    <div class="bg-white p-7 rounded-2xl border border-gray-100 shadow-sm dark:bg-slate-800 dark:border-gray-700">
        <div class="flex justify-between items-center mb-7">
            <h4 class="font-extrabold text-base text-gray-800 tracking-tight dark:text-white">Waste / Adjustments</h4>
            <span class="bg-[#C41E24] text-white text-xs px-3 py-1 rounded-full font-bold shadow-sm">07</span>
        </div>
        <table class="w-full text-xs text-left">
            <thead class="text-gray-400 border-b border-gray-50 dark:text-gray-500 dark:border-gray-700">
                <tr>
                    <th class="pb-4 font-bold uppercase tracking-widest">Item</th>
                    <th class="pb-4 font-bold uppercase tracking-widest">Quantity</th>
                    <th class="pb-4 font-bold uppercase tracking-widest">Type</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-gray-50 dark:divide-gray-700">
                <tr>
                    <td class="py-4 font-bold text-gray-800 text-sm dark:text-white">Chicken Katsu(500g)</td>
                    <td class="py-4 font-black text-gray-800 text-sm dark:text-white">12</td>
                    <td class="py-4 text-gray-500 font-bold dark:text-gray-400">Spoilage</td>
                </tr>
                <tr>
                    <td class="py-4 font-bold text-gray-800 text-sm dark:text-white">Cabbage (kg)</td>
                    <td class="py-4 font-black text-gray-800 text-sm dark:text-white">5</td>
                    <td class="py-4 text-gray-500 font-bold dark:text-gray-400">Waste</td>
                </tr>
                <tr>
                    <td class="py-4 font-bold text-gray-800 text-sm dark:text-white">Marinated Pork</td>
                    <td class="py-4 font-black text-gray-800 text-sm dark:text-white">3</td>
                    <td class="py-4 text-gray-500 font-bold dark:text-gray-400">Adjustment</td>
                </tr>
            </tbody>
        </table>
    </div>
</div>

<div class="grid grid-cols-1 lg:grid-cols-12 gap-6">
    <div class="lg:col-span-7 bg-white p-7 rounded-2xl border border-gray-100 shadow-sm dark:bg-slate-800 dark:border-gray-700">
        <div class="flex justify-between items-center mb-6">
            <h4 class="font-extrabold text-base text-gray-800 tracking-tight dark:text-white">AI Demand Forecast</h4>
            <select class="text-xs border border-gray-200 bg-gray-50 rounded-lg px-4 py-2 font-bold text-gray-600 outline-none focus:ring-1 focus:ring-[#C41E24] dark:bg-slate-700/50 dark:text-gray-300 dark:border-gray-700"><option>Chicken Katsu</option></select>
        </div>
        <div class="h-48 relative mb-4"><canvas id="forecastChart"></canvas></div>
        <div class="bg-black text-white p-6 rounded-2xl flex items-center shadow-xl">
            <div class="text-[#C41E24] mr-5 text-2xl"><i class="bi bi-lightning-charge-fill animate-pulse"></i></div>
            <p class="text-xs leading-relaxed font-medium"><span class="text-[#C41E24] font-black uppercase tracking-[0.2em] mr-2 text-[10px]">Smart Alert:</span> Order 90kg of chicken breast today to meet the projected weekend demand.</p>
        </div>
    </div>

    <div class="lg:col-span-5 bg-white p-6 rounded-2xl border border-gray-100 shadow-sm dark:bg-slate-800 dark:border-gray-700">
        <div class="flex justify-between items-center mb-6">
            <h4 class="font-bold text-sm text-gray-800 dark:text-white">Leading Branches by Orders</h4>
            <span class="text-[9px] text-gray-400 font-bold uppercase dark:text-gray-500">This month</span>
        </div>
        <div class="space-y-6">
            @for (int i = 0; i < 3; i++)
            {
                <div class="flex justify-between items-center p-3 rounded-xl hover:bg-gray-50 transition-all dark:hover:bg-slate-700/50">
                    <div class="flex items-center space-x-4">
                        <div class="w-10 h-10 rounded-full bg-red-50 flex items-center justify-center text-[#C41E24] font-bold text-sm">@(i+1)</div>
                        <div>
                            <p class="text-sm font-bold text-gray-800 dark:text-white">Quezon City</p>
                            <p class="text-xs text-gray-400 uppercase font-bold tracking-widest dark:text-gray-500">Main Branch</p>
                        </div>
                    </div>
                    <div class="text-right">
                        <p class="text-sm font-black text-gray-900 tracking-tight dark:text-white">₱28,000.00</p>
                        <p class="text-red-500 text-xs font-bold flex items-center justify-end"><i class="bi bi-graph-up-arrow mr-1"></i> 18%</p>
                    </div>
                </div>
            }
        </div>
    </div>

    <div class="lg:col-span-7 bg-white p-6 rounded-2xl border border-gray-100 shadow-sm dark:bg-slate-800 dark:border-gray-700">
        <h4 class="font-bold text-sm mb-6 text-gray-800 dark:text-white">Recent Orders</h4>
        <div class="h-48 flex flex-col justify-center items-center border-2 border-dashed border-gray-50 rounded-xl bg-gray-50/30 text-gray-300 dark:border-gray-700">
            <i class="bi bi-receipt text-3xl mb-2"></i>
            <p class="text-[10px] font-bold uppercase tracking-widest">No recent orders found</p>
        </div>
    </div>

    <div class="lg:col-span-5 bg-white p-6 rounded-2xl border border-gray-100 shadow-sm dark:bg-slate-800 dark:border-gray-700">
        <h4 class="font-bold text-sm mb-6 text-gray-800 dark:text-white">Recent Activity</h4>
        <div class="space-y-8 mt-2">
            <div class="flex items-start space-x-5">
                <div class="mt-1.5 w-3 h-3 rounded-full bg-blue-500 shadow-[0_0_10px_rgba(59,130,246,0.6)]"></div>
                <div class="flex-1">
                    <p class="text-sm font-bold text-gray-800 dark:text-white">Commissary: Stocks received (Chicken Breast)</p>
                    <p class="text-xs text-gray-400 mt-1 font-medium dark:text-gray-500">2 minutes ago</p>
                </div>
            </div>
            <div class="flex items-start space-x-5">
                <div class="mt-1.5 w-3 h-3 rounded-full bg-[#C41E24] shadow-[0_0_10px_rgba(196,30,36,0.6)]"></div>
                <div class="flex-1">
                    <p class="text-sm font-black text-[#C41E24]">Commissary Alert: Low level detected in Oil</p>
                    <p class="text-xs text-gray-400 mt-1 font-medium dark:text-gray-500">15 minutes ago</p>
                </div>
            </div>
            <div class="flex items-start space-x-5">
                <div class="mt-1.5 w-3 h-3 rounded-full bg-green-500 shadow-[0_0_10px_rgba(34,197,94,0.6)]"></div>
                <div class="flex-1">
                    <p class="text-sm font-bold text-gray-800 dark:text-white">Commissary: New supplier "San Miguel" added</p>
                    <p class="text-xs text-gray-400 mt-1 font-medium dark:text-gray-500">1 hour ago</p>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            const ctx = document.getElementById('forecastChart').getContext('2d');
            const redGrad = ctx.createLinearGradient(0, 0, 0, 200);
            redGrad.addColorStop(0, 'rgba(196, 30, 36, 0.2)');
            redGrad.addColorStop(1, 'rgba(196, 30, 36, 0)');

            new Chart(ctx, {
                type: 'line',
                data: {
                    labels: ['Mon', 'Tue', 'Wed', 'Thu', 'Fri', 'Sat', 'Sun'],
                    datasets: [{
                        data: [20, 45, 30, 60, 85, 40, 50],
                        borderColor: '#C41E24',
                        backgroundColor: redGrad,
                        fill: true,
                        tension: 0.4,
                        pointRadius: 0,
                        borderWidth: 3
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: { legend: { display: false } },
                    scales: {
                        x: { grid: { display: false }, ticks: { font: { size: 10 } } },
                        y: { display: false }
                    }
                }
            });
        });
    </script>
}