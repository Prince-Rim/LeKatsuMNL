@page
@model LeKatsuMNL.Pages.Dashboard.IndexModel
@{
    ViewData["Title"] = "Dashboard";
}

<div class="grid grid-cols-1 md:grid-cols-4 gap-6 mb-6">
    <div class="bg-[#C41E24] text-white p-7 rounded-2xl shadow-lg relative overflow-hidden transition-all hover:scale-[1.01]">
        <div>
            <p class="text-sm font-bold opacity-80 uppercase tracking-widest mb-2">Total Branch Sales</p>
            <h3 class="text-4xl font-extrabold tracking-tight">₱@Model.TotalBranchSales.ToString("N2")</h3>
            <p class="text-xs font-bold mt-3 flex items-center">All-time completions</p>
        </div>
        <div class="absolute top-7 right-7 opacity-20 text-4xl"><i class="bi bi-wallet2"></i></div>
    </div>

    <div class="bg-white p-7 rounded-2xl border border-gray-100 shadow-sm relative transition-all hover:scale-[1.01] dark:bg-slate-800 dark:border-gray-700" title="Total number of items with stock levels below their reorder point.">
        <p class="text-gray-500 text-sm font-bold uppercase tracking-widest mb-2 dark:text-gray-400">Low Stock Items</p>
        <h3 class="text-4xl font-extrabold text-gray-800 tracking-tight dark:text-white">@Model.LowStockCount</h3>
        <p class="text-red-500 text-xs font-bold mt-3 flex items-center">@Model.LowStockCount items need restock</p>
        <div class="absolute top-7 right-7 text-[#C41E24] text-2xl opacity-80"><i class="bi bi-exclamation-triangle"></i></div>
</div>

    <div class="bg-white p-7 rounded-2xl border border-gray-100 shadow-sm relative transition-all hover:scale-[1.01] dark:bg-slate-800 dark:border-gray-700">
        <p class="text-gray-500 text-sm font-bold uppercase tracking-widest mb-2 dark:text-gray-400">Pending Orders</p>
        <h3 class="text-4xl font-extrabold text-gray-800 tracking-tight dark:text-white">@Model.PendingOrdersCount</h3>
        <p class="text-blue-500 text-xs font-bold mt-3 flex items-center">Orders in progress</p>
        <div class="absolute top-7 right-7 text-[#C41E24] text-2xl opacity-80"><i class="bi bi-cart-dash"></i></div>
</div>

    <div class="bg-white p-7 rounded-2xl border border-gray-100 shadow-sm relative transition-all hover:scale-[1.01] dark:bg-slate-800 dark:border-gray-700" title="Number of items marked as rejected today.">
        <p class="text-gray-500 text-sm font-bold uppercase tracking-widest mb-2 dark:text-gray-400">Today's Rejections</p>
        <h3 class="text-4xl font-extrabold text-gray-800 tracking-tight dark:text-white">@Model.DiscrepancyCount</h3>
        <p class="text-orange-500 text-xs font-bold mt-3 flex items-center">@Model.DiscrepancyCount new rejects today</p>
        <div class="absolute top-7 right-7 text-[#C41E24] text-2xl opacity-80"><i class="bi bi-exclamation-octagon"></i></div>
</div>
</div>

<div class="grid grid-cols-1 lg:grid-cols-2 gap-6 mb-6">
    <div class="bg-white p-7 rounded-2xl border border-gray-100 shadow-sm dark:bg-slate-800 dark:border-gray-700">
        <div class="flex justify-between items-center mb-7">
            <h4 class="font-extrabold text-base text-gray-800 tracking-tight dark:text-white">Low Stock Alert</h4>
            <span class="bg-[#C41E24] text-white text-xs px-3 py-1 rounded-full font-bold shadow-sm">@Model.LowStockCount.ToString("D2")</span>
        </div>
        <table class="w-full text-xs text-left">
            <thead class="text-gray-400 border-b border-gray-50 dark:text-gray-500 dark:border-gray-700">
                <tr>
                    <th class="pb-4 font-bold uppercase tracking-widest">Item</th>
                    <th class="pb-4 font-bold uppercase tracking-widest">Quantity</th>
                    <th class="pb-4 font-bold uppercase tracking-widest text-center">Safe Stock</th>
                    <th class="pb-4 font-bold uppercase tracking-widest text-right">Status</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-gray-50 dark:divide-gray-700">
                @if (Model.LowStockAlerts != null && Model.LowStockAlerts.Any())
                {
                    foreach (var item in Model.LowStockAlerts)
                    {
                        <tr class="transition-colors hover:bg-gray-50/50">
                            <td class="py-4 font-bold text-gray-800 text-sm dark:text-white">@item.ItemName</td>
                            <td class="py-4 font-black text-@(item.StatusColor)-600 text-sm">@item.CurrentStock.ToString("N0")</td>
                            <td class="py-4 text-gray-600 text-center font-bold dark:text-gray-300">@item.ReorderLevel?.ToString("N0")</td>
                            <td class="py-4 text-xs text-right">
                                <span class="px-4 py-1.5 rounded-lg font-black uppercase tracking-widest bg-@(item.StatusColor)-100 text-@(item.StatusColor)-600">@item.Status</span>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="4" class="py-8 text-center text-gray-400 font-bold uppercase tracking-widest">No stock alerts</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <div class="bg-white p-7 rounded-2xl border border-gray-100 shadow-sm dark:bg-slate-800 dark:border-gray-700">
        <div class="flex justify-between items-center mb-7">
            <h4 class="font-extrabold text-base text-gray-800 tracking-tight dark:text-white">Waste / Adjustments</h4>
            <span class="bg-[#C41E24] text-white text-xs px-3 py-1 rounded-full font-bold shadow-sm">@Model.DiscrepancyCount.ToString("D2")</span>
        </div>
        <table class="w-full text-xs text-left">
            <thead class="text-gray-400 border-b border-gray-50 dark:text-gray-500 dark:border-gray-700">
                <tr>
                    <th class="pb-4 font-bold uppercase tracking-widest">Item</th>
                    <th class="pb-4 font-bold uppercase tracking-widest">Quantity</th>
                    <th class="pb-4 font-bold uppercase tracking-widest text-right">Reason</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-gray-50 dark:divide-gray-700">
                @if (Model.RecentRejects != null && Model.RecentRejects.Any())
                {
                    foreach (var reject in Model.RecentRejects)
                    {
                        <tr>
                            <td class="py-4 font-bold text-gray-800 text-sm dark:text-white">@reject.ItemName</td>
                            <td class="py-4 font-black text-gray-800 text-sm dark:text-white">@reject.Quantity.ToString("N0")</td>
                            <td class="py-4 text-gray-500 font-bold dark:text-gray-400 text-right">@reject.Reason</td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="3" class="py-8 text-center text-gray-400 font-bold uppercase tracking-widest">No recent rejects</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

<div class="grid grid-cols-1 lg:grid-cols-12 gap-6">
    <div class="lg:col-span-7 bg-white p-7 rounded-2xl border border-gray-100 shadow-sm dark:bg-slate-800 dark:border-gray-700">
        <div class="flex justify-between items-center mb-6">
            <h4 class="font-extrabold text-base text-gray-800 tracking-tight dark:text-white">Demand Forecast</h4>
            <span class="text-[10px] bg-red-100 text-red-600 px-3 py-1 rounded-full font-bold uppercase tracking-widest">Live Analysis</span>
        </div>
        <div class="h-48 relative mb-4"><canvas id="forecastChart"></canvas></div>
        <div class="bg-black text-white p-6 rounded-2xl flex items-center shadow-xl">
            <div class="text-[#C41E24] mr-5 text-2xl"><i class="bi bi-lightning-charge-fill animate-pulse"></i></div>
            <p class="text-xs leading-relaxed font-medium">
                <span class="text-[#C41E24] font-black uppercase tracking-[0.2em] mr-2 text-[10px]">Smart Alert:</span>
                @if (Model.LowStockAlerts != null && Model.LowStockAlerts.Any())
                {
                    var topAlert = Model.LowStockAlerts.First();
                    <span>Consider ordering more <strong>@topAlert.ItemName</strong> today to maintain recommended safety stock levels.</span>
                }
                else
                {
                    <span>All inventory levels are currently within safe operating parameters. Good job!</span>
                }
            </p>
        </div>
    </div>

    <div class="lg:col-span-5 bg-white p-6 rounded-2xl border border-gray-100 shadow-sm dark:bg-slate-800 dark:border-gray-700">
        <div class="flex justify-between items-center mb-6">
            <h4 class="font-bold text-sm text-gray-800 dark:text-white">Leading Branches by Orders</h4>
            <span class="text-[9px] text-gray-400 font-bold uppercase dark:text-gray-500">This month</span>
        </div>
        <div class="space-y-6">
            @if (Model.TopBranches != null && Model.TopBranches.Any())
            {
                for (int i = 0; i < Model.TopBranches.Count; i++)
                {
                    var branch = Model.TopBranches[i];
                    <div class="flex justify-between items-center p-3 rounded-xl hover:bg-gray-50 transition-all dark:hover:bg-slate-700/50">
                        <div class="flex items-center space-x-4">
                            <div class="w-10 h-10 rounded-full bg-red-50 flex items-center justify-center text-[#C41E24] font-bold text-sm">@(i + 1)</div>
                            <div>
                                <p class="text-sm font-bold text-gray-800 dark:text-white">@branch.BranchName</p>
                                <p class="text-xs text-gray-400 uppercase font-bold tracking-widest dark:text-gray-500">Branch Performance</p>
                            </div>
                        </div>
                        <div class="text-right">
                            <p class="text-sm font-black text-gray-900 tracking-tight dark:text-white">₱@branch.TotalRevenue.ToString("N2")</p>
                            <p class="text-green-500 text-xs font-bold flex items-center justify-end"><i class="bi bi-graph-up-arrow mr-1"></i> @branch.GrowthPercentage%</p>
                        </div>
                    </div>
                }
            }
            else
            {
                <div class="py-12 text-center text-gray-300">
                    <i class="bi bi-bar-chart-steps text-3xl mb-2"></i>
                    <p class="text-[10px] font-bold uppercase tracking-widest">No branch data available</p>
                </div>
            }
        </div>
    </div>

    <div class="lg:col-span-7 bg-white p-6 rounded-2xl border border-gray-100 shadow-sm dark:bg-slate-800 dark:border-gray-700">
        <h4 class="font-bold text-sm mb-6 text-gray-800 dark:text-white">Recent Orders</h4>
        <div class="overflow-x-auto">
            <table class="w-full text-xs text-left">
                <thead class="text-gray-400 border-b border-gray-50 dark:text-gray-500 dark:border-gray-700">
                    <tr>
                        <th class="pb-4 font-bold uppercase tracking-widest">Order ID</th>
                        <th class="pb-4 font-bold uppercase tracking-widest">Branch</th>
                        <th class="pb-4 font-bold uppercase tracking-widest">Status</th>
                        <th class="pb-4 font-bold uppercase tracking-widest text-right">Date</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-gray-50 dark:divide-gray-700">
                    @if (Model.RecentOrders != null && Model.RecentOrders.Any())
                    {
                        foreach (var order in Model.RecentOrders)
                        {
                            string formattedOrderId = $"FO-{order.OrderDate.Year.ToString().Substring(2)}{order.OrderId:D4}";
                            <tr class="transition-colors hover:bg-gray-50/50">
                                <td class="py-4 font-bold text-[#C41E24] hover:underline text-sm dark:text-red-400">
                                    <a href="/Dashboard/OrderDetails?id=@order.OrderId">@formattedOrderId</a>
                                </td>
                                <td class="py-4 text-gray-600 dark:text-gray-300 font-medium">@order.BranchManager?.BranchLocation?.BranchName</td>
                                <td class="py-4">
                                    <span class="px-2 py-1 rounded-md text-[10px] font-black uppercase tracking-tight 
                                        @(order.Status == "Completed" ? "bg-green-100 text-green-700" : 
                                          order.Status == "Pending" ? "bg-amber-100 text-amber-700" : 
                                          order.Status == "Cancelled" ? "bg-red-100 text-red-700" : 
                                          "bg-blue-100 text-blue-700")">
                                        @order.Status
                                    </span>
                                </td>
                                <td class="py-4 text-gray-400 font-bold text-right">@order.OrderDate.ToString("MMM dd, yyyy")</td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="4" class="py-12 text-center text-gray-300">
                                <i class="bi bi-receipt text-3xl mb-2"></i>
                                <p class="text-[10px] font-bold uppercase tracking-widest">No recent orders found</p>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    <div class="lg:col-span-5 bg-white p-6 rounded-2xl border border-gray-100 shadow-sm dark:bg-slate-800 dark:border-gray-700">
        <h4 class="font-bold text-sm mb-6 text-gray-800 dark:text-white">Recent Activity</h4>
        <div class="space-y-8 mt-2">
            @if (Model.RecentActivities != null && Model.RecentActivities.Any())
            {
                foreach (var activity in Model.RecentActivities)
                {
                    <div class="flex items-start space-x-5">
                        <div class="mt-1.5 w-3 h-3 rounded-full bg-@(activity.Color)-500 shadow-[0_0_10px_rgba(var(--tw-shadow-color),0.6)]" style="--tw-shadow-color: @(activity.Color == "red" ? "196,30,36" : "59,130,246")"></div>
                        <div class="flex-1">
                            <p class="text-sm font-bold text-gray-800 dark:text-white">@activity.Title</p>
                            <p class="text-xs text-gray-400 mt-1 font-medium dark:text-gray-500">@activity.TimeAgo</p>
                        </div>
                    </div>
                }
            }
            else
            {
                <div class="py-12 text-center text-gray-300">
                    <i class="bi bi-clock-history text-3xl mb-2"></i>
                    <p class="text-[10px] font-bold uppercase tracking-widest">No recent activities</p>
                </div>
            }
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            const ctx = document.getElementById('forecastChart').getContext('2d');
            const redGrad = ctx.createLinearGradient(0, 0, 0, 200);
            redGrad.addColorStop(0, 'rgba(196, 30, 36, 0.2)');
            redGrad.addColorStop(1, 'rgba(196, 30, 36, 0)');

            new Chart(ctx, {
                type: 'line',
                data: {
                    labels: ['Mon', 'Tue', 'Wed', 'Thu', 'Fri', 'Sat', 'Sun'],
                    datasets: [{
                        data: [20, 45, 30, 60, 85, 40, 50],
                        borderColor: '#C41E24',
                        backgroundColor: redGrad,
                        fill: true,
                        tension: 0.4,
                        pointRadius: 0,
                        borderWidth: 3
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: { legend: { display: false } },
                    scales: {
                        x: { grid: { display: false }, ticks: { font: { size: 10 } } },
                        y: { display: false }
                    }
                }
            });
        });
    </script>
}