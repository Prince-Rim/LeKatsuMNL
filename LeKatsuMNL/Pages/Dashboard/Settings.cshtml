@page
@model LeKatsuMNL.Pages.Dashboard.SettingsModel
@{
    ViewData["Title"] = "Settings";
    Layout = "_DashboardLayout";
}

<div class="bg-white dark:bg-gray-800 rounded-2xl border border-gray-200 dark:border-gray-700 shadow-sm overflow-hidden mb-8 transition-colors duration-200">
    
    <!-- Tabs -->
    <div class="flex border-b border-gray-100 dark:border-gray-700 px-6">
        <button id="tab-account" onclick="switchTab('account')" class="px-6 py-4 text-sm font-bold text-[#C41E24] border-b-2 border-[#C41E24] transition-all">Account</button>
        <button id="tab-security" onclick="switchTab('security')" class="px-6 py-4 text-sm font-bold text-gray-500 dark:text-gray-400 hover:text-gray-700 dark:hover:text-gray-200 border-b-2 border-transparent transition-all">Security</button>
        <button id="tab-appearance" onclick="switchTab('appearance')" class="px-6 py-4 text-sm font-bold text-gray-500 dark:text-gray-400 hover:text-gray-700 dark:hover:text-gray-200 border-b-2 border-transparent transition-all">Appearance</button>
    </div>

    @* Notifications moved above content *@
    <div id="settings-alerts" class="px-8 pt-6">
        @if (TempData["SuccessMessage"] != null)
        {
            <div class="mb-6 p-4 bg-green-50 border border-green-200 text-green-700 rounded-xl flex items-center shadow-sm animate-fade-in">
                <i class="bi bi-check-circle-fill mr-3 text-lg"></i>
                <span class="text-sm font-bold">@TempData["SuccessMessage"]</span>
            </div>
        }
        @if (TempData["ErrorMessage"] != null)
        {
            <div class="mb-6 p-4 bg-red-50 border border-red-200 text-red-700 rounded-xl flex items-center shadow-sm animate-fade-in">
                <i class="bi bi-exclamation-triangle-fill mr-3 text-lg"></i>
                <span class="text-sm font-bold">@TempData["ErrorMessage"]</span>
            </div>
        }
    </div>

    <!-- Account Tab Content -->
    <div id="content-account" class="p-8">
        <form method="post" asp-page-handler="EditAccount" id="edit-account-form" class="space-y-8 max-w-4xl">
            <!-- User ID (Uneditable) -->
            <div class="grid grid-cols-[200px_1fr] gap-6 items-center">
                <label class="text-xs font-bold text-gray-700 tracking-wide dark:text-gray-200">User System ID</label>
                <div class="w-full">
                    <input type="text" value="@Model.UserSystemId" class="w-full px-4 py-3 bg-gray-50 border border-gray-100 rounded-lg text-sm font-bold text-[#C41E24] focus:outline-none pointer-events-none transition-colors duration-200 dark:bg-slate-700/50 dark:border-gray-700" readonly>
                </div>
            </div>

            <!-- Full Name -->
            <div class="grid grid-cols-[200px_1fr_1fr_1fr] gap-6 items-center">
                <label class="text-xs font-bold text-gray-700 tracking-wide dark:text-gray-200">Account Full Name</label>
                <div class="w-full">
                    <input type="text" asp-for="FirstName" placeholder="First Name" class="account-input w-full px-4 py-3 bg-gray-50 border border-gray-100 rounded-lg text-sm text-gray-700 focus:outline-none focus:border-[#C41E24] pointer-events-none transition-colors duration-200 dark:bg-slate-700/50 dark:text-gray-200 dark:border-gray-700" readonly>
                </div>
                <div class="w-full">
                    <input type="text" asp-for="MiddleName" placeholder="Middle Name" class="account-input w-full px-4 py-3 bg-gray-50 border border-gray-100 rounded-lg text-sm text-gray-700 focus:outline-none focus:border-[#C41E24] pointer-events-none transition-colors duration-200 dark:bg-slate-700/50 dark:text-gray-200 dark:border-gray-700" readonly>
                </div>
                <div class="w-full">
                    <input type="text" asp-for="LastName" placeholder="Last Name" class="account-input w-full px-4 py-3 bg-gray-50 border border-gray-100 rounded-lg text-sm text-gray-700 focus:outline-none focus:border-[#C41E24] pointer-events-none transition-colors duration-200 dark:bg-slate-700/50 dark:text-gray-200 dark:border-gray-700" readonly>
                </div>
            </div>

            <!-- Role (Uneditable) -->
            <div class="grid grid-cols-[200px_1fr] gap-6 items-center">
                <label class="text-xs font-bold text-gray-700 tracking-wide dark:text-gray-200">Role</label>
                <div class="w-full">
                    <input type="text" value="@Model.Role" class="w-full px-4 py-3 bg-gray-50 border border-gray-100 rounded-lg text-sm text-gray-700 focus:outline-none pointer-events-none transition-colors duration-200 dark:bg-slate-700/50 dark:text-gray-200 dark:border-gray-700" readonly>
                </div>
            </div>

            <!-- Email Address -->
            <div class="grid grid-cols-[200px_1fr] gap-6 items-center">
                <label class="text-xs font-bold text-gray-700 tracking-wide dark:text-gray-200">Email Address</label>
                <div class="max-w-[calc(50%-12px)]">
                    <input type="email" asp-for="Email" class="account-input w-full px-4 py-3 bg-gray-50 border border-gray-100 rounded-lg text-sm text-gray-700 focus:outline-none focus:border-[#C41E24] pointer-events-none transition-colors duration-200 dark:bg-slate-700/50 dark:text-gray-200 dark:border-gray-700" readonly>
                </div>
            </div>

            <!-- Edit / Save Actions -->
            <div class="flex justify-end pt-8 mt-4 border-t border-gray-50 transition-colors duration-200 dark:border-gray-700">
                <div id="start-edit-actions">
                    <button type="button" onclick="enableEdit()" class="px-5 py-2.5 bg-white border-2 border-[#C41E24] text-[#C41E24] rounded font-bold text-sm shadow-sm hover:bg-red-50 active:scale-95 transition-all dark:bg-slate-800 dark:hover:bg-slate-700 dark:text-gray-200">
                        Edit Details
                    </button>
                </div>
                <div id="save-edit-actions" class="hidden flex space-x-4">
                    <button type="button" onclick="cancelEdit()" class="px-5 py-2.5 bg-gray-200 text-gray-700 rounded font-bold text-sm shadow-sm hover:bg-gray-300 active:scale-95 transition-all dark:bg-slate-700 dark:text-gray-200 dark:hover:bg-slate-600">
                        Cancel
                    </button>
                    <button type="submit" class="px-5 py-2.5 bg-[#C41E24] text-white rounded font-bold text-sm shadow hover:bg-[#a51a1f] active:scale-95 transition-all">
                        Save Changes
                    </button>
                </div>
            </div>
        </form>

        <!-- Delete Account Form Separate -->
        <div class="max-w-4xl space-y-8 mt-4">
            <div class="grid grid-cols-[200px_1fr] gap-6 items-center pt-8 border-t border-gray-50 transition-colors duration-200 dark:border-gray-700">
                <div class="flex items-center">
                    <label class="text-xs font-bold text-red-600 tracking-wide">Danger Zone</label>
                </div>
                <div class="flex justify-end">
                    <form method="post" asp-page-handler="DeleteAccount" onsubmit="return confirm('Are you sure you want to delete your account? This action cannot be undone and you will be logged out immediately.');">
                        <button type="submit" class="px-5 py-2.5 bg-white border border-red-300 text-red-600 rounded font-bold text-sm shadow-sm hover:bg-red-50 hover:border-red-400 active:scale-95 transition-all dark:bg-slate-800 dark:hover:bg-slate-700 dark:border-red-900/50">
                            Delete Account
                        </button>
                    </form>
                </div>
            </div>
        </div>
    </div>


    <!-- Security Tab Content -->
    <div id="content-security" class="p-8 hidden">
        <div class="max-w-4xl">
            <h4 class="text-sm font-bold text-gray-800 dark:text-white mb-6 flex items-center">
                <i class="bi bi-shield-lock-fill mr-2 text-[#C41E24]"></i>
                Change Account Password
            </h4>
            
            <form method="post" asp-page-handler="ChangePassword" id="change-password-form" class="space-y-6">
                <!-- Current Password -->
                <div class="grid grid-cols-[200px_1fr] gap-6 items-center">
                    <label class="text-xs font-bold text-gray-700 tracking-wide dark:text-gray-200">Current Password</label>
                    <div class="max-w-md">
                        <input type="password" asp-for="CurrentPassword" class="w-full px-4 py-3 bg-gray-50 border border-gray-100 rounded-lg text-sm text-gray-700 focus:outline-none focus:border-[#C41E24] transition-colors duration-200 dark:bg-slate-700/50 dark:text-gray-200 dark:border-gray-700" required placeholder="Enter current password">
                    </div>
                </div>

                <!-- New Password -->
                <div class="grid grid-cols-[200px_1fr] gap-6 items-center">
                    <label class="text-xs font-bold text-gray-700 tracking-wide dark:text-gray-200">New Password</label>
                    <div class="max-w-md">
                        <input type="password" asp-for="NewPassword" id="settingsNewPassword" class="w-full px-4 py-3 bg-gray-50 border border-gray-100 rounded-lg text-sm text-gray-700 focus:outline-none focus:border-[#C41E24] transition-colors duration-200 dark:bg-slate-700/50 dark:text-gray-200 dark:border-gray-700" required placeholder="Enter new password">
                    </div>
                </div>

                <!-- Confirm New Password -->
                <div class="grid grid-cols-[200px_1fr] gap-6 items-center">
                    <label class="text-xs font-bold text-gray-700 tracking-wide dark:text-gray-200">Confirm New Password</label>
                    <div class="max-w-md">
                        <input type="password" asp-for="ConfirmNewPassword" id="settingsConfirmPassword" class="w-full px-4 py-3 bg-gray-50 border border-gray-100 rounded-lg text-sm text-gray-700 focus:outline-none focus:border-[#C41E24] transition-colors duration-200 dark:bg-slate-700/50 dark:text-gray-200 dark:border-gray-700" required placeholder="Confirm new password">
                    </div>
                </div>

                <div class="flex justify-end pt-6 border-t border-gray-50 dark:border-gray-700">
                    <button type="submit" class="px-6 py-2.5 bg-[#C41E24] text-white rounded font-bold text-sm shadow-lg hover:bg-[#a51a1f] active:scale-95 transition-all flex items-center">
                        <i class="bi bi-key-fill mr-2"></i>
                        Update Password
                    </button>
                </div>
            </form>
        </div>
    </div>


    <!-- Appearance Tab Content -->
    <div id="content-appearance" class="p-8 hidden">
        <div class="space-y-8 max-w-4xl">
            <!-- Theme Toggle -->
            <div class="grid grid-cols-[200px_1fr] gap-6 items-center">
                <div class="flex flex-col">
                    <label class="text-xs font-bold text-gray-700 dark:text-gray-300 tracking-wide">Interface Theme</label>
                    <span class="text-[10px] text-gray-400 dark:text-gray-500 mt-1">Select your color scheme preference</span>
                </div>
                <div class="flex items-center space-x-4">
                    <button id="theme-light" onclick="setTheme('light')" class="w-32 py-3 border-2 border-[#C41E24] bg-red-50 dark:bg-red-900/20 text-[#C41E24] rounded-xl font-bold text-sm transition-all focus:outline-none flex flex-col items-center justify-center space-y-2">
                        <i class="bi bi-sun-fill text-xl"></i>
                        <span>Light</span>
                    </button>
                    <button id="theme-dark" onclick="setTheme('dark')" class="w-32 py-3 border-2 border-gray-200 dark:border-gray-700 text-gray-500 dark:text-gray-400 hover:border-gray-300 dark:hover:border-gray-500 rounded-xl font-bold text-sm transition-all focus:outline-none flex flex-col items-center justify-center space-y-2">
                        <i class="bi bi-moon-fill text-xl"></i>
                        <span>Dark</span>
                    </button>
                </div>
            </div>

            <!-- Sidebar Toggle -->
            <div class="grid grid-cols-[200px_1fr] gap-6 items-center">
                <div class="flex flex-col">
                    <label class="text-xs font-bold text-gray-700 dark:text-gray-300 tracking-wide">Navigation Sidebar</label>
                    <span class="text-[10px] text-gray-400 dark:text-gray-500 mt-1">Choose layout density</span>
                </div>
                <div class="flex items-center space-x-4">
                    <button id="sidebar-expanded" onclick="setSidebar('expanded')" class="w-32 py-3 border-2 border-[#C41E24] bg-red-50 dark:bg-red-900/20 text-[#C41E24] rounded-xl font-bold text-sm transition-all focus:outline-none flex flex-col items-center justify-center space-y-2">
                        <i class="bi bi-layout-sidebar text-xl"></i>
                        <span>Expanded</span>
                    </button>
                    <button id="sidebar-collapsed" onclick="setSidebar('collapsed')" class="w-32 py-3 border-2 border-gray-200 dark:border-gray-700 text-gray-500 dark:text-gray-400 hover:border-gray-300 dark:hover:border-gray-500 rounded-xl font-bold text-sm transition-all focus:outline-none flex flex-col items-center justify-center space-y-2">
                        <i class="bi bi-layout-sidebar-inset text-xl"></i>
                        <span>Collapsed</span>
                    </button>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function enableEdit() {
            document.getElementById('start-edit-actions').classList.add('hidden');
            document.getElementById('save-edit-actions').classList.remove('hidden');
            
            const inputs = document.querySelectorAll('.account-input');
            inputs.forEach(input => {
                input.classList.remove('pointer-events-none');
                input.removeAttribute('readonly');
                input.classList.replace('bg-gray-50', 'bg-white');
            });
        }

        function cancelEdit() {
            window.location.reload();
        }

        function switchTab(tab, hideAlerts = true) {
            const tabs = ['account', 'security', 'appearance'];
            
            // Hide alerts when switching tabs
            const alerts = document.getElementById('settings-alerts');
            if (alerts && hideAlerts) alerts.classList.add('hidden');

            tabs.forEach(t => {
                const tabEl = document.getElementById(`tab-${t}`);
                const contentEl = document.getElementById(`content-${t}`);
                
                if (t === tab) {
                    tabEl.className = "px-6 py-4 text-sm font-bold text-[#C41E24] border-b-2 border-[#C41E24] transition-all";
                    contentEl.classList.remove('hidden');
                } else {
                    tabEl.className = "px-6 py-4 text-sm font-bold text-gray-500 hover:text-gray-700 border-b-2 border-transparent transition-all";
                    contentEl.classList.add('hidden');
                }
            });
        }

        function setTheme(theme) {
            const lightBtn = document.getElementById('theme-light');
            const darkBtn = document.getElementById('theme-dark');
            const activeClass = "w-32 py-3 border-2 border-[#C41E24] bg-red-50 dark:bg-red-900/20 text-[#C41E24] rounded-xl font-bold text-sm transition-all focus:outline-none flex flex-col items-center justify-center space-y-2";
            const inactiveClass = "w-32 py-3 border-2 border-gray-200 dark:border-gray-700 text-gray-500 dark:text-gray-400 hover:border-gray-300 dark:hover:border-gray-500 rounded-xl font-bold text-sm transition-all focus:outline-none flex flex-col items-center justify-center space-y-2";

            if (theme === 'dark') {
                document.documentElement.classList.add('dark');
                localStorage.setItem('admin_theme', 'dark');
                darkBtn.className = activeClass;
                lightBtn.className = inactiveClass;
            } else {
                document.documentElement.classList.remove('dark');
                localStorage.setItem('admin_theme', 'light');
                lightBtn.className = activeClass;
                darkBtn.className = inactiveClass;
            }
        }

        function setSidebar(state) {
            const expBtn = document.getElementById('sidebar-expanded');
            const colBtn = document.getElementById('sidebar-collapsed');
            const activeClass = "w-32 py-3 border-2 border-[#C41E24] bg-red-50 dark:bg-red-900/20 text-[#C41E24] rounded-xl font-bold text-sm transition-all focus:outline-none flex flex-col items-center justify-center space-y-2";
            const inactiveClass = "w-32 py-3 border-2 border-gray-200 dark:border-gray-700 text-gray-500 dark:text-gray-400 hover:border-gray-300 dark:hover:border-gray-500 rounded-xl font-bold text-sm transition-all focus:outline-none flex flex-col items-center justify-center space-y-2";

            if (state === 'collapsed') {
                document.documentElement.classList.add('sidebar-collapsed');
                localStorage.setItem('admin_sidebar', 'collapsed');
                colBtn.className = activeClass;
                expBtn.className = inactiveClass;
            } else {
                document.documentElement.classList.remove('sidebar-collapsed');
                localStorage.setItem('admin_sidebar', 'expanded');
                expBtn.className = activeClass;
                colBtn.className = inactiveClass;
            }
        }

        // Initialize button states on load
        document.addEventListener('DOMContentLoaded', () => {
            if (localStorage.getItem('admin_theme') === 'dark' || (!('admin_theme' in localStorage) && window.matchMedia('(prefers-color-scheme: dark)').matches)) {
                setTheme('dark');
            } else {
                setTheme('light');
            }

            if (localStorage.getItem('admin_sidebar') === 'collapsed') {
                setSidebar('collapsed');
            } else {
                setSidebar('expanded');
            }

            // Persistence for active tab
            const activeTab = "@Model.ActiveTab";
            if (activeTab && activeTab !== 'account') {
                switchTab(activeTab, false);
            }
        });
    </script>
}
