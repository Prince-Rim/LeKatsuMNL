@page
@model LeKatsuMNL.Pages.Dashboard.SupplierModel
@{
    ViewData["Title"] = "Supplier";
    Layout = "_DashboardLayout";
}

@section TitleActions {
    <button onclick="openModal('createModal')" class="bg-[#C41E24] text-white px-6 py-2.5 rounded-xl font-bold text-sm shadow-lg hover:bg-[#a51a1f] transition-all flex items-center">
        <i class="bi bi-plus-lg mr-2"></i> New Supplier
    </button>
}

<div class="space-y-6">
    <!-- Search and Refresh -->
    <div class="flex items-center justify-between gap-4">
        <div class="relative flex-1 max-w-sm">
            <i class="bi bi-search absolute left-4 top-1/2 -translate-y-1/2 text-gray-400"></i>
            <input type="text" id="supplierSearch" placeholder="Search suppliers..." 
                   class="w-full pl-11 pr-4 py-2.5 bg-white border border-gray-200 rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-[#C41E24]/10 focus:border-[#C41E24] transition-all">
        </div>
        <button onclick="window.location.reload()" class="px-6 py-2.5 bg-gray-100 text-gray-600 rounded-xl font-bold text-sm hover:bg-gray-200 transition-all">
            Refresh
        </button>
    </div>

    <!-- Suppliers Table -->
    <div class="overflow-x-auto bg-white rounded-2xl border border-gray-200 shadow-sm">
        <table class="w-full text-left border-collapse">
            <thead>
                <tr class="bg-gray-50/50 border-b border-gray-100">
                    <th class="px-6 py-4 text-xs font-bold text-gray-400 uppercase tracking-wider">Vendor name</th>
                    <th class="px-6 py-4 text-xs font-bold text-gray-400 uppercase tracking-wider">Contact num</th>
                    <th class="px-6 py-4 text-xs font-bold text-gray-400 uppercase tracking-wider">Created at</th>
                    <th class="px-6 py-4 text-xs font-bold text-gray-400 uppercase tracking-wider text-right">Actions</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-gray-50" id="supplierTableBody">
                @if (Model.Vendors != null && Model.Vendors.Any())
                {
                    foreach (var vendor in Model.Vendors)
                    {
                        <tr class="hover:bg-gray-50/50 transition-colors">
                            <td class="px-6 py-4 text-sm font-semibold text-gray-700">@vendor.VendorName</td>
                            <td class="px-6 py-4 text-sm text-gray-500 font-medium">@vendor.ContactNum</td>
                            <td class="px-6 py-4 text-sm text-gray-400">@vendor.CreatedAt.ToString("MMMM dd, yyyy")</td>
                            <td class="px-6 py-4 text-right space-x-2">
                                <button onclick="openEditModal('@vendor.VendorId', '@vendor.VendorName', '@vendor.ContactNum')" 
                                        class="px-4 py-1.5 bg-gray-100 text-gray-600 rounded-lg text-xs font-bold hover:bg-gray-200 transition-all">
                                    Edit
                                </button>
                                <form method="post" asp-page-handler="Delete" asp-route-id="@vendor.VendorId" class="inline" onsubmit="return confirm('Are you sure you want to delete this supplier?')">
                                    <button type="submit" class="px-4 py-1.5 bg-gray-100 text-gray-600 rounded-lg text-xs font-bold hover:bg-red-50 hover:text-red-600 transition-all">
                                        Delete
                                    </button>
                                </form>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="4" class="px-6 py-12 text-center text-gray-400 italic text-sm">
                            No suppliers found. Click "New Supplier" to add one.
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <!-- Pagination -->
    <div class="flex items-center justify-between px-2 text-xs text-gray-400 font-bold uppercase tracking-widest">
        <p>Showing 1 - @(Model.Vendors?.Count ?? 0) of @(Model.Vendors?.Count ?? 0)</p>
        <div class="flex items-center space-x-6">
            <div class="flex items-center space-x-3">
                <span>Records per page</span>
                <div class="px-3 py-1 bg-gray-100 rounded-lg text-gray-700">10</div>
            </div>
            <div class="flex items-center space-x-2">
                <button class="w-8 h-8 flex items-center justify-center bg-gray-100 rounded-lg text-gray-400 hover:bg-gray-200 transition-all">&lt;</button>
                <button class="w-8 h-8 flex items-center justify-center bg-[#C41E24] text-white rounded-lg shadow-md">1</button>
                <button class="w-8 h-8 flex items-center justify-center bg-gray-100 rounded-lg text-gray-400 hover:bg-gray-200 transition-all">&gt;</button>
            </div>
        </div>
    </div>
</div>

<!-- Create Supplier Modal -->
<div id="createModal" class="fixed inset-0 bg-black/40 hidden flex items-center justify-center z-[100] backdrop-blur-[2px] transition-all duration-300">
    <div class="bg-white rounded-2xl shadow-2xl w-full max-w-md mx-4 overflow-hidden border border-gray-100 transform transition-all opacity-0 scale-95">
        <div class="px-8 py-6 border-b border-gray-50 flex justify-between items-center bg-white">
            <h3 class="text-base font-bold text-gray-900">Create Supplier</h3>
            <button onclick="closeModal('createModal')" class="text-gray-500 hover:text-gray-700 transition-colors">
                <i class="bi bi-x-lg text-xl"></i>
            </button>
        </div>

        <form method="post" asp-page-handler="Create" class="p-8 space-y-6">
            <div class="space-y-1.5">
                <label class="block text-xs font-bold text-gray-700 uppercase tracking-widest ml-1">Vendor name*</label>
                <input asp-for="NewVendor.VendorName" placeholder="Vendor name" required
                       class="w-full border border-gray-200 rounded-xl px-5 py-3 text-sm outline-none focus:ring-2 focus:ring-[#C41E24]/20 focus:border-[#C41E24] bg-white transition-all placeholder:text-gray-500 text-gray-800 shadow-sm font-medium">
            </div>
            <div class="space-y-1.5">
                <label class="block text-xs font-bold text-gray-700 uppercase tracking-widest ml-1">Contact#</label>
                <input asp-for="NewVendor.ContactNum" placeholder="Contact#" 
                       class="w-full border border-gray-200 rounded-xl px-5 py-3 text-sm outline-none focus:ring-2 focus:ring-[#C41E24]/20 focus:border-[#C41E24] bg-white transition-all placeholder:text-gray-500 text-gray-800 shadow-sm font-medium">
            </div>
            <div class="flex justify-end space-x-4 pt-8">
                <button type="button" onclick="closeModal('createModal')" 
                        class="px-8 py-3 rounded-xl text-xs font-bold text-gray-500 uppercase tracking-widest hover:bg-gray-100 transition-all">
                    Cancel
                </button>
                <button type="submit" 
                        class="px-12 py-3 bg-[#C41E24] text-white rounded-xl text-xs font-bold uppercase tracking-widest hover:bg-[#a51a1f] shadow-lg hover:shadow-red-200 transition-all transform active:scale-95">
                    Submit
                </button>
            </div>
        </form>
    </div>
</div>

<!-- Edit Supplier Modal -->
<div id="editModal" class="fixed inset-0 bg-black/40 hidden flex items-center justify-center z-[100] backdrop-blur-[2px] transition-all duration-300">
    <div class="bg-white rounded-2xl shadow-2xl w-full max-w-md mx-4 overflow-hidden border border-gray-100 transform transition-all opacity-0 scale-95">
        <div class="px-8 py-6 border-b border-gray-50 flex justify-between items-center bg-white">
            <h3 class="text-base font-bold text-gray-900">Edit Supplier</h3>
            <button onclick="closeModal('editModal')" class="text-gray-500 hover:text-gray-700 transition-colors">
                <i class="bi bi-x-lg text-xl"></i>
            </button>
        </div>

        <form method="post" asp-page-handler="Update" class="p-8 space-y-6">
            <input type="hidden" asp-for="EditVendor.VendorId" id="editVendorId" />
            <div class="space-y-1.5">
                <label class="block text-xs font-bold text-gray-700 uppercase tracking-widest ml-1">Vendor name*</label>
                <input asp-for="EditVendor.VendorName" id="editVendorName" placeholder="Vendor name" required
                       class="w-full border border-gray-200 rounded-xl px-5 py-3 text-sm outline-none focus:ring-2 focus:ring-[#C41E24]/20 focus:border-[#C41E24] bg-white transition-all placeholder:text-gray-500 text-gray-800 shadow-sm font-medium">
            </div>
            <div class="space-y-1.5">
                <label class="block text-xs font-bold text-gray-700 uppercase tracking-widest ml-1">Contact#</label>
                <input asp-for="EditVendor.ContactNum" id="editContactNum" placeholder="Contact#" 
                       class="w-full border border-gray-200 rounded-xl px-5 py-3 text-sm outline-none focus:ring-2 focus:ring-[#C41E24]/20 focus:border-[#C41E24] bg-white transition-all placeholder:text-gray-500 text-gray-800 shadow-sm font-medium">
            </div>
            <div class="flex justify-end space-x-4 pt-8">
                <button type="button" onclick="closeModal('editModal')" 
                        class="px-8 py-3 rounded-xl text-xs font-bold text-gray-500 uppercase tracking-widest hover:bg-gray-100 transition-all">
                    Cancel
                </button>
                <button type="submit" 
                        class="px-12 py-3 bg-[#C41E24] text-white rounded-xl text-xs font-bold uppercase tracking-widest hover:bg-[#a51a1f] shadow-lg hover:shadow-red-200 transition-all transform active:scale-95">
                    Save
                </button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <script>
        function openModal(modalId) {
            const modal = document.getElementById(modalId);
            const content = modal.querySelector('div');
            modal.classList.remove('hidden');
            document.body.style.overflow = 'hidden';

            setTimeout(() => {
                content.classList.remove('opacity-0', 'scale-95');
                content.classList.add('opacity-100', 'scale-100');
            }, 10);
        }

        function closeModal(modalId) {
            const modal = document.getElementById(modalId);
            const content = modal.querySelector('div');
            
            content.classList.add('opacity-0', 'scale-95');
            content.classList.remove('opacity-100', 'scale-100');
            
            setTimeout(() => {
                modal.classList.add('hidden');
                document.body.style.overflow = 'auto';
            }, 300);
        }

        function openEditModal(id, name, contact) {
            document.getElementById('editVendorId').value = id;
            document.getElementById('editVendorName').value = name;
            document.getElementById('editContactNum').value = contact;
            openModal('editModal');
        }

        // Search logic
        document.getElementById('supplierSearch')?.addEventListener('input', function(e) {
            const searchTerm = e.target.value.toLowerCase();
            const rows = document.querySelectorAll('#supplierTableBody tr');
            
            rows.forEach(row => {
                const text = row.textContent.toLowerCase();
                if (row.querySelector('td[colspan]')) return;
                row.style.display = text.includes(searchTerm) ? '' : 'none';
            });
        });

        // Close modal on click outside
        window.onclick = function(event) {
            if (event.target.classList.contains('fixed')) {
                const modalId = event.target.id;
                closeModal(modalId);
            }
        }

        // Close on escape
        document.addEventListener('keydown', (e) => {
            if (e.key === 'Escape') {
                const openModals = document.querySelectorAll('.fixed:not(.hidden)');
                openModals.forEach(modal => closeModal(modal.id));
            }
        });
    </script>
}
