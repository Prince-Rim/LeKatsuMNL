@page
@model LeKatsuMNL.Pages.Dashboard.SKUModel
@using LeKatsuMNL.Helpers
@{
    ViewData["Title"] = "Inventory Items";
}

@section TitleActions {
    @if (PermissionHelper.HasPermission(User, "SKU", 'C'))
    {
        <button onclick="openNewProductModal()" class="bg-[#C41E24] text-white px-5 py-2 rounded-lg text-sm font-bold hover:bg-red-700 transition-colors shadow-sm whitespace-nowrap">
            + New Product
        </button>
    }
}

<div class="bg-white rounded-xl border border-gray-200 shadow-sm overflow-hidden dark:bg-slate-800 dark:border-gray-700" data-ajax-container>
    <!-- Tabs -->
    <div class="flex border-b border-gray-200 dark:border-gray-700">
        <a href="/Dashboard/Items" data-ajax-link class="px-10 py-4 text-sm font-bold text-gray-400 hover:text-gray-600 transition-all dark:text-gray-500">Ingredient</a>
        <button class="px-10 py-4 text-sm font-bold text-[#C41E24] border-b-2 border-[#C41E24] transition-all">SKU</button>
    </div>

    <!-- Toolbar -->
    <form method="get" data-ajax-form class="p-5 flex flex-wrap items-center gap-4 bg-white border-b border-gray-100 dark:bg-slate-800 dark:border-gray-700">
        <div class="relative inline-block text-left">
            <button type="button" onclick="toggleActions(event)" class="flex items-center space-x-2 border border-gray-300 rounded-lg px-4 py-2 text-sm text-gray-600 bg-white hover:bg-gray-50 outline-none transition-all dark:bg-slate-800 dark:hover:bg-slate-700/50 dark:text-gray-300 dark:border-gray-600">
                <span>Actions</span>
                <i class="bi bi-chevron-down text-xs"></i>
            </button>
            <div id="actionsMenu" class="hidden absolute left-0 mt-2 w-40 bg-white rounded-xl shadow-xl border border-gray-100 z-[70] overflow-hidden transform origin-top-left transition-all dark:bg-slate-800 dark:border-gray-700">
                <button type="button" onclick="handleArchive()" class="w-full text-left px-5 py-3 text-xs font-bold text-gray-700 uppercase tracking-widest hover:bg-gray-50 border-b border-gray-50 transition-colors dark:hover:bg-slate-700/50 dark:text-gray-200 dark:border-gray-700">
                    Archive
                </button>
                <button type="button" onclick="openRejectModal()" class="w-full text-left px-5 py-3 text-xs font-bold text-red-500 uppercase tracking-widest hover:bg-red-50 hover:text-[#C41E24] transition-colors">
                    Reject
                </button>
            </div>
        </div>

        <div class="relative flex-1 min-w-[200px] max-w-md">
            <span class="absolute inset-y-0 left-4 flex items-center text-gray-400 dark:text-gray-500">
                <i class="bi bi-search text-sm"></i>
            </span>
            <input type="text" name="searchTerm" value="@Model.SearchTerm" oninput="debouncedSubmit(this.form)" class="w-full border border-gray-300 rounded-lg pl-11 pr-4 py-2 text-sm focus:ring-1 focus:ring-[#C41E24] outline-none placeholder:text-gray-400 dark:placeholder:text-gray-500 dark:border-gray-600 dark:bg-slate-800 dark:text-white" placeholder="Search SKU product...">
        </div>

        <div class="flex flex-wrap items-center gap-3">
            <select name="categoryId" onchange="this.form.requestSubmit()" class="border border-gray-300 rounded-lg px-4 py-2 text-sm text-gray-600 bg-white outline-none cursor-pointer dark:bg-slate-800 dark:text-gray-300 dark:border-gray-600">
                <option value="">All Categories</option>
                @foreach (var cat in Model.Categories)
                {
                    @if (Model.FilterCategoryId == cat.CategoryId)
                    {
                        <option value="@cat.CategoryId" selected>@cat.CategoryName</option>
                    }
                    else
                    {
                        <option value="@cat.CategoryId">@cat.CategoryName</option>
                    }
                }
            </select>

            <select name="subCategoryId" onchange="this.form.requestSubmit()" class="border border-gray-300 rounded-lg px-4 py-2 text-sm text-gray-600 bg-white outline-none cursor-pointer dark:bg-slate-800 dark:text-gray-300 dark:border-gray-600">
                <option value="">All Sub-Categories</option>
                @foreach (var sub in Model.SubCategories.Where(s => !Model.FilterCategoryId.HasValue || s.CategoryId == Model.FilterCategoryId))
                {
                    @if (Model.FilterSubCategoryId == sub.SubCategoryId)
                    {
                        <option value="@sub.SubCategoryId" selected>@sub.SubCategoryName</option>
                    }
                    else
                    {
                        <option value="@sub.SubCategoryId">@sub.SubCategoryName</option>
                    }
                }
            </select>


            <div class="flex items-center gap-2">
                @if (!string.IsNullOrEmpty(Model.SearchTerm) || Model.FilterCategoryId.HasValue || Model.FilterSubCategoryId.HasValue)
                {
                    <a href="/Dashboard/SKU" data-ajax-link class="text-xs font-bold text-red-500 hover:text-red-700 uppercase tracking-widest px-2">Clear</a>
                }
                <button type="button" onclick="location.reload()" class="p-2 text-gray-400 hover:text-gray-600 transition-colors dark:text-gray-500">
                    <i class="bi bi-arrow-clockwise text-base"></i>
                </button>
            </div>
        </div>
    </form>

    <!-- Table & Pagination -->
    <div>
        <div class="overflow-x-auto">
            <table class="w-full text-left text-xs whitespace-nowrap">
                <thead class="bg-gray-50 text-gray-500 uppercase tracking-wider font-bold border-b border-gray-100 dark:bg-slate-700/50 dark:text-gray-400 dark:border-gray-700">
                    <tr>
                        <th class="px-8 py-4 w-12"><input type="checkbox" id="selectAll" onchange="toggleSelectAll(this)" class="w-4 h-4 rounded border-gray-300 text-[#C41E24] focus:ring-[#C41E24] dark:border-gray-600"></th>
                        <th class="px-6 py-4">Image</th>
                        <th class="px-6 py-4 text-center">
                            <a asp-page="./SKU" data-ajax-link 
                               asp-route-sortColumn="Id" 
                               asp-route-sortOrder="@(Model.CurrentSortColumn == "Id" && Model.CurrentSortOrder == "asc" ? "desc" : "asc")"
                               asp-route-searchTerm="@Model.SearchTerm"
                               asp-route-categoryId="@Model.FilterCategoryId"
                               asp-route-subCategoryId="@Model.FilterSubCategoryId"
                               class="flex items-center justify-center hover:text-[#C41E24] transition-colors">
                                ID
                                <i class="bi @(Model.CurrentSortColumn == "Id" ? (Model.CurrentSortOrder == "asc" ? "bi-sort-up" : "bi-sort-down-alt") : "bi-arrow-down-up opacity-30") ml-1"></i>
                            </a>
                        </th>
                        <th class="px-6 py-4">
                            <a asp-page="./SKU" data-ajax-link 
                               asp-route-sortColumn="Name" 
                               asp-route-sortOrder="@(Model.CurrentSortColumn == "Name" && Model.CurrentSortOrder == "asc" ? "desc" : "asc")"
                               asp-route-searchTerm="@Model.SearchTerm"
                               asp-route-categoryId="@Model.FilterCategoryId"
                               asp-route-subCategoryId="@Model.FilterSubCategoryId"
                               class="flex items-center hover:text-[#C41E24] transition-colors">
                                Product Name
                                <i class="bi @(Model.CurrentSortColumn == "Name" ? (Model.CurrentSortOrder == "asc" ? "bi-sort-up" : "bi-sort-down-alt") : "bi-arrow-down-up opacity-30") ml-1"></i>
                            </a>
                        </th>
                        <th class="px-6 py-4">Category</th>
                        <th class="px-6 py-4">Sub-Category</th>
                        <th class="px-6 py-4">Yield</th>
                        <th class="px-6 py-4 text-right">
                            <a asp-page="./SKU" data-ajax-link 
                               asp-route-sortColumn="Cost" 
                               asp-route-sortOrder="@(Model.CurrentSortColumn == "Cost" && Model.CurrentSortOrder == "asc" ? "desc" : "asc")"
                               asp-route-searchTerm="@Model.SearchTerm"
                               asp-route-categoryId="@Model.FilterCategoryId"
                               asp-route-subCategoryId="@Model.FilterSubCategoryId"
                               class="flex items-center justify-end hover:text-[#C41E24] transition-colors">
                                Unit Cost
                                <i class="bi @(Model.CurrentSortColumn == "Cost" ? (Model.CurrentSortOrder == "asc" ? "bi-sort-up" : "bi-sort-down-alt") : "bi-arrow-down-up opacity-30") ml-1"></i>
                            </a>
                        </th>
                        <th class="px-6 py-4 text-right">
                            <a asp-page="./SKU" data-ajax-link 
                               asp-route-sortColumn="Price" 
                               asp-route-sortOrder="@(Model.CurrentSortColumn == "Price" && Model.CurrentSortOrder == "asc" ? "desc" : "asc")"
                               asp-route-searchTerm="@Model.SearchTerm"
                               asp-route-categoryId="@Model.FilterCategoryId"
                               asp-route-subCategoryId="@Model.FilterSubCategoryId"
                               class="flex items-center justify-end hover:text-[#C41E24] transition-colors">
                                Selling Price
                                <i class="bi @(Model.CurrentSortColumn == "Price" ? (Model.CurrentSortOrder == "asc" ? "bi-sort-up" : "bi-sort-down-alt") : "bi-arrow-down-up opacity-30") ml-1"></i>
                            </a>
                        </th>
                        <th class="px-6 py-4 text-center">Action</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-gray-50 dark:divide-gray-700">
                    @if (Model.SkuHeaders != null && Model.SkuHeaders.Any())
                    {
                        foreach (var sku in Model.SkuHeaders)
                        {
                            <tr class="hover:bg-gray-50/50 transition-colors group">
                                <td class="px-8 py-5"><input type="checkbox" class="row-checkbox w-4 h-4 rounded border-gray-300 text-[#C41E24] focus:ring-[#C41E24] dark:border-gray-600" data-id="@sku.SkuId" data-item-name="@sku.ItemName" data-uom="@sku.Uom" onchange="updateSelectAll()"></td>
                                <td class="px-6 py-5">
                                    <div class="w-12 h-12 bg-gray-200 rounded-xl flex items-center justify-center text-gray-400 group-hover:bg-gray-300 transition-colors dark:text-gray-500">
                                        <i class="bi bi-image text-2xl"></i>
                                    </div>
                                </td>
                                <td class="px-6 py-5 text-center font-black text-[#C41E24] dark:text-red-400">SKU-@sku.SkuId.ToString("D4")</td>
                                <td class="px-6 py-5">
                                    <a href="/Dashboard/SkuDetails/@sku.SkuId" class="font-bold text-gray-900 hover:text-[#C41E24] hover:underline text-sm dark:text-white">@sku.ItemName</a>
                                </td>
                                <td class="px-6 py-5 text-gray-600 dark:text-gray-300">@(sku.Category?.CategoryName ?? "-")</td>
                                <td class="px-6 py-5 text-gray-600 dark:text-gray-300">@(sku.SubCategory?.SubCategoryName ?? "-")</td>
                                <td class="px-6 py-5 text-gray-600 font-semibold uppercase dark:text-gray-300">
                                    @if(!string.IsNullOrEmpty(sku.PackagingType)) {
                                        @($"{sku.PackagingType} / {sku.PackSize}{sku.PackagingUnit}")
                                    } else {
                                        @("-")
                                    }
                                </td>
                                <td class="px-6 py-5 font-bold text-gray-900 text-sm tracking-tight dark:text-white">@(sku.UnitCost.HasValue ? $"₱ {sku.UnitCost.Value:0.00}" : "-")</td>
                                <td class="px-6 py-5 font-bold text-gray-900 text-sm tracking-tight dark:text-white">₱ @sku.SellingPrice.ToString("F2")</td>
                                <td class="px-6 py-5">
                                    @if (PermissionHelper.HasPermission(User, "SKU", 'U'))
                                    {
                                        <button onclick='openEditProductModal(@Html.Raw(System.Text.Json.JsonSerializer.Serialize(new { 
                                            skuId = sku.SkuId, 
                                            itemName = sku.ItemName, 
                                            categoryId = sku.CategoryId, 
                                            subCategoryId = sku.SubCategoryId,
                                            packagingType = sku.PackagingType,
                                            packagingUnit = sku.PackagingUnit,
                                            packSize = sku.PackSize,
                                            uom = sku.Uom,
                                            isSellingPriceEnabled = sku.IsSellingPriceEnabled,
                                            sellingPrice = sku.SellingPrice,
                                            unitCost = sku.UnitCost
                                        })))' class="text-blue-500 hover:text-blue-700 transition-colors">
                                            <i class="bi bi-pencil-square text-lg"></i>
                                        </button>
                                    }
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="10" class="px-6 py-8 text-center text-gray-500 font-semibold italic dark:text-gray-400">No SKU products found. Create a new product to get started.</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <partial name="_Pagination" model="Model.SkuHeaders" />
    </div>
</div>

<!-- Modal: Create New Product -->
<div id="newProductModal" class="fixed inset-0 bg-black/40 hidden flex items-center justify-center z-[100] backdrop-blur-[2px] transition-all duration-300 font-sans">
    <div class="bg-white rounded-2xl shadow-2xl w-full max-w-lg mx-4 overflow-hidden border border-gray-100 transform transition-all opacity-0 scale-95 dark:bg-slate-800 dark:border-gray-700">
        <!-- Header -->
        <div class="px-8 py-6 border-b border-gray-50 flex justify-between items-center bg-white dark:bg-slate-800 dark:border-gray-700">
            <h3 class="text-base font-bold text-gray-900 dark:text-white">Create New Product</h3>
            <button onclick="closeModal('newProductModal')" class="text-gray-500 hover:text-gray-700 transition-colors dark:text-gray-400">
                <i class="bi bi-x-lg text-lg"></i>
            </button>
        </div>

        <form method="post" asp-page-handler="Create">
            <div class="px-8 py-6 space-y-6 max-h-[60vh] overflow-y-auto custom-scrollbar">
                <div class="space-y-6">
                    <!-- Name -->
                    <div class="space-y-1.5">
                        <label class="block text-xs font-bold text-gray-700 uppercase tracking-widest ml-1 dark:text-gray-200">Name</label>
                        <input type="text" name="ProductName" placeholder="Product Name" required
                               class="w-full border border-gray-200 rounded-xl px-5 py-3 text-sm outline-none focus:ring-2 focus:ring-[#C41E24]/20 focus:border-[#C41E24] bg-white transition-all placeholder:text-gray-500 text-gray-800 shadow-sm font-medium dark:bg-slate-800 dark:text-white dark:placeholder:text-gray-400 dark:border-gray-700">
                    </div>

                    <!-- Category & Sub-Category -->
                    <div class="grid grid-cols-2 gap-5">
                        <div class="space-y-1.5">
                            <label class="block text-xs font-bold text-gray-700 uppercase tracking-widest ml-1 dark:text-gray-200">Category</label>
                            <div class="relative">
                                <select name="CategoryId" required onchange="filterSubCategories(this.value, 'newSubCategory')" class="w-full border border-gray-200 rounded-xl px-5 py-3 text-sm outline-none focus:ring-2 focus:ring-[#C41E24]/20 focus:border-[#C41E24] bg-white transition-all cursor-pointer text-gray-700 shadow-sm font-medium appearance-none dark:bg-slate-800 dark:text-gray-200 dark:border-gray-700">
                                    <option value="" disabled selected hidden>Select Category</option>
                                    @if(Model.Categories != null) {
                                        foreach(var cat in Model.Categories) {
                                            <option value="@cat.CategoryId">@cat.CategoryName</option>
                                        }
                                    }
                                </select>
                                <i class="bi bi-chevron-down absolute right-4 top-1/2 -translate-y-1/2 text-gray-500 pointer-events-none text-xs dark:text-gray-400"></i>
                            </div>
                        </div>
                        <div class="space-y-1.5">
                            <label class="block text-xs font-bold text-gray-700 uppercase tracking-widest ml-1 dark:text-gray-200">Sub-Category</label>
                            <div class="relative">
                                <select name="SubCategoryId" id="newSubCategory" class="w-full border border-gray-200 rounded-xl px-5 py-3 text-sm outline-none focus:ring-2 focus:ring-[#C41E24]/20 focus:border-[#C41E24] bg-white transition-all cursor-pointer text-gray-700 shadow-sm font-medium appearance-none dark:bg-slate-800 dark:text-gray-200 dark:border-gray-700">
                                    <option value="">Select Sub-Category</option>
                                </select>
                                <i class="bi bi-chevron-down absolute right-4 top-1/2 -translate-y-1/2 text-gray-500 pointer-events-none text-xs dark:text-gray-400"></i>
                            </div>
                        </div>
                    </div>

                    <!-- Packaging -->
                    <div class="grid grid-cols-3 gap-5">
                        <div class="space-y-1.5">
                            <label class="block text-xs font-bold text-gray-700 uppercase tracking-widest ml-1 whitespace-nowrap dark:text-gray-200">Packaging Type</label>
                            <input type="text" name="PackagingType" list="pkgTypeList" placeholder="Type"
                                   onfocus="handleDatalistFocus(this)" onblur="handleDatalistBlur(this)"
                                   class="w-full border border-gray-200 rounded-xl px-5 py-3 text-sm outline-none focus:ring-2 focus:ring-[#C41E24]/20 focus:border-[#C41E24] bg-white transition-all placeholder:text-gray-500 text-gray-800 shadow-sm font-medium dark:bg-slate-800 dark:text-white dark:placeholder:text-gray-400 dark:border-gray-700">
                        </div>
                        <div class="space-y-1.5">
                            <label class="block text-xs font-bold text-gray-700 uppercase tracking-widest ml-1 whitespace-nowrap dark:text-gray-200">Packaging Unit</label>
                            <input type="text" name="PackagingUnit" list="pkgUnitList" placeholder="Unit"
                                   onfocus="handleDatalistFocus(this)" onblur="handleDatalistBlur(this)"
                                   class="w-full border border-gray-200 rounded-xl px-5 py-3 text-sm outline-none focus:ring-2 focus:ring-[#C41E24]/20 focus:border-[#C41E24] bg-white transition-all placeholder:text-gray-500 text-gray-800 shadow-sm font-medium dark:bg-slate-800 dark:text-white dark:placeholder:text-gray-400 dark:border-gray-700">
                        </div>
                        <div class="space-y-1.5">
                            <label class="block text-xs font-bold text-gray-700 uppercase tracking-widest ml-1 dark:text-gray-200">Pack Size</label>
                            <input type="text" name="PackSize" placeholder="00"
                                   class="w-full border border-gray-200 rounded-xl px-5 py-3 text-sm outline-none focus:ring-2 focus:ring-[#C41E24]/20 focus:border-[#C41E24] bg-white transition-all placeholder:text-gray-500 text-gray-800 shadow-sm font-medium dark:bg-slate-800 dark:text-white dark:placeholder:text-gray-400 dark:border-gray-700">
                        </div>
                    </div>

                    <!-- UOM -->
                    <div class="grid grid-cols-1 gap-5">
                        <div class="space-y-1.5">
                            <label class="block text-xs font-bold text-gray-700 uppercase tracking-widest ml-1 dark:text-gray-200">Unit of Measurement</label>
                            <input type="text" name="UOM" list="uomList" placeholder="UOM" required
                                   onfocus="handleDatalistFocus(this)" onblur="handleDatalistBlur(this)"
                                   class="w-full border border-gray-200 rounded-xl px-5 py-3 text-sm outline-none focus:ring-2 focus:ring-[#C41E24]/20 focus:border-[#C41E24] bg-white transition-all placeholder:text-gray-500 text-gray-800 shadow-sm font-medium dark:bg-slate-800 dark:text-white dark:placeholder:text-gray-400 dark:border-gray-700">
                        </div>
                    </div>

                    <!-- Pricing -->
                    <div class="grid grid-cols-2 gap-5">
                        <div class="space-y-1.5">
                            <label class="block text-xs font-bold text-gray-700 uppercase tracking-widest ml-1 dark:text-gray-200">Unit Cost</label>
                            <div class="relative">
                                <span class="absolute left-4 top-1/2 -translate-y-1/2 text-gray-500 font-bold dark:text-gray-400 text-sm">₱</span>
                                <input type="number" step="0.01" name="UnitCost" placeholder="0.00" onfocus="this.select()"
                                       class="w-full border border-gray-200 rounded-xl pl-9 pr-5 py-3 text-sm outline-none focus:ring-2 focus:ring-[#C41E24]/20 focus:border-[#C41E24] bg-white transition-all placeholder:text-gray-500 text-gray-800 shadow-sm font-medium dark:bg-slate-800 dark:text-white dark:placeholder:text-gray-400 dark:border-gray-700">
                            </div>
                        </div>
                        <!-- Selling Price (Always visible, required) -->
                        <div id="newSellingPriceContainer" class="space-y-1.5">
                            <label class="block text-xs font-bold text-gray-700 uppercase tracking-widest ml-1 dark:text-gray-200">Selling Price</label>
                            <div class="relative">
                                <span class="absolute left-4 top-1/2 -translate-y-1/2 text-gray-500 font-bold dark:text-gray-400 text-sm">₱</span>
                                <input type="number" step="0.01" name="SellingPrice" placeholder="0.00" required onfocus="this.select()"
                                       class="w-full border border-gray-200 rounded-xl pl-9 pr-5 py-3 text-sm outline-none focus:ring-2 focus:ring-[#C41E24]/20 focus:border-[#C41E24] bg-white transition-all placeholder:text-gray-500 text-gray-800 shadow-sm font-medium dark:bg-slate-800 dark:text-white dark:placeholder:text-gray-400 dark:border-gray-700">
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Buttons -->
            <div class="p-8 bg-gray-50 flex justify-end space-x-4 border-t border-gray-100 dark:bg-slate-700/50 dark:border-gray-700">
                <button type="button" onclick="closeModal('newProductModal')" 
                        class="px-8 py-3 rounded-xl text-xs font-bold text-gray-500 uppercase tracking-widest hover:bg-gray-100 transition-all dark:hover:bg-slate-700 dark:text-gray-400">
                    Cancel
                </button>
                <button type="submit" 
                        class="px-12 py-3 bg-[#C41E24] text-white rounded-xl text-xs font-bold uppercase tracking-widest hover:bg-[#a51a1f] shadow-lg hover:shadow-red-200 transition-all transform active:scale-95">
                    Save Item
                </button>
            </div>
        </form>
    </div>
</div>

<!-- Modal: Edit Product -->
<div id="editProductModal" class="fixed inset-0 bg-black/40 hidden flex items-center justify-center z-[100] backdrop-blur-[2px] transition-all duration-300 font-sans">
    <div class="bg-white rounded-2xl shadow-2xl w-full max-w-lg mx-4 overflow-hidden border border-gray-100 transform transition-all opacity-0 scale-95 dark:bg-slate-800 dark:border-gray-700">
        <!-- Header -->
        <div class="px-8 py-6 border-b border-gray-50 flex justify-between items-center bg-white dark:bg-slate-800 dark:border-gray-700">
            <h3 class="text-base font-bold text-gray-900 dark:text-white">Edit Product</h3>
            <button onclick="closeModal('editProductModal')" class="text-gray-500 hover:text-gray-700 transition-colors dark:text-gray-400">
                <i class="bi bi-x-lg text-lg"></i>
            </button>
        </div>

        <form method="post" asp-page-handler="Update">
            <input type="hidden" name="SkuId" id="editSkuId">
            <div class="px-8 py-6 space-y-6 max-h-[60vh] overflow-y-auto custom-scrollbar">
                <div class="space-y-6">
                    <!-- Name -->
                    <div class="space-y-1.5">
                        <label class="block text-xs font-bold text-gray-700 uppercase tracking-widest ml-1 dark:text-gray-200">Name</label>
                        <input type="text" name="ProductName" id="editProductName" placeholder="Product Name" required
                               class="w-full border border-gray-200 rounded-xl px-5 py-3 text-sm outline-none focus:ring-2 focus:ring-[#C41E24]/20 focus:border-[#C41E24] bg-white transition-all placeholder:text-gray-500 text-gray-800 shadow-sm font-medium dark:bg-slate-800 dark:text-white dark:placeholder:text-gray-400 dark:border-gray-700">
                    </div>

                    <!-- Category & Sub-Category -->
                    <div class="grid grid-cols-2 gap-5">
                        <div class="space-y-1.5">
                            <label class="block text-xs font-bold text-gray-700 uppercase tracking-widest ml-1 dark:text-gray-200">Category</label>
                            <div class="relative">
                                <select name="CategoryId" id="editCategoryId" required onchange="filterSubCategories(this.value, 'editSubCategory')" class="w-full border border-gray-200 rounded-xl px-5 py-3 text-sm outline-none focus:ring-2 focus:ring-[#C41E24]/20 focus:border-[#C41E24] bg-white transition-all cursor-pointer text-gray-700 shadow-sm font-medium appearance-none dark:bg-slate-800 dark:text-gray-200 dark:border-gray-700">
                                    <option value="" disabled selected hidden>Select Category</option>
                                    @if(Model.Categories != null) {
                                        foreach(var cat in Model.Categories) {
                                            <option value="@cat.CategoryId">@cat.CategoryName</option>
                                        }
                                    }
                                </select>
                                <i class="bi bi-chevron-down absolute right-4 top-1/2 -translate-y-1/2 text-gray-500 pointer-events-none text-xs dark:text-gray-400"></i>
                            </div>
                        </div>
                        <div class="space-y-1.5">
                            <label class="block text-xs font-bold text-gray-700 uppercase tracking-widest ml-1 dark:text-gray-200">Sub-Category</label>
                            <div class="relative">
                                <select name="SubCategoryId" id="editSubCategory" class="w-full border border-gray-200 rounded-xl px-5 py-3 text-sm outline-none focus:ring-2 focus:ring-[#C41E24]/20 focus:border-[#C41E24] bg-white transition-all cursor-pointer text-gray-700 shadow-sm font-medium appearance-none dark:bg-slate-800 dark:text-gray-200 dark:border-gray-700">
                                    <option value="">Select Sub-Category</option>
                                </select>
                                <i class="bi bi-chevron-down absolute right-4 top-1/2 -translate-y-1/2 text-gray-500 pointer-events-none text-xs dark:text-gray-400"></i>
                            </div>
                        </div>
                    </div>

                    <!-- Packaging -->
                    <div class="grid grid-cols-3 gap-5">
                        <div class="space-y-1.5">
                            <label class="block text-xs font-bold text-gray-700 uppercase tracking-widest ml-1 whitespace-nowrap dark:text-gray-200">Packaging Type</label>
                            <input type="text" name="PackagingType" id="editPackagingType" list="pkgTypeList" placeholder="Type"
                                   onfocus="handleDatalistFocus(this)" onblur="handleDatalistBlur(this)"
                                   class="w-full border border-gray-200 rounded-xl px-5 py-3 text-sm outline-none focus:ring-2 focus:ring-[#C41E24]/20 focus:border-[#C41E24] bg-white transition-all placeholder:text-gray-500 text-gray-800 shadow-sm font-medium dark:bg-slate-800 dark:text-white dark:placeholder:text-gray-400 dark:border-gray-700">
                        </div>
                        <div class="space-y-1.5">
                            <label class="block text-xs font-bold text-gray-700 uppercase tracking-widest ml-1 whitespace-nowrap dark:text-gray-200">Packaging Unit</label>
                            <input type="text" name="PackagingUnit" id="editPackagingUnit" list="pkgUnitList" placeholder="Unit"
                                   onfocus="handleDatalistFocus(this)" onblur="handleDatalistBlur(this)"
                                   class="w-full border border-gray-200 rounded-xl px-5 py-3 text-sm outline-none focus:ring-2 focus:ring-[#C41E24]/20 focus:border-[#C41E24] bg-white transition-all placeholder:text-gray-500 text-gray-800 shadow-sm font-medium dark:bg-slate-800 dark:text-white dark:placeholder:text-gray-400 dark:border-gray-700">
                        </div>
                        <div class="space-y-1.5">
                            <label class="block text-xs font-bold text-gray-700 uppercase tracking-widest ml-1 dark:text-gray-200">Pack Size</label>
                            <input type="text" name="PackSize" id="editPackSize" placeholder="00"
                                   class="w-full border border-gray-200 rounded-xl px-5 py-3 text-sm outline-none focus:ring-2 focus:ring-[#C41E24]/20 focus:border-[#C41E24] bg-white transition-all placeholder:text-gray-500 text-gray-800 shadow-sm font-medium dark:bg-slate-800 dark:text-white dark:placeholder:text-gray-400 dark:border-gray-700">
                        </div>
                    </div>

                    <!-- UOM -->
                    <div class="grid grid-cols-1 gap-5">
                        <div class="space-y-1.5">
                            <label class="block text-xs font-bold text-gray-700 uppercase tracking-widest ml-1 dark:text-gray-200">Unit of Measurement</label>
                            <input type="text" name="UOM" id="editUOM" list="uomList" placeholder="UOM"
                                   onfocus="handleDatalistFocus(this)" onblur="handleDatalistBlur(this)"
                                   class="w-full border border-gray-200 rounded-xl px-5 py-3 text-sm outline-none focus:ring-2 focus:ring-[#C41E24]/20 focus:border-[#C41E24] bg-white transition-all placeholder:text-gray-500 text-gray-800 shadow-sm font-medium dark:bg-slate-800 dark:text-white dark:placeholder:text-gray-400 dark:border-gray-700">
                        </div>
                    </div>

                    <!-- Pricing -->
                    <div class="grid grid-cols-2 gap-5">
                        <div class="space-y-1.5">
                            <label class="block text-xs font-bold text-gray-700 uppercase tracking-widest ml-1 dark:text-gray-200">Unit Cost</label>
                            <div class="relative">
                                <span class="absolute left-4 top-1/2 -translate-y-1/2 text-gray-500 font-bold dark:text-gray-400 text-sm">₱</span>
                                <input type="number" step="0.01" name="UnitCost" id="editUnitCost" placeholder="0.00" onfocus="this.select()"
                                       class="w-full border border-gray-200 rounded-xl pl-9 pr-5 py-3 text-sm outline-none focus:ring-2 focus:ring-[#C41E24]/20 focus:border-[#C41E24] bg-white transition-all placeholder:text-gray-500 text-gray-800 shadow-sm font-medium dark:bg-slate-800 dark:text-white dark:placeholder:text-gray-400 dark:border-gray-700">
                            </div>
                        </div>
                        <!-- Selling Price (Always visible, required) -->
                        <div id="editSellingPriceContainer" class="space-y-1.5">
                            <label class="block text-xs font-bold text-gray-700 uppercase tracking-widest ml-1 dark:text-gray-200">Selling Price</label>
                            <div class="relative">
                                <span class="absolute left-4 top-1/2 -translate-y-1/2 text-gray-500 font-bold dark:text-gray-400 text-sm">₱</span>
                                <input type="number" step="0.01" name="SellingPrice" id="editSellingPrice" placeholder="0.00" required onfocus="this.select()"
                                       class="w-full border border-gray-200 rounded-xl pl-9 pr-5 py-3 text-sm outline-none focus:ring-2 focus:ring-[#C41E24]/20 focus:border-[#C41E24] bg-white transition-all placeholder:text-gray-500 text-gray-800 shadow-sm font-medium dark:bg-slate-800 dark:text-white dark:placeholder:text-gray-400 dark:border-gray-700">
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Buttons -->
            <div class="p-8 bg-gray-50 flex justify-end space-x-4 border-t border-gray-100 dark:bg-slate-700/50 dark:border-gray-700">
                <button type="button" onclick="closeModal('editProductModal')" 
                        class="px-8 py-3 rounded-xl text-xs font-bold text-gray-500 uppercase tracking-widest hover:bg-gray-100 transition-all dark:hover:bg-slate-700 dark:text-gray-400">
                    Cancel
                </button>
                <button type="submit" 
                        class="px-12 py-3 bg-[#C41E24] text-white rounded-xl text-xs font-bold uppercase tracking-widest hover:bg-[#a51a1f] shadow-lg hover:shadow-red-200 transition-all transform active:scale-95">
                    Update Item
                </button>
            </div>
        </form>
    </div>
</div>

<div id="rejectItemModal" class="fixed inset-0 bg-black/40 hidden flex items-center justify-center z-[100] backdrop-blur-[2px] transition-all duration-300">
    <div class="bg-white rounded-2xl shadow-2xl w-full max-w-md mx-4 overflow-hidden border border-gray-100 transform transition-all opacity-0 scale-95 dark:bg-slate-800 dark:border-gray-700">
        <div class="px-8 py-6 border-b border-gray-50 flex justify-between items-center bg-white dark:bg-slate-800 dark:border-gray-700">
            <h3 class="text-base font-bold text-gray-900 dark:text-white">Reject SKU</h3>
            <button type="button" onclick="closeModal('rejectItemModal')" class="text-gray-500 hover:text-gray-700 transition-colors dark:text-gray-400">
                <i class="bi bi-x-lg text-xl"></i>
            </button>
        </div>

        <form method="post" asp-page-handler="Reject" class="p-8 space-y-5">
            <div class="space-y-1.5">
                <label class="block text-xs font-bold text-gray-700 uppercase tracking-widest ml-1 dark:text-gray-200">SKU Name</label>
                <input type="hidden" name="RejectId" id="rejectComId">
                <input type="text" name="RejectName" id="rejectItemName" readonly 
                       class="w-full border border-gray-200 rounded-xl px-5 py-3 text-sm outline-none bg-gray-50 text-gray-800 shadow-sm font-medium dark:bg-slate-700/50 dark:text-white dark:border-gray-700 cursor-default">
            </div>
            <div class="grid grid-cols-2 gap-5">
                <div class="space-y-1.5">
                    <label class="block text-xs font-bold text-gray-700 uppercase tracking-widest ml-1 dark:text-gray-200">Quantity</label>
                    <input type="number" name="RejectQty" placeholder="0" 
                           class="w-full border border-gray-200 rounded-xl px-5 py-3 text-sm outline-none focus:ring-2 focus:ring-[#C41E24]/20 focus:border-[#C41E24] bg-white transition-all placeholder:text-gray-500 text-gray-800 shadow-sm font-medium dark:bg-slate-800 dark:text-white dark:placeholder:text-gray-400 dark:border-gray-700">
                </div>
                <div class="space-y-1.5">
                    <label class="block text-xs font-bold text-gray-700 uppercase tracking-widest ml-1 dark:text-gray-200">Unit (UOM)</label>
                    <input type="text" name="RejectUOM" id="rejectUOM" readonly
                           class="w-full border border-gray-200 rounded-xl px-5 py-3 text-sm outline-none bg-gray-50 text-gray-800 shadow-sm font-medium dark:bg-slate-700/50 dark:text-white dark:border-gray-700 cursor-default">
                </div>
            </div>
            <div class="space-y-1.5">
                <label class="block text-xs font-bold text-gray-700 uppercase tracking-widest ml-1 dark:text-gray-200">Reason</label>
                <textarea name="RejectReason" rows="3" placeholder="Reason for rejection..." 
                          class="w-full border border-gray-200 rounded-xl px-5 py-3 text-sm outline-none focus:ring-2 focus:ring-[#C41E24]/20 focus:border-[#C41E24] bg-white transition-all resize-none placeholder:text-gray-500 text-gray-800 shadow-sm font-medium dark:bg-slate-800 dark:text-white dark:placeholder:text-gray-400 dark:border-gray-700"></textarea>
            </div>
            <div class="flex justify-end space-x-4 pt-8 border-t border-gray-50 dark:border-gray-700">
                <button type="button" onclick="closeModal('rejectItemModal')" 
                        class="px-8 py-3 rounded-xl text-xs font-bold text-gray-500 uppercase tracking-widest hover:bg-gray-100 transition-all dark:hover:bg-slate-700 dark:text-gray-400">
                    Cancel
                </button>
                <button type="submit" 
                        class="px-12 py-3 bg-[#C41E24] text-white rounded-xl text-xs font-bold uppercase tracking-widest hover:bg-[#a51a1f] shadow-lg hover:shadow-red-200 transition-all transform active:scale-95">
                    Submit Reject
                </button>
            </div>
        </form>
    </div>
</div>

<!-- Data Lists for Client Standards -->
<datalist id="pkgTypeList">
    <option value="Case"></option>
    <option value="Pack"></option>
    <option value="Bottle"></option>
    <option value="Gallon"></option>
    <option value="Sack"></option>
    <option value="Box"></option>
    <option value="Bundle"></option>
    <option value="Can"></option>
    <option value="Tub"></option>
    <option value="Tubs"></option>
    <option value="Jar"></option>
    <option value="Tray"></option>
    <option value="Ctn"></option>
</datalist>

<datalist id="pkgUnitList">
    <option value="Cans"></option>
    <option value="Grams (g)"></option>
    <option value="Milliliter (mL)"></option>
    <option value="Kilogram (kg)"></option>
    <option value="Pieces (pcs)"></option>
    <option value="Liter (L)"></option>
    <option value="Pull"></option>
    <option value="Sticks"></option>
    <option value="Bottles"></option>
    <option value="Per pc"></option>
</datalist>

<datalist id="uomList">
    <option value="Grams"></option>
    <option value="Dips"></option>
    <option value="mL"></option>
    <option value="Sticks"></option>
    <option value="pcs"></option>
    <option value="pack"></option>
    <option value="bottle"></option>
    <option value="cans"></option>
</datalist>

@section Scripts {
    <script>
        function toggleActions(event) {
            event.stopPropagation();
            const menu = document.getElementById('actionsMenu');
            menu.classList.toggle('hidden');
        }

        function openModal(modalId) {
            const modal = document.getElementById(modalId);
            const content = modal.querySelector('div');
            
            modal.classList.remove('hidden');
            document.body.style.overflow = 'hidden';
            
            setTimeout(() => {
                content.classList.remove('opacity-0', 'scale-95');
                content.classList.add('opacity-100', 'scale-100');
            }, 10);
        }

        function closeModal(modalId) {
            const modal = document.getElementById(modalId);
            const content = modal.querySelector('div');
            const form = modal.querySelector('form');
            
            content.classList.add('opacity-0', 'scale-95');
            content.classList.remove('opacity-100', 'scale-100');
            
            setTimeout(() => {
                modal.classList.add('hidden');
                document.body.style.overflow = 'auto';
                if (form) form.reset();
            }, 300);
        }

        function openNewProductModal() {
            openModal('newProductModal');
        }

        function openRejectModal() {
            const actionsMenu = document.getElementById('actionsMenu');
            if (actionsMenu) actionsMenu.classList.add('hidden');

            const checked = document.querySelectorAll('.row-checkbox:checked');
            if (checked.length === 0) {
                alert('Please select an SKU to reject.');
                return;
            }
            if (checked.length > 1) {
                alert('Please select only one SKU at a time for rejection.');
                return;
            }

            const item = checked[0];
            const id = item.dataset.id;
            const name = item.dataset.itemName;
            const uom = item.dataset.uom;

            document.getElementById('rejectComId').value = id;
            document.getElementById('rejectItemName').value = name;
            document.getElementById('rejectUOM').value = uom;

            openModal('rejectItemModal');
        }

        // SubCategory Filtering Logic
        const subCategories = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.SubCategories.Select(s => new { s.SubCategoryId, s.SubCategoryName, s.CategoryId })));

        function filterSubCategories(categoryId, subCategorySelectId, selectedSubCategoryId = null) {
            const select = document.getElementById(subCategorySelectId);
            select.innerHTML = '<option value="">Select Sub-Category</option>';
            
            if (!categoryId) return;

            const filtered = subCategories.filter(s => s.CategoryId == categoryId);
            filtered.forEach(s => {
                const option = document.createElement('option');
                option.value = s.SubCategoryId;
                option.textContent = s.SubCategoryName;
                if (selectedSubCategoryId && s.SubCategoryId == selectedSubCategoryId) {
                    option.selected = true;
                }
                select.appendChild(option);
            });
        }

        // Attach listeners to Category selects
        document.addEventListener('DOMContentLoaded', function() {
            const newCatSelect = document.querySelector('#newProductModal select[name="CategoryId"]');
            if (newCatSelect) {
                newCatSelect.addEventListener('change', function() {
                    filterSubCategories(this.value, 'newSubCategory');
                });
            }

            const editCatSelect = document.getElementById('editCategoryId');
            if (editCatSelect) {
                editCatSelect.addEventListener('change', function() {
                    filterSubCategories(this.value, 'editSubCategory');
                });
            }
        });

        function openNewProductModal() {
            const modal = document.getElementById('newProductModal');
            modal.classList.remove('hidden');
            setTimeout(() => {
                modal.querySelector('div').classList.remove('opacity-0', 'scale-95');
                modal.querySelector('div').classList.add('opacity-100', 'scale-100');
            }, 10);
            
            // Reset sub-categories
            document.getElementById('newSubCategory').innerHTML = '<option value="">Select Sub-Category</option>';
        }

        function openEditProductModal(sku) {
            document.getElementById('editSkuId').value = sku.skuId;
            document.getElementById('editProductName').value = sku.itemName;
            document.getElementById('editCategoryId').value = sku.categoryId;
            
            // Filter and set subcategory
            filterSubCategories(sku.categoryId, 'editSubCategory', sku.subCategoryId);

            document.querySelector('#editProductModal [name="PackagingType"]').value = sku.packagingType || '';
            document.querySelector('#editProductModal [name="PackagingUnit"]').value = sku.packagingUnit || '';
            document.querySelector('#editProductModal [name="PackSize"]').value = sku.packSize || '';
            document.querySelector('#editProductModal [name="UOM"]').value = sku.uom || '';
            document.getElementById('editUnitCost').value = sku.unitCost ? parseFloat(sku.unitCost).toFixed(2) : '';
            document.getElementById('editSellingPrice').value = sku.sellingPrice ? parseFloat(sku.sellingPrice).toFixed(2) : '';

            const modal = document.getElementById('editProductModal');
            modal.classList.remove('hidden');
            setTimeout(() => {
                modal.querySelector('div').classList.remove('opacity-0', 'scale-95');
                modal.querySelector('div').classList.add('opacity-100', 'scale-100');
            }, 10);
        }


        function toggleSelectAll(source) {
            const checkboxes = document.querySelectorAll('.row-checkbox');
            checkboxes.forEach(cb => cb.checked = source.checked);
        }

        function updateSelectAll() {
            const all = document.querySelectorAll('.row-checkbox');
            const checked = document.querySelectorAll('.row-checkbox:checked');
            const selectAll = document.getElementById('selectAll');
            selectAll.checked = all.length > 0 && all.length === checked.length;
            selectAll.indeterminate = checked.length > 0 && checked.length < all.length;
        }

        document.addEventListener('click', function (event) {
            const menu = document.getElementById('actionsMenu');
            if (menu && !menu.contains(event.target)) {
                menu.classList.add('hidden');
            }
            // Backdrop click closure disabled as per plan
            /*
            if (event.target.classList.contains('fixed')) {
                closeModal(event.target.id);
            }
            */
        });

        // Datalist Usability Helpers
        function handleDatalistFocus(input) {
            if (input.value) {
                input.dataset.originalValue = input.value;
                input.dataset.tempPlaceholder = input.placeholder;
                input.placeholder = input.value; // Show value as placeholder while focused
                input.value = '';
            }
        }

        function handleDatalistBlur(input) {
            setTimeout(() => {
                if (input.value === '' && input.dataset.originalValue) {
                    input.value = input.dataset.originalValue;
                }
                if (input.dataset.tempPlaceholder !== undefined) {
                    input.placeholder = input.dataset.tempPlaceholder;
                }
            }, 200);
        }
    </script>
}
