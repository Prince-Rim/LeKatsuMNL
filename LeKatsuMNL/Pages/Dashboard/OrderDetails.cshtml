@page
@model LeKatsuMNL.Pages.Dashboard.OrderDetailsModel
@{
    string formattedOrderId = $"{Model.Order.OrderDate.Year}-{Model.Order.OrderId:D5}";
    ViewData["Title"] = $"Transaction / Branch Orders / {formattedOrderId}";
}





    @if (!string.IsNullOrEmpty(Model.ErrorMessage))
    {
        <div class="mb-6 bg-red-50 border-l-4 border-red-500 p-4 rounded-r-lg shadow-sm flex items-center animate-pulse dark:bg-red-500/10 dark:border-red-500/50">
            <i class="bi bi-exclamation-triangle-fill text-red-500 mr-3 text-lg"></i>
            <span class="text-sm font-bold text-red-700 dark:text-red-400">@Model.ErrorMessage</span>
        </div>
    }

    <div class="bg-white rounded-xl border border-gray-200 shadow-sm mb-8 overflow-hidden dark:bg-slate-800 dark:border-gray-700">
        <div class="p-6 border-b border-gray-100 flex justify-between items-center bg-gray-50/30 dark:border-gray-700">
            <div class="flex items-center space-x-3 text-gray-700 dark:text-gray-200">
                <i class="bi bi-chevron-down text-sm font-bold"></i>
                <h4 class="text-sm font-bold uppercase tracking-widest">Franchise Invoice Details</h4>
            </div>
            <div class="flex items-center space-x-4">
                @if (Model.Order.Invoices != null && Model.Order.Invoices.Any())
                {
                    var inv = Model.Order.Invoices.First();
                    if (inv.PaymentStatus == "Paid")
                    {
                        <span class="bg-blue-100 text-blue-700 px-4 py-2 rounded-lg text-[10px] font-bold uppercase tracking-widest shadow-sm dark:bg-blue-500/10 dark:text-blue-400">
                            Payment: Paid (@inv.PaymentMethod)
                        </span>
                    }
                    else
                    {
                        <span class="bg-amber-100 text-amber-700 px-4 py-2 rounded-lg text-[10px] font-bold uppercase tracking-widest shadow-sm dark:bg-amber-500/10 dark:text-amber-400">
                            Payment: Pending
                        </span>
                    }
                }

                <a asp-page="PrintPO" asp-route-id="@Model.Order.OrderId" target="_blank" class="flex items-center space-x-2 bg-indigo-50 text-indigo-600 px-4 py-2.5 rounded-lg text-[10px] font-bold uppercase tracking-widest hover:bg-indigo-100 transition-all border border-indigo-100">
                    <i class="bi bi-file-earmark-pdf"></i>
                    <span>Print PO</span>
                </a>

                @if (Model.Order.Status == "Pending")
                {
                    <div class="flex items-center space-x-3">
                        <form method="post" asp-page-handler="RejectOrder">
                            <input type="hidden" name="OrderId" value="@Model.Order.OrderId">
                            <button type="submit" class="bg-gray-100 text-gray-600 px-6 py-2.5 rounded-lg text-xs font-bold uppercase tracking-widest hover:bg-gray-200 transition-all shadow-sm border border-gray-200">
                                Reject Order
                            </button>
                        </form>
                        <form method="post" asp-page-handler="ApproveOrder">
                            <input type="hidden" name="OrderId" value="@Model.Order.OrderId">
                            <button type="submit" class="bg-[#C41E24] text-white px-6 py-2.5 rounded-lg text-xs font-bold uppercase tracking-widest hover:bg-red-700 transition-all shadow-sm">
                                Approve Order
                            </button>
                        </form>
                    </div>
                }
                else if (Model.Order.Status == "Approved")
                {
                    <form method="post" asp-page-handler="Prepare">
                        <input type="hidden" name="OrderId" value="@Model.Order.OrderId">
                        <button type="submit" class="bg-indigo-600 text-white px-6 py-2.5 rounded-lg text-xs font-bold uppercase tracking-widest hover:bg-indigo-700 transition-all shadow-sm">
                            Start Preparing
                        </button>
                    </form>
                }
                else if (Model.Order.Status == "Preparing")
                {
                    <form method="post" asp-page-handler="Deliver">
                        <input type="hidden" name="OrderId" value="@Model.Order.OrderId">
                        <button type="submit" class="bg-green-600 text-white px-6 py-2.5 rounded-lg text-xs font-bold uppercase tracking-widest hover:bg-green-700 transition-all shadow-sm">
                            Mark as Delivered
                        </button>
                    </form>
                }
                else if (Model.Order.Status == "Delivered")
                {
                    <span class="bg-gray-100 text-gray-700 px-6 py-2.5 rounded-lg text-xs font-bold uppercase tracking-widest flex items-center shadow-sm dark:bg-slate-700 dark:text-gray-300">
                        Transaction Completed
                    </span>
                }
                else if (Model.Order.Status == "Rejected")
                {
                    <span class="bg-red-100 text-red-700 px-6 py-2.5 rounded-lg text-xs font-bold uppercase tracking-widest flex items-center shadow-sm dark:bg-red-500/10 dark:text-red-400">
                        Order Rejected
                    </span>
                }
            </div>
        </div>

        <div class="p-8 grid grid-cols-1 md:grid-cols-2 gap-x-16 gap-y-4">
            <div class="flex border border-gray-200 rounded-lg overflow-hidden shadow-sm dark:border-gray-700">
                <span class="bg-gray-50 px-5 py-3 text-xs font-bold text-gray-600 uppercase w-44 border-r border-gray-200 flex items-center dark:bg-slate-700/50 dark:text-gray-300 dark:border-gray-700">Invoice ID</span>
                <span class="px-5 py-3 text-sm text-gray-500 font-bold flex-1 flex items-center dark:text-gray-400">@formattedOrderId</span>
            </div>
            <div class="flex border border-gray-200 rounded-lg overflow-hidden shadow-sm dark:border-gray-700">
                <span class="bg-gray-50 px-5 py-3 text-xs font-bold text-gray-600 uppercase w-44 border-r border-gray-200 flex items-center dark:bg-slate-700/50 dark:text-gray-300 dark:border-gray-700">Manager ID</span>
                <span class="px-5 py-3 text-sm text-gray-500 font-bold flex-1 flex items-center dark:text-gray-400">
                    @(Model.Order.BranchManager != null ? $"BRCH-{Model.Order.BranchManager.BManagerId:D4}" : "-")
                </span>
            </div>
            <div class="flex border border-gray-200 rounded-lg overflow-hidden shadow-sm dark:border-gray-700">
                <span class="bg-gray-50 px-5 py-3 text-xs font-bold text-gray-600 uppercase w-44 border-r border-gray-200 flex items-center dark:bg-slate-700/50 dark:text-gray-300 dark:border-gray-700">Order date</span>
                <span class="px-5 py-3 text-sm text-gray-500 font-bold flex-1 flex items-center dark:text-gray-400">@Model.Order.OrderDate.ToString("MM/dd/yyyy")</span>
            </div>
            <div class="flex border border-gray-200 rounded-lg overflow-hidden shadow-sm dark:border-gray-700">
                <span class="bg-gray-50 px-5 py-3 text-xs font-bold text-gray-600 uppercase w-44 border-r border-gray-200 flex items-center dark:bg-slate-700/50 dark:text-gray-300 dark:border-gray-700">Quantity</span>
                <span class="px-5 py-3 text-sm text-gray-500 font-bold flex-1 flex items-center dark:text-gray-400">@Model.Order.OrderLists.Sum(ol => ol.Quantity).ToString("N0")</span>
            </div>
            <div class="flex border border-gray-200 rounded-lg overflow-hidden shadow-sm dark:border-gray-700">
                <span class="bg-gray-50 px-5 py-3 text-xs font-bold text-gray-600 uppercase w-44 border-r border-gray-200 flex items-center dark:bg-slate-700/50 dark:text-gray-300 dark:border-gray-700">Delivery date</span>
                <span class="px-5 py-3 text-sm text-gray-500 font-bold flex-1 flex items-center dark:text-gray-400">@(Model.Order.DeliveryDate?.ToString("MM/dd/yyyy") ?? "-")</span>
            </div>
            <div class="flex border border-gray-200 rounded-lg overflow-hidden shadow-sm dark:border-gray-700">
                <span class="bg-gray-50 px-5 py-3 text-xs font-bold text-gray-600 uppercase w-44 border-r border-gray-200 flex items-center dark:bg-slate-700/50 dark:text-gray-300 dark:border-gray-700">Total Amount Due</span>
                <span class="px-5 py-3 text-sm text-[#C41E24] font-bold flex-1 flex items-center text-lg">₱ @Model.Order.OrderLists.Sum(ol => ol.TotalPrice).ToString("N2")</span>
            </div>
        </div>
    </div>

    <div class="bg-white rounded-xl border border-gray-200 shadow-sm overflow-hidden dark:bg-slate-800 dark:border-gray-700 min-h-[500px] flex flex-col">
        <div class="flex border-b border-gray-200 px-8 dark:border-gray-700 shrink-0">
            <button onclick="switchTab('invoice')" id="tab-invoice" class="tab-btn px-8 py-5 text-xs font-bold uppercase tracking-widest text-[#C41E24] border-b-4 border-[#C41E24] -mb-[2px] transition-all">Invoice</button>
            <button onclick="switchTab('stocks')" id="tab-stocks" class="tab-btn px-8 py-5 text-xs font-bold uppercase tracking-widest text-gray-400 hover:text-gray-700 transition-colors border-b-4 border-transparent -mb-[2px] dark:text-gray-500">Stock Check</button>
            <button onclick="switchTab('issues')" id="tab-issues" class="tab-btn px-8 py-5 text-xs font-bold uppercase tracking-widest text-gray-400 hover:text-gray-700 transition-colors border-b-4 border-transparent -mb-[2px] dark:text-gray-500">Issue Reports</button>
        </div>

        <div id="content-invoice" class="tab-content block flex-1">
            <div class="p-0">
                <table class="w-full text-left text-xs whitespace-nowrap">
                    <thead class="bg-gray-50 text-gray-500 uppercase tracking-wider font-bold border-b border-gray-100 dark:bg-slate-700/50 dark:text-gray-400 dark:border-gray-700">
                        <tr>
                            <th class="px-8 py-4">Item Name</th>
                            <th class="px-8 py-4 text-center">Category</th>
                            <th class="px-8 py-4 text-center">Quantity</th>
                            <th class="px-8 py-4 text-right">Price</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-gray-100 dark:divide-gray-700">
                        @if (Model.Order.OrderLists != null)
                        {
                            foreach (var item in Model.Order.OrderLists)
                            {
                                <tr class="hover:bg-gray-50 transition-colors dark:hover:bg-slate-700/50">
                                    <td class="px-8 py-5 font-bold text-gray-800 text-sm dark:text-white">@item.SkuHeader?.ItemName</td>
                                    <td class="px-8 py-5 text-center text-gray-600 font-medium dark:text-gray-300">@item.SkuHeader?.Category?.CategoryName</td>
                                    <td class="px-8 py-5 text-center text-gray-500 font-medium dark:text-gray-400">@item.Quantity.ToString("0.##")</td>
                                    <td class="px-8 py-5 text-right text-gray-500 font-medium dark:text-gray-400">₱ @item.TotalPrice.ToString("N2")</td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>

            <div class="bg-white p-5 border-t border-gray-100 flex justify-between items-center text-xs text-gray-500 font-bold uppercase tracking-widest dark:bg-slate-800 dark:text-gray-400 dark:border-gray-700">
                <div>Showing 1 - @Model.Order.OrderLists.Count of @Model.Order.OrderLists.Count</div>
                <div class="flex items-center space-x-8">
                    <div class="flex items-center space-x-3">
                        <span>Records per page</span>
                        <div class="border border-gray-200 rounded-lg px-3 py-1 bg-gray-50 text-gray-700 flex items-center dark:bg-slate-700/50 dark:text-gray-200 dark:border-gray-700">
                            <span>10</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div id="content-stocks" class="tab-content hidden flex-1">
            <div class="p-0">
                <table class="w-full text-left text-xs whitespace-nowrap">
                    <thead class="bg-gray-50 text-gray-500 uppercase tracking-wider font-bold border-b border-gray-100 dark:bg-slate-700/50 dark:text-gray-400 dark:border-gray-700">
                        <tr>
                            <th class="px-8 py-4">Ingredient / Item</th>
                            <th class="px-8 py-4 text-center">Unit</th>
                            <th class="px-8 py-4 text-center">Needed</th>
                            <th class="px-8 py-4 text-center">Available</th>
                            <th class="px-8 py-4 text-right">Status</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-gray-100 dark:divide-gray-700">
                        @if (Model.StockCheckList != null)
                        {
                            foreach (var item in Model.StockCheckList)
                            {
                                <tr class="hover:bg-gray-50 transition-colors dark:hover:bg-slate-700/50">
                                    <td class="px-8 py-5 font-bold text-gray-800 text-sm dark:text-white">@item.ItemName</td>
                                    <td class="px-8 py-5 text-center text-gray-500 font-medium dark:text-gray-400">@item.Uom</td>
                                    <td class="px-8 py-5 text-center text-gray-800 font-black dark:text-white">@item.RequiredQuantity.ToString("0.##")</td>
                                    <td class="px-8 py-5 text-center text-gray-600 font-bold dark:text-gray-300">@item.CurrentStock.ToString("0.##")</td>
                                    <td class="px-8 py-5 text-right">
                                        @if (item.IsSufficient)
                                        {
                                            <span class="bg-green-100 text-green-700 px-3 py-1 rounded-full text-[10px] font-black uppercase tracking-tighter shadow-sm dark:bg-green-500/10 dark:text-green-500">Sufficient</span>
                                        }
                                        else
                                        {
                                            <span class="bg-red-100 text-red-700 px-3 py-1 rounded-full text-[10px] font-black uppercase tracking-tighter shadow-sm animate-pulse dark:bg-red-500/10 dark:text-red-400">Insufficient</span>
                                        }
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
            <div class="bg-white p-5 border-t border-gray-100 flex justify-between items-center text-xs text-gray-500 font-bold uppercase tracking-widest dark:bg-slate-800 dark:text-gray-400 dark:border-gray-700">
                <div>Analyzing @Model.StockCheckList.Count stock requirements</div>
            </div>
        </div>

        <div id="content-issues" class="tab-content hidden flex-1 flex flex-col">
            <div class="bg-gray-50/50 px-8 py-3 dark:bg-slate-900/50">
                <h5 class="text-xs font-bold text-gray-500 uppercase tracking-widest">Comment</h5>
            </div>
            
            <div class="flex-1 overflow-y-auto p-8 space-y-8">
                @if (Model.Comments != null && Model.Comments.Any())
                {
                    foreach (var comment in Model.Comments)
                    {
                        <div class="flex space-x-4">
                            <div class="flex-shrink-0">
                                <div class="w-10 h-10 rounded-full bg-gray-300 flex items-center justify-center text-gray-600 font-bold text-sm overflow-hidden">
                                    <i class="bi bi-person-fill text-2xl"></i>
                                </div>
                            </div>
                            <div class="flex-1 space-y-2">
                                <div class="flex flex-col">
                                    @if (comment.AdminAccount != null)
                                    {
                                        <span class="text-sm font-bold text-gray-800 dark:text-white">@(comment.AdminAccount.FirstName) @(comment.AdminAccount.LastName) - Main Office</span>
                                        <span class="text-[10px] font-bold text-gray-400 uppercase">@(comment.AdminAccount.Role)</span>
                                    }
                                    else if (comment.BranchManager != null)
                                    {
                                        <span class="text-sm font-bold text-gray-800 dark:text-white">@(comment.BranchManager.FirstName) @(comment.BranchManager.LastName) - @(comment.BranchManager.BranchLocation?.BranchName)</span>
                                        <span class="text-[10px] font-bold text-gray-400 uppercase">Branch Manager</span>
                                    }
                                    else
                                    {
                                        <span class="text-sm font-bold text-gray-800 dark:text-white">Unknown User</span>
                                    }
                                </div>
                                <div class="bg-gray-50 rounded-2xl p-4 border border-gray-100 dark:bg-slate-700/50 dark:border-gray-600 max-w-2xl">
                                    <p class="text-sm text-gray-600 leading-relaxed dark:text-gray-300">@comment.Comment</p>
                                </div>
                            </div>
                        </div>
                    }
                }
                else
                {
                    <div class="flex flex-col items-center justify-center py-20 text-gray-400">
                        <i class="bi bi-chat-left-dots text-4xl mb-4 opacity-20"></i>
                        <p class="text-xs font-bold uppercase tracking-widest">No issue reports yet</p>
                    </div>
                }
            </div>

            <div class="p-8 border-t border-gray-100 dark:border-gray-700 bg-white dark:bg-slate-800">
                <form method="post" asp-page-handler="AddComment">
                    <input type="hidden" name="OrderId" value="@Model.Order.OrderId">
                    <div class="relative mb-6">
                        <textarea name="CommentText" placeholder="Add Comment" required
                                  class="w-full border-b border-gray-200 py-3 text-sm outline-none focus:border-[#C41E24] bg-transparent transition-all placeholder:text-gray-400 text-gray-800 dark:text-white dark:border-gray-700 resize-none h-10 min-h-[40px]"></textarea>
                    </div>
                    <div class="flex justify-end space-x-4">
                        <button type="button" onclick="switchTab('invoice')" class="px-6 py-2 rounded-lg text-xs font-bold text-gray-500 uppercase tracking-widest hover:bg-gray-50 transition-all dark:text-gray-400 dark:hover:bg-slate-700">Cancel</button>
                        <button type="submit" class="px-8 py-2.5 bg-[#C41E24] text-white rounded-lg text-xs font-bold uppercase tracking-widest hover:bg-red-700 shadow-md transition-all">Send</button>
                    </div>
                </form>
            </div>
        </div>

    </div>

@section Scripts {
    <script>
        function switchTab(tab) {
            // Hide all contents
            document.querySelectorAll('.tab-content').forEach(el => el.classList.add('hidden'));
            document.querySelectorAll('.tab-content').forEach(el => el.classList.remove('block'));
            
            // Show selected content
            document.getElementById('content-' + tab).classList.remove('hidden');
            document.getElementById('content-' + tab).classList.add('block');

            // Update button styles
            document.querySelectorAll('.tab-btn').forEach(btn => {
                btn.classList.remove('text-[#C41E24]', 'border-[#C41E24]');
                btn.classList.add('text-gray-400', 'border-transparent');
            });
            
            const activeBtn = document.getElementById('tab-' + tab);
            activeBtn.classList.add('text-[#C41E24]', 'border-[#C41E24]');
            activeBtn.classList.remove('text-gray-400', 'border-transparent');
        }

        // Auto-expand textarea
        const textarea = document.querySelector('textarea[name="CommentText"]');
        if (textarea) {
            textarea.addEventListener('input', function() {
                this.style.height = 'auto';
                this.style.height = (this.scrollHeight) + 'px';
            });
        }

        // On load, check for tab parameter
        window.addEventListener('load', () => {
            const urlParams = new URLSearchParams(window.location.search);
            let tabParam = urlParams.get('tab');
            if (tabParam) {
                if (tabParam === 'items') tabParam = 'invoice';
                switchTab(tabParam);
            }
        });
    </script>
}
    