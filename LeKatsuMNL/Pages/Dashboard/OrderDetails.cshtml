@page
@model LeKatsuMNL.Pages.Dashboard.OrderDetailsModel
@{
    ViewData["Title"] = "Transaction / Branch Orders / Order Details";
}



    <div class="bg-white rounded-xl border border-gray-200 shadow-sm mb-8 overflow-hidden">
        <div class="p-6 border-b border-gray-100 flex justify-between items-center bg-gray-50/30">
            <div class="flex items-center space-x-3 text-gray-700">
                <i class="bi bi-chevron-down text-sm font-bold"></i>
                <h4 class="text-sm font-bold uppercase tracking-widest">Franchise Order Details</h4>
            </div>
            <button class="bg-[#C41E24] text-white px-6 py-2.5 rounded-lg text-xs font-bold uppercase tracking-widest hover:bg-red-700 transition-all flex items-center shadow-sm">
                <i class="bi bi-plus-lg mr-3 text-sm"></i> Mark as approved
            </button>
        </div>

        <div class="p-8 grid grid-cols-1 md:grid-cols-2 gap-x-16 gap-y-4">
            <div class="flex border border-gray-200 rounded-lg overflow-hidden shadow-sm">
                <span class="bg-gray-50 px-5 py-3 text-xs font-bold text-gray-600 uppercase w-40 border-r border-gray-200 flex items-center">Order ID</span>
                <span class="px-5 py-3 text-sm text-gray-500 font-bold flex-1 flex items-center">-</span>
            </div>
            <div class="flex border border-gray-200 rounded-lg overflow-hidden shadow-sm">
                <span class="bg-gray-50 px-5 py-3 text-xs font-bold text-gray-600 uppercase w-40 border-r border-gray-200 flex items-center">Manager ID</span>
                <span class="px-5 py-3 text-sm text-gray-500 font-bold flex-1 flex items-center">-</span>
            </div>
            <div class="flex border border-gray-200 rounded-lg overflow-hidden shadow-sm">
                <span class="bg-gray-50 px-5 py-3 text-xs font-bold text-gray-600 uppercase w-40 border-r border-gray-200 flex items-center">Order date</span>
                <span class="px-5 py-3 text-sm text-gray-500 font-bold flex-1 flex items-center">-</span>
            </div>
            <div class="flex border border-gray-200 rounded-lg overflow-hidden shadow-sm">
                <span class="bg-gray-50 px-5 py-3 text-xs font-bold text-gray-600 uppercase w-40 border-r border-gray-200 flex items-center">Quantity</span>
                <span class="px-5 py-3 text-sm text-gray-500 font-bold flex-1 flex items-center">-</span>
            </div>
            <div class="flex border border-gray-200 rounded-lg overflow-hidden shadow-sm">
                <span class="bg-gray-50 px-5 py-3 text-xs font-bold text-gray-600 uppercase w-40 border-r border-gray-200 flex items-center">Delivery date</span>
                <span class="px-5 py-3 text-sm text-gray-500 font-bold flex-1 flex items-center">-</span>
            </div>
            <div class="flex border border-gray-200 rounded-lg overflow-hidden shadow-sm">
                <span class="bg-gray-50 px-5 py-3 text-xs font-bold text-gray-600 uppercase w-40 border-r border-gray-200 flex items-center">Total Price</span>
                <span class="px-5 py-3 text-sm text-[#C41E24] font-bold flex-1 flex items-center">-</span>
            </div>
        </div>
    </div>

    <div class="bg-white rounded-xl border border-gray-200 shadow-sm overflow-hidden">
        <div class="flex border-b border-gray-200 px-8">
            <button class="px-8 py-5 text-xs font-bold uppercase tracking-widest text-[#C41E24] border-b-4 border-[#C41E24] -mb-[2px] transition-all">Items</button>
            <button class="px-8 py-5 text-xs font-bold uppercase tracking-widest text-gray-400 hover:text-gray-700 transition-colors border-b-4 border-transparent -mb-[2px]">Issue Reports</button>
            <button class="px-8 py-5 text-xs font-bold uppercase tracking-widest text-gray-400 hover:text-gray-700 transition-colors border-b-4 border-transparent -mb-[2px]">Invoice</button>
        </div>

        <div class="p-0">
            <table class="w-full text-left text-xs whitespace-nowrap">
                <thead class="bg-gray-50 text-gray-500 uppercase tracking-wider font-bold border-b border-gray-100">
                    <tr>
                        <th class="px-8 py-4">Item Name</th>
                        <th class="px-8 py-4 text-center">Category</th>
                        <th class="px-8 py-4 text-center">Quantity</th>
                        <th class="px-8 py-4 text-right">Price</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-gray-100">
                    <tr class="hover:bg-gray-50 transition-colors">
                        <td class="px-8 py-5 font-bold text-gray-800 text-sm">Allen Kalbo</td>
                        <td class="px-8 py-5 text-center text-gray-600 font-medium">Wet Goods</td>
                        <td class="px-8 py-5 text-center text-gray-500 font-medium">-</td>
                        <td class="px-8 py-5 text-right text-gray-500 font-medium">-</td>
                    </tr>
                </tbody>
            </table>
        </div>

        <div class="bg-white p-5 border-t border-gray-100 flex justify-between items-center text-xs text-gray-500 font-bold uppercase tracking-widest">
            <div>Showing 1 - 5 of 10</div>
            <div class="flex items-center space-x-8">
                <div class="flex items-center space-x-3">
                    <span>Records per page</span>
                    <div class="border border-gray-200 rounded-lg px-3 py-1 bg-gray-50 text-gray-700 flex items-center">
                        <span>10</span>
                    </div>
                </div>
                <div class="flex items-center space-x-2">
                    <button class="w-9 h-9 flex items-center justify-center border border-gray-200 rounded-lg text-gray-400 bg-gray-50 hover:bg-gray-100 transition-colors">&lt;</button>
                    <button class="w-9 h-9 flex items-center justify-center border border-gray-200 rounded-lg bg-gray-600 text-white shadow-md">1</button>
                    <button class="w-9 h-9 flex items-center justify-center border border-gray-200 rounded-lg text-gray-400 bg-gray-50 hover:bg-gray-100 transition-colors">&gt;</button>
                </div>
            </div>
        </div>
    