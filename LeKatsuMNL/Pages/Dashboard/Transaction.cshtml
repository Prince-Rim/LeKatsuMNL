@page
@model LeKatsuMNL.Pages.Dashboard.TransactionModel
@{
    ViewData["Title"] = "Transaction";
}

<div class="p-6 bg-gray-50 min-h-screen">

    <div class="bg-white rounded-t-xl border border-gray-200 p-4 flex items-center justify-between shadow-sm">

        <div class="flex items-center space-x-3 flex-1 max-w-2xl">
            <div class="relative inline-block text-left">
                <button onclick="toggleActions(event)" class="flex items-center space-x-2 border border-gray-300 rounded-md px-3 py-1.5 text-xs text-gray-500 bg-white hover:bg-gray-50 outline-none transition-all">
                    <span>Actions</span>
                    <i class="bi bi-chevron-down text-[10px]"></i>
                </button>

                <div id="actionsMenu" class="hidden absolute left-0 mt-2 w-32 bg-white rounded-xl shadow-xl border border-gray-100 z-[70] overflow-hidden transform origin-top-left transition-all">
                    <button onclick="handleArchive()" class="w-full text-left px-4 py-2.5 text-[10px] font-bold text-gray-600 uppercase tracking-widest hover:bg-gray-50 border-b border-gray-50 transition-colors">
                        Archive
                    </button>
                    <button onclick="openRejectModal()" class="w-full text-left px-4 py-2.5 text-[10px] font-bold text-gray-600 uppercase tracking-widest hover:bg-red-50 hover:text-[#C41E24] transition-colors">
                        Reject
                    </button>
                </div>
            </div>

            <div class="relative flex-1 max-w-md">
                <span class="absolute inset-y-0 left-3 flex items-center text-gray-400 text-xs">🔍</span>
                <input type="text" class="w-full border border-gray-300 rounded-md pl-9 pr-3 py-1.5 text-xs focus:ring-1 focus:ring-[#C41E24] outline-none" placeholder="Search item name...">
            </div>
        </div>

        <div class="flex items-center space-x-2">

            <button class="p-2 text-gray-400 hover:bg-gray-50 rounded transition-colors flex items-center justify-center">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 4a1 1 0 011-1h16a1 1 0 011 1v2.586a1 1 0 01-.293.707l-6.414 6.414a1 1 0 00-.293.707V17l-4 4v-6.586a1 1 0 00-.293-.707L3.293 7.293A1 1 0 013 6.586V4z"></path>
                </svg>
            </button>

            <select class="border border-gray-300 rounded px-3 py-1.5 text-xs text-gray-500 bg-gray-50 outline-none cursor-pointer">
                <option>All Types</option>
            </select>

            <select class="border border-gray-300 rounded px-3 py-1.5 text-xs text-gray-500 bg-gray-50 outline-none cursor-pointer">
                <option>All Statuses</option>
            </select>

            <button class="flex items-center space-x-2 border border-gray-300 rounded px-3 py-1.5 text-xs text-gray-600 hover:bg-gray-50 transition-colors">
                <span>🔄</span> <span>Refresh</span>
            </button>

            <button onclick="openNewItemModal()" class="bg-[#C41E24] text-white px-4 py-1.5 rounded-md text-xs font-bold hover:bg-red-700 transition-colors shadow-sm whitespace-nowrap">
                + New Item
            </button>
        </div>
    </div>

    <div class="bg-white border-x border-b border-gray-200 shadow-sm overflow-hidden">
        <table class="w-full text-left text-[11px] whitespace-nowrap">
            <thead class="bg-gray-200 text-gray-500 uppercase tracking-wider font-bold">
                <tr>
                    <th class="px-6 py-3 border-b"><input type="checkbox" class="rounded border-gray-300 text-[#C41E24] focus:ring-[#C41E24]"></th>
                    <th class="px-4 py-3 border-b">Image</th>
                    <th class="px-4 py-3 border-b">Item Name</th>
                    <th class="px-4 py-3 border-b">Category</th>
                    <th class="px-4 py-3 border-b">Sub-Category</th>
                    <th class="px-4 py-3 border-b">Sub-class</th>
                    <th class="px-4 py-3 border-b">In Stock</th>
                    <th class="px-4 py-3 border-b text-right">Price</th>
                    <th class="px-4 py-3 border-b text-right">Yield</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-gray-100">
                @for (int i = 0; i < 6; i++)
                {
                    <tr class="hover:bg-gray-50 transition-colors">
                        <td class="px-6 py-4"><input type="checkbox" class="rounded border-gray-300"></td>
                        <td class="px-4 py-4">
                            <div class="w-10 h-10 bg-gray-300 rounded-lg flex items-center justify-center text-gray-400">
                                <i class="bi bi-image text-xl"></i>
                            </div>
                        </td>
                        <td class="px-4 py-4 font-semibold text-gray-700">Beef Marinated</td>
                        <td class="px-4 py-4 text-gray-500 font-medium">Raw Material</td>
                        <td class="px-4 py-4 text-gray-500 font-medium">Wet Goods</td>
                        <td class="px-4 py-4 text-gray-500 font-medium">Food</td>
                        <td class="px-4 py-4">
                            <span class="bg-blue-100 text-blue-700 px-3 py-1 rounded-md font-bold">500g</span>
                        </td>
                        <td class="px-4 py-4 font-bold text-right text-gray-800">₱ 0.00</td>
                        <td class="px-4 py-4 font-bold text-right text-gray-400">₱ 0.00</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <div class="bg-white rounded-b-xl border-x border-b border-gray-200 p-4 flex justify-between items-center text-[10px] text-gray-400 font-bold uppercase tracking-widest">
        <div>Showing 1 - 5 of 10</div>
        <div class="flex items-center space-x-6">
            <div class="flex items-center space-x-2">
                <span>Records per page</span>
                <select class="border border-gray-300 rounded px-2 py-0.5 bg-white text-gray-600 outline-none">
                    <option>10</option>
                </select>
            </div>
            <div class="flex items-center space-x-1">
                <button class="px-2 py-1 border border-gray-300 rounded hover:bg-gray-50">&lt;</button>
                <button class="px-3 py-1 bg-gray-600 text-white rounded shadow-md">1</button>
                <button class="px-2 py-1 border border-gray-300 rounded hover:bg-gray-50">&gt;</button>
            </div>
        </div>
    </div>
</div>

<div id="newItemModal" class="fixed inset-0 bg-black/40 hidden flex items-center justify-center z-[100] backdrop-blur-[2px] transition-all duration-300">
    <div class="bg-white rounded-2xl shadow-2xl w-full max-w-lg mx-4 overflow-hidden border border-gray-100">
        <div class="px-8 py-5 border-b border-gray-50 flex justify-between items-center bg-gray-50/50">
            <h3 class="text-xs font-extrabold text-gray-800 uppercase tracking-widest">Create New Item</h3>
            <button onclick="closeModal('newItemModal')" class="text-gray-400 hover:text-gray-600 transition-colors"><i class="bi bi-x-lg text-lg"></i></button>
        </div>
        <form method="post" class="p-8 space-y-5">
            <div class="space-y-1">
                <label class="block text-[10px] font-bold text-gray-500 uppercase tracking-widest ml-1">Item Name</label>
                <input type="text" name="ItemName" placeholder="Enter item name..." class="w-full border border-gray-200 rounded-xl px-4 py-2.5 text-xs outline-none focus:ring-2 focus:ring-[#C41E24]/20 focus:border-[#C41E24] bg-gray-50/50 transition-all">
            </div>
            <div class="grid grid-cols-2 gap-5">
                <div class="space-y-1">
                    <label class="block text-[10px] font-bold text-gray-500 uppercase tracking-widest ml-1">Category</label>
                    <input type="text" name="Category" placeholder="Category" class="w-full border border-gray-200 rounded-xl px-4 py-2.5 text-xs outline-none focus:ring-2 focus:ring-[#C41E24]/20 focus:border-[#C41E24] bg-gray-50/50 transition-all">
                </div>
                <div class="space-y-1">
                    <label class="block text-[10px] font-bold text-gray-500 uppercase tracking-widest ml-1">Sub-Category</label>
                    <input type="text" name="SubCategory" placeholder="Sub-Category" class="w-full border border-gray-200 rounded-xl px-4 py-2.5 text-xs outline-none focus:ring-2 focus:ring-[#C41E24]/20 focus:border-[#C41E24] bg-gray-50/50 transition-all">
                </div>
            </div>
            <div class="grid grid-cols-2 gap-5">
                <div class="space-y-1">
                    <label class="block text-[10px] font-bold text-gray-500 uppercase tracking-widest ml-1">Yield</label>
                    <input type="text" name="Yield" placeholder="0.00" class="w-full border border-gray-200 rounded-xl px-4 py-2.5 text-xs outline-none focus:ring-2 focus:ring-[#C41E24]/20 focus:border-[#C41E24] bg-gray-50/50 transition-all">
                </div>
                <div class="space-y-1">
                    <label class="block text-[10px] font-bold text-gray-500 uppercase tracking-widest ml-1">Unit (UOM)</label>
                    <input type="text" name="UOM" placeholder="e.g. kg, grams" class="w-full border border-gray-200 rounded-xl px-4 py-2.5 text-xs outline-none focus:ring-2 focus:ring-[#C41E24]/20 focus:border-[#C41E24] bg-gray-50/50 transition-all">
                </div>
            </div>
            <div class="grid grid-cols-2 gap-5">
                <div class="space-y-1">
                    <label class="block text-[10px] font-bold text-gray-500 uppercase tracking-widest ml-1">Sub-Class</label>
                    <input type="text" name="SubClass" placeholder="Sub-Class" class="w-full border border-gray-200 rounded-xl px-4 py-2.5 text-xs outline-none focus:ring-2 focus:ring-[#C41E24]/20 focus:border-[#C41E24] bg-gray-50/50 transition-all">
                </div>
                <div class="space-y-1">
                    <label class="block text-[10px] font-bold text-gray-500 uppercase tracking-widest ml-1">Price (SRP)</label>
                    <input type="text" name="SRP" placeholder="₱ 0.00" class="w-full border border-gray-200 rounded-xl px-4 py-2.5 text-xs outline-none focus:ring-2 focus:ring-[#C41E24]/20 focus:border-[#C41E24] bg-gray-50/50 transition-all font-bold">
                </div>
            </div>
            <div class="space-y-1">
                <label class="block text-[10px] font-bold text-gray-500 uppercase tracking-widest ml-1">Supplier</label>
                <input type="text" name="Supplier" placeholder="Select supplier..." class="w-full border border-gray-200 rounded-xl px-4 py-2.5 text-xs outline-none focus:ring-2 focus:ring-[#C41E24]/20 focus:border-[#C41E24] bg-gray-50/50 transition-all">
            </div>
            <div class="flex justify-end space-x-3 pt-6">
                <button type="button" onclick="closeModal('newItemModal')" class="px-6 py-2.5 rounded-xl text-[10px] font-bold text-gray-400 uppercase tracking-widest hover:bg-gray-100 transition-all">Cancel</button>
                <button type="submit" class="px-10 py-2.5 bg-[#C41E24] text-white rounded-xl text-[10px] font-bold uppercase tracking-widest hover:bg-red-700 transition-all">Save Item</button>
            </div>
        </form>
    </div>
</div>

<div id="rejectItemModal" class="fixed inset-0 bg-black/40 hidden flex items-center justify-center z-[100] backdrop-blur-[2px] transition-all duration-300">
    <div class="bg-white rounded-2xl shadow-2xl w-full max-w-md mx-4 overflow-hidden border border-gray-100">
        <div class="px-8 py-5 border-b border-gray-50 flex justify-between items-center bg-gray-50/50">
            <h3 class="text-xs font-extrabold text-gray-800 uppercase tracking-widest">Reject Item</h3>
            <button onclick="closeModal('rejectItemModal')" class="text-gray-400 hover:text-gray-600 transition-colors"><i class="bi bi-x-lg text-lg"></i></button>
        </div>
        <form method="post" class="p-8 space-y-5">
            <div class="space-y-1">
                <label class="block text-[10px] font-bold text-gray-500 uppercase tracking-widest ml-1">Item Name</label>
                <input type="text" name="RejectName" placeholder="Item Name" class="w-full border border-gray-200 rounded-xl px-4 py-2.5 text-xs outline-none focus:ring-2 focus:ring-[#C41E24]/20 focus:border-[#C41E24] bg-gray-50/50 transition-all">
            </div>
            <div class="grid grid-cols-2 gap-5">
                <div class="space-y-1">
                    <label class="block text-[10px] font-bold text-gray-500 uppercase tracking-widest ml-1">Quantity</label>
                    <input type="number" name="RejectQty" placeholder="0" class="w-full border border-gray-200 rounded-xl px-4 py-2.5 text-xs outline-none focus:ring-2 focus:ring-[#C41E24]/20 focus:border-[#C41E24] bg-gray-50/50 transition-all">
                </div>
                <div class="space-y-1">
                    <label class="block text-[10px] font-bold text-gray-500 uppercase tracking-widest ml-1">Type</label>
                    <select name="RejectType" class="w-full border border-gray-200 rounded-xl px-4 py-2.5 text-xs outline-none focus:ring-2 focus:ring-[#C41E24]/20 focus:border-[#C41E24] bg-gray-50/50 transition-all cursor-pointer">
                        <option>Damaged</option>
                        <option>Expired</option>
                        <option>Return</option>
                    </select>
                </div>
            </div>
            <div class="space-y-1">
                <label class="block text-[10px] font-bold text-gray-500 uppercase tracking-widest ml-1">Reason</label>
                <textarea name="RejectReason" rows="3" placeholder="Reason for rejection..." class="w-full border border-gray-200 rounded-xl px-4 py-2.5 text-xs outline-none focus:ring-2 focus:ring-[#C41E24]/20 focus:border-[#C41E24] bg-gray-50/50 transition-all resize-none"></textarea>
            </div>
            <div class="flex justify-end space-x-3 pt-6">
                <button type="button" onclick="closeModal('rejectItemModal')" class="px-6 py-2.5 rounded-xl text-[10px] font-bold text-gray-400 uppercase tracking-widest hover:bg-gray-100 transition-all">Cancel</button>
                <button type="submit" class="px-10 py-2.5 bg-[#C41E24] text-white rounded-xl text-[10px] font-bold uppercase tracking-widest hover:bg-red-700 transition-all">Submit Reject</button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <script>
        const actionsMenu = document.getElementById('actionsMenu');

        function toggleActions(e) {
            e.stopPropagation();
            actionsMenu.classList.toggle('hidden');
        }

        function openNewItemModal() {
            document.getElementById('newItemModal').classList.remove('hidden');
            document.body.style.overflow = 'hidden';
        }

        function openRejectModal() {
            actionsMenu.classList.add('hidden');
            document.getElementById('rejectItemModal').classList.remove('hidden');
            document.body.style.overflow = 'hidden';
        }

        function closeModal(modalId) {
            document.getElementById(modalId).classList.add('hidden');
            document.body.style.overflow = 'auto';
        }

        function handleArchive() {
            alert("Archive action triggered.");
            actionsMenu.classList.add('hidden');
        }

        // Close dropdown when clicking anywhere else
        window.onclick = function(event) {
            if (!event.target.closest('.relative')) {
                actionsMenu.classList.add('hidden');
            }
            if (event.target.classList.contains('fixed')) {
                event.target.classList.add('hidden');
                document.body.style.overflow = 'auto';
            }
        }
    </script>
}