@page
@model LeKatsuMNL.Pages.Dashboard.BillingModel
@{
    ViewData["Title"] = "Billing";
    Layout = "_DashboardLayout";
}

<div class="h-[calc(100vh-12rem)] flex flex-col">
    <!-- Top toolbar -->
    <div class="bg-white rounded-t-xl border border-gray-200 p-5 flex items-center justify-between shadow-sm dark:bg-slate-800 dark:border-gray-700">
        <div class="relative flex-1 max-w-lg">
            <span class="absolute inset-y-0 left-4 flex items-center text-gray-400 dark:text-gray-500">
                <i class="bi bi-search text-sm"></i>
            </span>
            <input type="text" id="billingSearchInput" class="w-full border border-gray-300 rounded-lg pl-11 pr-4 py-2.5 text-sm focus:ring-1 focus:ring-[#C41E24] outline-none placeholder:text-gray-400 dark:bg-white dark:placeholder:text-gray-400 dark:border-gray-600 dark:text-gray-800" placeholder="Search invoices...">
        </div>

        <button onclick="window.location.reload()" class="flex items-center space-x-3 border border-gray-300 rounded-lg px-5 py-2.5 text-sm text-gray-600 hover:bg-gray-50 transition-all font-medium dark:hover:bg-slate-700/50 dark:text-gray-300 dark:border-gray-600">
            <i class="bi bi-arrow-clockwise text-base"></i> <span>Refresh Data</span>
        </button>
    </div>

    <!-- Table content -->
    <div class="flex-1 overflow-auto bg-white border-x border-b border-gray-200 shadow-sm dark:bg-slate-800 dark:border-gray-700 custom-scrollbar">
        <table class="w-full text-left text-xs whitespace-nowrap">
            <thead class="bg-gray-50 text-gray-500 uppercase tracking-wider font-bold border-b border-gray-100 dark:bg-slate-700/50 dark:text-gray-400 dark:border-gray-700 sticky top-0 z-10 backdrop-blur-sm">
                <tr>
                    <th class="px-8 py-4">Date</th>
                    <th class="px-8 py-4">Order ID</th>
                    <th class="px-8 py-4 text-right">Total Amount</th>
                    <th class="px-8 py-4 text-center">Payment Status</th>
                    <th class="px-8 py-4 text-center">Order Status</th>
                    <th class="px-8 py-4 text-center">Actions</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-gray-100 dark:divide-gray-700" id="billingTableBody">
                @if (Model.Invoices != null && Model.Invoices.Any())
                {
                    foreach (var invoice in Model.Invoices)
                    {
                        <tr class="hover:bg-gray-50 transition-colors border-t border-gray-100 dark:hover:bg-slate-700/50 dark:border-gray-700">
                            <td class="px-8 py-5 text-gray-600 font-medium dark:text-gray-300">@invoice.InvoiceDate.ToString("MMM dd, yyyy")</td>
                            <td class="px-8 py-5 font-bold text-gray-800 text-sm dark:text-white">
                                <a asp-page="PrintInvoice" asp-route-id="@invoice.OrderId" target="_blank" class="text-blue-600 hover:text-blue-800 transition-colors">
                                    ORD-@invoice.OrderId.ToString("D5")
                                </a>
                            </td>
                            <td class="px-8 py-5 text-right font-bold text-gray-900 text-sm dark:text-white">₱ @invoice.TotalPrice.ToString("N2")</td>
                            <td class="px-8 py-5 text-center">
                                <span class="px-3 py-1 rounded-full text-[10px] font-bold uppercase tracking-wider @(invoice.PaymentStatus.ToLower() == "paid" ? "bg-green-50 text-green-600" : "bg-orange-50 text-orange-600")">
                                    @invoice.PaymentStatus
                                </span>
                            </td>
                            <td class="px-8 py-5 text-center">
                                @{
                                    var orderStatus = invoice.OrderInfo?.Status?.ToLower() ?? "unknown";
                                    var statusClass = orderStatus switch
                                    {
                                        "approved" => "bg-emerald-50 text-emerald-600 border-emerald-100 dark:bg-emerald-500/10 dark:text-emerald-400 dark:border-emerald-500/20",
                                        "preparing" => "bg-indigo-50 text-indigo-600 border-indigo-100 dark:bg-indigo-500/10 dark:text-indigo-400 dark:border-indigo-500/20",
                                        "delivered" => "bg-gray-50 text-gray-600 border-gray-100 dark:bg-slate-700 dark:text-gray-400 dark:border-gray-600",
                                        "pending" => "bg-amber-50 text-amber-600 border-amber-100 dark:bg-amber-500/10 dark:text-amber-400 dark:border-amber-500/20",
                                        _ => "bg-gray-50 text-gray-600 border-gray-100 dark:bg-slate-700 dark:text-gray-400 dark:border-gray-600"
                                    };
                                }
                                <span class="px-3 py-1 rounded-full text-[10px] font-black uppercase tracking-widest border @statusClass">
                                    @orderStatus
                                </span>
                            </td>
                            <td class="px-8 py-5 text-center">
                                <div class="flex items-center justify-center space-x-4">
                                    <a asp-page="OrderDetails" asp-route-id="@invoice.OrderId" class="text-blue-600 hover:underline font-bold text-[10px] uppercase tracking-widest" title="View Order Details">
                                        View Details
                                    </a>
                                    @if (invoice.PaymentStatus.ToLower() != "paid")
                                    {
                                        <button onclick="openPaymentModal(@invoice.InvoiceId)" class="text-green-600 hover:underline font-bold text-[10px] uppercase tracking-widest" title="Mark as Paid">
                                            Mark as Paid
                                        </button>
                                    }
                                </div>
                            </td>
                        </tr>
                    }
                }
@* ... (no changes to else block) ... *@
            </tbody>
        </table>
    </div>
    
    <partial name="_Pagination" model="Model.Invoices" />
</div>

<!-- Mark as Paid Modal -->
<div id="paymentModal" class="fixed inset-0 z-[60] hidden overflow-y-auto" aria-labelledby="modal-title" role="dialog" aria-modal="true">
    <div class="flex items-end justify-center min-h-screen pt-4 px-4 pb-20 text-center sm:block sm:p-0">
        <div class="fixed inset-0 bg-gray-500 bg-opacity-75 transition-opacity" aria-hidden="true" onclick="closePaymentModal()"></div>
        <span class="hidden sm:inline-block sm:align-middle sm:h-screen" aria-hidden="true">&#8203;</span>
        <div class="inline-block align-middle bg-white rounded-lg text-left overflow-hidden shadow-xl transform transition-all sm:my-8 sm:align-middle sm:max-w-lg sm:w-full dark:bg-slate-800">
            <form method="post" asp-page-handler="MarkAsPaid">
                <input type="hidden" id="modalInvoiceId" name="id" />
                <div class="bg-white px-4 pt-5 pb-4 sm:p-6 sm:pb-4 dark:bg-slate-800">
                    <div class="sm:flex sm:items-start">
                        <div class="mx-auto flex-shrink-0 flex items-center justify-center h-12 w-12 rounded-full bg-green-100 sm:mx-0 sm:h-10 sm:w-10">
                            <i class="bi bi-currency-dollar text-green-600 text-xl"></i>
                        </div>
                        <div class="mt-3 text-center sm:mt-0 sm:ml-4 sm:text-left w-full">
                            <h3 class="text-lg leading-6 font-bold text-gray-900 dark:text-white" id="modal-title">Complete Payment</h3>
                            <div class="mt-4 space-y-4">
                                <div>
                                    <label class="block text-xs font-bold text-gray-400 uppercase tracking-widest mb-1">Payment Method</label>
                                    <select name="paymentMethod" required class="w-full border border-gray-300 rounded-lg px-4 py-2 text-sm focus:ring-1 focus:ring-[#C41E24] outline-none dark:bg-slate-700 dark:border-gray-600 dark:text-white">
                                        <option value="Cash">Cash</option>
                                        <option value="Bank Transfer">Bank Transfer</option>
                                        <option value="GCash">GCash</option>
                                        <option value="Maya">Maya</option>
                                        <option value="Other">Other</option>
                                    </select>
                                </div>
                                <div>
                                    <label class="block text-xs font-bold text-gray-400 uppercase tracking-widest mb-1">Reference Number</label>
                                    <input type="text" name="referenceNumber" required placeholder="e.g. GCash-123456" class="w-full border border-gray-300 rounded-lg px-4 py-2 text-sm focus:ring-1 focus:ring-[#C41E24] outline-none dark:bg-slate-700 dark:border-gray-600 dark:text-white" />
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="bg-gray-50 px-4 py-3 sm:px-6 sm:flex sm:flex-row-reverse dark:bg-slate-700/50">
                    <button type="submit" class="w-full inline-flex justify-center rounded-md border border-transparent shadow-sm px-4 py-2 bg-[#C41E24] text-base font-bold text-white hover:bg-red-700 focus:outline-none sm:ml-3 sm:w-auto sm:text-sm transition-all text-sm">
                        Confirm Payment
                    </button>
                    <button type="button" onclick="closePaymentModal()" class="mt-3 w-full inline-flex justify-center rounded-md border border-gray-300 shadow-sm px-4 py-2 bg-white text-base font-medium text-gray-700 hover:bg-gray-50 focus:outline-none sm:mt-0 sm:ml-3 sm:w-auto sm:text-sm dark:bg-slate-800 dark:text-gray-300 dark:border-gray-600">
                        Cancel
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function openPaymentModal(invoiceId) {
            document.getElementById('modalInvoiceId').value = invoiceId;
            document.getElementById('paymentModal').classList.remove('hidden');
        }

        function closePaymentModal() {
            document.getElementById('paymentModal').classList.add('hidden');
        }

        // Search functionality
        document.getElementById('billingSearchInput')?.addEventListener('keyup', function() {
            const searchTerm = this.value.toLowerCase();
            const rows = document.querySelectorAll('#billingTableBody tr');
            
            rows.forEach(row => {
                const text = row.innerText.toLowerCase();
                row.style.display = text.includes(searchTerm) ? '' : 'none';
            });
        });
    </script>
}
