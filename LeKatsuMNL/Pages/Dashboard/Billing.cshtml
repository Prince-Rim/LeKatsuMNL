@page
@model LeKatsuMNL.Pages.Dashboard.BillingModel
@{
    ViewData["Title"] = "Billing";
    Layout = "_DashboardLayout";
}

<div class="h-[calc(100vh-12rem)] flex flex-col">
    <!-- Top toolbar -->
    <div class="bg-white rounded-t-xl border border-gray-200 p-5 flex items-center justify-between shadow-sm dark:bg-slate-800 dark:border-gray-700">
        <div class="relative flex-1 max-w-lg">
            <span class="absolute inset-y-0 left-4 flex items-center text-gray-400 dark:text-gray-500">
                <i class="bi bi-search text-sm"></i>
            </span>
            <input type="text" id="billingSearchInput" class="w-full border border-gray-300 rounded-lg pl-11 pr-4 py-2.5 text-sm focus:ring-1 focus:ring-[#C41E24] outline-none placeholder:text-gray-400 dark:bg-white dark:placeholder:text-gray-400 dark:border-gray-600 dark:text-gray-800" placeholder="Search invoices...">
        </div>

        <button onclick="window.location.reload()" class="flex items-center space-x-3 border border-gray-300 rounded-lg px-5 py-2.5 text-sm text-gray-600 hover:bg-gray-50 transition-all font-medium dark:hover:bg-slate-700/50 dark:text-gray-300 dark:border-gray-600">
            <i class="bi bi-arrow-clockwise text-base"></i> <span>Refresh Data</span>
        </button>
    </div>

    <!-- Table content -->
    <div class="flex-1 overflow-auto bg-white border-x border-b border-gray-200 shadow-sm dark:bg-slate-800 dark:border-gray-700 custom-scrollbar">
        <table class="w-full text-left text-xs whitespace-nowrap">
            <thead class="bg-gray-50 text-gray-500 uppercase tracking-wider font-bold border-b border-gray-100 dark:bg-slate-700/50 dark:text-gray-400 dark:border-gray-700 sticky top-0 z-10 backdrop-blur-sm">
                <tr>
                    <th class="px-8 py-4">Date</th>
                    <th class="px-8 py-4">Order ID</th>
                    <th class="px-8 py-4 text-right">Total Amount</th>
                    <th class="px-8 py-4 text-center">Payment Status</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-gray-100 dark:divide-gray-700" id="billingTableBody">
                @if (Model.Invoices != null && Model.Invoices.Any())
                {
                    foreach (var invoice in Model.Invoices)
                    {
                        <tr class="hover:bg-gray-50 transition-colors border-t border-gray-100 dark:hover:bg-slate-700/50 dark:border-gray-700">
                            <td class="px-8 py-5 text-gray-600 font-medium dark:text-gray-300">@invoice.InvoiceDate.ToString("MMM dd, yyyy")</td>
                            <td class="px-8 py-5 font-bold text-gray-800 text-sm dark:text-white">#@invoice.OrderId</td>
                            <td class="px-8 py-5 text-right font-bold text-gray-900 text-sm dark:text-white">₱ @invoice.TotalPrice.ToString("N2")</td>
                            <td class="px-8 py-5 text-center">
                                <span class="px-3 py-1 rounded-full text-[10px] font-bold uppercase tracking-wider @(invoice.PaymentStatus.ToLower() == "paid" ? "bg-green-50 text-green-600" : "bg-orange-50 text-orange-600")">
                                    @invoice.PaymentStatus
                                </span>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="4" class="px-8 py-16 text-center text-gray-400 italic text-sm dark:text-gray-500">
                            - No invoices found -
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
    
    <partial name="_Pagination" model="Model.Invoices" />
</div>

@section Scripts {
    <script>
        // Search functionality
        document.getElementById('billingSearchInput')?.addEventListener('keyup', function() {
            const searchTerm = this.value.toLowerCase();
            const rows = document.querySelectorAll('#billingTableBody tr');
            
            rows.forEach(row => {
                const text = row.innerText.toLowerCase();
                row.style.display = text.includes(searchTerm) ? '' : 'none';
            });
        });
    </script>
}
