@using LeKatsuMNL.Helpers
@{
    var currentPage = ViewContext.RouteData.Values["page"]?.ToString() ?? "";
    var branchName = User.FindFirst("BranchName")?.Value ?? "Branch";
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - LeKatsuMNL</title>
    <script>
        if (localStorage.getItem('branch_theme') === 'dark' || (!('branch_theme' in localStorage) && window.matchMedia('(prefers-color-scheme: dark)').matches)) {
            document.documentElement.classList.add('dark');
        } else {
            document.documentElement.classList.remove('dark');
        }
        if (localStorage.getItem('branch_sidebar') === 'collapsed') {
            document.documentElement.classList.add('sidebar-collapsed');
        }
    </script>
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
        tailwind.config = {
            darkMode: 'class',
            theme: {
                extend: {}
            }
        }
    </script>
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <style>
        body { font-family: 'Inter', sans-serif; background-color: #f9fafb; }
        .active-nav { background-color: #C41E24; color: white; box-shadow: 0 4px 6px -1px rgb(0 0 0 / 0.1); }
        aside::-webkit-scrollbar { width: 4px; }
        aside::-webkit-scrollbar-thumb { background: #e5e7eb; border-radius: 10px; }
        html.sidebar-collapsed aside { width: 5rem; transition: width 0.2s ease-in-out; overflow-x: hidden; z-index: 50; }
        html.sidebar-collapsed aside:hover { width: 14rem; }
        html.sidebar-collapsed aside span.sidebar-text, html.sidebar-collapsed aside .logout-text { display: none; }
        html.sidebar-collapsed aside:hover span.sidebar-text, html.sidebar-collapsed aside:hover .logout-text { display: inline; }
        html.sidebar-collapsed aside nav a i { margin-right: 0; font-size: 1.5rem; }
        html.sidebar-collapsed aside nav a { justify-content: center; padding-left: 0; padding-right: 0; }
        html.sidebar-collapsed aside:hover nav a i { margin-right: 1rem; font-size: 1.125rem; }
        html.sidebar-collapsed aside:hover nav a { justify-content: flex-start; padding-left: 1rem; padding-right: 1rem; }
        html.sidebar-collapsed main { padding-left: 7rem; transition: padding-left 0.2s ease-in-out; }
    </style>
    @await RenderSectionAsync("Styles", required: false)
</head>
<body class="antialiased text-gray-800 dark:bg-gray-900 dark:text-gray-100 transition-colors duration-200">
    <header class="fixed top-0 left-0 right-0 h-20 bg-white dark:bg-gray-800 border-b border-gray-200 dark:border-gray-700 z-[60] flex items-center justify-between px-8 transition-colors duration-200">
        <div class="flex items-center space-x-4">
            <img src="/images/lekatsu_icon.jpg" class="h-10 w-10 rounded-full border border-gray-100 dark:border-gray-600" alt="Logo">
            <span class="font-bold text-base tracking-tight text-gray-800 dark:text-gray-100">Le Katsu MNL <span class="text-gray-400 font-medium mx-1 dark:text-gray-500">-</span> <span class="text-gray-400 font-medium text-xs dark:text-gray-500">@branchName Branch</span></span>
        </div>
        <div class="flex items-center space-x-6">
            <div class="relative">
                <i class="bi bi-bell text-2xl text-gray-500 dark:text-gray-400"></i>
                <span class="absolute -top-1 -right-1 bg-[#C41E24] text-white text-[10px] w-4.5 h-4.5 flex items-center justify-center rounded-full border-2 border-white dark:border-gray-800 font-bold">1</span>
            </div>
            <div class="flex items-center space-x-3 border-l pl-6 border-gray-200 dark:border-gray-700">
                <div class="text-right">
                    <p class="text-sm font-bold leading-none">@User.Identity?.Name</p>
                    <p class="text-[10px] text-gray-400 font-bold uppercase mt-1 dark:text-gray-500">@User.FindFirst(System.Security.Claims.ClaimTypes.Role)?.Value</p>
                </div>
                <div class="w-10 h-10 bg-[#C41E24] rounded-full border border-gray-300 dark:border-gray-600 overflow-hidden flex items-center justify-center">
                    <img src="https://ui-avatars.com/api/?name=@(Uri.EscapeDataString(User.Identity?.Name ?? "User"))&background=C41E24&color=fff&bold=true&size=40" alt="User profile" class="w-full h-full object-cover">
                </div>
            </div>
        </div>
    </header>

    <aside class="fixed top-20 left-0 bottom-0 w-56 bg-white dark:bg-gray-800 border-r border-gray-200 dark:border-gray-700 flex flex-col transition-colors duration-200 shadow-sm z-50 overflow-y-auto">
        <nav class="flex-1 px-4 py-6 space-y-2">
            <a href="/BranchDashboard" class="@(currentPage.Contains("/BranchDashboard/Index") ? "active-nav" : "text-gray-500 dark:text-gray-400 hover:bg-gray-50 dark:hover:bg-gray-700") flex items-center px-4 py-3 rounded-xl text-base font-semibold transition-all group" title="Dashboard">
                <i class="bi bi-grid-fill mr-4 text-lg"></i> <span class="sidebar-text">Dashboard</span>
            </a>
            <a href="/BranchDashboard/Catalog" class="@(currentPage.Contains("/Catalog") ? "active-nav" : "text-gray-500 dark:text-gray-400 hover:bg-gray-50 dark:hover:bg-gray-700") flex items-center px-4 py-3 rounded-xl text-base font-semibold transition-all group" title="Catalog">
                <i class="bi bi-journal-text mr-4 text-lg"></i> <span class="sidebar-text">Catalog</span>
            </a>
            <a href="/BranchDashboard/MyOrder" class="@(currentPage.Contains("/MyOrder") || currentPage.Contains("/OrderDetails") || currentPage.Contains("/PrintPO") ? "active-nav" : "text-gray-500 dark:text-gray-400 hover:bg-gray-50 dark:hover:bg-gray-700") flex items-center px-4 py-3 rounded-xl text-base font-semibold transition-all group" title="My Order">
                <i class="bi bi-cart-fill mr-4 text-lg"></i> <span class="sidebar-text">My Order</span>
            </a>
            <a href="/BranchDashboard/OrderHistory" class="@(currentPage.Contains("/OrderHistory") ? "active-nav" : "text-gray-500 dark:text-gray-400 hover:bg-gray-50 dark:hover:bg-gray-700") flex items-center px-4 py-3 rounded-xl text-base font-semibold transition-all group" title="Order History">
                <i class="bi bi-clock-history mr-4 text-lg"></i> <span class="sidebar-text">Order History</span>
            </a>
            <a href="/BranchDashboard/Settings" class="@(currentPage.Contains("/Settings") ? "active-nav" : "text-gray-500 dark:text-gray-400 hover:bg-gray-50 dark:hover:bg-gray-700") flex items-center px-4 py-3 rounded-xl text-base font-semibold transition-all group" title="Settings">
                <i class="bi bi-gear-fill mr-4 text-lg"></i> <span class="sidebar-text">Settings</span>
            </a>
        </nav>
        <div class="px-3 pb-4 border-t border-gray-100 dark:border-gray-700 pt-3">
            <form method="post" asp-page="/Login/login" asp-page-handler="Logout" class="block w-full">
                <button type="submit" class="w-full flex items-center px-4 py-3 text-gray-500 dark:text-gray-400 hover:bg-red-50 dark:hover:bg-gray-700 hover:text-[#C41E24] dark:hover:text-red-400 rounded-xl transition-all font-medium group text-sm">
                    <i class="bi bi-box-arrow-left mr-3 text-base"></i>
                    <span class="logout-text">Logout</span>
                </button>
            </form>
        </div>
    </aside>

    <main class="pt-24 pl-64 pr-8 pb-8 min-h-screen bg-[#fcfcfc] dark:bg-gray-900 transition-colors duration-200">
        <div class="bg-white dark:bg-gray-800 rounded-xl border border-gray-200 dark:border-gray-700 py-3 px-5 mb-6 flex items-center justify-between shadow-sm transition-colors duration-200">
            <div class="flex items-center">
                <button onclick="history.back()" class="bg-[#C41E24] text-white rounded-full p-2 mr-4 hover:bg-[#a51a1f] transition-colors shadow-md flex items-center justify-center">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3.5" d="M15 19l-7-7 7-7"></path>
                    </svg>
                </button>
                <h1 class="text-lg font-bold text-gray-800 dark:text-gray-100 tracking-tight">@ViewData["Title"]</h1>
            </div>
            <div>@await RenderSectionAsync("TitleActions", required: false)</div>
        </div>
        @RenderBody()
    </main>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
