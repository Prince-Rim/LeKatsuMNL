@model dynamic
@{
    var pageIndex = (int)Model.PageIndex;
    var totalPages = (int)Model.TotalPages;
    var hasPreviousPage = (bool)Model.HasPreviousPage;
    var hasNextPage = (bool)Model.HasNextPage;
    var totalItems = (int)Model.TotalItems;
    var pageSize = (int)Model.PageSize; 
    
    var startRecord = totalItems == 0 ? 0 : (pageIndex - 1) * pageSize + 1;
    var endRecord = Math.Min(pageIndex * pageSize, totalItems);
    
    int startPage = Math.Max(1, pageIndex - 2);
    int endPage = Math.Min(totalPages, pageIndex + 2);

    // Create a dictionary for route data to preserve existing query parameters (like tab, search, etc.)
    var routeData = new Dictionary<string, string>();
    foreach (var key in Context.Request.Query.Keys)
    {
        if (!string.Equals(key, "pageIndex", StringComparison.OrdinalIgnoreCase) && 
            !string.Equals(key, "PageSize", StringComparison.OrdinalIgnoreCase))
        {
            routeData[key] = Context.Request.Query[key];
        }
    }
}

<div class="bg-white rounded-b-xl border-x border-b border-gray-200 p-5 flex justify-between items-center text-xs text-gray-500 font-bold uppercase tracking-widest border-t border-gray-100 dark:bg-slate-800 dark:text-gray-400 dark:border-gray-700">
    <div class="flex items-center space-x-2">
        @if (totalItems > 0)
        {
            <span>Showing <span class="text-gray-900 dark:text-white font-black">@startRecord</span> - <span class="text-gray-900 dark:text-white font-black">@endRecord</span> of <span class="text-gray-900 dark:text-white font-black">@totalItems</span></span>
        }
        else
        {
            <span>No records found</span>
        }
    </div>

    <div class="flex items-center space-x-8">
        <div class="hidden sm:flex items-center space-x-3">
            <span>Rows per page</span>
            <select onchange="const url = new URL(window.location.href); url.searchParams.set('pageIndex', '1'); url.searchParams.set('PageSize', this.value); window.location.href = url.href;" 
                    class="border border-gray-200 rounded-lg px-2 py-1 bg-gray-50 text-gray-700 outline-none focus:ring-1 focus:ring-[#C41E24] dark:bg-slate-700/50 dark:text-gray-200 dark:border-gray-700">
                <!option value="5" @(pageSize == 5 ? "selected" : "")>5</!option>
                <!option value="10" @(pageSize == 10 ? "selected" : "")>10</!option>
                <!option value="20" @(pageSize == 20 ? "selected" : "")>20</!option>
                <!option value="50" @(pageSize == 50 ? "selected" : "")>50</!option>
            </select>
        </div>
        
        <div class="flex items-center space-x-2">
            @{
                var firstPageRoute = new Dictionary<string, string>(routeData) { ["pageIndex"] = "1", ["pageSize"] = pageSize.ToString() };
                var prevPageRoute = new Dictionary<string, string>(routeData) { ["pageIndex"] = (pageIndex - 1).ToString(), ["pageSize"] = pageSize.ToString() };
            }
            
            <a asp-all-route-data="firstPageRoute" 
               class="w-9 h-9 flex items-center justify-center border border-gray-200 rounded-lg text-gray-400 bg-gray-50 hover:bg-gray-100 transition-colors dark:bg-slate-700/50 dark:hover:bg-slate-700 dark:text-gray-500 dark:border-gray-700 @(!hasPreviousPage ? "pointer-events-none opacity-50" : "")"
               title="First Page">
                <i class="bi bi-chevron-double-left"></i>
            </a>

            <a asp-all-route-data="prevPageRoute" 
               class="w-9 h-9 flex items-center justify-center border border-gray-200 rounded-lg text-gray-400 bg-gray-50 hover:bg-gray-100 transition-colors dark:bg-slate-700/50 dark:hover:bg-slate-700 dark:text-gray-500 dark:border-gray-700 @(!hasPreviousPage ? "pointer-events-none opacity-50" : "")"
               title="Previous Page">
                <i class="bi bi-chevron-left"></i>
            </a>

            @if (startPage > 1)
            {
                var fRoute = new Dictionary<string, string>(routeData) { ["pageIndex"] = "1", ["pageSize"] = pageSize.ToString() };
                <a asp-all-route-data="fRoute" class="w-9 h-9 flex items-center justify-center border border-gray-200 rounded-lg text-gray-400 bg-gray-50 hover:bg-gray-100 transition-colors dark:bg-slate-700/50 dark:hover:bg-slate-700 dark:text-gray-500 dark:border-gray-700">1</a>
                @if (startPage > 2) { <span class="px-1 text-gray-300 dark:text-gray-600">...</span> }
            }

            @for (int i = startPage; i <= endPage; i++)
            {
                var pageRoute = new Dictionary<string, string>(routeData) { ["pageIndex"] = i.ToString(), ["pageSize"] = pageSize.ToString() };
                <a asp-all-route-data="pageRoute"
                   class="w-9 h-9 flex items-center justify-center border border-gray-200 rounded-lg transition-all @(i == pageIndex ? "bg-[#C41E24] text-white shadow-md border-[#C41E24]" : "text-gray-400 bg-gray-50 hover:bg-gray-100 dark:bg-slate-700/50 dark:hover:bg-slate-700 dark:text-gray-500 dark:border-gray-700")">
                    @i
                </a>
            }

            @if (endPage < totalPages)
            {
                @if (endPage < totalPages - 1) { <span class="px-1 text-gray-300 dark:text-gray-600">...</span> }
                var lRoute = new Dictionary<string, string>(routeData) { ["pageIndex"] = totalPages.ToString(), ["pageSize"] = pageSize.ToString() };
                <a asp-all-route-data="lRoute" class="w-9 h-9 flex items-center justify-center border border-gray-200 rounded-lg text-gray-400 bg-gray-50 hover:bg-gray-100 transition-colors dark:bg-slate-700/50 dark:hover:bg-slate-700 dark:text-gray-500 dark:border-gray-700">@totalPages</a>
            }

            @{
                var nextPageRoute = new Dictionary<string, string>(routeData) { ["pageIndex"] = (pageIndex + 1).ToString(), ["pageSize"] = pageSize.ToString() };
                var lastPageRoute = new Dictionary<string, string>(routeData) { ["pageIndex"] = totalPages.ToString(), ["pageSize"] = pageSize.ToString() };
            }
            <a asp-all-route-data="nextPageRoute"
               class="w-9 h-9 flex items-center justify-center border border-gray-200 rounded-lg text-gray-400 bg-gray-50 hover:bg-gray-100 transition-colors dark:bg-slate-700/50 dark:hover:bg-slate-700 dark:text-gray-500 dark:border-gray-700 @(!hasNextPage ? "pointer-events-none opacity-50" : "")"
               title="Next Page">
                <i class="bi bi-chevron-right"></i>
            </a>

            <a asp-all-route-data="lastPageRoute"
               class="w-9 h-9 flex items-center justify-center border border-gray-200 rounded-lg text-gray-400 bg-gray-50 hover:bg-gray-100 transition-colors dark:bg-slate-700/50 dark:hover:bg-slate-700 dark:text-gray-500 dark:border-gray-700 @(!hasNextPage ? "pointer-events-none opacity-50" : "")"
               title="Last Page">
                <i class="bi bi-chevron-double-right"></i>
            </a>
        </div>
    </div>
</div>
