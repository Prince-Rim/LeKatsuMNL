@page "{id:int}"
@model LeKatsuMNL.Pages.BranchDashboard.InvoicePDFModel
@{
    Layout = null;
    var order = Model.Order;
    var invoice = Model.Invoice;
    string formattedOrderId = $"FO-{order.OrderDate.Year.ToString().Substring(2)}{order.OrderId:D4}";
    string invoiceNo = $"INV-{invoice.InvoiceId:D5}";
    decimal grandTotal = order.OrderLists?.Sum(ol => ol.TotalPrice) ?? 0;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Invoice - @invoiceNo</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <style>
        body { font-family: 'Inter', sans-serif; -webkit-print-color-adjust: exact; print-color-adjust: exact; }
        @@media print {
            .no-print { display: none !important; }
            body { background: white !important; }
            .paper { box-shadow: none !important; border: none !important; margin: 0 !important; padding: 0 !important; width: 100% !important; }
        }
        .paper { width: 210mm; min-height: 297mm; padding: 20mm; margin: 20px auto; background: white; box-shadow: 0 0 10px rgba(0,0,0,0.1); border: 1px solid #eee; }
    </style>
</head>
<body class="bg-gray-100">

    @* Top action bar *@
    <div class="no-print bg-slate-800 text-white p-4 sticky top-0 z-50 flex justify-between items-center shadow-lg">
        <div class="flex items-center space-x-4">
            <a href="javascript:void(0)" onclick="goBackOrClose('/BranchDashboard/OrderDetails?id=@order.OrderId')"
               class="text-slate-400 hover:text-white transition-colors">
                <i class="bi bi-arrow-left"></i> Back to Order Details
            </a>
            <span class="text-slate-500">|</span>
            <span class="font-bold flex items-center">
                <i class="bi bi-receipt text-[#C41E24] mr-2 text-xl"></i>
                Invoice: @invoiceNo
            </span>
        </div>
        <button onclick="window.print()"
                class="bg-[#C41E24] hover:bg-red-700 text-white px-6 py-2 rounded-lg font-bold text-sm shadow-md transition-all flex items-center">
            <i class="bi bi-printer-fill mr-2"></i> Print Invoice
        </button>
    </div>

    @* Paper *@
    <div class="paper">
        @* Header *@
        <div class="flex justify-between items-start mb-10">
            <div>
                <h1 class="text-3xl font-extrabold text-[#C41E24] uppercase tracking-tighter mb-1">Le Katsu MNL</h1>
                <p class="text-xs text-gray-500 font-bold uppercase tracking-widest">Commissary &amp; Main Office</p>
                <div class="mt-3 text-xs text-gray-600 leading-relaxed">
                    <p>27 Ground floor Touch of class Katipunan Ave. Kingspoint Subdivision</p>
                    <p>Brgy. Bagbag Novaliches Q.C.</p>
                    <p>Email: lekatsumnl@gmail.com</p>
                </div>
            </div>
            <div class="text-right">
                <h2 class="text-4xl font-black text-gray-900 uppercase tracking-tight mb-3">INVOICE</h2>
                <div class="space-y-1 text-xs text-gray-600">
                    <div class="flex justify-end gap-3">
                        <span class="text-gray-400">Invoice No:</span>
                        <span class="font-bold bg-[#C41E24] text-white px-2 py-0.5 rounded">@invoiceNo</span>
                    </div>
                    <div class="flex justify-end gap-3">
                        <span class="text-gray-400">PO Reference:</span>
                        <span class="font-bold">@formattedOrderId</span>
                    </div>
                    <div class="flex justify-end gap-3">
                        <span class="text-gray-400">Invoice Date:</span>
                        <span class="font-bold">@invoice.InvoiceDate.ToString("MMMM dd, yyyy")</span>
                    </div>
                    <div class="flex justify-end gap-3">
                        <span class="text-gray-400">Order Date:</span>
                        <span class="font-bold">@order.OrderDate.ToString("MMMM dd, yyyy")</span>
                    </div>
                </div>
            </div>
        </div>

        @* Bill To / Status *@
        <div class="grid grid-cols-2 gap-12 mb-10 border-y border-gray-100 py-8">
            <div>
                <h3 class="text-[10px] font-bold text-gray-400 uppercase tracking-[0.2em] mb-3">Bill To</h3>
                <p class="text-base font-bold text-gray-800">@(order.BranchManager?.BranchLocation?.BranchName ?? "—")</p>
                <p class="text-sm text-gray-500 font-medium">@(order.BranchManager?.FirstName) @(order.BranchManager?.LastName)</p>
                <p class="text-xs text-gray-400 mt-2 leading-relaxed">@(order.BranchManager?.BranchLocation?.BranchLocationAddress ?? "—")</p>
            </div>
            <div class="text-right">
                <h3 class="text-[10px] font-bold text-gray-400 uppercase tracking-[0.2em] mb-3">Payment Info</h3>
                <div class="space-y-1.5 text-xs">
                    <div class="flex justify-end gap-3">
                        <span class="text-gray-400">Status:</span>
                        <span class="font-black px-2 py-0.5 rounded
                            @(invoice.PaymentStatus == "Paid" ? "bg-green-100 text-green-700" : "bg-orange-100 text-orange-700")">
                            @(invoice.PaymentStatus ?? "Pending")
                        </span>
                    </div>
                    <div class="flex justify-end gap-3">
                        <span class="text-gray-400">Method:</span>
                        <span class="font-bold text-gray-700">@(invoice.PaymentMethod ?? "—")</span>
                    </div>
                    @if (invoice.PaymentDate.HasValue)
                    {
                        <div class="flex justify-end gap-3">
                            <span class="text-gray-400">Paid On:</span>
                            <span class="font-bold text-gray-700">@invoice.PaymentDate.Value.ToString("MMMM dd, yyyy")</span>
                        </div>
                    }
                    @if (!string.IsNullOrEmpty(invoice.ReferenceNumber))
                    {
                        <div class="flex justify-end gap-3">
                            <span class="text-gray-400">Ref #:</span>
                            <span class="font-bold text-gray-700">@invoice.ReferenceNumber</span>
                        </div>
                    }
                </div>
            </div>
        </div>

        @* Items Table *@
        <div class="mb-10">
            <table class="w-full text-sm">
                <thead>
                    <tr class="border-b-2 border-gray-900">
                        <th class="py-3 text-left font-bold uppercase text-xs tracking-widest text-gray-400">Item</th>
                        <th class="py-3 text-center font-bold uppercase text-xs tracking-widest text-gray-400">Qty</th>
                        <th class="py-3 text-center font-bold uppercase text-xs tracking-widest text-gray-400">Unit</th>
                        <th class="py-3 text-right font-bold uppercase text-xs tracking-widest text-gray-400">Unit Price</th>
                        <th class="py-3 text-right font-bold uppercase text-xs tracking-widest text-gray-400">Amount</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-gray-100">
                    @if (order.OrderLists != null)
                    {
                        @foreach (var item in order.OrderLists)
                        {
                            string itemName = item.SkuId.HasValue ? item.SkuHeader?.ItemName : item.CommissaryInventory?.ItemName;
                            string itemCode = item.SkuId.HasValue ? $"SKU-{item.SkuId:D4}" : $"COM-{item.ComId:D4}";
                            string uom = item.SkuId.HasValue ? item.SkuHeader?.Uom : item.CommissaryInventory?.Uom;
                            decimal unitPrice = item.Quantity > 0 ? item.TotalPrice / item.Quantity : 0;
                            <tr>
                                <td class="py-3">
                                    <p class="font-bold text-gray-800">@itemName</p>
                                    <p class="text-[10px] text-gray-400 uppercase font-medium">@itemCode</p>
                                </td>
                                <td class="py-3 text-center text-gray-600">@item.Quantity.ToString("0.##")</td>
                                <td class="py-3 text-center text-gray-600">@uom</td>
                                <td class="py-3 text-right text-gray-600">₱ @unitPrice.ToString("N2")</td>
                                <td class="py-3 text-right font-bold text-gray-800">₱ @item.TotalPrice.ToString("N2")</td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>

        @* Totals *@
        <div class="flex justify-end mb-16">
            <div class="w-72 space-y-3 text-sm">
                <div class="flex justify-between">
                    <span class="text-gray-500">Subtotal</span>
                    <span class="font-bold text-gray-800">₱ @grandTotal.ToString("N2")</span>
                </div>
                <div class="flex justify-between border-t-2 border-gray-900 pt-3">
                    <span class="text-base font-black uppercase text-[#C41E24]">Total Due</span>
                    <span class="text-base font-black text-gray-900">₱ @grandTotal.ToString("N2")</span>
                </div>
            </div>
        </div>

        @* Footer note *@
        <div class="border-t border-gray-100 pt-6 text-[10px] text-gray-400 text-center leading-relaxed">
            <p>This is a system-generated invoice from Le Katsu MNL. Thank you for your order.</p>
            <p>For questions, contact lekatsumnl@gmail.com</p>
        </div>
    </div>

    <script>
        function goBackOrClose(fallbackUrl) {
            if (window.opener || window.history.length === 1) { window.close(); }
            setTimeout(function() { window.location.href = fallbackUrl; }, 100);
        }
    </script>
</body>
</html>
