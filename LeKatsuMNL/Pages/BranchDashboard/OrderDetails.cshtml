@page
@model LeKatsuMNL.Pages.BranchDashboard.OrderDetailsModel
@{
    ViewData["Title"] = "Order Details";
    Layout = "_BranchLayout";

    var order = Model.Order;
    var invoice = Model.Invoice;
    string formattedId = order != null ? $"FO-{order.OrderDate.Year.ToString().Substring(2)}{order.OrderId:D4}" : "—";
    string statusPath = order?.Status == "Approved" ? "Approved Order" :
                        order?.Status == "Completed" ? "Completed Order" :
                        order?.Status == "Cancelled" ? "Cancelled Order" : "Purchase Order";
    decimal grandTotal = order?.OrderLists?.Sum(ol => ol.TotalPrice) ?? 0;
    string branchName = User.FindFirst("BranchName")?.Value ?? "Branch";
}

@section TitleActions {
    <div class="flex items-center gap-2">
        @if (Model.Invoice != null)
        {
            <a href="/BranchDashboard/InvoicePDF/@Model.Order.OrderId" target="_blank"
               class="px-3 py-1.5 text-xs font-bold border border-[#C41E24] text-[#C41E24] rounded-lg hover:bg-red-50 dark:hover:bg-red-900/20 transition-colors flex items-center gap-1.5"
               title="View Invoice">
                <i class="bi bi-receipt"></i> Invoice
            </a>
        }
        <a href="/BranchDashboard/PrintPO/@Model.Order.OrderId" target="_blank"
           class="w-9 h-9 rounded-lg border border-gray-200 flex items-center justify-center text-gray-500 hover:bg-gray-50 dark:border-gray-600 dark:text-gray-400 dark:hover:bg-slate-700 transition-colors"
           title="Print PO">
            <i class="bi bi-printer"></i>
        </a>
    </div>
}

@section Styles {
<style>
    /* Hide print-only element on screen */
    #po-printable { display: none; }

    @@media print {
        /* Show PO, hide everything else */
        header, aside, .breadcrumb-bar, .action-buttons { display: none !important; }
        main { padding: 0 !important; }
        .screen-only { display: none !important; }
        #po-printable { display: block; }
        @@page { margin: 1.5cm 2cm; }
    }
</style>
}

@* Print-only PO document (hidden on screen, visible on print) *@
<div id="po-printable" style="font-family:sans-serif; font-size:14px; color:#1a1a1a; padding:0 8px;">
    @* PO Header *@
    <div style="display:flex; justify-content:space-between; align-items:flex-start; border-bottom:2px solid #C41E24; padding-bottom:14px; margin-bottom:20px;">
        <div>
            <h1 style="font-size:22px; font-weight:900; color:#C41E24; margin:0;">Le Katsu MNL</h1>
            <p style="margin:2px 0; font-size:12px; color:#555;">@branchName</p>
            <p style="margin:2px 0; font-size:11px; color:#777;">Purchase Order</p>
        </div>
        <div style="text-align:right; font-size:12px; color:#555;">
            <p style="margin:2px 0;"><strong>Statement No:</strong> @formattedId</p>
            <p style="margin:2px 0;"><strong>Date Issued:</strong> @(order?.OrderDate.ToString("MMMM dd, yyyy") ?? "—")</p>
            <p style="margin:2px 0;"><strong>Status:</strong> @(order?.Status ?? "—")</p>
        </div>
    </div>

    @* Order meta *@
    <table style="width:100%; margin-bottom:20px; font-size:12px; border-collapse:collapse;">
        <tr>
            <td style="width:50%; padding:4px 0;">
                <span style="color:#888;">Reference PO:</span>
                <strong style="margin-left:8px;">@(invoice?.ReferenceNumber ?? "—")</strong>
            </td>
            <td style="width:50%; padding:4px 0;">
                <span style="color:#888;">Approved Date:</span>
                <strong style="margin-left:8px;">@(invoice?.InvoiceDate.ToString("MMMM dd, yyyy") ?? "—")</strong>
            </td>
        </tr>
        <tr>
            <td style="padding:4px 0;">
                <span style="color:#888;">Payment Terms:</span>
                <strong style="margin-left:8px;">@(invoice?.PaymentMethod ?? "—")</strong>
            </td>
        </tr>
    </table>

    @* Items table *@
    <table style="width:100%; border-collapse:collapse; font-size:12px; margin-bottom:20px;">
        <thead>
            <tr style="background:#C41E24; color:white;">
                <th style="padding:8px 10px; text-align:left;">Item Code</th>
                <th style="padding:8px 10px; text-align:left;">Description</th>
                <th style="padding:8px 10px; text-align:left;">Classification</th>
                <th style="padding:8px 10px; text-align:right;">Qty</th>
                <th style="padding:8px 10px; text-align:right;">Unit Price</th>
                <th style="padding:8px 10px; text-align:right;">Line Total</th>
            </tr>
        </thead>
        <tbody>
            @if (order?.OrderLists != null)
            {
                int rowIndex = 0;
                @foreach (var item in order.OrderLists)
                {
                    string itemCode = item.SkuId.HasValue ? $"SKU-{item.SkuId:D3}" : $"RM-{item.ComId:D3}";
                    string itemName = item.SkuHeader?.ItemName ?? item.CommissaryInventory?.ItemName ?? "—";
                    string category = item.SkuHeader?.Category?.CategoryName ?? item.CommissaryInventory?.Category?.CategoryName ?? "—";
                    decimal unitPrice = item.Quantity > 0 ? item.TotalPrice / item.Quantity : 0;
                    string rowBg = rowIndex % 2 == 0 ? "#f9f9f9" : "#ffffff";
                    rowIndex++;
                    <tr style="background:@rowBg;">
                        <td style="padding:7px 10px; border-bottom:1px solid #eee; font-family:monospace;">@itemCode</td>
                        <td style="padding:7px 10px; border-bottom:1px solid #eee;">@itemName</td>
                        <td style="padding:7px 10px; border-bottom:1px solid #eee; color:#666;">@category</td>
                        <td style="padding:7px 10px; border-bottom:1px solid #eee; text-align:right;">@item.Quantity.ToString("G")</td>
                        <td style="padding:7px 10px; border-bottom:1px solid #eee; text-align:right;">₱@unitPrice.ToString("N2")</td>
                        <td style="padding:7px 10px; border-bottom:1px solid #eee; text-align:right; font-weight:bold;">₱@item.TotalPrice.ToString("N2")</td>
                    </tr>
                }
            }
        </tbody>
        <tfoot>
            <tr>
                <td colspan="5" style="padding:10px; text-align:right; font-weight:bold; font-size:13px;">Grand Total:</td>
                <td style="padding:10px; text-align:right; font-weight:900; font-size:15px; color:#C41E24;">₱@grandTotal.ToString("N2")</td>
            </tr>
        </tfoot>
    </table>

    @* Signature area *@
    <div style="display:flex; justify-content:space-between; margin-top:40px; font-size:11px; color:#555;">
        <div style="text-align:center;">
            <div style="border-top:1px solid #333; width:180px; margin-bottom:4px;"></div>
            <p style="margin:0;">Prepared by</p>
        </div>
        <div style="text-align:center;">
            <div style="border-top:1px solid #333; width:180px; margin-bottom:4px;"></div>
            <p style="margin:0;">Approved by</p>
        </div>
        <div style="text-align:center;">
            <div style="border-top:1px solid #333; width:180px; margin-bottom:4px;"></div>
            <p style="margin:0;">Received by</p>
        </div>
    </div>
</div>



@* Main content *@
<!-- Main content -->
<div class="screen-only px-1 mb-6">
    <div class="flex items-center gap-4 mb-8">
        <a href="/BranchDashboard/MyOrder" class="w-10 h-10 rounded-full bg-red-50 text-[#C41E24] flex items-center justify-center hover:bg-[#C41E24] hover:text-white transition-all shadow-sm dark:bg-red-500/10 dark:hover:bg-[#C41E24]">
            <i class="bi bi-chevron-left text-lg"></i>
        </a>
        <h1 class="text-2xl font-black text-gray-800 dark:text-white uppercase tracking-tight">Order Details</h1>
    </div>
</div>

<div class="screen-only px-1 mb-4">
    @if (TempData["Message"] != null)
    {
        <div class="mb-4 p-4 rounded-xl bg-blue-50 border border-blue-100 text-blue-600 text-sm font-medium flex items-center gap-3">
            <i class="bi bi-info-circle-fill"></i> @TempData["Message"]
        </div>
    }
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="mb-4 p-4 rounded-xl bg-red-50 border border-red-100 text-red-600 text-sm font-medium flex items-center gap-3">
            <i class="bi bi-exclamation-triangle-fill"></i> @TempData["ErrorMessage"]
        </div>
    }
</div>

<div class="screen-only grid grid-cols-1 lg:grid-cols-5 gap-4 mb-4">
    @* Order Details Panel *@
    <div class="lg:col-span-2 bg-white rounded-2xl border border-gray-100 shadow-sm p-6 dark:bg-slate-800 dark:border-gray-700">
        <p class="text-xs font-bold uppercase text-gray-400 tracking-widest mb-5 dark:text-gray-500">Order Details</p>
        <dl class="space-y-4 text-sm">
            <div class="flex gap-3">
                <dt class="w-36 text-gray-400 dark:text-gray-500 flex-shrink-0">Statement No</dt>
                <dd class="font-bold text-gray-800 dark:text-white">@formattedId</dd>
            </div>
            <div class="flex gap-3 border-b border-gray-50 dark:border-gray-700/50 pb-3">
                <dt class="w-36 text-gray-400 dark:text-gray-500 flex-shrink-0 font-bold uppercase text-[10px] tracking-widest pt-1">Reference PO</dt>
                <dd class="font-bold text-gray-800 dark:text-white">
                    @if (invoice?.ReferenceNumber != null && invoice.ReferenceNumber.StartsWith("SESSION:"))
                    {
                        <div class="flex flex-col gap-1">
                            <span class="text-amber-600 dark:text-amber-400 flex items-center gap-2">
                                <i class="bi bi-hourglass-split animate-spin text-sm"></i>
                                <span class="animate-pulse">Verifying Payment...</span>
                            </span>
                            @if (order?.Status == "Approved" && invoice.PaymentStatus == "Pending")
                            {
                                <form method="post" asp-page-handler="Verify" class="mt-1">
                                    <input type="hidden" name="id" value="@order.OrderId" />
                                    <button type="submit" class="text-[10px] bg-amber-100 text-amber-700 dark:bg-amber-900/40 dark:text-amber-300 px-3 py-1 rounded-lg font-black uppercase hover:bg-amber-200 transition-colors shadow-sm active:scale-95">
                                        <i class="bi bi-arrow-clockwise mr-1"></i> Force Refresh
                                    </button>
                                </form>
                            }
                        </div>
                    }
                    else
                    {
                        @(invoice?.ReferenceNumber ?? "—")
                    }
                </dd>
            </div>
            <div class="flex gap-3">
                <dt class="w-36 text-gray-400 dark:text-gray-500 flex-shrink-0">Date Issued</dt>
                <dd class="font-medium text-gray-600 dark:text-gray-300">@(order?.OrderDate.ToString("MMMM dd, yyyy") ?? "—")</dd>
            </div>
            <div class="flex gap-3">
                <dt class="w-36 text-gray-400 dark:text-gray-500 flex-shrink-0">Approved date</dt>
                <dd class="font-medium text-gray-600 dark:text-gray-300">@(invoice?.InvoiceDate.ToString("MMMM dd, yyyy") ?? "—")</dd>
            </div>
            <div class="flex gap-3">
                <dt class="w-36 text-gray-400 dark:text-gray-500 flex-shrink-0">Payment Terms</dt>
                <dd class="font-medium text-gray-600 dark:text-gray-300">@(invoice?.PaymentMethod ?? "—")</dd>
            </div>
            <div class="flex gap-3">
                <dt class="w-36 text-gray-400 dark:text-gray-500 flex-shrink-0">Status</dt>
                <dd>
                    <span class="px-2.5 py-1 rounded-full text-[10px] font-black uppercase tracking-widest border
                        @(order?.Status == "Completed" ? "bg-emerald-50 text-emerald-600 border-emerald-100 dark:bg-emerald-500/10 dark:text-emerald-400 dark:border-emerald-500/20" :
                          order?.Status == "Rejected" ? "bg-rose-50 text-rose-600 border-rose-100 dark:bg-rose-500/10 dark:text-rose-400 dark:border-rose-500/20" :
                          order?.Status == "Cancelled" ? "bg-gray-50 text-gray-600 border-gray-100 dark:bg-slate-700 dark:text-gray-400 dark:border-gray-600" :
                          order?.Status == "Delivering" ? "bg-cyan-50 text-cyan-600 border-cyan-100 dark:bg-cyan-500/10 dark:text-cyan-400 dark:border-cyan-500/20" :
                          order?.Status == "Preparing" ? "bg-indigo-50 text-indigo-600 border-indigo-100 dark:bg-indigo-500/10 dark:text-indigo-400 dark:border-indigo-500/20" :
                          order?.Status == "Approved" ? "bg-blue-50 text-blue-600 border-blue-100 dark:bg-blue-500/10 dark:text-blue-400 dark:border-blue-500/20" :
                          "bg-amber-50 text-amber-600 border-amber-100 dark:bg-amber-500/10 dark:text-amber-400 dark:border-amber-500/20")">
                        @(order?.Status ?? "—")
                    </span>
                </dd>
            </div>
        </dl>
    </div>

    @* Order Items Panel *@
    <div class="lg:col-span-3 bg-white rounded-2xl border border-gray-100 shadow-sm overflow-hidden dark:bg-slate-800 dark:border-gray-700">
        <div class="overflow-x-auto">
            <table class="w-full text-sm">
                <thead>
                    <tr class="text-gray-400 text-xs uppercase border-b border-gray-100 dark:border-gray-700 dark:text-gray-500">
                        <th class="px-5 py-4 font-bold text-left">Item Code</th>
                        <th class="px-4 py-4 font-bold text-left">Item Description</th>
                        <th class="px-4 py-4 font-bold text-left">Classification</th>
                        <th class="px-4 py-4 font-bold text-right">Quantity</th>
                        <th class="px-4 py-4 font-bold text-right">Line Total</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-gray-50 dark:divide-gray-700">
                    @if (order?.OrderLists != null && order.OrderLists.Any())
                    {
                        @foreach (var item in order.OrderLists)
                        {
                            string itemCode = item.SkuId.HasValue
                                ? $"SKU-{item.SkuId:D3}"
                                : $"RM-{item.ComId:D3}";
                            string itemName = item.SkuHeader?.ItemName ?? item.CommissaryInventory?.ItemName ?? "—";
                            string category = item.SkuHeader?.Category?.CategoryName
                                ?? item.CommissaryInventory?.Category?.CategoryName ?? "—";

                            <tr class="hover:bg-gray-50/50 dark:hover:bg-slate-700/30 transition-colors">
                                <td class="px-5 py-4 text-gray-500 dark:text-gray-400 font-mono text-xs">@itemCode</td>
                                <td class="px-4 py-4 font-medium text-gray-800 dark:text-white">@itemName</td>
                                <td class="px-4 py-4 text-gray-500 dark:text-gray-400">@category</td>
                                <td class="px-4 py-4 text-right font-medium text-gray-700 dark:text-gray-200">@item.Quantity.ToString("0.##")</td>
                                <td class="px-4 py-4 text-right font-bold text-gray-800 dark:text-white">₱@item.TotalPrice.ToString("N2")</td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="5" class="px-6 py-10 text-center text-gray-300 text-xs uppercase tracking-wider">No items found</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@* Bottom section: Payment Instructions + Financial Summary *@
<div class="screen-only grid grid-cols-1 lg:grid-cols-2 gap-4 mb-5">
    <div class="bg-white rounded-2xl border border-gray-100 shadow-sm p-6 dark:bg-slate-800 dark:border-gray-700">
        <p class="text-xs font-bold uppercase text-gray-400 tracking-widest mb-6 dark:text-gray-500">Order Journey</p>
        <div class="relative flex items-center justify-between w-full px-2">
            @* Progress Line Background *@
            <div class="absolute left-10 right-10 h-1 bg-gray-100 dark:bg-gray-700 top-1/2 -translate-y-4"></div>
            
            @* Progress Line Active *@
            @{
                var stages = new[] { "Pending", "Approved", "Preparing", "Delivering", "Completed" };
                int currentStageIndex = Array.IndexOf(stages, order?.Status ?? "Pending");
                if (order?.Status == "Delivering") currentStageIndex = 3;
                if (order?.Status == "Preparing") currentStageIndex = 2;
                if (order?.Status == "Approved") currentStageIndex = 1;
                if (order?.Status == "Completed") currentStageIndex = 4;
                
                double progressWidth = currentStageIndex * 25; // 0, 25, 50, 75, 100
            }
            <div class="absolute left-10 h-1 bg-[#C41E24] top-1/2 -translate-y-4 transition-all duration-700 ease-out" style="width: calc(@(progressWidth)% - 10px)"></div>

            @* Steps *@
            @for (int i = 0; i < stages.Length; i++)
            {
                bool isCompleted = i < currentStageIndex;
                bool isCurrent = i == currentStageIndex;
                bool isFuture = i > currentStageIndex;
                
                string icon = i == 0 ? "bi-send" : 
                              i == 1 ? "bi-check2-circle" : 
                              i == 2 ? "bi-box-seam" : 
                              i == 3 ? "bi-truck" : "bi-flag";
                
                <div class="relative z-10 flex flex-col items-center">
                    <div class="w-8 h-8 rounded-full flex items-center justify-center border-2 transition-all duration-300 
                        @(isCurrent ? "bg-white border-[#C41E24] text-[#C41E24] shadow-[0_0_15px_rgba(196,30,36,0.3)] scale-125 dark:bg-slate-800" : 
                          isCompleted ? "bg-[#C41E24] border-[#C41E24] text-white" : 
                          "bg-white border-gray-200 text-gray-300 dark:bg-slate-800 dark:border-gray-700")">
                        <i class="bi @icon text-xs"></i>
                    </div>
                    <span class="mt-2 text-[10px] font-black uppercase tracking-tighter @(isCurrent ? "text-[#C41E24]" : isCompleted ? "text-gray-600 dark:text-gray-300" : "text-gray-300 dark:text-gray-600")">@stages[i]</span>
                </div>
            }
        </div>
    </div>

        <div class="bg-white rounded-2xl border border-gray-100 shadow-sm p-6 dark:bg-slate-800 dark:border-gray-700">
            <p class="text-xs font-bold uppercase text-gray-400 tracking-widest mb-4 dark:text-gray-500">Financial Summary</p>
            <div class="flex items-center justify-between text-sm">
                <span class="text-gray-600 dark:text-gray-300 font-medium">Total Amount:</span>
                <span class="font-bold text-2xl text-gray-800 dark:text-white">₱@grandTotal.ToString("N2")</span>
            </div>
            @if (invoice != null)
            {
                <div class="mt-2 flex items-center justify-between text-sm">
                    <span class="text-gray-500 dark:text-gray-400">Payment Status:</span>
                    <span class="font-bold text-[#C41E24]">@invoice.PaymentStatus</span>
                </div>
            }
        </div>
    </div>

    @* Chat Section Trigger *@
    <div class="screen-only px-1 mb-6">
        <button onclick="document.getElementById('chatSection').scrollIntoView({behavior: 'smooth'})" class="w-full flex items-center justify-between p-5 bg-white border border-gray-100 rounded-2xl shadow-sm hover:border-[#C41E24] hover:bg-red-50/30 transition-all group dark:bg-slate-800 dark:border-gray-700 dark:hover:border-red-500/50">
            <div class="flex items-center space-x-5">
                <div class="w-12 h-12 bg-red-50 rounded-2xl flex items-center justify-center group-hover:bg-white transition-colors dark:bg-red-500/10">
                    <i class="bi bi-chat-left-dots-fill text-[#C41E24] text-xl"></i>
                </div>
                <div class="flex flex-col items-start">
                    <span class="text-sm font-black text-gray-800 uppercase tracking-widest dark:text-white">Chat with Main Office</span>
                    <span class="text-[10px] font-bold text-gray-400 uppercase">Recent activity: @(Model.Comments.LastOrDefault()?.Comment ?? "No messages yet")</span>
                </div>
            </div>
            <i class="bi bi-chevron-down text-gray-300 group-hover:text-[#C41E24] transition-colors"></i>
        </button>
    </div>

    @* Full Chat Interface *@
    <div id="chatSection" class="screen-only bg-white rounded-2xl border border-gray-100 shadow-xl overflow-hidden mb-12 flex flex-col min-h-[600px] dark:bg-slate-800 dark:border-gray-700">
        <div class="px-8 py-5 border-b border-gray-50 bg-gray-50/30 flex items-center justify-between dark:bg-slate-700/30 dark:border-gray-700">
            <div class="flex items-center space-x-3">
                <i class="bi bi-chat-square-text-fill text-[#C41E24] text-lg"></i>
                <h4 class="text-sm font-black uppercase tracking-widest text-gray-800 dark:text-white">Order Discussion - @formattedId</h4>
            </div>
            <span class="bg-green-100 text-green-700 px-3 py-1 rounded-full text-[9px] font-black uppercase tracking-widest dark:bg-green-500/10 dark:text-green-500">Online</span>
        </div>

        <div class="flex-1 overflow-y-auto p-8 space-y-6 bg-white dark:bg-slate-800/50" id="chatContainer">
            @if (Model.Comments != null && Model.Comments.Any())
            {
                foreach (var comment in Model.Comments)
                {
                    if (comment.Comment.StartsWith("System:"))
                    {
                        <div class="flex justify-center my-6">
                            <span class="bg-gray-50 text-gray-400 px-6 py-2 rounded-full text-[9px] font-bold uppercase tracking-widest border border-gray-100 shadow-sm dark:bg-slate-900/40 dark:text-gray-500 dark:border-gray-700">
                                @comment.Comment
                            </span>
                        </div>
                    }
                    else
                    {
                        var currentUserIdStr = User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;
                        int.TryParse(currentUserIdStr, out int currentUserId);
                        
                        bool isMe = comment.BranchManagerId == currentUserId;
                        
                        <div class="flex @(isMe ? "justify-end" : "justify-start")">
                            <div class="max-w-[85%] md:max-w-[70%] @(isMe ? "bg-red-50 border-red-100" : "bg-gray-50 border-gray-100") rounded-3xl p-5 border shadow-sm dark:bg-slate-700/50 dark:border-gray-700">
                                <div class="flex items-center space-x-3 mb-2.5">
                                    <span class="text-[10px] font-black uppercase tracking-widest @(isMe ? "text-red-700" : "text-gray-700 dark:text-gray-200")">
                                        @if (comment.AdminAccount != null) { @($"{comment.AdminAccount.FirstName} {comment.AdminAccount.LastName} (Main Office)") }
                                        else if (comment.BranchManager != null) { @($"{comment.BranchManager.FirstName} {comment.BranchManager.LastName} (Me)") }
                                        else { @("Unknown") }
                                    </span>
                                    <span class="text-[9px] font-bold text-gray-400">@comment.CreatedAt.ToString("hh:mm tt")</span>
                                </div>
                                <p class="text-sm text-gray-600 leading-relaxed dark:text-gray-300">@comment.Comment</p>
                            </div>
                        </div>
                    }
                }
            }
            else
            {
                <div class="flex flex-col items-center justify-center py-20 text-gray-400">
                    <div class="w-20 h-20 bg-gray-50 rounded-full flex items-center justify-center mb-6 dark:bg-slate-700/30">
                        <i class="bi bi-chat-dots text-4xl opacity-20"></i>
                    </div>
                    <p class="text-[10px] font-black uppercase tracking-widest">Start a conversation with the Main Office</p>
                </div>
            }
        </div>

        <div class="p-8 border-t border-gray-50 bg-white dark:bg-slate-800 dark:border-gray-700">
            <form method="post" asp-page-handler="AddComment" class="relative">
                <input type="hidden" name="OrderId" value="@Model.Order.OrderId">
                <div class="flex items-center space-x-4 bg-gray-50 rounded-2xl px-6 py-3 border border-gray-100 focus-within:border-[#C41E24] focus-within:ring-2 focus-within:ring-[#C41E24]/10 transition-all dark:bg-slate-700/50 dark:border-gray-700">
                    <textarea name="CommentText" placeholder="Type your message here..." required
                              class="flex-1 bg-transparent border-none py-2 text-sm outline-none focus:ring-0 text-gray-800 dark:text-white dark:placeholder:text-gray-500 resize-none h-12 min-h-[48px]"></textarea>
                    <button type="submit" class="bg-[#C41E24] text-white p-3 rounded-xl hover:bg-red-700 transition-all shadow-lg flex items-center justify-center shrink-0">
                        <i class="bi bi-send-fill text-xl"></i>
                    </button>
                </div>
            </form>
        </div>
    </div>

@* Action buttons *@
@if (order?.Status == "Pending")
{
    <div class="screen-only flex justify-end gap-3">
        <form method="post" asp-page-handler="Cancel">
            <input type="hidden" name="id" value="@order.OrderId" />
            <button type="submit"
                    onclick="return confirm('Are you sure you want to cancel this order?')"
                    class="px-5 py-2.5 text-sm border border-gray-200 rounded-lg text-gray-600 font-medium hover:bg-gray-50 dark:border-gray-600 dark:text-gray-300 dark:hover:bg-slate-700 transition-colors">
                Cancel Order
            </button>
        </form>
    </div>
}

@if (order?.Status == "Approved" && invoice != null && invoice.PaymentStatus == "Pending")
{
    <div class="screen-only flex justify-end gap-3 mt-4">
        <form method="post" asp-page-handler="Pay">
            <input type="hidden" name="id" value="@order.OrderId" />
            <button type="submit"
                    class="px-6 py-3 bg-[#C41E24] text-white font-bold rounded-xl hover:bg-red-700 transition-all shadow-lg flex items-center gap-2 transform hover:scale-105">
                <i class="bi bi-wallet2"></i> Pay with PayMongo
            </button>
        </form>
        @if (invoice?.ReferenceNumber != null && invoice.ReferenceNumber.StartsWith("SESSION:"))
        {
            <form method="post" asp-page-handler="Verify">
                <input type="hidden" name="id" value="@order.OrderId" />
                <button type="submit"
                        class="px-6 py-3 bg-amber-500 text-white font-bold rounded-xl hover:bg-amber-600 transition-all shadow-lg flex items-center gap-2 transform hover:scale-105">
                    <i class="bi bi-patch-check"></i> Verify Payment Status
                </button>
            </form>
        }
    </div>
}
@if (order?.Status == "Delivering")
{
    <div class="screen-only flex justify-end gap-3">
        <form method="post" asp-page-handler="Complete">
            <input type="hidden" name="id" value="@order.OrderId" />
            <button type="submit"
                    onclick="return confirm('Please confirm you have received the items. Are you sure you want to complete this transaction?')"
                    class="px-5 py-2.5 text-sm bg-green-600 text-white font-bold rounded-lg hover:bg-green-700 transition-colors shadow-sm">
                <i class="bi bi-check-circle me-1"></i> Complete Transaction
            </button>
        </form>
    </div>
}
    </div>
}

@section Scripts {
    <script>
        function scrollToBottom() {
            const container = document.getElementById('chatContainer');
            if (container) {
                container.scrollTop = container.scrollHeight;
            }
        }

        window.addEventListener('load', scrollToBottom);

        // Auto-scroll on dynamic content if needed
        const observer = new MutationObserver(scrollToBottom);
        const chatContainer = document.getElementById('chatContainer');
        if (chatContainer) {
            observer.observe(chatContainer, { childList: true });
        }
    </script>
}
