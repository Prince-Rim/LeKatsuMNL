@page
@model LeKatsuMNL.Pages.BranchDashboard.OrderDetailsModel
@{
    ViewData["Title"] = "Order Details";
    Layout = "_BranchLayout";

    var order = Model.Order;
    var invoice = order.Invoices.FirstOrDefault();
    string formattedId = order != null ? $"FO-{order.OrderDate.Year.ToString().Substring(2)}{order.OrderId:D4}" : "—";
    string statusPath = order?.Status == "Approved" ? "Approved Order" :
                        order?.Status == "Completed" ? "Completed Order" :
                        order?.Status == "Cancelled" ? "Cancelled Order" : "Purchase Order";
    decimal grandTotal = order?.OrderLists?.Sum(ol => ol.TotalPrice) ?? 0;
    string branchName = User.FindFirst("BranchName")?.Value ?? "Branch";
}

@section TitleActions {
    <div class="flex items-center gap-2">
        @if (Model.Invoice != null)
        {
            <a href="/BranchDashboard/InvoicePDF/@Model.Order.OrderId" target="_blank"
               class="px-3 py-1.5 text-xs font-bold border border-[#C41E24] text-[#C41E24] rounded-lg hover:bg-red-50 dark:hover:bg-red-900/20 transition-colors flex items-center gap-1.5"
               title="View Invoice">
                <i class="bi bi-receipt"></i> Invoice
            </a>
        }
        <a href="/BranchDashboard/PrintPO/@Model.Order.OrderId" target="_blank"
           class="w-9 h-9 rounded-lg border border-gray-200 flex items-center justify-center text-gray-500 hover:bg-gray-50 dark:border-gray-600 dark:text-gray-400 dark:hover:bg-slate-700 transition-colors"
           title="Print PO">
            <i class="bi bi-printer"></i>
        </a>
    </div>
}

@section Styles {
<style>
    /* Hide print-only element on screen */
    #po-printable { display: none; }

    @@media print {
        /* Show PO, hide everything else */
        header, aside, .breadcrumb-bar, .action-buttons { display: none !important; }
        main { padding: 0 !important; }
        .screen-only { display: none !important; }
        #po-printable { display: block; }
        @@page { margin: 1.5cm 2cm; }
    }
</style>
}

@* Print-only PO document (hidden on screen, visible on print) *@
<div id="po-printable" style="font-family:sans-serif; font-size:14px; color:#1a1a1a; padding:0 8px;">
    @* PO Header *@
    <div style="display:flex; justify-content:space-between; align-items:flex-start; border-bottom:2px solid #C41E24; padding-bottom:14px; margin-bottom:20px;">
        <div>
            <h1 style="font-size:22px; font-weight:900; color:#C41E24; margin:0;">Le Katsu MNL</h1>
            <p style="margin:2px 0; font-size:12px; color:#555;">@branchName</p>
            <p style="margin:2px 0; font-size:11px; color:#777;">Purchase Order</p>
        </div>
        <div style="text-align:right; font-size:12px; color:#555;">
            <p style="margin:2px 0;"><strong>Statement No:</strong> @formattedId</p>
            <p style="margin:2px 0;"><strong>Date Issued:</strong> @(order?.OrderDate.ToString("MMMM dd, yyyy") ?? "—")</p>
            <p style="margin:2px 0;"><strong>Status:</strong> @(order?.Status ?? "—")</p>
        </div>
    </div>

    @* Order meta *@
    <table style="width:100%; margin-bottom:20px; font-size:12px; border-collapse:collapse;">
        <tr>
            <td style="width:50%; padding:4px 0;">
                <span style="color:#888;">Reference PO:</span>
                <strong style="margin-left:8px;">@(invoice?.ReferenceNumber ?? "—")</strong>
            </td>
            <td style="width:50%; padding:4px 0;">
                <span style="color:#888;">Approved Date:</span>
                <strong style="margin-left:8px;">@(invoice?.InvoiceDate.ToString("MMMM dd, yyyy") ?? "—")</strong>
            </td>
        </tr>
        <tr>
            <td style="padding:4px 0;">
                <span style="color:#888;">Payment Terms:</span>
                <strong style="margin-left:8px;">@(invoice?.PaymentMethod ?? "—")</strong>
            </td>
        </tr>
    </table>

    @* Items table *@
    <table style="width:100%; border-collapse:collapse; font-size:12px; margin-bottom:20px;">
        <thead>
            <tr style="background:#C41E24; color:white;">
                <th style="padding:8px 10px; text-align:left;">Item Code</th>
                <th style="padding:8px 10px; text-align:left;">Description</th>
                <th style="padding:8px 10px; text-align:left;">Classification</th>
                <th style="padding:8px 10px; text-align:right;">Qty</th>
                <th style="padding:8px 10px; text-align:right;">Unit Price</th>
                <th style="padding:8px 10px; text-align:right;">Line Total</th>
            </tr>
        </thead>
        <tbody>
            @if (order?.OrderLists != null)
            {
                int rowIndex = 0;
                @foreach (var item in order.OrderLists)
                {
                    string itemCode = item.SkuId.HasValue ? $"SKU-{item.SkuId:D3}" : $"RM-{item.ComId:D3}";
                    string itemName = item.SkuHeader?.ItemName ?? item.CommissaryInventory?.ItemName ?? "—";
                    string category = item.SkuHeader?.Category?.CategoryName ?? item.CommissaryInventory?.Category?.CategoryName ?? "—";
                    decimal unitPrice = item.Quantity > 0 ? item.TotalPrice / item.Quantity : 0;
                    string rowBg = rowIndex % 2 == 0 ? "#f9f9f9" : "#ffffff";
                    rowIndex++;
                    <tr style="background:@rowBg;">
                        <td style="padding:7px 10px; border-bottom:1px solid #eee; font-family:monospace;">@itemCode</td>
                        <td style="padding:7px 10px; border-bottom:1px solid #eee;">@itemName</td>
                        <td style="padding:7px 10px; border-bottom:1px solid #eee; color:#666;">@category</td>
                        <td style="padding:7px 10px; border-bottom:1px solid #eee; text-align:right;">@item.Quantity.ToString("G")</td>
                        <td style="padding:7px 10px; border-bottom:1px solid #eee; text-align:right;">₱@unitPrice.ToString("N2")</td>
                        <td style="padding:7px 10px; border-bottom:1px solid #eee; text-align:right; font-weight:bold;">₱@item.TotalPrice.ToString("N2")</td>
                    </tr>
                }
            }
        </tbody>
        <tfoot>
            <tr>
                <td colspan="5" style="padding:10px; text-align:right; font-weight:bold; font-size:13px;">Grand Total:</td>
                <td style="padding:10px; text-align:right; font-weight:900; font-size:15px; color:#C41E24;">₱@grandTotal.ToString("N2")</td>
            </tr>
        </tfoot>
    </table>

    @* Signature area *@
    <div style="display:flex; justify-content:space-between; margin-top:40px; font-size:11px; color:#555;">
        <div style="text-align:center;">
            <div style="border-top:1px solid #333; width:180px; margin-bottom:4px;"></div>
            <p style="margin:0;">Prepared by</p>
        </div>
        <div style="text-align:center;">
            <div style="border-top:1px solid #333; width:180px; margin-bottom:4px;"></div>
            <p style="margin:0;">Approved by</p>
        </div>
        <div style="text-align:center;">
            <div style="border-top:1px solid #333; width:180px; margin-bottom:4px;"></div>
            <p style="margin:0;">Received by</p>
        </div>
    </div>
</div>



@* Main content *@
<!-- Main content -->

<div class="screen-only px-1 mb-4">
    @if (TempData["Message"] != null)
    {
        <div class="mb-4 p-4 rounded-xl bg-blue-50 border border-blue-100 text-blue-600 text-sm font-medium flex items-center gap-3">
            <i class="bi bi-info-circle-fill"></i> @TempData["Message"]
        </div>
    }
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="mb-4 p-4 rounded-xl bg-red-50 border border-red-100 text-red-600 text-sm font-medium flex items-center gap-3">
            <i class="bi bi-exclamation-triangle-fill"></i> @TempData["ErrorMessage"]
        </div>
    }



<div class="screen-only bg-white rounded-2xl border border-gray-100 shadow-sm overflow-hidden dark:bg-slate-800 dark:border-gray-700 min-h-[600px] flex flex-col mb-8">
    @* Tab Navigation *@
    <div class="flex border-b border-gray-100 dark:border-gray-700 px-6 overflow-x-auto no-scrollbar bg-gray-50/30 dark:bg-slate-900/10">
        <button onclick="switchTab('overview')" id="tab-overview" class="tab-btn px-6 py-4 text-[10px] font-black uppercase tracking-[0.2em] text-[#C41E24] border-b-2 border-[#C41E24] transition-all whitespace-nowrap">Overview</button>
        <button onclick="switchTab('transaction')" id="tab-transaction" class="tab-btn px-6 py-4 text-[10px] font-black uppercase tracking-[0.2em] text-gray-400 border-b-2 border-transparent hover:text-gray-600 transition-colors whitespace-nowrap">Transaction</button>
        <button onclick="switchTab('chat')" id="tab-chat" class="tab-btn px-6 py-4 text-[10px] font-black uppercase tracking-[0.2em] text-gray-400 border-b-2 border-transparent hover:text-gray-600 transition-all whitespace-nowrap flex items-center gap-2">
            Discussion
            @if (Model.Comments.Any(c => !c.Comment.StartsWith("System:")))
            {
                <span class="w-1.5 h-1.5 rounded-full bg-red-500 animate-pulse"></span>
            }
        </button>
    </div>

    @* Tab Content Wrapper *@
    <div class="flex-1 flex flex-col">
        @* Tab 1: Overview *@
        <div id="content-overview" class="tab-content block animate-in fade-in duration-500">
            <div class="p-6">
                <div class="grid grid-cols-1 lg:grid-cols-5 gap-6 mb-6">
                    @* Left: Status and Journey *@
                    <div class="lg:col-span-2 space-y-6">
                        <div class="bg-gray-50/50 rounded-2xl p-6 border border-gray-100 dark:bg-slate-900/20 dark:border-gray-700">
                            <p class="text-[10px] font-black uppercase text-gray-400 tracking-widest mb-6">Order Journey</p>
                            <div class="relative flex items-center justify-between w-full px-2 py-4">
                                <div class="absolute left-8 right-8 h-1 bg-gray-100 dark:bg-gray-700 top-1/2 -translate-y-4"></div>
                                @{
                                    var stages = new[] { "Pending", "Approved", "Preparing", "Delivering", "Completed" };
                                    int currentStageIdx = Array.IndexOf(stages, order?.Status ?? "Pending");
                                    if (order?.Status == "Delivering") currentStageIdx = 3;
                                    double progWidth = currentStageIdx * 25;
                                }
                                <div class="absolute left-8 h-1 bg-[#C41E24] top-1/2 -translate-y-4 transition-all duration-700 ease-out" style="width: calc(@(progWidth)% - 8px)"></div>
                                @for (int i = 0; i < stages.Length; i++)
                                {
                                    bool isDone = i < currentStageIdx;
                                    bool isNow = i == currentStageIdx;
                                    string icon = i == 0 ? "bi-send" : i == 1 ? "bi-check2-circle" : i == 2 ? "bi-box-seam" : i == 3 ? "bi-truck" : "bi-flag";
                                    <div class="relative z-10 flex flex-col items-center">
                                        <div class="w-8 h-8 rounded-full flex items-center justify-center border-2 transition-all duration-300 
                                            @(isNow ? "bg-white border-[#C41E24] text-[#C41E24] shadow-md scale-110 dark:bg-slate-800" : isDone ? "bg-[#C41E24] border-[#C41E24] text-white" : "bg-white border-gray-100 text-gray-200 dark:bg-slate-800 dark:border-gray-700")">
                                            <i class="bi @icon text-[10px]"></i>
                                        </div>
                                        <span class="mt-3 text-[8px] font-black uppercase tracking-tighter @(isNow ? "text-[#C41E24]" : "text-gray-400")">@stages[i]</span>
                                    </div>
                                }
                            </div>
                        </div>

                        <div class="bg-white rounded-2xl p-6 border border-gray-100 shadow-sm dark:bg-slate-800 dark:border-gray-700">
                            <p class="text-[10px] font-black uppercase text-gray-400 tracking-widest mb-5">Order Properties</p>
                            <dl class="space-y-4 text-xs">
                                <div class="flex justify-between items-center border-b border-gray-50 pb-3 dark:border-gray-700/50">
                                    <dt class="text-gray-400 uppercase font-bold tracking-widest text-[9px]">Statement ID</dt>
                                    <dd class="font-black text-gray-800 dark:text-white">@formattedId</dd>
                                </div>
                                <div class="flex justify-between items-center border-b border-gray-50 pb-3 dark:border-gray-700/50">
                                    <dt class="text-gray-400 uppercase font-bold tracking-widest text-[9px]">Issued Date</dt>
                                    <dd class="font-medium text-gray-600 dark:text-gray-300">@(order?.OrderDate.ToString("MMMM dd, yyyy") ?? "—")</dd>
                                </div>
                                <div class="flex justify-between items-center border-b border-gray-50 pb-3 dark:border-gray-700/50">
                                    <dt class="text-gray-400 uppercase font-bold tracking-widest text-[9px]">Approved On</dt>
                                    <dd class="font-medium text-gray-600 dark:text-gray-300">@(invoice?.InvoiceDate.ToString("MMMM dd, yyyy") ?? "—")</dd>
                                </div>
                                <div class="flex justify-between items-center">
                                    <dt class="text-gray-400 uppercase font-bold tracking-widest text-[9px]">Origin</dt>
                                    <dd class="font-black text-[#C41E24] uppercase tracking-widest">Main Office</dd>
                                </div>
                            </dl>
                        </div>

                    </div>

                    @* Right: Items Table *@
                    <div class="lg:col-span-3 bg-white rounded-2xl border border-gray-100 shadow-sm overflow-hidden flex flex-col border dark:bg-slate-800 dark:border-gray-700">
                        <p class="p-5 text-[10px] font-black uppercase text-gray-400 tracking-widest border-b border-gray-50 dark:border-gray-700/50">Requisition Items</p>
                        <div class="flex-1 overflow-x-auto custom-scrollbar">
                            <table class="w-full text-xs text-left">
                                <thead class="bg-gray-50/50 text-gray-400 uppercase text-[9px] font-black tracking-widest dark:bg-slate-900/20">
                                    <tr>
                                        <th class="px-6 py-4">Item Details</th>
                                        <th class="px-4 py-4 text-center">Qty</th>
                                        <th class="px-6 py-4 text-right">Line Total</th>
                                    </tr>
                                </thead>
                                <tbody class="divide-y divide-gray-50 dark:divide-gray-700">
                                    @foreach (var item in order.OrderLists)
                                    {
                                        <tr class="hover:bg-gray-50/50 transition-colors dark:hover:bg-slate-700/30">
                                            <td class="px-6 py-5">
                                                <div class="flex flex-col">
                                                    <span class="font-bold text-gray-800 dark:text-white">@(item.SkuHeader?.ItemName ?? item.CommissaryInventory?.ItemName)</span>
                                                    <span class="text-[9px] text-gray-400 uppercase mt-1">@item.SkuHeader?.Category?.CategoryName</span>
                                                </div>
                                            </td>
                                            <td class="px-4 py-5 text-center font-bold text-gray-600 dark:text-gray-300">@item.Quantity.ToString("G")</td>
                                            <td class="px-6 py-5 text-right font-black text-gray-800 dark:text-white">₱@item.TotalPrice.ToString("N2")</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                        <div class="p-6 bg-gray-50/50 border-t border-gray-100 flex justify-between items-center dark:bg-slate-900/40 dark:border-gray-700/50">
                            <span class="text-[10px] font-black uppercase text-gray-400 tracking-widest">Grand Total</span>
                            <span class="text-xl font-black text-[#C41E24]">₱@grandTotal.ToString("N2")</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        @* Tab 2: Transaction (Restored) *@
        <div id="content-transaction" class="tab-content hidden animate-in slide-in-from-right-4 duration-500">
            <div class="p-8">
                <div class="max-w-4xl mx-auto">
                    <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
                        @* Left: Financial Summary *@
                        <div class="lg:col-span-1 space-y-6">
                            <div class="bg-white rounded-3xl border border-gray-100 p-8 shadow-sm dark:bg-slate-800 dark:border-gray-700">
                                <div class="text-center mb-8">
                                    <div class="w-16 h-16 bg-red-50 rounded-2xl flex items-center justify-center mx-auto mb-4 dark:bg-red-500/10">
                                        <i class="bi bi-wallet2 text-[#C41E24] text-2xl"></i>
                                    </div>
                                    <h3 class="text-sm font-black text-gray-800 uppercase tracking-widest dark:text-white">Payment Summary</h3>
                                </div>
                                
                                <div class="space-y-6">
                                    <div class="flex justify-between items-center text-xs">
                                        <span class="text-gray-400 uppercase font-black tracking-widest">Amount Due</span>
                                        <span class="font-bold text-gray-700 dark:text-gray-300">₱@grandTotal.ToString("N2")</span>
                                    </div>
                                    <div class="flex justify-between items-center text-xs">
                                        <span class="text-gray-400 uppercase font-black tracking-widest">Status</span>
                                        <span class="font-black @(invoice?.PaymentStatus == "Paid" ? "text-emerald-500" : "text-orange-500") uppercase tracking-widest text-[10px]">@(invoice?.PaymentStatus ?? "Pending")</span>
                                    </div>
                                    <div class="pt-6 border-t border-gray-50 flex justify-between items-center dark:border-gray-700">
                                        <span class="text-xs font-black text-[#C41E24] uppercase tracking-widest">Total</span>
                                        <span class="text-2xl font-black text-gray-900 dark:text-white">₱@grandTotal.ToString("N2")</span>
                                    </div>
                                </div>

                                <div class="mt-10">
                                    @if (invoice?.PaymentStatus != "Paid" && order?.Status == "Approved")
                                    {
                                        <form method="post" asp-page-handler="Pay" class="w-full">
                                            <input type="hidden" name="id" value="@order.OrderId" />
                                            <button type="submit" class="w-full py-4 bg-[#C41E24] text-white rounded-2xl font-black uppercase text-[11px] tracking-widest hover:bg-black transition-all shadow-xl shadow-red-100 active:scale-95 dark:shadow-none">
                                                Pay via PayMongo
                                            </button>
                                        </form>
                                    }
                                    else if (invoice?.PaymentStatus == "Paid")
                                    {
                                        <div class="p-6 bg-emerald-50 rounded-2xl border border-emerald-100 text-center dark:bg-emerald-500/5 dark:border-emerald-500/10">
                                            <p class="text-[10px] font-black text-emerald-600 uppercase tracking-widest">Payment Verified</p>
                                            <p class="text-[9px] text-gray-400 mt-2 uppercase font-bold">Ref: @invoice.ReferenceNumber</p>
                                        </div>
                                    }
                                    else
                                    {
                                        <div class="p-6 bg-gray-50 rounded-2xl border border-gray-100 text-center dark:bg-slate-900/40 dark:border-gray-700">
                                            <p class="text-[10px] font-black text-gray-400 uppercase tracking-widest">Awaiting Approval</p>
                                        </div>
                                    }
                                </div>
                            </div>
                            
                            <div class="bg-amber-50 p-6 rounded-2xl border border-amber-100 dark:bg-amber-500/5 dark:border-amber-500/10 flex gap-4">
                                <i class="bi bi-info-circle-fill text-amber-500 text-lg"></i>
                                <p class="text-[10px] text-amber-800/80 leading-relaxed font-bold uppercase tracking-wide dark:text-amber-500/80">
                                    Include Statement ID <span class="bg-amber-200 px-1.5 py-0.5 rounded text-amber-900 dark:bg-amber-900/40 dark:text-amber-300">@formattedId</span> in remarks for faster verification.
                                </p>
                            </div>
                        </div>

                        @* Right: Payment Instructions / FAQs *@
                        <div class="lg:col-span-2 space-y-6">
                            <div class="bg-white rounded-3xl border border-gray-100 p-8 shadow-sm dark:bg-slate-800 dark:border-gray-700">
                                <p class="text-[10px] font-black uppercase text-gray-400 tracking-widest mb-6">Payment Instructions</p>
                                <div class="space-y-6">
                                    <div class="flex gap-4 p-4 rounded-2xl bg-gray-50/50 dark:bg-slate-900/20">
                                        <div class="w-8 h-8 rounded-full bg-white flex items-center justify-center font-black text-[#C41E24] text-[10px] shadow-sm dark:bg-slate-800">1</div>
                                        <div>
                                            <h5 class="text-[10px] font-black uppercase tracking-widest text-gray-800 dark:text-white">Choose Method</h5>
                                            <p class="text-[10px] text-gray-500 mt-1">Select PayMongo for GCash, Maya, or Credit Cards.</p>
                                        </div>
                                    </div>
                                    <div class="flex gap-4 p-4 rounded-2xl bg-gray-50/50 dark:bg-slate-900/20">
                                        <div class="w-8 h-8 rounded-full bg-white flex items-center justify-center font-black text-[#C41E24] text-[10px] shadow-sm dark:bg-slate-800">2</div>
                                        <div>
                                            <h5 class="text-[10px] font-black uppercase tracking-widest text-gray-800 dark:text-white">Confirm Transfer</h5>
                                            <p class="text-[10px] text-gray-500 mt-1">Wait for the redirection and complete the secure payment.</p>
                                        </div>
                                    </div>
                                    <div class="flex gap-4 p-4 rounded-2xl bg-gray-50/50 dark:bg-slate-900/20">
                                        <div class="w-8 h-8 rounded-full bg-white flex items-center justify-center font-black text-[#C41E24] text-[10px] shadow-sm dark:bg-slate-800">3</div>
                                        <div>
                                            <h5 class="text-[10px] font-black uppercase tracking-widest text-gray-800 dark:text-white">Auto-Update</h5>
                                            <p class="text-[10px] text-gray-500 mt-1">Status will automatically change to "Paid" once verified by PayMongo.</p>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        @* Tab 3: Chat *@
        <div id="content-chat" class="tab-content hidden animate-in slide-in-from-bottom-4 duration-500">
            <div class="flex flex-col min-h-[600px] bg-white dark:bg-slate-800">
                @* Chat Header *@
                <div class="px-8 py-5 border-b border-gray-50 flex items-center justify-between dark:border-gray-700/50">
                    <div class="flex items-center gap-4">
                        <div class="w-10 h-10 bg-red-50 rounded-xl flex items-center justify-center text-[#C41E24] dark:bg-red-500/10">
                            <i class="bi bi-chat-left-quote-fill-dots text-xl"></i>
                        </div>
                        <div>
                            <h4 class="text-xs font-black uppercase tracking-widest text-gray-800 dark:text-white">Order Discussion</h4>
                            <p class="text-[9px] text-gray-400 font-bold uppercase">Direct line to Main Office</p>
                        </div>
                    </div>
                    <div class="flex items-center gap-2">
                        <span class="w-2 h-2 rounded-full bg-green-500"></span>
                        <span class="text-[9px] font-black uppercase text-green-600 tracking-widest">Online</span>
                    </div>
                </div>

                @* Messages List *@
                <div class="flex-1 overflow-y-auto p-10 space-y-8 max-h-[500px] custom-scrollbar bg-gray-50/20 dark:bg-slate-900/10" id="chatContainer">
                    @if (Model.Comments != null && Model.Comments.Any())
                    {
                        foreach (var comment in Model.Comments)
                        {
                            if (comment.Comment.StartsWith("System:"))
                            {
                                <div class="flex justify-center">
                                    <div class="bg-white/80 backdrop-blur-sm border border-gray-100 px-6 py-2 rounded-full shadow-sm dark:bg-slate-800/80 dark:border-gray-700">
                                        <span class="text-[9px] font-black uppercase text-gray-400 tracking-widest italic">@comment.Comment</span>
                                    </div>
                                </div>
                            }
                            else
                            {
                                var currentUserIdStr = User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;
                                int.TryParse(currentUserIdStr, out int currentUserId);
                                bool isMe = comment.BranchManagerId == currentUserId;
                                
                                <div class="flex @(isMe ? "justify-end" : "justify-start")">
                                    <div class="max-w-[80%] md:max-w-[65%] group">
                                        <div class="flex items-center gap-3 mb-2 px-1 @(isMe ? "justify-end" : "justify-start")">
                                            <span class="text-[9px] font-black uppercase tracking-widest @(isMe ? "text-red-700" : "text-gray-500 dark:text-gray-300")">
                                                @(isMe ? "You" : (comment.AdminAccount != null ? $"{comment.AdminAccount.FirstName} (Admin)" : "Main Office"))
                                            </span>
                                            <span class="text-[8px] font-bold text-gray-400">@comment.CreatedAt.ToString("hh:mm tt")</span>
                                        </div>
                                        <div class="p-5 rounded-3xl shadow-sm border @(isMe ? "bg-red-50 border-red-100 text-gray-800 rounded-tr-none" : "bg-white border-gray-100 text-gray-700 rounded-tl-none") dark:bg-slate-700 dark:border-gray-600 dark:text-gray-200">
                                            <p class="text-xs leading-relaxed">@comment.Comment</p>
                                        </div>
                                    </div>
                                </div>
                            }
                        }
                    }
                    else
                    {
                        <div class="flex flex-col items-center justify-center py-20 text-gray-300">
                            <div class="w-24 h-24 bg-gray-50 rounded-full flex items-center justify-center mb-6 dark:bg-slate-800">
                                <i class="bi bi-chat-dots-fill text-5xl opacity-10"></i>
                            </div>
                            <p class="text-[10px] font-black uppercase tracking-widest">No conversation history yet</p>
                        </div>
                    }
                </div>

                @* Input Area *@
                <div class="p-8 border-t border-gray-50 bg-white dark:bg-slate-800 dark:border-gray-700">
                    <form method="post" asp-page-handler="AddComment" class="relative">
                        <input type="hidden" name="OrderId" value="@Model.Order.OrderId">
                        <div class="flex items-center gap-5 bg-gray-50 rounded-3xl px-8 py-3 border border-gray-100 focus-within:border-[#C41E24] focus-within:ring-4 focus-within:ring-[#C41E24]/5 focus-within:bg-white transition-all dark:bg-slate-700/50 dark:border-gray-700">
                            <textarea name="CommentText" placeholder="Start typing a message..." required
                                      class="flex-1 bg-transparent border-none py-2.5 text-xs outline-none focus:ring-0 text-gray-800 dark:text-white dark:placeholder:text-gray-500 resize-none h-12 min-h-[48px]"></textarea>
                            <button type="submit" class="bg-[#C41E24] text-white p-3.5 rounded-2xl hover:bg-black transition-all shadow-xl shadow-red-100 dark:shadow-none active:scale-95">
                                <i class="bi bi-send-fill text-xl"></i>
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@* Action buttons *@
@if (order?.Status == "Pending")
{
    <div class="screen-only flex justify-end gap-3">
        <form method="post" asp-page-handler="Cancel">
            <input type="hidden" name="id" value="@order.OrderId" />
            <button type="submit"
                    onclick="return confirm('Are you sure you want to cancel this order?')"
                    class="px-5 py-2.5 text-sm border border-gray-200 rounded-lg text-gray-600 font-medium hover:bg-gray-50 dark:border-gray-600 dark:text-gray-300 dark:hover:bg-slate-700 transition-colors">
                Cancel Order
            </button>
        </form>
    </div>
}

@if (order?.Status == "Approved" && invoice != null && invoice.PaymentStatus == "Pending")
{
    <div class="screen-only flex justify-end gap-3 mt-4">
        <form method="post" asp-page-handler="Pay">
            <input type="hidden" name="id" value="@order.OrderId" />
            <button type="submit"
                    class="px-6 py-3 bg-[#C41E24] text-white font-bold rounded-xl hover:bg-red-700 transition-all shadow-lg flex items-center gap-2 transform hover:scale-105">
                <i class="bi bi-wallet2"></i> Pay with PayMongo
            </button>
        </form>
        @if (invoice?.ReferenceNumber != null && invoice.ReferenceNumber.StartsWith("SESSION:"))
        {
            <form method="post" asp-page-handler="Verify">
                <input type="hidden" name="id" value="@order.OrderId" />
                <button type="submit"
                        class="px-6 py-3 bg-amber-500 text-white font-bold rounded-xl hover:bg-amber-600 transition-all shadow-lg flex items-center gap-2 transform hover:scale-105">
                    <i class="bi bi-patch-check"></i> Verify Payment Status
                </button>
            </form>
        }
    </div>
}
@if (order?.Status == "Delivering")
{
    <div class="screen-only flex justify-end gap-3">
        <form method="post" asp-page-handler="Complete">
            <input type="hidden" name="id" value="@order.OrderId" />
            <button type="submit"
                    onclick="return confirm('Please confirm you have received the items. Are you sure you want to complete this transaction?')"
                    class="px-5 py-2.5 text-sm bg-green-600 text-white font-bold rounded-lg hover:bg-green-700 transition-colors shadow-sm">
                <i class="bi bi-check-circle me-1"></i> Complete Transaction
            </button>
        </form>
    </div>
}
    

@section Scripts {
    <script>
        function switchTab(tabId) {
            // Hide all contents
            document.querySelectorAll('.tab-content').forEach(el => el.classList.add('hidden'));
            document.querySelectorAll('.tab-content').forEach(el => el.classList.remove('block'));
            
            // Show selected content
            document.getElementById('content-' + tabId).classList.remove('hidden');
            document.getElementById('content-' + tabId).classList.add('block');
            
            // Update tab button styles
            document.querySelectorAll('.tab-btn').forEach(btn => {
                btn.classList.remove('text-[#C41E24]', 'border-[#C41E24]');
                btn.classList.add('text-gray-400', 'border-transparent');
            });
            
            const activeBtn = document.getElementById('tab-' + tabId);
            activeBtn.classList.add('text-[#C41E24]', 'border-[#C41E24]');
            activeBtn.classList.remove('text-gray-400', 'border-transparent');

            if (tabId === 'chat') {
                scrollToBottom();
            }
        }

        function scrollToBottom() {
            const container = document.getElementById('chatContainer');
            if (container) {
                container.scrollTop = container.scrollHeight;
            }
        }

        window.addEventListener('load', scrollToBottom);

        // Auto-scroll on dynamic content if needed
        const observer = new MutationObserver(scrollToBottom);
        const chatContainer = document.getElementById('chatContainer');
        if (chatContainer) {
            observer.observe(chatContainer, { childList: true });
        }
    </script>
}
