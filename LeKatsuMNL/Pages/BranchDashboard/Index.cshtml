@page
@model LeKatsuMNL.Pages.BranchDashboard.IndexModel
@{
    ViewData["Title"] = "Dashboard";
    Layout = "_BranchLayout";
}

<div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-6">
    <div class="bg-[#C41E24] text-white p-7 rounded-2xl shadow-lg relative overflow-hidden transition-all hover:scale-[1.01]">
        <div>
            <p class="text-sm font-bold opacity-80 uppercase tracking-widest mb-2">Total Monthly Spend</p>
            <h3 class="text-4xl font-extrabold tracking-tight">₱@Model.TotalMonthlySpend.ToString("N2")</h3>
            <p class="text-xs font-bold mt-3">vs last month</p>
        </div>
        <div class="absolute top-7 right-7 opacity-20 text-4xl"><i class="bi bi-wallet2"></i></div>
    </div>

    <div class="bg-white p-7 rounded-2xl border border-gray-100 shadow-sm relative transition-all hover:scale-[1.01] dark:bg-slate-800 dark:border-gray-700">
        <p class="text-gray-500 text-sm font-bold uppercase tracking-widest mb-2 dark:text-gray-400">Pending Orders</p>
        <h3 class="text-4xl font-extrabold text-[#C41E24] tracking-tight">@Model.PendingOrdersCount</h3>
        <p class="text-[#C41E24] text-xs font-bold mt-3 flex items-center">Active purchase orders</p>
        <div class="absolute top-7 right-7 text-[#C41E24] text-2xl opacity-80"><i class="bi bi-cart-fill"></i></div>
    </div>

    <div class="bg-white p-7 rounded-2xl border border-gray-100 shadow-sm relative transition-all hover:scale-[1.01] dark:bg-slate-800 dark:border-gray-700">
        <p class="text-gray-500 text-sm font-bold uppercase tracking-widest mb-2 dark:text-gray-400">Pending Payments</p>
        <h3 class="text-4xl font-extrabold text-[#C41E24] tracking-tight">@Model.PendingPaymentsCount</h3>
        <p class="text-[#C41E24] text-xs font-bold mt-3 flex items-center">Awaiting payment confirmation</p>
        <div class="absolute top-7 right-7 text-[#C41E24] text-2xl opacity-80"><i class="bi bi-credit-card-fill"></i></div>
    </div>
</div>

<div class="grid grid-cols-1 lg:grid-cols-12 gap-6 mb-6">
    <div class="lg:col-span-12 bg-white p-7 rounded-2xl border border-gray-100 shadow-sm dark:bg-slate-800 dark:border-gray-700">
        <div class="flex justify-between items-center mb-6">
            <h4 class="font-bold text-gray-800 tracking-tight dark:text-white">Weekly Spend (Last 7 Days)</h4>
        </div>
        <div class="h-64 relative">
            <canvas id="weeklySpendChart"></canvas>
        </div>
    </div>
</div>

<div class="grid grid-cols-1 lg:grid-cols-12 gap-6 mb-6">
    <div class="lg:col-span-12 bg-white p-7 rounded-2xl border border-gray-100 shadow-sm dark:bg-slate-800 dark:border-gray-700">
        <div class="flex justify-between items-center mb-6">
            <h4 class="font-bold text-gray-800 tracking-tight dark:text-white">Monthly Orders (Current Year)</h4>
        </div>
        <div class="h-64 relative">
            <canvas id="monthlyOrdersChart"></canvas>
        </div>
    </div>
</div>

<div class="bg-white p-7 rounded-2xl border border-gray-100 shadow-sm dark:bg-slate-800 dark:border-gray-700">
    <div class="flex items-center justify-between mb-6">
        <h4 class="font-bold text-gray-800 dark:text-white">My Recent Orders</h4>
        <a href="/BranchDashboard/MyOrder" class="text-xs font-bold text-[#C41E24] hover:underline">View All</a>
    </div>
    @if (Model.RecentOrders != null && Model.RecentOrders.Any())
    {
        <div class="overflow-x-auto">
            <table class="w-full text-xs text-left">
                <thead class="text-gray-400 border-b border-gray-50 dark:text-gray-500 dark:border-gray-700">
                    <tr>
                        <th class="px-4 pb-4 font-bold uppercase">Order ID</th>
                        <th class="px-4 pb-4 font-bold uppercase text-center">Date</th>
                        <th class="px-4 pb-4 font-bold uppercase text-center">Status</th>
                        <th class="px-4 pb-4 font-bold uppercase text-right">Total</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-gray-50 dark:divide-gray-700">
                    @foreach (var order in Model.RecentOrders)
                    {
                        string formattedId = $"FO-{order.OrderDate.Year.ToString().Substring(2)}{order.OrderId:D4}";
                        <tr>
                            <td class="px-4 py-4 font-bold text-gray-800 dark:text-white">
                                <a href="/BranchDashboard/OrderDetails?id=@order.OrderId" class="text-[#C41E24] hover:underline">@formattedId</a>
                            </td>
                            <td class="px-4 py-4 text-center text-gray-600 dark:text-gray-300">@order.OrderDate.ToString("MMM dd, yyyy")</td>
                            <td class="px-4 py-4 text-center">
                                <span class="px-2.5 py-1 rounded-full text-[10px] font-bold
                                    @(order.Status == "Completed" ? "bg-green-100 text-green-700" :
                                      order.Status == "Cancelled" ? "bg-red-100 text-red-700" :
                                      order.Status == "Approved" || order.Status == "Delivered" ? "bg-blue-100 text-blue-700" :
                                      "bg-orange-100 text-orange-700")">
                                    @order.Status
                                </span>
                            </td>
                            <td class="px-4 py-4 text-right font-bold text-gray-800 dark:text-white">₱@order.OrderLists.Sum(ol => ol.TotalPrice).ToString("N2")</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
    else
    {
        <div class="h-48 flex flex-col justify-center items-center border-2 border-dashed border-gray-50 rounded-xl bg-gray-50/30 text-gray-300 dark:border-gray-700">
            <i class="bi bi-receipt text-3xl mb-2"></i>
            <p class="text-[10px] font-bold uppercase tracking-widest">No recent orders found</p>
        </div>
    }
</div>

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            // Weekly Spend Chart
            const weeklyCtx = document.getElementById('weeklySpendChart').getContext('2d');
            new Chart(weeklyCtx, {
                type: 'line',
                data: {
                    labels: @Html.Raw(Json.Serialize(Model.WeeklySpendLabels)),
                    datasets: [{
                        data: @Html.Raw(Json.Serialize(Model.WeeklySpendData)),
                        borderColor: '#C41E24',
                        backgroundColor: 'rgba(196, 30, 36, 0.1)',
                        fill: true,
                        tension: 0.4,
                        pointRadius: 4,
                        pointBackgroundColor: '#C41E24'
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: { legend: { display: false } },
                    scales: {
                        y: { 
                            beginAtZero: true,
                            grid: { color: 'rgba(0,0,0,0.05)' },
                            ticks: { callback: value => '₱' + (value/1000) + 'k' }
                        },
                        x: { grid: { display: false } }
                    }
                }
            });

            // Monthly Orders Chart
            const monthlyCtx = document.getElementById('monthlyOrdersChart').getContext('2d');
            new Chart(monthlyCtx, {
                type: 'bar',
                data: {
                    labels: ['Jan', 'Feb', 'Mar', 'Apr', 'May', 'Jun', 'Jul', 'Aug', 'Sep', 'Oct', 'Nov', 'Dec'],
                    datasets: [{
                        data: @Html.Raw(Json.Serialize(Model.MonthlyOrdersData)),
                        backgroundColor: '#C41E24',
                        borderRadius: 4
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: { legend: { display: false } },
                    scales: {
                        y: { beginAtZero: true, grid: { color: 'rgba(0,0,0,0.05)' } },
                        x: { grid: { display: false } }
                    }
                }
            });
        });
    </script>
}
