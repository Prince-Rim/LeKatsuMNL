@page
@model LeKatsuMNL.Pages.BranchDashboard.AccountModel
@{
    ViewData["Title"] = "Account";
    Layout = "_BranchLayout";
    var m = Model.Manager;
}

@* Alerts *@
@if (!string.IsNullOrEmpty(Model.SuccessMessage))
{
    <div class="mb-4 flex items-center gap-3 bg-green-50 border border-green-200 text-green-700 text-sm rounded-xl px-5 py-3 dark:bg-green-900/20 dark:border-green-800 dark:text-green-400">
        <i class="bi bi-check-circle-fill text-base flex-shrink-0"></i>
        <span>@Model.SuccessMessage</span>
    </div>
}
@if (!string.IsNullOrEmpty(Model.ErrorMessage))
{
    <div class="mb-4 flex items-center gap-3 bg-red-50 border border-red-200 text-red-700 text-sm rounded-xl px-5 py-3 dark:bg-red-900/20 dark:border-red-800 dark:text-red-400">
        <i class="bi bi-exclamation-triangle-fill text-base flex-shrink-0"></i>
        <span>@Model.ErrorMessage</span>
    </div>
}

<div class="bg-white rounded-2xl border border-gray-100 shadow-sm dark:bg-slate-800 dark:border-gray-700 overflow-hidden">
    <form method="post" asp-page-handler="Save" id="accountForm">

        @* Action row *@
        <div class="flex justify-end gap-3 px-8 py-5 border-b border-gray-50 dark:border-gray-700">
            @* Edit button — visible by default *@
            <button type="button" id="editBtn" onclick="enableEdit()"
                    class="px-5 py-2 bg-[#C41E24] text-white text-sm font-bold rounded-lg hover:bg-red-700 transition-colors shadow-sm">
                <i class="bi bi-pencil-fill mr-1"></i> Edit
            </button>
            @* Save button — hidden by default, shown after Edit is clicked *@
            <button type="submit" id="saveBtn"
                    class="hidden px-5 py-2 bg-[#C41E24] text-white text-sm font-bold rounded-lg hover:bg-red-700 transition-colors shadow-sm">
                <i class="bi bi-check-lg mr-1"></i> Save Changes
            </button>
            <button type="button" id="cancelBtn" onclick="disableEdit()"
                    class="hidden px-5 py-2 border border-gray-200 text-gray-600 text-sm font-bold rounded-lg hover:bg-gray-50 dark:border-gray-600 dark:text-gray-400 dark:hover:bg-slate-700 transition-colors">
                Cancel
            </button>
        </div>

        @* Form body *@
        <div class="px-8 py-8 space-y-6 max-w-3xl">
            @* Account Full Name *@
            <div class="grid grid-cols-12 items-start gap-4">
                <label class="col-span-3 text-sm text-gray-500 dark:text-gray-400 pt-2">Account Full Name</label>
                <div class="col-span-9 grid grid-cols-3 gap-3">
                    <div>
                        <input asp-for="FirstName" placeholder="First" readonly
                               class="field-input w-full border border-gray-100 bg-gray-50 rounded-lg px-3 py-2 text-sm focus:outline-none dark:bg-slate-700/50 dark:border-gray-700 dark:text-gray-300"
                               required />
                        <span asp-validation-for="FirstName" class="text-red-500 text-xs"></span>
                    </div>
                    <div>
                        <input asp-for="MiddleName" placeholder="Middle" readonly
                               class="field-input w-full border border-gray-100 bg-gray-50 rounded-lg px-3 py-2 text-sm focus:outline-none dark:bg-slate-700/50 dark:border-gray-700 dark:text-gray-300" />
                    </div>
                    <div>
                        <input asp-for="LastName" placeholder="Last" readonly
                               class="field-input w-full border border-gray-100 bg-gray-50 rounded-lg px-3 py-2 text-sm focus:outline-none dark:bg-slate-700/50 dark:border-gray-700 dark:text-gray-300"
                               required />
                        <span asp-validation-for="LastName" class="text-red-500 text-xs"></span>
                    </div>
                </div>
            </div>

            @* Branch Name (always read-only) *@
            <div class="grid grid-cols-12 items-center gap-4">
                <label class="col-span-3 text-sm text-gray-500 dark:text-gray-400">Branch Name</label>
                <div class="col-span-4">
                    <input type="text" value="@(m?.BranchLocation?.BranchName ?? "—")" readonly
                           class="w-full border border-gray-100 rounded-lg px-3 py-2 text-sm bg-gray-50 text-gray-500 cursor-not-allowed dark:bg-slate-700/50 dark:border-gray-700 dark:text-gray-400" />
                </div>
            </div>

            @* Email Address *@
            <div class="grid grid-cols-12 items-center gap-4">
                <label class="col-span-3 text-sm text-gray-500 dark:text-gray-400">Email Address</label>
                <div class="col-span-6">
                    <input asp-for="Email" type="email" placeholder="email@example.com" readonly
                           class="field-input w-full border border-gray-100 bg-gray-50 rounded-lg px-3 py-2 text-sm focus:outline-none dark:bg-slate-700/50 dark:border-gray-700 dark:text-gray-300" />
                    <span asp-validation-for="Email" class="text-red-500 text-xs"></span>
                </div>
            </div>

            @* Contact # *@
            <div class="grid grid-cols-12 items-center gap-4">
                <label class="col-span-3 text-sm text-gray-500 dark:text-gray-400">Contact#</label>
                <div class="col-span-4">
                    <input asp-for="ContactNum" type="tel" placeholder="+63 900 000 0000" readonly
                           class="field-input w-full border border-gray-100 bg-gray-50 rounded-lg px-3 py-2 text-sm focus:outline-none dark:bg-slate-700/50 dark:border-gray-700 dark:text-gray-300" />
                </div>
            </div>

            @* Branch Address (always read-only) *@
            <div class="grid grid-cols-12 items-start gap-4">
                <label class="col-span-3 text-sm text-gray-500 dark:text-gray-400 pt-2">Branch Address</label>
                <div class="col-span-9">
                    <textarea rows="4" readonly
                              class="w-full border border-gray-100 rounded-lg px-3 py-2 text-sm bg-gray-50 text-gray-500 cursor-not-allowed resize-none dark:bg-slate-700/50 dark:border-gray-700 dark:text-gray-400">@(m?.BranchLocation?.BranchLocationAddress ?? "—")</textarea>
                </div>
            </div>
        </div>
    </form>

    @* Delete Account *@
    <div class="px-8 pb-8">
        <form method="post" asp-page-handler="Delete"
              onsubmit="return confirm('Are you sure you want to delete your account? This action cannot be undone.')">
            <button type="submit"
                    class="px-5 py-2 border border-red-200 text-[#C41E24] text-sm font-bold rounded-lg hover:bg-red-50 dark:border-red-800 dark:hover:bg-red-900/20 transition-colors">
                <i class="bi bi-trash mr-1"></i> Delete Account
            </button>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        const editableClasses = ['border-gray-200', 'bg-white', 'focus:ring-2', 'focus:ring-[#C41E24]/30', 'dark:bg-slate-700', 'dark:border-gray-600', 'dark:text-white'];
        const readonlyClasses = ['border-gray-100', 'bg-gray-50', 'dark:bg-slate-700/50', 'dark:border-gray-700', 'dark:text-gray-300'];

        function enableEdit() {
            document.querySelectorAll('.field-input').forEach(el => {
                el.removeAttribute('readonly');
                readonlyClasses.forEach(c => el.classList.remove(c));
                editableClasses.forEach(c => el.classList.add(c));
            });
            document.getElementById('editBtn').classList.add('hidden');
            document.getElementById('saveBtn').classList.remove('hidden');
            document.getElementById('cancelBtn').classList.remove('hidden');
        }

        function disableEdit() {
            // Revert changes
            document.getElementById('accountForm').reset();
            
            document.querySelectorAll('.field-input').forEach(el => {
                el.setAttribute('readonly', '');
                editableClasses.forEach(c => el.classList.remove(c));
                readonlyClasses.forEach(c => el.classList.add(c));
            });
            document.getElementById('editBtn').classList.remove('hidden');
            document.getElementById('saveBtn').classList.add('hidden');
            document.getElementById('cancelBtn').classList.add('hidden');
        }
    </script>
}
