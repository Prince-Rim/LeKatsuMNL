@page
@model LeKatsuMNL.Pages.BranchDashboard.MyOrderModel
@{
    ViewData["Title"] = "My Order";
    Layout = "_BranchLayout";
}

<div class="bg-white rounded-2xl border border-gray-100 shadow-sm overflow-hidden dark:bg-slate-800 dark:border-gray-700">

    @* Table *@
    <div class="overflow-x-auto">
        <table class="w-full text-sm">
            <thead>
                <tr class="text-gray-400 text-xs uppercase border-b border-gray-100 dark:border-gray-700 dark:text-gray-500">
                    <th class="px-6 py-4 font-bold text-left">Order ID</th>
                    <th class="px-4 py-4 font-bold text-left">Status</th>
                    <th class="px-4 py-4 font-bold text-left">Created at</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-gray-50 dark:divide-gray-700">
                @if (Model.Orders != null && Model.Orders.Any())
                {
                    @foreach (var order in Model.Orders)
                    {
                        string formattedId = $"FO-{order.OrderDate.Year.ToString().Substring(2)}{order.OrderId:D4}";
                        <tr class="hover:bg-gray-50/50 dark:hover:bg-slate-700/30 transition-colors">
                            <td class="px-6 py-4">
                                <a href="/BranchDashboard/OrderDetails?id=@order.OrderId"
                                   class="font-bold text-[#C41E24] hover:underline">
                                    @formattedId
                                </a>
                            </td>
                            <td class="px-4 py-4">
                                <span class="px-2.5 py-1 rounded-full text-[10px] font-black uppercase tracking-widest border
                                    @(order.Status == "Completed" ? "bg-emerald-50 text-emerald-600 border-emerald-100 dark:bg-emerald-500/10 dark:text-emerald-400 dark:border-emerald-500/20" :
                                      order.Status == "Rejected" ? "bg-rose-50 text-rose-600 border-rose-100 dark:bg-rose-500/10 dark:text-rose-400 dark:border-rose-500/20" :
                                      order.Status == "Cancelled" ? "bg-gray-50 text-gray-600 border-gray-100 dark:bg-slate-700 dark:text-gray-400 dark:border-gray-600" :
                                      order.Status == "Delivering" ? "bg-cyan-50 text-cyan-600 border-cyan-100 dark:bg-cyan-500/10 dark:text-cyan-400 dark:border-cyan-500/20" :
                                      order.Status == "Preparing" ? "bg-indigo-50 text-indigo-600 border-indigo-100 dark:bg-indigo-500/10 dark:text-indigo-400 dark:border-indigo-500/20" :
                                      order.Status == "Approved" ? "bg-blue-50 text-blue-600 border-blue-100 dark:bg-blue-500/10 dark:text-blue-400 dark:border-blue-500/20" :
                                      "bg-amber-50 text-amber-600 border-amber-100 dark:bg-amber-500/10 dark:text-amber-400 dark:border-amber-500/20")">
                                    @order.Status
                                </span>
                            </td>
                            <td class="px-4 py-4 text-gray-500 dark:text-gray-400">@order.OrderDate.ToString("MMMM dd, yyyy")</td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="3" class="px-6 py-16 text-center">
                            <div class="flex flex-col items-center gap-2 text-gray-300">
                                <i class="bi bi-clipboard-x text-3xl"></i>
                                <p class="text-xs font-bold uppercase tracking-widest">No orders found</p>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    @* Pagination *@
    <div class="flex flex-wrap items-center justify-between px-6 py-3 border-t border-gray-100 text-xs text-gray-500 dark:border-gray-700 dark:text-gray-400">
        @if (Model.Orders != null)
        {
            @if (Model.Orders.TotalItems > 0)
            {
                <span>
                    Showing @((Model.Orders.PageIndex - 1) * Model.Orders.PageSize + 1) – @(Math.Min(Model.Orders.PageIndex * Model.Orders.PageSize, Model.Orders.TotalItems)) of @Model.Orders.TotalItems
                </span>
            }
            else
            {
                <span>Showing 0 of 0</span>
            }
            <div class="flex items-center gap-2">
                <span>Records per page</span>
                <form method="get" id="pageSizeForm" class="inline">
                    <input type="number" name="PageSize" value="@Model.PageSize" min="5" max="100"
                           class="w-14 text-center border border-gray-200 rounded px-2 py-1 text-xs dark:bg-slate-700 dark:border-gray-600 dark:text-white"
                           onchange="this.closest('form').submit()" />
                </form>
                @if (Model.Orders.HasPreviousPage)
                {
                    <a href="?pageIndex=@(Model.Orders.PageIndex - 1)&PageSize=@Model.PageSize"
                       class="w-7 h-7 flex items-center justify-center border border-gray-200 rounded hover:bg-gray-100 dark:border-gray-600 dark:hover:bg-slate-700 transition-colors">
                        <i class="bi bi-chevron-left"></i>
                    </a>
                }
                else
                {
                    <span class="w-7 h-7 flex items-center justify-center border border-gray-100 rounded text-gray-300 dark:border-gray-700 cursor-not-allowed">
                        <i class="bi bi-chevron-left"></i>
                    </span>
                }
                <span class="w-7 h-7 flex items-center justify-center bg-[#C41E24] text-white rounded text-xs font-bold">@Model.Orders.PageIndex</span>
                @if (Model.Orders.HasNextPage)
                {
                    <a href="?pageIndex=@(Model.Orders.PageIndex + 1)&PageSize=@Model.PageSize"
                       class="w-7 h-7 flex items-center justify-center border border-gray-200 rounded hover:bg-gray-100 dark:border-gray-600 dark:hover:bg-slate-700 transition-colors">
                        <i class="bi bi-chevron-right"></i>
                    </a>
                }
                else
                {
                    <span class="w-7 h-7 flex items-center justify-center border border-gray-100 rounded text-gray-300 dark:border-gray-700 cursor-not-allowed">
                        <i class="bi bi-chevron-right"></i>
                    </span>
                }
            </div>
        }
    </div>
</div>
